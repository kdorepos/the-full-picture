{
  "slug": "the-robert-zemeckis-hall-of-fame-and-here",
  "title": "The Robert Zemeckis Hall of Fame, and ‘Here’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Bryan Curtis"
  ],
  "published": "2024-11-08",
  "runtimeMin": 91,
  "format": "Zemeckis reunites the 'Forrest Gump' team for 'Here,' a fixed-camera swing across millennia in a single living room. Sean and Bryan Curtis wrestle with the movie, detour through the craziest gimmicks in moviegoing history, then walk the whole Zemeckis filmography to build a 10-film Hall of Fame.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Here’",
      "note": "the new Zemeckis",
      "films": [
        {
          "title": "Here",
          "year": 2024,
          "note": "Adapted from Richard McGuire's graphic novel: one fixed corner of a room, centuries of the people who lived in it, told in a static camera and cross-cut across time. Reunites the 'Forrest Gump' crew: Hanks, Robin Wright, composer Alan Silvestri, DP Don Burgess, writer Eric Roth. Both hosts find the writing leaden and the de-aging uneven (Wright's convincing, Hanks's not), but Sean liked it more than he expected: 'not good, but good to me.' A $5M bomb on 2,500 screens."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The craziest gimmicks in movie history",
      "note": "3-D, William Castle, popcorn buckets",
      "films": [
        {
          "title": "Clue",
          "year": 1985,
          "note": "Shipped with multiple endings across different theaters. It's the gimmick Sean most wants to see revived."
        },
        {
          "title": "Matinee",
          "year": 1993,
          "note": "Its showman-huckster is loosely based on William Castle, king of Percepto, Emergo, and the theater-lobby fainting nurse."
        },
        {
          "title": "Avatar",
          "year": 2009,
          "note": "Cameron's 3-D revival: mind-bending once, then every action movie went 3-D and the novelty wore off."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Robert Zemeckis Hall of Fame",
      "note": "24 films graded green/yellow/red: 10 inducted",
      "honoree": "Robert Zemeckis",
      "films": [
        {
          "title": "I Wanna Hold Your Hand",
          "year": 1978,
          "note": "The debut: kids scrambling to reach the Beatles' Ed Sullivan taping. Alive and clever, now in the Criterion Collection. In."
        },
        {
          "title": "1941",
          "year": 1979,
          "note": "A co-writing credit, not a directing one, for Spielberg's WWII comedy bomb. Neither host can rescue it. Out."
        },
        {
          "title": "Used Cars",
          "year": 1980,
          "note": "Kurt Russell as a used-car huckster; a cable-rerun classic in the Caddyshack vein, ripe for rediscovery. In."
        },
        {
          "title": "Romancing the Stone",
          "year": 1984,
          "note": "The studio-for-hire adventure he took because he couldn't yet get Back to the Future made. Turner and Douglas, straight down the middle, still works. In."
        },
        {
          "title": "Back to the Future",
          "year": 1985,
          "note": "The peak. A strange premise turned into 40 years of American culture. Automatic. In."
        },
        {
          "title": "Who Framed Roger Rabbit",
          "year": 1988,
          "note": "Sean's most-formative movie: cartoons colliding with hard-bitten noir. In on principle even if you hate it."
        },
        {
          "title": "Back to the Future Part II",
          "year": 1989,
          "note": "Right on the edge (the sequel they hadn't planned for), but it certifies him as a Hollywood master. In."
        },
        {
          "title": "Back to the Future Part III",
          "year": 1990,
          "note": "The Western homage they were economically obligated to make. Fine, and only fine. Out."
        },
        {
          "title": "Death Becomes Her",
          "year": 1992,
          "note": "Landmark makeup effects and a beauty-standards streak that predates 'The Substance.' Yellowed, then cut to make room for Contact."
        },
        {
          "title": "Forrest Gump",
          "year": 1994,
          "note": "Best Picture and Best Director. Treacly boomer crap and genuinely magic at once, a top-five Zemeckis. In."
        },
        {
          "title": "Contact",
          "year": 1997,
          "note": "His boldest swing: Forrest Gump sincerity welded to science-forward ideas. Bryan lobbied it in over Death Becomes Her. In."
        },
        {
          "title": "What Lies Beneath",
          "year": 2000,
          "note": "His Hitchcock movie: a big hit built on a good reveal, but iterative and inessential. Out."
        },
        {
          "title": "Cast Away",
          "year": 2000,
          "note": "Bryan's second-best Zemeckis. The plane crash still plays 20 years on, and only Hanks could sell talking to Wilson. In."
        },
        {
          "title": "The Polar Express",
          "year": 2004,
          "note": "Important to the history of motion capture, downright creepy as a movie. Sean makes the case for its import, not for the Hall. Out."
        },
        {
          "title": "Beowulf",
          "year": 2007,
          "note": "The mocap roll continues; deeper renderings, but nobody talks about it. Out."
        },
        {
          "title": "A Christmas Carol",
          "year": 2009,
          "note": "A Disney hit and, per Sean, a freakish mocap disaster. Out."
        },
        {
          "title": "Flight",
          "year": 2012,
          "note": "The 'I'm back' movie: a great Denzel performance and a thrilling near-crash, dragged only by the on-the-nose needle drops. In."
        },
        {
          "title": "The Walk",
          "year": 2015,
          "note": "The Twin Towers wire walk, formally cool but slight, and 'Man on Wire' got there first. Out."
        },
        {
          "title": "Allied",
          "year": 2016,
          "note": "Sumptuous WWII romance with Pitt and Cotillard; Sean lobbied a generous yellow, but it doesn't make the cut. Out."
        },
        {
          "title": "Welcome to Marwen",
          "year": 2018,
          "note": "The living-army-men PTSD movie: batshit, inscrutable, and the effective end of Steve Carell as a bankable star. Out."
        },
        {
          "title": "The Witches",
          "year": 2020,
          "note": "A pointless Roald Dahl remake dumped to streaming in COVID; as if it doesn't exist. Out."
        },
        {
          "title": "Pinocchio",
          "year": 2022,
          "note": "Looks like a fake movie on a poster, critically destroyed, and buried by del Toro's version the same year. Out."
        },
        {
          "title": "Here",
          "year": 2024,
          "note": "The new one, and the first Zemeckis in years Sean felt had something to say, but even he can't in good conscience call it green. Out."
        }
      ]
    }
  ],
