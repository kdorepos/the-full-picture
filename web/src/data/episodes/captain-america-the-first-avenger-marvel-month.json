  "runtimeMin": 75,
  "format": "Sean and Amanda open a five-film Marvel Month with the phase-one outlier: the WWII period piece Marvel tried once and never repeated.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Marvel Month: 'Captain America: The First Avenger'",
      "note": "Amanda's pick to kick off the MCU series",
      "films": [
        {
          "title": "Captain America: The First Avenger",
          "year": 2011,
          "note": "The pick. A Paramount-era, phase-one WWII movie, war picture and spy picture and doomed romance in one, that Marvel never tried again. Joe Johnston directs in full Rocketeer mode; a digitally shrunk Chris Evans goes into the machine and comes out greased and enormous."
        },
        {
          "title": "Captain America: The Winter Soldier",
          "year": 2014,
          "note": "Where the Cap films stop being about Cap and become about the Avengers; Bucky's turn."
        },
        {
          "title": "Captain America: Civil War",
          "year": 2016,
          "note": "The further pivot from solo hero to ensemble and moral dilemma."
        },
        {
          "title": "The Avengers",
          "year": 2012,
          "note": "The first Disney release; the tesseract gets uttered 50 times more and the merchandising machine turns on."
        },
        {
          "title": "Avengers: Infinity War",
          "year": 2018,
          "note": "Cap's clapped-for entrance; Red Skull reappears guarding the Soul Stone, played by a different actor."
        },
        {
          "title": "Avengers: Endgame",
          "year": 2019,
          "note": "The looming three-hour finale the whole series is built to sell, and likely Evans's exit."
        },
        {
          "title": "Iron Man",
          "year": 2008,
          "note": "Downey's alcoholic-genius template, the internal conflict Steve Rogers pointedly lacks."
        },
        {
          "title": "Iron Man 2",
          "year": 2010,
          "note": "One of the four pre-Avengers Paramount films."
        },
        {
          "title": "Thor",
          "year": 2011,
          "note": "Released just before this one; introduced a then-unknown Chris Hemsworth."
        },
        {
          "title": "The Incredible Hulk",
          "year": 2008,
          "note": "The Norton/Leterrier entry, technically canon but now largely ignored after the Ruffalo recast."
        },
        {
          "title": "Guardians of the Galaxy",
          "year": 2014,
          "note": "The kind of wooly, weird MCU Amanda finds harder to engage with than a war movie."
        },
        {
          "title": "Captain Marvel",
          "year": 2019,
          "note": "The then-current fight over when women get to headline these movies."
        },
        {
          "title": "Black Panther",
          "year": 2018,
          "note": "Held up as evidence of how much the MCU grew past by-the-numbers punching."
        },
        {
          "title": "Thor: Ragnarok",
          "year": 2017,
          "note": "Cited as the global, weird register this movie never reaches."
        },
        {
          "title": "Ant-Man",
          "year": 2015,
          "note": "Another entry in the daddy-issues catalog of hero motivations."
        }
      ]
    }
  ],
