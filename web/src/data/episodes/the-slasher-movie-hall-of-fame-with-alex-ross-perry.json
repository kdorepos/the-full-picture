{
  "slug": "the-slasher-movie-hall-of-fame-with-alex-ross-perry",
  "title": "The Slasher Movie Hall of Fame, With Alex Ross Perry",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Alex Ross Perry"
  ],
  "published": "2024-10-23",
  "runtimeMin": 109,
  "format": "A Halloween bonus episode: Sean Fennessey and returning champion Alex Ross Perry catch up on Perry's Pavement film and this year's slasher wave, then build a slasher hall of fame live, yellowing and redding candidates until ten survive (eleven, once they cheat and pair X with Terrifier).",
  "segments": [
    {
      "kind": "halloffame",
      "heading": "The Slasher Movie Hall of Fame",
      "note": "the ten (well, eleven) that survived the vote",
      "honoree": "The slasher movie",
      "films": [
        {
          "title": "Psycho",
          "year": 1960,
          "note": "The one the conversation keeps circling back to. Greenlit outright, since leaving it out would be silly."
        },
        {
          "title": "The Texas Chain Saw Massacre",
          "year": 1974,
          "note": "Auto-green. The movie all three hosts tried to grab first in their old horror draft."
        },
        {
          "title": "Deep Red",
          "year": 1975,
          "note": "The lone Italian pick, chosen over Blood and Black Lace so the list isn't all American. It's Argento's Profondo Rosso, the button Perry is wearing on mic."
        },
        {
          "title": "Halloween",
          "year": 1978,
          "note": "The other no-brainer, in immediately alongside Chainsaw."
        },
        {
          "title": "Friday the 13th Part 2",
          "year": 1981,
          "note": "The Jason entry, and Perry's favorite of the franchise. Sean would program Part 3 in 3D instead, but concedes 2 is undeniable."
        },
        {
          "title": "Pieces",
          "year": 1982,
          "note": "The Spanish slot, a Camp Blood drive-in favorite that Sean has advocated for on the show for years."
        },
        {
          "title": "The House on Sorority Row",
          "year": 1982,
          "note": "Perry's academia pick, taken over Slumber Party Massacre and Black Christmas."
        },
        {
          "title": "Silent Night, Deadly Night",
          "year": 1984,
          "note": "The Christmas slot. Its first 20 minutes rank among the most depraved in the genre, and it was protested on release."
        },
        {
          "title": "Scream",
          "year": 1996,
          "note": "Called the best horror movie of the '90s and a true slasher. The mandatory meta pick."
        },
        {
          "title": "Terrifier",
          "year": 2018,
          "note": "Half of the X/Terrifier 'cheat' closing slot. Damien Leone's meaning-free continuation of the movies he was raised on."
        },
        {
          "title": "X",
          "year": 2022,
          "note": "The other half of the closing slot: Ti West's signifier-heavy throwback, set against Terrifier as the two ends of where slashers are now."
        }
      ]
    }
  ],
