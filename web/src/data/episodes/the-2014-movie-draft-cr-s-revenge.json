{
  "slug": "the-2014-movie-draft-cr-s-revenge",
  "title": "The 2014 Movie Draft: CR's Revenge",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2020-11-25",
  "runtimeMin": 89,
  "format": "Sean, Amanda, and Chris Ryan snake-draft the movies of 2014 across six categories, then Sean talks to Clea Duvall about writing, directing, and moving Happiest Season to Hulu.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "How 2014 stacked up",
      "note": "pre-draft reflections",
      "films": [
        {
          "title": "Interstellar",
          "year": 2014,
          "note": "Chris hated it on first viewing, then rewatched it this year and came around; still not calling it a masterpiece."
        },
        {
          "title": "Birdman",
          "year": 2014,
          "note": "Won Best Picture for the year; Amanda names it as one of the consensus movies she just doesn't care for."
        },
        {
          "title": "Boyhood",
          "year": 2014,
          "note": "Amanda calls it a Linklater film she admires but doesn't enjoy; ran second to Birdman for Best Picture."
        },
        {
          "title": "Inherent Vice",
          "year": 2014,
          "note": "Amanda's 'sour memory' of the year: her now-husband made her watch an Eagles game, then took her to the Angelika, then they fought on the subway home."
        },
        {
          "title": "The Theory of Everything",
          "year": 2014,
          "note": "Sean calls it 'incredibly dull,' part of what he sees as the last gasp of the Weinstein Oscar-campaign era."
        },
        {
          "title": "The Imitation Game",
          "year": 2014,
          "note": "Grouped with The Theory of Everything as prestige movies from a campaign playbook that stopped working."
        },
        {
          "title": "Whiplash",
          "year": 2014,
          "note": "Cited alongside Selma as a newer generation of filmmakers breaking through that year."
        },
        {
          "title": "Selma",
          "year": 2014
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The 2014 movie draft",
      "draftOf": "the movies of 2014",
      "categories": [
        "Drama",
        "Comedy/Horror",
        "Blockbuster",
        "Animated/Foreign Language",
        "Sequel",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Captain America: The Winter Soldier",
              "year": 2014,
              "category": "Sequel",
              "note": "Opens the draft with it; puts it in the conversation for best MCU movie and best sequel of the decade. The Russo Brothers' 'director bullshit' name-checked The Parallax View and The Conversation, but Sean thinks it's closer kin to Extraction."
            },
            {
              "title": "Whiplash",
              "year": 2014,
              "category": "Drama",
              "note": "One of his five favorite movies of the last decade; says he relates to it in an unhealthy way."
            },
            {
              "title": "Inherent Vice",
              "year": 2014,
              "category": "Comedy/Horror",
              "note": "Saw it at the New Beverly with Paul Thomas Anderson in the room; a woman in the front row dropped her Dr. Pepper during his remarks and PTA got her a new one. Calls it a real Easter-egg movie, not his favorite PTA film but very much in line with his specific sense of humor."
            },
            {
              "title": "Guardians of the Galaxy",
              "year": 2014,
              "category": "Blockbuster",
              "note": "The only year he'd consider drafting two Marvel movies; likes the mix of comedy, action, and serialized story."
            },
            {
              "title": "Snowpiercer",
              "year": 2014,
              "category": "Wildcard",
              "note": "Delayed by Harvey Weinstein's meddling before finally reaching American audiences close to Bong Joon Ho's intended cut. Calls it the movie that put Bong on the map here."
            },
            {
              "title": "Paddington",
              "year": 2014,
              "category": "Animated/Foreign Language",
              "note": "His backup plan the whole draft; floats it as a question first ('would you guys consider Paddington to be an animated movie?') before taking it."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Edge of Tomorrow",
              "year": 2014,
              "category": "Blockbuster",
              "note": "Cleared the $100 million domestic bar by exactly $206,256. His favorite late-period Tom Cruise, better than the Mission Impossible run because it leans into Cruise's self-aware charm; also praises Emily Blunt."
            },
            {
              "title": "The Grand Budapest Hotel",
              "year": 2014,
              "category": "Comedy/Horror",
              "note": "Says the whole cast 'fired on the same cylinders'; singles out Saoirse Ronan and Ralph Fiennes."
            },
            {
              "title": "Nightcrawler",
              "year": 2014,
              "category": "Drama",
              "note": "Part of Jake Gyllenhaal's Prisoners-Enemy-Nightcrawler run in a 16-month span. A gritty L.A. noir about ambition and media that does the most with what it has."
            },
            {
              "title": "The Raid 2",
              "year": 2014,
              "category": "Animated/Foreign Language",
              "note": "Thinks it tops the original; ties it back to Gareth Evans's later Amazon series Gangs of London."
            },
            {
              "title": "Dawn of the Planet of the Apes",
              "year": 2014,
              "category": "Sequel",
              "note": "More director bullshit: Apocalypse Now and Bresson name-checks that don't really apply. Likes Gary Oldman's post-collapse, Infowars-guy performance."
            },
            {
              "title": "The Gambler",
              "year": 2014,
              "category": "Wildcard",
              "note": "The pick the whole episode's cold open is built around. A remake of the James Toback/James Caan film; raves about Mark Wahlberg's largely invented Shakespeare lecture and John Goodman's 'fuck you' speech."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Gone Girl",
              "year": 2014,
              "category": "Drama",
              "note": "An easy, obvious No. 1 in the category, one of the few 2014 movies she says she genuinely loves."
            },
            {
              "title": "Interstellar",
              "year": 2014,
              "category": "Blockbuster",
              "note": "Admits she barely remembers it: saw it once and it fell out of her head walking out of the theater, unlike Inception, which stuck."
            },
            {
              "title": "Neighbors",
              "year": 2014,
              "category": "Comedy/Horror",
              "note": "82 minutes, no filler. Calls it close to a personality test: if someone doesn't like this movie, they're not friends."
            },
            {
              "title": "22 Jump Street",
              "year": 2014,
              "category": "Sequel",
              "note": "Didn't rewatch before the draft but remembers the fake-sequel end-credits gag. Says it introduced her to Wyatt Russell."
            },
            {
              "title": "Force Majeure",
              "year": 2014,
              "category": "Animated/Foreign Language",
              "note": "Probably her favorite foreign-language film of the year; likes that it works as a parlor game, since you leave arguing about what you'd actually do."
            },
            {
              "title": "Beyond the Lights",
              "year": 2014,
              "category": "Wildcard",
              "note": "A Gina Prince-Bythewood film she calls underappreciated, a Gugu Mbatha-Raw character study about image-making as much as the central mother-daughter relationship."
            }
          ]
        }
      ],
