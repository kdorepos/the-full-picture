{
  "slug": "the-1990s-summer-blockbuster-movie-draft",
  "title": "The 1990s Summer Blockbuster Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2023-04-25",
  "runtimeMin": 107,
  "format": "A teardown of Ghosted first, then Sean, Amanda, and Chris Ryan draft eighteen 90s summer blockbusters across six categories.",
  "segments": [
    {
      "kind": "review",
      "heading": "Ghosted",
      "note": "Sean's review",
      "films": [
        {
          "title": "Ghosted",
          "year": 2023,
          "note": "Apple TV+'s Chris Evans/Ana de Armas spy-rom-com. \"This shit got turned into glue so fast.\""
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The 1990s Summer Blockbuster Draft",
      "note": "released May 1-September 1 in the 90s, $100M+ box office",
      "draftOf": "1990s summer blockbusters",
      "categories": [
        "Action",
        "Comedy",
        "Drama",
        "Sequel",
        "Oscar nominee",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Terminator 2: Judgment Day",
              "year": 1991,
              "category": "Sequel",
              "note": "His round-one lock: \"the ultimate summer movie of my youth.\""
            },
            {
              "title": "The Fugitive",
              "year": 1993,
              "category": "Oscar nominee",
              "note": "Saw it twice in two days on release; calls it the Rewatchables episode he wishes he'd been on."
            },
            {
              "title": "There's Something About Mary",
              "year": 1998,
              "category": "Comedy",
              "note": "Remembers theaters in \"pandemonium\" at the hair-gel scene."
            },
            {
              "title": "Twister",
              "year": 1996,
              "category": "Action",
              "note": "A movie he's grown into: \"possibly the craziest cast of the 90s.\""
            },
            {
              "title": "Ghost",
              "year": 1990,
              "category": "Drama",
              "note": "His sixth-grade first-date movie: \"I'm not Patrick Swayze.\""
            },
            {
              "title": "Point Break",
              "year": 1991,
              "category": "Wildcard",
              "note": "\"I love bank-robbing surfers.\""
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Jurassic Park",
              "year": 1993,
              "category": "Action",
              "note": "Still her No. 1 Spielberg: \"they put dinosaurs on the movies.\""
            },
            {
              "title": "Apollo 13",
              "year": 1995,
              "category": "Drama",
              "note": "The Tom Hanks role she's demanded a Rewatchables episode over."
            },
            {
              "title": "Sleepless in Seattle",
              "year": 1993,
              "category": "Oscar nominee",
              "note": "The film that, after When Harry Met Sally, made the modern rom-com \"a real thing.\""
            },
            {
              "title": "Die Hard with a Vengeance",
              "year": 1995,
              "category": "Sequel",
              "note": "Took it over Clear and Present Danger, which she'd drafted recently."
            },
            {
              "title": "My Best Friend's Wedding",
              "year": 1997,
              "category": "Comedy",
              "note": "Her Julia Roberts pick, and the movie she says taught her how rom-com tropes work."
            },
            {
              "title": "The Firm",
              "year": 1993,
              "category": "Wildcard",
              "note": "Cruise's Mitch McDeere doing handsprings on Beale Street: \"the best sequence in movie history.\""
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Speed",
              "year": 1994,
              "category": "Action",
              "note": "His quintessential summer blockbuster: \"the commercial explains the premise in ten seconds.\""
            },
            {
              "title": "Unforgiven",
              "year": 1992,
              "category": "Oscar nominee",
              "note": "An August release that looked like proof Clint was through."
            },
            {
              "title": "A League of Their Own",
              "year": 1992,
              "category": "Comedy",
              "note": "A hit twice over in his house: \"incredible drama in addition to being really really funny.\""
            },
            {
              "title": "Saving Private Ryan",
              "year": 1998,
              "category": "Drama",
              "note": "Released on his 16th birthday weekend; he saw it that weekend."
            },
            {
              "title": "Star Wars: Episode I - The Phantom Menace",
              "year": 1999,
              "category": "Sequel",
              "note": "A deliberately weird pick: \"not a good film, but I like it.\""
            },
            {
              "title": "The Truman Show",
              "year": 1998,
              "category": "Wildcard",
              "note": "His self-described tanking pick: \"anti-drafting, but only with good films.\""
            }
          ]
        }
      ],
