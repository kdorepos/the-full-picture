            },
            {
              "title": "Mission: Impossible",
              "year": 1996,
              "category": "Blockbuster",
              "note": "De Palma, Cruise; nobody expected the franchise it became."
            },
            {
              "title": "Bottle Rocket",
              "year": 1996,
