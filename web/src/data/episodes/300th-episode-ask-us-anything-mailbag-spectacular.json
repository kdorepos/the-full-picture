{
  "slug": "300th-episode-ask-us-anything-mailbag-spectacular",
  "title": "300th Episode Ask-Us-Anything Mailbag Spectacular",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Bobby Wagner"
  ],
  "published": "2020-10-13",
  "runtimeMin": 131,
  "format": "The 300th episode: a listener mailbag with Bobby Wagner reading the questions, then Sean's interview with Garrett Bradley about her documentary Time.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "In the news",
      "films": [
        {
          "title": "Mank",
          "year": 2020,
          "note": "David Fincher's Herman Mankiewicz film; the teaser is shot and cut to look like a 1940s picture. Out December 4. Sean's verdict: neat idea, gimmick or not is a wait-and-see."
        },
        {
          "title": "Soul",
          "year": 2020,
          "note": "Pixar's Disney+ pivot: skipping theaters and the $30 Mulan-style PVOD tag to land free on the service Christmas Day. Possibly the most-seen Disney film ever, by default."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The 300th-episode mailbag",
      "note": "the picks that got a real answer",
      "films": [
        {
          "title": "Good Will Hunting",
          "year": 1997,
          "note": "Amanda's answer to what got her into this: at 12 or 13, the movie plus the Damon/Affleck/Robin Williams Oscar campaign got her hooked on the whole world around a film, as much as the film itself."
        },
        {
          "title": "Transformers",
          "year": 2007,
          "note": "Sean's origin story: a Vibe-era press trip to the Michael Bay premiere, Escalade and VIP ticket included, that made him want to cover movies instead of rap records."
        },
        {
          "title": "The Martian",
          "year": 2015,
          "note": "Used as the case study for a critic's blurred work/play line: a feel-good movie he watched at 2 a.m. as an assignment, not for fun."
        },
        {
          "title": "1917",
          "year": 2019,
          "note": "A friend's line Sean found astute: maybe the last film to get in before the gate closed, a global, award-worthy, $500M-capable event picture."
        },
        {
          "title": "Dick Johnson Is Dead",
          "year": 2020,
          "note": "Sean's counterweight to the doom: a small film one person could make, now watchable by 150 million homes."
        },
        {
          "title": "The Butterfly Effect",
          "year": 2004,
          "note": "Sean's pick for a bad movie built on a great idea: a mainstream Sliding Doors. He'd hand it to Spielberg and Colin Farrell with an Eric Roth script."
        },
        {
          "title": "Ocean's 8",
          "year": 2018,
          "note": "Amanda's on-paper no-brainer that didn't work: an all-female heist she'd happily see remade with the same cast."
        },
        {
          "title": "Public Enemies",
          "year": 2009,
          "note": "Sean's most disappointing film of the last 15 years: Mann's digital Dillinger, miscast Depp. He'd hand the story to Christopher Nolan."
        },
        {
          "title": "Tully",
          "year": 2018,
          "note": "Amanda liked parts, hated the ending and one scene she says a female director wouldn't have shot; she'd give it to Karen Kusama despite the Diablo Cody script."
        },
        {
          "title": "No Time to Die",
          "year": 2021,
          "note": "Amanda's first pick of postponed movies she'd see in a theater today: Bond belongs on a big screen."
        },
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "Sean's: a dumb-and-beautiful theater experience, song at giant volume."
        },
        {
          "title": "Deep Water",
          "year": 2022,
          "note": "Amanda's second postponed pick: the Adrian Lyne / Affleck / de Armas movie whose off-screen narrative she wants resolved."
        },
        {
          "title": "Last Night in Soho",
          "year": 2021,
          "note": "Sean's Halloween-season want: a new Edgar Wright he trusts to make an instant horror classic, and one that won't play as well at home."
        },
        {
          "title": "Last Action Hero",
          "year": 1993,
          "note": "Sean's model for a 'save its reputation' bad-movie pod: a clever, fun Schwarzenegger movie he thinks went over or under people's heads."
        },
        {
          "title": "The Thomas Crown Affair",
          "year": 1999,
          "note": "Sean's standing 'critics got it wrong' pick; he notes Christopher Nolan is a fan."
        },
        {
          "title": "Marie Antoinette",
          "year": 2006,
          "note": "Sean's other one: booed at Cannes, written off, and probably his favorite Sofia Coppola film."
        },
        {
          "title": "A Cure for Wellness",
          "year": 2016,
          "note": "Sean's rescue: Gore Verbinski at 42% on Rotten Tomatoes, weird and disgusting but artfully mounted."
        },
        {
          "title": "mother!",
          "year": 2017,
          "note": "Revisited after David Sims called it a masterpiece on Twitter. Sean always thought so, Amanda always didn't; it's one of the podcast's first debates, three years on."
        },
        {
          "title": "Gone Girl",
          "year": 2014,
          "note": "The Fincher Amanda would hand to Nancy Meyers: she could nail Amy, though Meyers might soft-pedal the viciousness."
        },
        {
          "title": "The Intern",
          "year": 2015,
          "note": "The Meyers Sean would hand to Fincher: a movie about obsession with a darkness at its edge he could explore."
        },
        {
          "title": "Panic Room",
          "year": 2002,
          "note": "Amanda's other Fincher-for-Meyers: a domestic drama, a house that turns against you, right in Meyers's core themes."
        },
        {
          "title": "I Love Trouble",
          "year": 1994,
          "note": "Sean's Meyers-for-Fincher: her worst, most troubled movie, but essentially a Fincher murder mystery that needs his obsessive attention to detail."
        },
        {
          "title": "Guardians of the Galaxy",
          "year": 2014,
          "note": "Cited (via an unnamed Hollywood friend) as proof the Marvel movie has effectively replaced the studio comedy."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Garrett Bradley on Time",
      "guest": "Garrett Bradley on",
      "films": [
        {
          "title": "Time",
          "year": 2020,
          "note": "Her documentary on Fox Rich and her fight to free her husband Rob, in theaters and hitting Amazon Prime that Friday. Built from her own footage plus ~100 hours of Fox's family archive, scored to the 96-year-old Ethiopian nun Emahoy's music."
        },
        {
          "title": "Alone",
          "year": 2017,
          "note": "The 13-minute New York Times op-doc, a Sundance winner, where she first met Fox Rich; Time began as its sister film."
        },
        {
          "title": "Heat",
          "year": 1995,
          "note": "Her answer to the closing 'last great thing': a rewatch that got her talking about how many great films the '90s made."
        }
      ]
    }
  ],
