  ],
  "published": "2022-03-29",
  "runtimeMin": 90,
  "format": "Thirty-six hours after the slap, Sean Fennessey and Bobby Wagner open the mailbag on a strange Oscars, then Sean talks to the Daniels about Everything Everywhere All at Once.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Post-Oscars mailbag",
      "note": "with Bobby Wagner",
      "films": [
        {
          "title": "King Richard",
          "year": 2021,
          "note": "Will Smith's Best Actor win; he apologized to Chris Rock, the Academy and his King Richard collaborators the next day."
        },
        {
          "title": "The Power of the Dog",
          "year": 2021,
          "note": "Netflix's 12-nomination Best Picture play and the favorite from September to late February; an art-house movie that made under $10M without the platform."
        },
        {
          "title": "CODA",
          "year": 2021,
          "note": "Won Best Picture. Sean argues it wouldn't have won on a Feb 2 date: the SAG ensemble win and a White House visit turned it late."
        },
        {
          "title": "Dune",
          "year": 2021,
          "note": "Six below-the-line wins; Sean calls Villeneuve's directing snub borderline offensive."
        },
        {
          "title": "The Irishman",
          "year": 2019,
          "note": "Netflix, 10 nominations. One of Sean's earlier auteur bets that lost: seen four times, 'one of the deepest films about mortality.'"
        },
        {
          "title": "Mank",
          "year": 2020,
          "note": "Netflix, 10 nominations, Sean's No. 1 of 2020: the other 'blank check to an auteur' play that didn't convert."
        },
        {
          "title": "Belfast",
          "year": 2021,
          "note": "Branagh's Original Screenplay win over Licorice Pizza, which Sean can't accept."
        },
        {
          "title": "Licorice Pizza",
          "year": 2021,
          "note": "January's Original Screenplay favorite before the consensus 'wilted'; PTA's tenth-place-to-nowhere Best Picture nominee."
        },
        {
          "title": "The Eyes of Tammy Faye",
          "year": 2021,
          "note": "Chastain's transformation win; the show did an actor-transformation episode on it in September."
        },
        {
          "title": "West Side Story",
          "year": 2021,
          "note": "Ariana DeBose's supporting win, 'undeniably incredible.'"
        },
        {
          "title": "The Lost City",
          "year": 2022,
          "note": "$32M opening cited as evidence theaters are back: an original Bullock/Tatum vehicle Sean calls basically Romancing the Stone."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "Neon and Tom Quinn's campaign held up as the good version of the smaller-distributor upset."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "The Daniels on their new movie",
      "guest": "Daniel Kwan & Daniel Scheinert on",
      "films": [
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "Spoiler-free chat before the wide April 8 release. On casting Yeoh, Quan and the everything bagel as a nihilism symbol, and building an 'Impossible Burger' of blockbuster and indie."
        },
        {
          "title": "Swiss Army Man",
          "year": 2016,
          "note": "The prior feature; after it, Hollywood came calling with franchises they didn't want."
        },
        {
          "title": "The Death of Dick Long",
          "year": 2019,
          "note": "Scheinert pitched Sean this one years earlier and Sean thought it was a prank."
        }
      ]
    }
