          "title": "Oppenheimer",
          "year": 2023,
          "note": "Sean's back-to-back order: the heavy dinner first."
        },
        {
          "title": "Barbie",
          "year": 2023,
          "note": "Dessert. Bobby would flip it for a daytime-then-dinner-then-night split."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "What movie best describes the 2023 Mets?",
      "note": "Andrew",
      "films": [
        {
          "title": "Black Sunday",
          "year": 1977,
          "note": "Andrew's answer; a '70s thriller about blowing up the Super Bowl blimp. Sean thinks it's worse than that."
        },
        {
          "title": "Deep Impact",
          "year": 1998,
          "note": "Sean's read: the mournful apocalypse movie where everyone knows they're doomed."
        },
        {
          "title": "Armageddon",
          "year": 1998,
          "note": "The flashy Michael Bay version that came out the same year."
        },
        {
          "title": "Titanic",
          "year": 1997,
          "note": "Bobby's amendment: a ship everyone knew would sink, boarded anyway."
        }
      ]
    },
