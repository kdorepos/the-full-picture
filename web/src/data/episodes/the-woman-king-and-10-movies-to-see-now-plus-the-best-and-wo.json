{
  "slug": "the-woman-king-and-10-movies-to-see-now-plus-the-best-and-wo",
  "title": "‘The Woman King’ and 10 Movies to See Now. Plus: The Best and Worst Films at TIFF.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2022-09-20",
  "runtimeMin": 88,
  "format": "Gina Prince-Bythewood's all-female-warrior epic opens the fall movie season. Ten more movies worth catching this week, and Adam Nayman calls in from TIFF with The Fabelmans, Women Talking, Glass Onion and the rest of the festival.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Woman King",
      "note": "and Gina Prince-Bythewood's career",
      "films": [
        {
          "title": "The Woman King",
          "year": 2022,
          "note": "Viola Davis leads the Agoji, the all-female warriors of the Kingdom of Dahomey, in a historical epic both hosts call straight-down-the-middle mainstream entertainment in the best sense, recalling Braveheart and Gladiator, with a thrilling opening-night crowd reaction. They also flag the film's softened take on Dahomey's role in the slave trade, pointing listeners to Julian Lucas's New Yorker piece on the history."
        },
        {
          "title": "The Old Guard",
          "year": 2020,
          "note": "Prince-Bythewood's Charlize Theron vehicle for Netflix, discussed as the training-wheels version of The Woman King: half a Prince-Bythewood movie, half a bland Netflix action flick, but proof she could handle the budget."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "10 movies to see now",
      "films": [
        {
          "title": "Do Revenge",
          "year": 2022,
          "note": "Netflix teen comedy with Camila Mendes and Maya Hawke, watched without much intention but with real charm, mostly because Hawke plays it as a dead ringer for her mother, Uma Thurman."
        },
        {
          "title": "Moonage Daydream",
          "year": 2022,
          "note": "Brett Morgen's sound-and-image David Bowie documentary, seen in Dolby. It skips narrative biography for an immersive, archival-footage experience Sean calls one of the best things he's seen all year."
        },
        {
          "title": "Pearl",
          "year": 2022,
          "note": "Ti West's X prequel, shot back to back with X in New Zealand. Mia Goth plays a farm girl with movie-star delusions and a murderous streak; a John Waters-style camp horror turn Amanda calls the best use yet of Goth's unsettling register."
        },
        {
          "title": "Speak No Evil",
          "year": 2022,
          "note": "Christian Tafdrup's Danish horror film about a vacation friendship gone very wrong, compared to Bryan Bertino's The Strangers for pure dread. Streaming on Shudder; described as a dare more than a recommendation."
        },
        {
          "title": "Confess Fletch",
          "year": 2022,
          "note": "Jon Hamm's low-key mystery comedy, undersold by its studio and well-liked once people found it on VOD: loose plotting, strong supporting cast (Marcia Gay Harden, Kyle MacLachlan, Annie Mumolo, John Slattery)."
        },
        {
          "title": "Riotsville, USA",
          "year": 2022,
          "note": "Sierra Pettengill's archival documentary built from the fake towns law enforcement built to train for riot control in the 1960s. Premiered at Sundance."
        },
        {
          "title": "See How They Run",
          "year": 2022,
          "note": "Agatha Christie parody with Sam Rockwell, Saoirse Ronan and Adrien Brody, set around a stage adaptation of The Mousetrap. Both hosts found it too jokey and self-aware to land, unlike Knives Out."
        },
        {
          "title": "God's Country",
          "year": 2022,
          "note": "Thandiwe Newton stars as a woman confronting encroachment on her property in a desolate Montana town, a naturalistic thriller Sean calls really well done, out of Sundance via IFC."
        },
        {
          "title": "The Cathedral",
          "year": 2022,
          "note": "Ricky D'Ambrose's autobiographical, novelistic account of a fractured Long Island family, narrated in close third person with a strong Robert Bresson influence. Streaming on Mubi."
        },
        {
          "title": "Pinocchio",
          "year": 2022,
          "note": "Robert Zemeckis's Disney+ live-action remake with Tom Hanks and Joseph Gordon-Levitt, called out as unnecessary and poorly rendered, part of a run of Disney remakes neither host can name a good one from."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "The best and worst of TIFF",
      "guest": "Adam Nayman on",
      "films": [
        {
          "title": "The Fabelmans",
          "year": 2022,
          "note": "Steven Spielberg's autobiographical drama won TIFF's audience award, notable partly because Spielberg hadn't brought a film to a festival since The Sugarland Express at Cannes in 1974."
        },
        {
          "title": "My Policeman",
          "year": 2022,
          "note": "Harry Styles won a TIFF ensemble acting prize for this closeted-1950s-England drama. Nayman thought Styles held his own but was let down by the actor playing his older self."
        },
        {
          "title": "Aftersun",
          "year": 2022,
          "note": "Charlotte Wells's father-daughter drama, with Paul Mescal as a dad on vacation with his preteen daughter in Turkey, the one film Nayman calls an early lock for his year-end list."
        },
        {
          "title": "The Inspection",
          "year": 2022,
          "note": "Elegance Bratton's autobiographical drama about a closeted Marine recruit, which Nayman found underwhelming despite its personal stakes. He compares it to Full Metal Jacket on shuffle."
        },
        {
          "title": "The Whale",
          "year": 2022,
          "note": "Darren Aronofsky's awards-season conversation piece; Nayman didn't like it but singles out Brendan Fraser's performance, for which Fraser also picked up a TIFF award."
        },
        {
          "title": "The Menu",
          "year": 2022,
          "note": "Mark Mylod's eat-the-rich satire, which Nayman calls much more literal about its theme than Glass Onion and simply not very good, despite Mylod's pedigree directing Succession."
        },
        {
          "title": "Women Talking",
          "year": 2022,
          "note": "Sarah Polley's adaptation of Miriam Toews's novel, based on real assaults in a Mennonite colony. Strong reception out of Venice cooled somewhat in Toronto; Nayman calls it a rhetorical thought experiment that flatters its audience and eventually lost him, despite a striking desaturated look and a strong Jessie Buckley performance."
        },
        {
          "title": "Glass Onion: A Knives Out Mystery",
          "year": 2022,
          "note": "Rian Johnson's follow-up, which got rapturous reviews Nayman felt were a bit much: well-crafted and better than The Menu, but he found its eat-the-rich messaging in tension with its Netflix-funded scale."
        },
        {
          "title": "How to Blow Up a Pipeline",
          "year": 2022,
          "note": "Daniel Goldhaber's dramatization of Andreas Malm's book, a heist-thriller about climate activists that Nayman calls unequivocal rather than ambivalent about its subject, a deliberately provocative film he expects to be a lightning rod, picked up by Neon."
        }
      ]
    }
  ],
