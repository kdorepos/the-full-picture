  "published": "2021-04-20",
  "runtimeMin": 106,
  "format": "Sean, Amanda, and Wesley Morris run the Big Picks back for year two: a verdict on Soderbergh's no-Zoom Oscars and the Amazon problem in Nomadland, then invented categories and six reimagined real ones. Time wins Best Picture, Ben Affleck wins Best Actor, and Wesley picks a fight with a nine-year-old.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "State of the 2021 Oscars",
      "note": "before the ballots",
      "films": [
        {
          "title": "The Trial of the Chicago 7",
          "year": 2020,
          "note": "Sean didn't realize it was Oscar-eligible until pundits started floating Sacha Baron Cohen for supporting actor."
        },
        {
          "title": "Judas and the Black Messiah",
          "year": 2021,
          "note": "Wesley meets it on its own terms, as a two-hour action movie about a spy; Amanda wants more interest in what William O'Neal's betrayal actually means."
        },
        {
          "title": "Nomadland",
          "year": 2020,
          "note": "The presumptive winner. Wesley's read: a well-made, palatable movie about domestic grief that flinches from the rage underneath it, especially once the scene with Fern's sister explains her away."
        },
        {
          "title": "Sorry We Missed You",
          "year": 2019,
          "note": "Wesley's counterpoint: Ken Loach's actual screed against the Amazon business model, with none of Nomadland's ambiguity, and no path to an Oscar nomination."
        },
        {
          "title": "Minari",
          "year": 2020,
          "note": "Cited as one of the good things a broken, streaming-driven Oscar season still let through."
        },
        {
          "title": "Mank",
          "year": 2020,
          "note": "The most Oscar-shaped nominee almost by design: a David Fincher movie about writing the idea of Citizen Kane, not even about making it."
        },
        {
          "title": "News of the World",
          "year": 2020,
          "note": "Sean's example of a movie that could easily have filled a Best Picture slot this thin."
        },
        {
          "title": "Godzilla vs. Kong",
          "year": 2021,
          "note": "The only movie making real money in the U.S. this year, which Wesley reads as proof audiences want event movies, not anything like this year's Best Picture slate."
        },
        {
          "title": "Let Them All Talk",
          "year": 2020,
          "note": "What Wesley actually wants from Soderbergh right now, as opposed to producing a stripped-down Oscars broadcast."
        },
        {
          "title": "Dune",
          "year": 2021,
          "note": "Sean's test case for whether the Academy can still get behind a real blockbuster."
        },
        {
          "title": "Borat Subsequent Moviefilm",
          "year": 2020,
          "note": "Comes up for the joke about a Kazakhstan satellite-viewing site and Sacha Baron Cohen's own supporting buzz."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Coogler pipeline",
      "note": "indie cred as leverage",
      "films": [
        {
          "title": "Fruitvale Station",
          "year": 2013,
          "note": "Wesley's starting point for Ryan Coogler: a true story that announced him."
        },
        {
          "title": "Creed",
          "year": 2015,
          "note": "IP Coogler had an actual reason to take on, in Wesley's telling: reviving a franchise rather than just servicing it."
        },
        {
          "title": "Black Panther",
          "year": 2018,
          "note": "The blockbuster payoff: historic, and a hit, whatever else you think about it."
        },
        {
          "title": "Schindler's List",
          "year": 1993,
          "note": "Sean's precedent: Spielberg banked enough studio hits that his passion project became a box-office smash too."
        }
      ]
    },
