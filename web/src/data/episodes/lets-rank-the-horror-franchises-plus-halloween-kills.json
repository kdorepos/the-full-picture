        {
          "title": "The Exorcist",
          "year": 1973,
          "note": "One and three are masterpieces; the middle films sink the average."
        },
        {
          "title": "Night of the Living Dead",
          "year": 1968,
          "note": "Dawn and Day give it real sequels."
        },
        {
          "title": "Psycho",
          "year": 1960,
