  "published": "2026-07-23",
  "runtimeMin": 103,
  "format": "The summer mailbag: Venice's thin lineup and the ArcLight's 2028 return up top, then 600 reader questions on IMAX, Nolan after The Odyssey, and girl-dad cinema.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The news: Venice, the ArcLight, Days of Thunder 2",
      "note": "before the mailbag",
      "films": [
        {
          "title": "Ink",
          "note": "Danny Boyle; the one big title playing Venice, TIFF, Telluride and New York, but announced before Netflix acquired it."
        },
        {
          "title": "Wild Horse Nine",
          "note": "Martin McDonagh; Malkovich, Rockwell, Buscemi. Effectively the festival's biggest movie this year, which says a lot."
        },
        {
          "title": "Prime Time",
          "note": "A24, Lance Oppenheim; Robert Pattinson as a Chris Hansen figure. Dated Sept 25."
        },
        {
          "title": "Bunker",
          "note": "Florian Zeller; Bardem and Cruz."
        },
        {
          "title": "Bucking Fastard",
          "note": "Werner Herzog, starring the Mara sisters; one more Venice title in a thin year."
        },
        {
          "title": "Look Back",
          "year": 2024,
          "note": "The Venice title is a live-action remake; Sean pushes the 60-minute anime on Prime instead."
        },
        {
          "title": "Oasis: Don't Look Back in Anger",
          "note": "Reunion-tour concert doc; the only major-studio movie at the whole festival."
        },
        {
          "title": "Once Upon a Time in Hollywood",
          "year": 2019,
          "note": "Cliff Booth drives past the Cinerama Dome, the theater Alamo Drafthouse is now restoring for 2028."
        },
        {
          "title": "Pride of the Yankees",
          "year": 1942,
          "note": "Gary Cooper as Lou Gehrig; a stiff but good original now that Linklater and Simon Rich are doing a Gehrig biopic with Glenn Powell."
        },
        {
          "title": "Days of Thunder",
          "year": 1990,
          "note": "Tony Scott; Cruise is now five years older than Duvall's coach was, but he'll be in the car, not coaching."
        },
        {
          "title": "Days of Thunder 2",
          "note": "Jonathan Levine directing, Cruise back. Do we need it? Because people like cars going fast."
        },
        {
          "title": "Baby Boom",
          "year": 1987,
          "note": "Amanda's on-air correction: Sam Shepard's character is a veterinarian, not a pediatrician."
        },
        {
          "title": "The Wackness",
          "year": 2008,
          "note": "How most people know Jonathan Levine."
        },
        {
          "title": "Snatched",
          "year": 2017,
          "note": "The Schumer/Hawn comedy, also Levine."
        },
        {
          "title": "F1",
          "year": 2025,
          "note": "The obvious reason Days of Thunder 2 exists."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The mailbag",
      "note": "600 questions, sifted by Jack Sanders and Lucas Cavanaugh",
      "films": [
        {
          "title": "The Odyssey",
          "year": 2026,
          "note": "The through-line: IMAX 70mm scarcity, Zendaya's Athena as conscience rather than literal goddess, the missing penises, top-five-follow-up talk."
        },
        {
          "title": "Avengers: Doomsday",
          "year": 2026,
          "note": "Dec 18, same day as Dune. 'Marvel is cooked' means creatively; it'll still make a billion dollars."
        },
        {
          "title": "Spider-Man: Brand New Day",
          "year": 2026,
          "note": "Like Batman, always interesting; a one-protagonist movie versus Doomsday's everything-at-once."
        },
        {
          "title": "Dune Messiah",
          "note": "Denis Villeneuve; opens against Doomsday. Won't win the box office, likely wins the awards."
        },
        {
          "title": "Project Hail Mary",
          "year": 2026,
          "note": "Near-lock for a Best Picture nomination alongside The Odyssey."
        },
        {
          "title": "The Invite",
          "year": 2026,
          "note": "Olivia Wilde; the counter-programming awards play: small, one location, strong word of mouth, a Best Picture maybe."
        },
        {
          "title": "Behemoth",
          "note": "Also Olivia Wilde; keeps her around all season."
        },
        {
          "title": "Obsession",
          "note": "Box-office horror hit in the Weapons mold; the movie Nolan took his kids to."
        },
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "The kind of late-breaking festival surprise that could nudge The Invite out."
        },
        {
          "title": "Wuthering Heights",
          "year": 2026,
          "note": "Sean's foil for The Odyssey: an adaptation whose changes he couldn't follow."
        },
        {
          "title": "Eyes Wide Shut",
          "year": 1999,
          "note": "Sean's rebuttal to the Nolan-is-Kubrick comparison."
        },
        {
          "title": "Sense and Sensibility",
          "year": 1995,
          "note": "Amanda's pitch: Nolan retells it from Mr. Willoughby's perspective."
        },
        {
          "title": "Barbie",
          "year": 2023,
          "note": "The Barbenheimer template for splitting Doomsday/Dune coverage."
        },
        {
          "title": "Oppenheimer",
