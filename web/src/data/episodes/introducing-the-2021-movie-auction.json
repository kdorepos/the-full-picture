          "budgetLeft": 83,
          "picks": [
            {
              "title": "The Matrix Resurrections",
              "year": 2021,
              "price": 355,
              "note": "Sean's costliest lot, run up by Chris out of pure mischief. Lana Wachowski returns with Keanu Reeves and Yahya Abdul-Mateen II."
            },
            {
              "title": "Top Gun: Maverick",
              "year": 2022,
              "price": 255,
              "note": "Amanda nominated it to bait a bidding war, then let Sean have it. Tom Cruise, Miles Teller, Glen Powell, Jon Hamm."
            },
            {
              "title": "Dune",
              "year": 2021,
              "price": 225,
              "note": "Denis Villeneuve's Frank Herbert adaptation with Timothée Chalamet. Chris tapped out and later regretted it."
            },
            {
              "title": "Black Widow",
              "year": 2021,
              "price": 81,
              "note": "Chris bid him up on a movie Sean called a turkey Marvel was dumping. Scarlett Johansson's solo turn."
            },
            {
              "title": "Cry Macho",
              "year": 2021,
              "price": 1,
              "note": "A $1 uncontested grab. Clint Eastwood directs and stars."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "No Time to Die",
              "year": 2021,
              "price": 370,
              "note": "The one she came for. Cary Joji Fukunaga's Bond, with Daniel Craig; she says she'd have gone to $600."
            },
            {
              "title": "The French Dispatch",
              "year": 2021,
              "price": 310,
              "note": "Spent her entire remaining budget on the last pick, uncontested. Wes Anderson."
            },
            {
              "title": "The Beatles: Get Back",
              "year": 2021,
              "price": 135,
              "note": "Stolen from Sean over his objection that he doesn't care about the Beatles. Peter Jackson's documentary."
            },
            {
              "title": "No Sudden Move",
              "year": 2021,
              "price": 110,
              "note": "Steven Soderbergh's HBO Max heist picture; Chris nominated it and lost it. Don Cheadle, Benicio del Toro, Jon Hamm."
            },
            {
              "title": "The Last Duel",
              "year": 2021,
              "price": 75,
              "note": "Uncontested at her opening bid. Ridley Scott; Matt Damon, Adam Driver, Jodie Comer, Ben Affleck."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "House of Gucci",
              "year": 2021,
              "price": 275,
              "note": "The market-setting first lot, more than a quarter of his budget. Ridley Scott; Lady Gaga, Adam Driver, Al Pacino, Jared Leto."
            },
            {
              "title": "The Velvet Underground",
              "year": 2021,
              "price": null,
              "note": "One of four uncontested end-game picks: Chris swept his final slots with his remaining $725, 'divided equally.' Todd Haynes's music documentary."
            },
            {
              "title": "The Guilty",
              "year": 2021,
