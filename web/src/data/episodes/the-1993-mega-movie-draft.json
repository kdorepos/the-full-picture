{
  "slug": "the-1993-mega-movie-draft",
  "title": "The 1993 Mega Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-02-14",
  "runtimeMin": 89,
  "tmdbOverrides": {
    "Blood In, Blood Out": 9702
  },
  "format": "Sean, Amanda, Chris Ryan, Van Lathan, and Rob Mahoney draft the movies of 1993 across six categories, a year so stacked that Tombstone and Demolition Man are still on the board deep into the later rounds.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The 1993 Movie Draft",
      "note": "drama, comedy, Oscar nominee, action/horror, blockbuster, wildcard",
      "draftOf": "1993 movies",
      "categories": [
        "Drama",
        "Comedy",
        "Oscar Nominee",
        "Action/Horror",
        "Blockbuster",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Jurassic Park",
              "year": 1993,
              "category": "Blockbuster",
              "note": "The first overall pick, taken without hesitation, called \"the most universally beloved movie among the five of us.\""
            },
            {
              "title": "So I Married an Axe Murderer",
              "year": 1993,
              "category": "Comedy",
              "note": "Mike Myers doing multiple characters for the first time Sean had seen it done: the old Scottish grandfather \"lives in my heart.\""
            },
            {
              "title": "In the Line of Fire",
              "year": 1993,
              "category": "Oscar Nominee",
              "note": "Clint Eastwood's Secret Service agent versus John Malkovich, a shout-out to the late Wolfgang Petersen and a below-the-line \"hitters team\" (John Bailey, Anne V. Coates)."
            },
            {
              "title": "Cliffhanger",
              "year": 1993,
              "category": "Action/Horror",
              "note": "Renny Harlin's mountain thriller, \"Sly in his bag\" against Michael Rooker and John Lithgow's overacting."
            },
            {
              "title": "True Romance",
              "year": 1993,
              "category": "Drama",
              "note": "Sean's second-favorite film of the year: Tony Scott directing a young Tarantino script, plus the Walken/Hopper scene."
            },
            {
              "title": "A Bronx Tale",
              "year": 1993,
              "category": "Wildcard",
              "note": "Robert De Niro's directorial debut, written by and starring Chaz Palminteri, hitting its 30th anniversary."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Dazed and Confused",
              "year": 1993,
              "category": "Comedy",
              "note": "\"The greatest American high school movie ever made,\" quotable front to back. Launched Richard Linklater after Slacker."
            },
            {
              "title": "Carlito's Way",
              "year": 1993,
              "category": "Drama",
              "note": "De Palma's New York crime epic with Al Pacino and Sean Penn, singled out for the subway tracking sequence."
            },
            {
              "title": "The Firm",
              "year": 1993,
              "category": "Oscar Nominee",
              "note": "Sydney Pollack's Tom Cruise legal thriller with a stacked ensemble (Holly Hunter, Gene Hackman, Hal Holbrook, Wilford Brimley) that barely sets foot in a courtroom."
            },
            {
              "title": "El Mariachi",
              "year": 1993,
              "category": "Action/Horror",
              "note": "Robert Rodriguez's self-financed 16mm debut, the movie that led to Desperado."
            },
            {
              "title": "The Pelican Brief",
              "year": 1993,
              "category": "Blockbuster",
              "note": "Denzel Washington and Julia Roberts; Chris argues it's more emotionally felt than The Firm even if \"The Firm is way more fun.\""
            },
            {
              "title": "Searching for Bobby Fischer",
              "year": 1993,
              "category": "Wildcard",
              "note": "Laurence Fishburne, Ben Kingsley, and Joan Allen star in a movie Chris says he has near-total recall of."
            }
          ]
        },
        {
          "host": "Van Lathan",
          "picks": [
            {
              "title": "Menace II Society",
              "year": 1993,
              "category": "Drama",
              "note": "The Hughes brothers refusing to let Caine get out clean the way Boyz n the Hood let Tre. \"I've never recovered from the experience of watching it.\""
            },
            {
              "title": "Groundhog Day",
              "year": 1993,
              "category": "Comedy",
              "note": "One of Van's top ten movies ever. He wrote a ninth-grade Groundhog Day prequel screenplay called Punxsutawney."
            },
            {
              "title": "What's Love Got to Do with It",
              "year": 1993,
              "category": "Oscar Nominee",
              "note": "Angela Bassett and Laurence Fishburne's Tina Turner biopic, which Van calls the first biopic that ever moved him."
            },
            {
              "title": "Blood In, Blood Out",
              "year": 1993,
              "category": "Action/Horror",
              "note": "Shout-out to Shea Serrano, grouped alongside American Me and Mi Vida Loca as the year's LA gang-life movies."
            },
            {
              "title": "Mrs. Doubtfire",
              "year": 1993,
              "category": "Blockbuster",
              "note": "The No. 2 domestic grosser of 1993 releases at $220 million. Van calls it \"my generation's Kramer vs. Kramer,\" too sad to really file as comedy."
            },
            {
              "title": "Tombstone",
              "year": 1993,
              "category": "Wildcard",
              "note": "\"It fucking kicks ass\": Val Kilmer's Doc Holliday, and the open secret that Kurt Russell actually directed it."
            }
          ]
        },
        {
          "host": "Rob Mahoney",
          "picks": [
            {
              "title": "Sleepless in Seattle",
              "year": 1993,
              "category": "Blockbuster",
              "note": "Taken right out from under Amanda, who says she was \"banking on\" it. Tom Hanks sells an absurd premise without sharing a scene with Meg Ryan until the end."
            },
            {
              "title": "Schindler's List",
              "year": 1993,
              "category": "Oscar Nominee",
              "note": "Shown to Rob twice in school, once in European history and once in American history: \"incredible, difficult, beautiful.\""
            },
            {
              "title": "Short Cuts",
              "year": 1993,
              "category": "Drama",
              "note": "Altman's ensemble of eight overlapping stories, adapted from Raymond Carver. Robert Downey Jr. waking himself up with a fart sealed it for Rob."
            },
            {
              "title": "Demolition Man",
              "year": 1993,
              "category": "Action/Horror",
              "note": "Rob's pick that Van never saw coming: Stallone vs. Wesley Snipes, and the movie that inspired Dennis Rodman's platinum hair."
            },
            {
              "title": "Addams Family Values",
              "year": 1993,
              "category": "Comedy",
              "note": "Christina Ricci burning down Camp Chippewa, Barry Sonnenfeld's last movie before Get Shorty."
            },
            {
              "title": "The Nightmare Before Christmas",
              "year": 1993,
              "category": "Wildcard",
              "note": "An animated movie and an all-time musical, per Rob. He missed Danny Elfman and Phoebe Bridgers performing the score live in London."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Fugitive",
              "year": 1993,
              "category": "Action/Horror",
              "note": "The pick Amanda was sure everyone else would take first: Tommy Lee Jones's Oscar-winning Gerard chasing Harrison Ford's Richard Kimble."
            },
            {
              "title": "Dave",
              "year": 1993,
              "category": "Comedy",
              "note": "A defining movie of her childhood, owned on VHS, with Kevin Kline's presidential double and Charles Grodin balancing the budget with sauerkraut money."
            },
            {
              "title": "The Age of Innocence",
              "year": 1993,
              "category": "Oscar Nominee",
              "note": "Scorsese's Edith Wharton adaptation with Daniel Day-Lewis, Michelle Pfeiffer, and Winona Ryder. Amanda calls it his most underrated movie."
            },
            {
              "title": "Indecent Proposal",
              "year": 1993,
              "category": "Blockbuster",
              "note": "Robert Redford and Demi Moore, directed by Adrian Lyne: \"caused so much ruckus in my house.\""
            },
            {
              "title": "Rudy",
              "year": 1993,
              "category": "Drama",
              "note": "One of Amanda's favorite sports movies. She asked her Tennessee-fan dad if they could root for Notre Dame after seeing it."
            },
            {
              "title": "Sister Act 2: Back in the Habit",
              "year": 1993,
              "category": "Wildcard",
              "note": "Watched at least ten times the year it came out, especially the closing Lauryn Hill solo."
            }
          ]
        }
      ]
    }
  ],
