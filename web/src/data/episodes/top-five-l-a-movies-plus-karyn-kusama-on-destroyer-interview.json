{
  "slug": "top-five-l-a-movies-plus-karyn-kusama-on-destroyer-interview",
  "title": "Top Five L.A. Movies, Plus Karyn Kusama on ‘Destroyer’ | Interview (Ep. 116)",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessy",
    "Chris Ryan"
  ],
  "published": "2019-01-11",
  "runtimeMin": 75,
  "format": "Sean Fennessy and Chris Ryan each count down their five favorite L.A. movies since Chinatown, then Karyn Kusama joins to talk Destroyer, the East Side geography she and her husband built it around, and directing Nicole Kidman.",
  "segments": [
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top Five L.A. Movies",
      "note": "since Chinatown",
      "subject": "L.A. movies",
      "ranked": true,
      "films": [
        {
          "title": "The Player",
          "year": 1992,
          "note": "Chris's No. 1. Altman's Hollywood satire, written by Michael Tolkin, stars Tim Robbins as a studio exec who thinks he's more important than he is, a delusion Chris says \"runs through the veins of so many people in this city.\""
        },
        {
          "title": "Drive",
          "year": 2011,
          "note": "Paired with Speed as his driving movies. Chris moved to L.A. right before it came out and admits none of the neon, Johnny Jewel soundtrack, or Carey Mulligan picnics by the L.A. River panned out in real life."
        },
        {
          "title": "Speed",
          "year": 1994,
          "note": "Came out right when Chris got his license. He calls it \"a 12 Angry Men update,\" a bus full of strangers thrown together by geography and a bomb."
        },
        {
          "title": "Repo Man",
          "year": 1984,
          "note": "Chris's gateway to punk rock and independent film, discovered on VHS. Released the same year as Beverly Hills Cop. The two form his opening pair."
        },
        {
          "title": "Beverly Hills Cop",
          "year": 1984,
          "note": "The first movie that made Chris ask \"what is Los Angeles?\" Eddie Murphy as a stranger dropped into a Maserati-and-plastic-surgery version of the city."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessy's Top Five L.A. Movies",
      "note": "since Chinatown",
      "subject": "L.A. movies",
      "ranked": true,
      "films": [
        {
          "title": "Afternoon Delight",
          "year": 2013,
          "note": "Sean's No. 1, though he says he ordered his five \"chronologically\" rather than by favorite. Kathryn Hahn as a woman filling an empty, well-off L.A. life by taking in Juno Temple's stripper as her family's nanny."
        },
        {
          "title": "Swingers",
          "year": 1996,
          "note": "Paired with The Player as two sides of the same coin: trying to make it in L.A. versus what happens once you do. Doug Liman directed; Jon Favreau wrote and starred."
        },
        {
          "title": "Magnolia",
          "year": 1999,
          "note": "PTA's tapestry of a hundred lonely Angelenos, anchored by Philip Seymour Hoffman's Phil Parma. Sean calls it the rare L.A. movie that \"feels like it's made by an Angeleno.\""
        },
        {
          "title": "The Big Lebowski",
          "year": 1998,
          "note": "A nod to noir without doing noir. The Dude's supposedly-rich foil shows how illusory L.A. money can be, down to who actually owns the house."
        },
        {
          "title": "White Men Can't Jump",
          "year": 1992,
          "note": "Sean's No. 5, and, per Chris, \"the Green Book of its time,\" a hustler's tour of Venice Beach courts and the alleys behind L.A. apartment buildings."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Karyn Kusama on",
      "films": [
        {
          "title": "Destroyer",
          "year": 2018,
          "note": "Kusama's noir, led by Nicole Kidman as a burned-out detective revisiting an old undercover case. Shot on the East Side and in Frogtown rather than the Beverly Hills version of L.A. the film deliberately avoids."
        },
        {
          "title": "Taxi Driver",
          "year": 1976,
          "note": "Kusama's touchstone for keeping an audience with a broken character, what she calls \"a portrait of mental illness\" that's thrillingly entertaining despite itself."
        },
        {
          "title": "In a Lonely Place",
          "year": 1950,
          "note": "Sean's comparison for Nicole Kidman's Erin Bell, a wounded, ruthless Bogart-style investigator."
        },
        {
          "title": "The Invitation",
          "year": 2016,
          "note": "Kusama's dinner-party horror movie, written by her husband Phil Hay and Matt Manfredi. It's the project that reunited the three after Æon Flux."
        },
        {
          "title": "Æon Flux",
          "year": 2005,
          "note": "Kusama's second feature. A creatively difficult shoot that still forged the working relationship with Hay and Manfredi that led to The Invitation and Destroyer."
        },
        {
          "title": "Jennifer's Body",
          "year": 2009,
          "note": "Kusama's film, marketed in a way she says she couldn't fully stand behind. She credits its \"five-year bounce,\" the later reassessment once it was seen apart from that original campaign."
        },
        {
          "title": "Mandy",
          "year": 2018,
          "note": "Kusama's answer to the show's closing question. She drove her husband to see it in a theater and calls it \"a version of feminism I can get behind in a kind of macho exploitation flick.\""
        }
      ]
    }
  ],
