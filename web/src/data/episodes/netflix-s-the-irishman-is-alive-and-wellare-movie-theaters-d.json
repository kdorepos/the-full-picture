    {
      "kind": "interview",
      "heading": "Antonio Banderas",
      "note": "in conversation",
      "guest": "Antonio Banderas on",
      "films": [
        {
          "title": "Pain and Glory",
          "year": 2019,
          "note": "Almodóvar directing Banderas as a version of himself: hair, apartment, paintings copied exactly. Post-heart-attack, Banderas came to it \"from zero\" and let the director's own emotion feed the performance."
        },
        {
          "title": "Labyrinth of Passion",
          "year": 1982,
          "note": "The early Almodóvar film that caused a literal scandal at San Sebastián: audiences split between wanting to kill them and cheering."
        },
        {
          "title": "Matador",
          "year": 1986,
          "note": "One of the provocative, daring 80s films that made him and Pedro the enfants terribles of Spanish cinema."
        },
        {
          "title": "Tie Me Up! Tie Me Down!",
          "year": 1990,
          "note": "Revisited the night before the interview; the Berlin trip where Pedro signed a photo on the Wall with \"The Mambo Kings play very sad songs,\" his goodbye slap about Banderas leaving for America."
        },
        {
          "title": "Law of Desire",
          "year": 1987,
          "note": "First explicit homosexuality in a Spanish film; his character also kills someone, and only the kiss caused an uproar. Banderas on the hypocrisy of that."
        },
        {
          "title": "Women on the Verge of a Nervous Breakdown",
          "year": 1988,
          "note": "The Best Foreign Film nomination that first brought the Almodóvar company to Los Angeles."
        },
        {
          "title": "The Mambo Kings",
          "year": 1992,
          "note": "His first American film, learned phonetically for Arne Glimcher after faking his way through a London meeting in almost no English."
        },
        {
          "title": "Philadelphia",
          "year": 1993,
          "note": "Where Tom Hanks told him to stop apologizing for the accent: \"all we want is to understand you.\""
        },
        {
          "title": "The Skin I Live In",
          "year": 2011,
          "note": "The 2011 reunion after 22 years apart: a reflection on creation dressed as a psychological thriller. He arrived guarded and full of American technique, and it strained the shoot."
        },
        {
          "title": "Puss in Boots",
          "year": 2011,
          "note": "The role that folded his voice into American consciousness, Hollywood calling him just to use it."
        },
        {
          "title": "The Laundromat",
          "year": 2019,
          "note": "Sean says the accent works for the character; Banderas found himself luxuriating in it."
        }
      ]
    }
