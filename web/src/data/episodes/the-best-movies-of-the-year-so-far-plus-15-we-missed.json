    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Ben David Grabinski on",
      "films": [
        {
          "title": "Mike & Nick & Nick & Alice",
          "year": 2026,
          "note": "Grabinski's 20th Century studio debut: a time-travel buddy comedy where a future Nick comes back to stop Mike's murder, built around two Vince Vaughns, James Marsden, and a five-minute Gilmore Girls debate. They talk McTiernan lenses, step-printing, needle drops (an Oasis song, Dave Matthews in a strip club), casting Keith David, and getting a studio to leave every edge on."
        }
      ]
    }
