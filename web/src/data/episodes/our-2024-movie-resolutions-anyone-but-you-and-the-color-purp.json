{
  "slug": "our-2024-movie-resolutions-anyone-but-you-and-the-color-purp",
  "title": "Our 2024 Movie Resolutions, ‘Anyone but You,’ and ‘The Color Purple’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2024-01-02",
  "runtimeMin": 83,
  "format": "Back from the holidays, Sean and Amanda eulogize Tom Wilkinson, run down a soft Christmas box office, review the rom-com Anyone but You and the musical The Color Purple, then swap resolutions for how they'll watch and cover movies in 2024.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Remembering Tom Wilkinson",
      "note": "the actor, 1948–2023",
      "films": [
        {
          "title": "Michael Clayton",
          "year": 2007,
          "note": "The performance both come back to: the brilliant, unwell lawyer with the baguettes. Sean rates it one of the great screen turns of the century."
        },
        {
          "title": "In the Bedroom",
          "year": 2001,
          "note": "Todd Field's first film, where most Americans first noticed him, opposite Sissy Spacek."
        },
        {
          "title": "Duplicity",
          "year": 2009,
          "note": "Amanda's number one: another Tony Gilroy script he could make human and highfalutin at once."
        },
        {
          "title": "Sense and Sensibility",
          "year": 1995,
          "note": "A small, essential part: his death early on sets the whole movie in motion."
        },
        {
          "title": "The Full Monty",
          "year": 1997
        },
        {
          "title": "Shakespeare in Love",
          "year": 1998
        },
        {
          "title": "Eternal Sunshine of the Spotless Mind",
          "year": 2004
        },
        {
          "title": "Batman Begins",
          "year": 2005,
          "note": "Carmine Falcone."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The holiday box office",
      "note": "a soft Christmas, and a thin 2024 calendar",
      "films": [
        {
          "title": "Wonka",
          "year": 2023,
          "note": "Past $400M worldwide. Sean's verdict: Chalamet is now a confirmed global movie star."
        },
        {
          "title": "The Color Purple (2023)",
          "year": 2023,
          "note": "The Christmas box-office champion: $55M in under a week, roughly $18M on Christmas Day, with Black audiences north of 60% of the crowd."
        },
        {
          "title": "Aquaman and the Lost Kingdom",
          "year": 2023,
          "note": "'Bombed' only relative to itself: already ahead of The Marvels and Blue Beetle. James Wan doing Butch Cassidy underwater; the last DCEU film before James Gunn takes over."
        },
        {
          "title": "Rebel Moon – Part One: A Child of Fire",
          "year": 2023,
          "note": "Sean's burned solo ticket, watched on Netflix instead: 'very, very bad.' Snyder should stop being his own cinematographer."
        },
        {
          "title": "The Iron Claw",
          "year": 2023,
          "note": "Already past $18M, likely to clear Past Lives and Priscilla, a strong start for A24's bigger-budget era."
        },
        {
          "title": "Poor Things",
          "year": 2023,
          "note": "$11M in only 800 theaters; the show keeps trying to time a wide-release episode. Coverage promised for next week."
        },
        {
          "title": "Ferrari",
          "year": 2023,
          "note": "Money-wise it bricked; lives on 'in the hearts of dads everywhere.'"
        },
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "A year on from dominating Christmas 2022 with $2.35B, the point of comparison for how soft this holiday was."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Anyone but You’",
      "note": "Will Gluck's rom-com",
      "films": [
        {
          "title": "Anyone But You",
          "year": 2023,
          "note": "Neither fish nor fowl: too tame for a raunchy sex comedy, too janky for a classic rom-com, with a Much Ado About Nothing riff wallpapered on. Glenn Powell is 'the man' and the only one awake; Sean argues Sweeney can't yet do comic delivery in this tone, and blames the underwritten script. The set pieces (Powell and the spider, the Sydney Harbour boat bit) and the closing Natasha Bedingfield montage are the highlights. A likely box-office and streaming win either way."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘The Color Purple’",
      "note": "the musical adaptation",
      "films": [
        {
          "title": "The Color Purple (2023)",
          "year": 2023,
          "note": "Blitz Bazawule's first major studio film, from the Broadway musical of Alice Walker's novel. Both find it broadly unsuccessful (the epistolary novel loses Celie at its center once flattened into a 40-year epic, and the abuse-to-musical-number whiplash is jarring), but grant three or four undeniable numbers. Danielle Brooks (Sofia) is the standout; Fantasia Barrino has the toughest assignment; Taraji P. Henson, Colman Domingo, and Gabriella Wilson all get big moments."
        },
        {
          "title": "The Color Purple (1985)",
          "year": 1985,
          "note": "Spielberg's eighth film, Ebert's favorite of 1985: 11 Oscar nominations, zero wins, and heavy criticism from Black critics (James Baldwin among them). Beautifully made but, Sean argues, a director fitting his innocence onto a brutal story he doesn't quite understand, and among his least-seen '80s work now."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Our 2024 movie resolutions",
      "note": "the inaugural set - Sean resolves, Amanda rebuts",
      "films": [
        {
          "title": "Fast X",
          "year": 2023,
          "note": "The site of the infamous meltdown Sean now resolves to stop having over franchise garbage. Amanda doesn't believe him."
        },
        {
          "title": "Madame Web",
          "year": 2024,
          "note": "Sean's first franchise episode of the year isn't until February 16, which Amanda notes undercuts the whole resolution."
        },
        {
          "title": "Godzilla x Kong: The New Empire",
          "year": 2024,
          "note": "Exhibit A for 'spend less time on filler movies': a good stoned watch, probably not a good podcast. Cover it last."
        },
        {
          "title": "Migration",
          "year": 2023,
          "note": "Bigger at the box office than Anyone but You and skipped anyway, the kind of solid-but-negligible film the resolution is about."
        },
        {
          "title": "The Passionate Friends",
          "year": 1949,
          "note": "The David Lean film, watched at home, that sparked the 'watch more, and more intentionally' resolution, aiming at 800 movies in 2024."
        },
        {
          "title": "The Lady Vanishes",
          "year": 1938,
          "note": "Hitchcock, part of the black-and-white bedtime phase feeding the resolution to devote five episodes to non-contemporary greats (Lumet, Brando, Bacall all turn 100 in 2024)."
        },
        {
          "title": "Megalopolis",
          "year": 2024,
          "note": "The payoff for a new movie-books club, kicking off with Sam Wasson's Coppola biography The Path to Paradise."
        }
      ]
    }
  ],
