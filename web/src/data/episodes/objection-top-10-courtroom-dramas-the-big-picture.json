{
  "slug": "objection-top-10-courtroom-dramas-the-big-picture",
  "title": "Objection! Top 10 Courtroom Dramas | The Big Picture",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-05-05",
  "runtimeMin": 95,
  "format": "Sean and Amanda pick their 10 favorite courtroom dramas, walking them chronologically from 1947 to 1996, after ruling that legal thrillers, deposition scenes, and 12 Angry Men don't qualify.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Top 10 Courtroom Dramas",
      "note": "in the order they aired, chronological, 1947 to 1996",
      "films": [
        {
          "title": "Miracle on 34th Street",
          "year": 1947,
          "note": "Amanda's pick. George Seaton's Christmas movie whose climax is a trial: Kris Kringle prosecuted over whether he's the real Santa, the case won when the Post Office delivering his mail is entered as evidence. With a very small Natalie Wood."
        },
        {
          "title": "Witness for the Prosecution",
          "year": 1957,
          "note": "Billy Wilder's Agatha Christie adaptation, from the middle of his blackout-great run. Charles Laughton (nominated alongside real-life wife Elsa Lanchester), Marlene Dietrich, and Tyrone Power in his last completed film. The end credits ask the audience not to spoil the twist."
        },
        {
          "title": "Anatomy of a Murder",
          "year": 1959,
          "note": "Otto Preminger's nearly three-hour trial. Lawyers consider it the ultimate procedural because you watch the whole thing. Jimmy Stewart crazy like a fox, George C. Scott as the out-of-town prosecutor, Ben Gazzara, Lee Remick, Saul Bass titles, a Duke Ellington score. Includes the debate over whether you can say 'panties' in court."
        },
        {
          "title": "Inherit the Wind",
          "year": 1960,
          "note": "Sean's pick. Stanley Kramer's not-subtle civics lesson on the Scopes Monkey Trial, built on two 68-year-olds screaming about God: Spencer Tracy and Fredric March. Gene Kelly plays the slimy H.L. Mencken-style reporter who keeps sitting at the lawyers' table."
        },
        {
          "title": "A Man for All Seasons",
          "year": 1966,
          "note": "Amanda's pick. Fred Zinnemann's Thomas More film: Paul Scofield won Best Actor, it won Best Picture. One of the few on the list where the man you're rooting for loses. Robert Shaw as Henry VIII, Orson Welles as Wolsey, a very young John Hurt."
        },
        {
          "title": "The Verdict",
          "year": 1982,
          "note": "Sidney Lumet, a David Mamet script, and Paul Newman as a washed-up alcoholic lawyer chasing a hospital malpractice case. The foundational modern courtroom drama, the checklist for every one that follows starts here. Bill Simmons texts instantly whenever it comes up."
        },
        {
          "title": "JFK",
          "year": 1991,
          "note": "Sean's pick. Oliver Stone's assassination counter-myth as three-hour argument, culminating in a 35-minute courtroom finale as DA Jim Garrison (Kevin Costner) tries Clay Shaw. Peak Costner, Tommy Lee Jones, Pesci, Bacon; a John Williams score composed before he'd seen a frame. Hogwash and mesmerizing."
        },
        {
          "title": "My Cousin Vinny",
          "year": 1992,
          "note": "Amanda's pick, argued up from 'fun' to 'important.' A comedy with the best evidence-explaining scene in the genre and Marisa Tomei's Oscar-winning turn: the rare film here that lets a woman do the lawyering. Joe Pesci, and Fred Gwynne as the small-town judge."
        },
        {
          "title": "A Few Good Men",
          "year": 1992,
          "note": "The de facto No. 1 both hosts share. Rob Reiner directs Aaron Sorkin's script; Cruise and Nicholson nose to nose over 'You can't handle the truth.' Sean's theory: Cruise wins the scene, not Nicholson."
        },
        {
          "title": "A Time to Kill",
          "year": 1996,
          "note": "Joel Schumacher's Grisham adaptation that throws the whole genre in a blender: country lawyer, big-shot prosecutor, cranky judge, and Matthew McConaughey's closing argument. Chris Cooper steals the interrogation scene."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "Bonus recommendations",
      "note": "courtroom-adjacent picks on the way out",
      "picks": [
        {
          "title": "Rashomon",
          "year": 1950,
          "by": "Sean Fennessey",
          "note": "A different kind of courtroom: testimonial and unreliable."
        },
        {
          "title": "Paths of Glory",
          "year": 1957,
          "by": "Sean Fennessey",
          "note": "Not really a courtroom movie, just a great one, Kubrick's WWI drama."
        },
        {
          "title": "Compulsion",
          "year": 1959,
          "by": "Sean Fennessey",
          "note": "Sean's one discovery: the Leopold and Loeb trial, with Orson Welles dominating the final 30 minutes."
        },
        {
          "title": "Legally Blonde",
          "year": 2001,
          "by": "Amanda Dobbins",
          "note": "Amanda's shout-out: a woman gets to do the lawyering, with one of the great witness reveals. Left off only because My Cousin Vinny already covers the comic slot."
        }
      ]
    }
  ],
