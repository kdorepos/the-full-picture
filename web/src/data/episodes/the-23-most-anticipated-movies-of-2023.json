{
  "slug": "the-23-most-anticipated-movies-of-2023",
  "title": "The 23 Most Anticipated Movies of 2023",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-01-03",
  "runtimeMin": 113,
  "format": "Sean and Amanda count down twenty-three movies they can't wait for in 2023 - Scorsese, Nolan, Gerwig, Fincher, a Von Erich biopic - then Sean talks with Nanny director Nikyatu Jusu.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "State of the Box Office",
      "note": "Back from the holiday break",
      "films": [
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "James Cameron's sequel rose in its third weekend, up to $66.8 million over the holiday frame and $1.4 billion worldwide after 17 days - the kind of legs a movie hasn't had since E.T. in 1982. Sean and Amanda agree it's a singular event, not a template for the industry."
        },
        {
          "title": "Babylon",
          "year": 2022,
          "note": "Damien Chazelle's 3-hour-8-minute old-Hollywood epic struggled at the box office, but Sean calls it one of his five favorite films of the year and has seen it twice; he spent New Year's posting about it from a hot tub while Amanda handled both their kids solo."
        },
        {
          "title": "Puss in Boots: The Last Wish",
          "year": 2022,
          "note": "One of the only other wide releases over the holiday frame; Sean gave it two and a half stars on Letterboxd."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Most Anticipated Movies of 2023",
      "note": "best to worst",
      "subject": "2023 anticipation",
      "ranked": true,
      "films": [
        {
          "title": "Barbie",
          "year": 2023,
          "note": "No. 1. Greta Gerwig directs from a script with Noah Baumbach, starring Margot Robbie and Ryan Gosling. Amanda trusts Gerwig completely to make something sneakily ambitious out of a Mattel movie."
        },
        {
          "title": "Mission: Impossible - Dead Reckoning Part One",
          "year": 2023,
          "note": "No. 2, sort of - Amanda admits it isn't formally her No. 2, but in her heart it is. Tom Cruise and Christopher McQuarrie, out July 14."
        },
        {
          "title": "Challengers",
          "year": 2023,
          "note": "No. 3. Luca Guadagnino's tennis romantic comedy, starring Zendaya and Josh O'Connor, out August 11."
        },
        {
          "title": "Priscilla",
          "year": 2023,
          "note": "No. 4. Sofia Coppola writes and directs, adapting Priscilla Presley's memoir Elvis and Me. Cailee Spaeny plays Priscilla, Jacob Elordi plays Elvis."
        },
        {
          "title": "Napoleon",
          "year": 2023,
          "note": "No. 5. Ridley Scott directs Joaquin Phoenix as Napoleon Bonaparte and Vanessa Kirby as Empress Josephine. Traded onto Amanda's list from Sean's just before they started recording."
        },
        {
          "title": "Leave the World Behind",
          "year": 2023,
          "note": "No. 6. Sam Esmail adapts Rumaan Alam's novel, starring Julia Roberts. Amanda and Sean interviewed Esmail about directing it while the film was still in post."
        },
        {
          "title": "Magic Mike's Last Dance",
          "year": 2023,
          "note": "No. 7. Steven Soderbergh and Channing Tatum again, with Salma Hayek, out February 10 - which happens to be her son Knox's first birthday."
        },
        {
          "title": "You Hurt My Feelings",
          "year": 2023,
          "note": "No. 8. Nicole Holofcener reunites with Julia Louis-Dreyfus for a Sundance premiere; formerly titled Beth and Dawn."
        },
        {
          "title": "Maestro",
          "year": 2023,
          "note": "No. 9. Bradley Cooper directs and stars as Leonard Bernstein, with Carey Mulligan; delayed a year, which Amanda thinks was the smart call to avoid Tar."
        },
        {
          "title": "Air",
          "year": 2023,
          "note": "No. 10, called Air Jordan on the show. Ben Affleck directs, Matt Damon plays Nike's Sonny Vaccaro, Viola Davis co-stars; based on Phil Knight's memoir Shoe Dog."
        },
        {
          "title": "Creed III",
          "year": 2023,
          "note": "No. 11. Michael B. Jordan's directorial debut, with Jonathan Majors; Sylvester Stallone sits this one out."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Most Anticipated Movies of 2023",
      "note": "best to worst",
      "subject": "2023 anticipation",
      "ranked": true,
      "films": [
        {
          "title": "Killers of the Flower Moon",
          "year": 2023,
          "note": "No. 1, again - it topped Sean's list last year too and still hasn't come out. Martin Scorsese directs Leonardo DiCaprio, Robert De Niro, and Jesse Plemons, from David Grann's book, for Apple."
        },
        {
          "title": "The Killer",
          "year": 2023,
          "note": "No. 2, also carried over from last year. David Fincher directs Michael Fassbender, back from a five-year break, as an assassin having a change of heart. For Netflix."
        },
        {
          "title": "Beau Is Afraid",
          "year": 2023,
          "note": "No. 3, formerly titled Disappointment Boulevard and on Sean's list for three years running. Ari Aster's surrealist comedy-horror, starring Joaquin Phoenix, Nathan Lane, and Patti LuPone."
        },
        {
          "title": "Dune: Part Two",
          "year": 2023,
          "note": "No. 4. Denis Villeneuve's follow-up adds Florence Pugh, Christopher Walken, and Lea Seydoux to the cast; out November 3."
        },
        {
          "title": "The Zone of Interest",
          "year": 2023,
          "note": "No. 5. Jonathan Glazer's first film in eight or nine years since Under the Skin, a Holocaust drama based on Martin Amis's novel, starring Sandra Huller."
        },
        {
          "title": "Oppenheimer",
          "year": 2023,
          "note": "No. 6. Christopher Nolan's J. Robert Oppenheimer biopic, with Cillian Murphy, Emily Blunt, Matt Damon, and Robert Downey Jr. among a huge cast; out July 21, the same day as Barbie."
        },
        {
          "title": "Asteroid City",
          "year": 2023,
          "note": "No. 7. Wes Anderson's western-adjacent ensemble piece, out June 16, with a companion Netflix short, The Wonderful Story of Henry Sugar, starring Benedict Cumberbatch."
        },
        {
          "title": "Ferrari",
          "year": 2023,
          "note": "No. 8, though Sean isn't sure it makes it out this year. Michael Mann directs Adam Driver as Enzo Ferrari, distributed by a financially shaky STX."
        },
        {
          "title": "Ant-Man and the Wasp: Quantumania",
          "year": 2023,
          "note": "No. 9 - Sean's one last shot at the MCU. Peyton Reed directs Paul Rudd, with Jonathan Majors as Kang, out February 17."
        },
        {
          "title": "The Boy and the Heron",
          "year": 2023,
          "note": "No. 10, called How Do You Live on the show, the direct translation of its Japanese title. Hayao Miyazaki's Studio Ghibli comeback."
        },
        {
          "title": "The Iron Claw",
          "year": 2023,
          "note": "No. 11. Sean Durkin's docudrama about the Von Erich wrestling family, with Zac Efron as Kevin Von Erich, plus Jeremy Allen White, Lily James, Harris Dickinson, and Maura Tierney. An A24 release."
        },
        {
          "title": "Knock at the Cabin",
          "year": 2023,
          "note": "No. 12. M. Night Shyamalan adapts Paul Tremblay's novel The Cabin at the End of the World, starring Dave Bautista, Jonathan Groff, and Rupert Grint; out February 3."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "Honorable Mentions",
      "note": "one more each",
      "picks": [
        {
          "title": "M3GAN",
          "year": 2023,
          "by": "Sean Fennessey",
          "note": "Out in three days."
        },
        {
          "title": "Bottoms",
          "year": 2023,
          "by": "Sean Fennessey",
          "note": "Emma Seligman and Rachel Sennott reunite after Shiva Baby and Bodies Bodies Bodies."
        },
        {
          "title": "The Governesses",
          "year": 2023,
          "by": "Sean Fennessey",
          "note": "Said to be Joe Talbot's first film since The Last Black Man in San Francisco."
        },
        {
          "title": "Landscape with Invisible Hand",
          "year": 2023,
          "by": "Sean Fennessey",
          "note": "Cory Finley, who made Thoroughbreds and Bad Education, adapts the Sundance sci-fi novel."
        },
        {
          "title": "Are You There God? It's Me, Margaret",
          "year": 2023,
          "by": "Amanda Dobbins",
          "note": "The Judy Blume adaptation."
        },
        {
          "title": "Blitz",
          "year": 2023,
          "by": "Amanda Dobbins",
          "note": "Steve McQueen directs Saoirse Ronan."
        },
        {
          "title": "Firebrand",
          "year": 2023,
          "by": "Amanda Dobbins",
          "note": "A costume drama about Catherine Parr, Henry VIII's last wife, starring Alicia Vikander and Jude Law."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Nikyatu Jusu on Nanny",
      "guest": "Nikyatu Jusu on",
      "films": [
        {
          "title": "Nanny",
          "year": 2022,
          "note": "Her Sundance Grand Jury Prize-winning debut feature, now streaming on Amazon via Blumhouse. She shot it over 27 days at the height of the pandemic without a single COVID case shutting down production."
        },
        {
          "title": "Drop Dead Fred",
          "year": 1991,
          "note": "The first film she remembers being moved by as a kid - about a woman's chaotic imaginary friend."
        },
        {
          "title": "Suicide by Sunlight",
          "year": 2019,
          "note": "Her breakthrough short, funded by a Tribeca Film Institute/Chanel grant and premiered at Sundance's Midnight section, which led directly to her representation and Nanny."
        },
        {
          "title": "The Invisible Man",
          "year": 2020,
          "note": "The Blumhouse film she points to as evidence the label can support something more than jump-scare horror."
        },
        {
          "title": "Decision to Leave",
          "year": 2022,
          "note": "Her answer to the show's closing question - the last great thing she's seen. She loves Park Chan-wook's use of sound and match cuts."
        }
      ]
    }
  ],
