{
  "slug": "bullet-train-and-the-top-5-movies-set-on-a-train",
  "title": "‘Bullet Train’ and the Top 5 Movies Set on a Train",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Van Lathan"
  ],
  "published": "2022-08-05",
  "runtimeMin": 60,
  "format": "Sean and Van Lathan review David Leitch's ‘Bullet Train,’ then each count down five favorite movies set on a train.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Bullet Train’",
      "films": [
        {
          "title": "Bullet Train",
          "year": 2022,
          "note": "David Leitch directs Brad Pitt as Ladybug, an unlucky assassin taking one last job on a Japanese bullet train packed with rival killers (Brian Tyree Henry, Aaron Taylor-Johnson, Joey King, Andrew Koji, Hiroyuki Sanada, plus Bad Bunny and Zazie Beetz). Sean and Van agree it fails: adapted from Kotaro Isaka's serious novel but rewritten by Leitch and Pitt into a jokey comedy with no stakes. Van's read — a very violent movie masking itself with humor, like ‘Deadpool,’ and a cast full of memes over characters; both call it Kill Bill-inspired but a poor homage. Van pegs Aaron Taylor-Johnson as the best thing in it and Joey King as strong."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Van's top five movies set on a train",
      "note": "counted down 5 to 1 on air",
      "subject": "movies set on a train, per Van",
      "ranked": true,
      "films": [
        {
          "title": "From Russia with Love",
          "year": 1963,
          "note": "No. 1. Bond and SPECTRE, most of the second and third act on the train; Van praises Robert Shaw's Red Grant as a nastier, scaled-down villain."
        },
        {
          "title": "Snowpiercer",
          "year": 2013,
          "note": "No. 2. Bong Joon-ho's class satire on a train that never stops. One of Van's favorites; his partner Kalika was horrified by it."
        },
        {
          "title": "Under Siege 2: Dark Territory",
          "year": 1995,
          "note": "No. 3. Die Hard on a train with Steven Seagal; Sean rides for Eric Bogosian's villain."
        },
        {
          "title": "Source Code",
          "year": 2011,
          "note": "No. 4. Duncan Jones's Groundhog Day-meets-espionage puzzle with Jake Gyllenhaal reliving eight minutes on a train. Van thinks it's underrated; Sean likes it but sees a third-act problem."
        },
        {
          "title": "Silver Streak",
          "year": 1976,
          "note": "No. 5. The Gene Wilder / Richard Pryor comedy, one of the first movies Van ever saw."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's top five movies set on a train",
      "note": "counted down 5 to 1 on air",
      "subject": "movies set on a train, per Sean",
      "ranked": true,
      "films": [
        {
          "title": "The Taking of Pelham One Two Three",
          "year": 1974,
          "note": "No. 1. Joseph Sargent's subway crime drama with Walter Matthau; Sean calls it one of the best movies of the '70s and a template for later heist films."
        },
        {
          "title": "Runaway Train",
          "year": 1985,
          "note": "No. 2. Konchalovsky's runaway-train epic from an Akira Kurosawa story; Jon Voight and Eric Roberts both earned Oscar nods. Sister film to ‘Unstoppable.’"
        },
        {
          "title": "The Darjeeling Limited",
          "year": 2007,
          "note": "No. 3. Wes Anderson's India-set brothers-on-a-train movie; Sean has come around on a pick he once dismissed as a white-savior film."
        },
        {
          "title": "Unstoppable",
          "year": 2010,
          "note": "No. 4. Tony Scott's Denzel Washington / Chris Pine runaway-train thriller, better than its reputation."
        },
        {
          "title": "The Train",
          "year": 1964,
          "note": "No. 5. John Frankenheimer's WWII resistance movie with Burt Lancaster stalling a Nazi art train; real trains, black and white."
        }
      ]
    }
  ],
