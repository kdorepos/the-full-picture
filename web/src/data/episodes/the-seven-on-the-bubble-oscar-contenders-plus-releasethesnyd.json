{
  "slug": "the-seven-on-the-bubble-oscar-contenders-plus-releasethesnyd",
  "title": "The Seven \"on the Bubble\" Oscar Contenders. Plus: #ReleaseTheSnyderCut ... or Something | The Oscars Show",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2019-11-19",
  "runtimeMin": 112,
  "format": "Seven Best Picture bubble contenders, a Stock Up/Stock Down on Charlie's Angels and the Snyder Cut discourse, an early Best Cinematography read, and Scott Z. Burns on directing The Report.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Seven \"on the Bubble\" Oscar Contenders",
      "note": "with a shortened season, who's actually got a shot",
      "films": [
        {
          "title": "Ford v Ferrari",
          "year": 2019,
          "note": "Opened to $31 million, soft against past Novembers but proof the James Mangold racing drama has adult-audience legs. Sean and Amanda see a Best Picture slot but call Christian Bale's Best Actor case an uphill climb in a stacked field, and doubt Mangold cracks the five directing slots."
        },
        {
          "title": "Waves",
          "year": 2019,
          "note": "Trey Edward Shults' family drama split the room: Amanda was overwhelmed by it, Sean found it style over substance. Sterling K. Brown looks like the clearest nomination path, in Best Supporting Actor."
        },
        {
          "title": "Honey Boy",
          "year": 2019,
          "note": "Shia LaBeouf plays a version of his own abusive father; Noah Jupe and Lucas Hedges play LaBeouf at different ages. Box office dropped off fast in week two, and Sean isn't convinced enough voters will seek it out."
        },
        {
          "title": "The Report",
          "year": 2019,
          "note": "Scott Z. Burns' directorial debut, with Adam Driver as Senate staffer Daniel Jones investigating the CIA torture program. Sean calls Annette Bening's Dianne Feinstein the film's best nomination shot, despite a thin part."
        },
        {
          "title": "Dark Waters",
          "year": 2019,
          "note": "Todd Haynes' DuPont-poisoning docudrama, with Mark Ruffalo as the lawyer who took on the company. Sean recommends it but doesn't think it's really on the bubble anymore: too bleak for Oscar voters, even with a strong Bill Camp performance."
        },
        {
          "title": "The Banker",
          "year": 2020,
          "note": "Apple TV+'s awards bid: Samuel L. Jackson and Anthony Mackie as Black entrepreneurs who buy a bank in the Jim Crow South, using Nicholas Hoult as their white front man. Amanda calls it purely watchable; Sean floats a lightweight Best Supporting Actor case for Jackson."
        },
        {
          "title": "Bombshell",
          "year": 2019,
          "note": "Jay Roach's Fox News docudrama, with Charlize Theron as Megyn Kelly, Nicole Kidman as Gretchen Carlson, and Margot Robbie as a composite character. Both predict four nominations: picture, actress, supporting actress, and original screenplay."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock Up, Stock Down",
      "films": [
        {
          "title": "Charlie's Angels",
          "year": 2019,
          "note": "Elizabeth Banks' reboot flopped hard: $8.5 million on 3,500 screens. Amanda blames a marketing push aimed at kids and general reboot fatigue; Kristen Stewart got the only real praise."
        },
        {
          "title": "The Good Liar",
          "year": 2019,
          "note": "Ian McKellen and Helen Mirren con-artist thriller from Bill Condon that pivots into an elder-care drama neither host expected. $5.6 million opening; Sean recommends Condon's Gods and Monsters instead."
        },
        {
          "title": "Earthquake Bird",
          "year": 2019,
          "note": "Alicia Vikander thriller set in Japan, from the director of Still Alice, that went straight to Netflix with almost no notice. Neither host thinks it works."
        },
        {
          "title": "Justice League",
          "year": 2017,
          "note": "Gal Gadot, Ben Affleck, and Ray Fisher all tweeted #ReleaseTheSnyderCut on the two-year anniversary of the theatrical cut's release. Sean reads it as a sign that an alternate Zack Snyder edit really exists, though he's skeptical it would actually be good."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Big Race: Best Cinematography",
      "films": [
        {
          "title": "Joker",
          "year": 2019,
          "note": "DP Lawrence Sher won the Golden Frog at Camera Image, following the Golden Lion in Venice. Sean expects the win to help drag Joker to picture, actor, and a pile of below-the-line nominations."
        },
        {
          "title": "Once Upon a Time in Hollywood",
          "year": 2019,
          "note": "Robert Richardson's ninth nomination looks likely, for recreating 1969 Hollywood with unusual stillness for a Tarantino movie."
        },
        {
          "title": "The Irishman",
          "year": 2019,
          "note": "Rodrigo Prieto shot around Scorsese's de-aging technology. Amanda prefers the film's mood and story to its look, and isn't as big a fan of Prieto's style as Sean is."
        },
        {
          "title": "The Lighthouse",
          "year": 2019,
          "note": "Jarin Blaschke's black-and-white, boxy-aspect-ratio photography is the kind of showy work this category tends to reward, though a nomination would be a surprise given the film's scale."
        },
        {
          "title": "1917",
          "year": 2019,
          "note": "Roger Deakins (14 nominations, one win, for Blade Runner 2049) shooting Sam Mendes' one-take World War I film. Sean calls this the movie \"created to get Deakins a second Oscar.\""
        },
        {
          "title": "The Two Popes",
          "year": 2019,
          "note": "César Charlone, zero prior nominations, won the Silver Frog at the same Camera Image festival."
        },
        {
          "title": "A Hidden Life",
          "year": 2019,
          "note": "Shot by Jörg Widmer, Terrence Malick's longtime camera operator making his own DP debut; zero prior nominations."
        },
        {
          "title": "Jojo Rabbit",
          "year": 2019,
          "note": "Shot by Mihai Mălaimare Jr., who also shot The Master; zero prior nominations."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "Shot by Hong Kyung-pyo; zero prior nominations."
        },
        {
          "title": "The Lion King",
          "year": 2019,
          "note": "Caleb Deschanel (six nominations, no wins) shot the photorealistic remake despite it being entirely digital, no live animals or landscapes. Sean thinks his name recognition could carry a nomination anyway."
        },
        {
          "title": "The Painted Bird",
          "year": 2019,
          "note": "Shot by Vladimir Smutný; neither host had seen it yet."
        },
        {
          "title": "Little Women",
          "year": 2019,
          "note": "Yorick Le Saux, zero prior nominations. Amanda calls the look understated but painterly, good at conveying the four sisters talking over each other."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Scott Z. Burns on",
      "films": [
        {
          "title": "The Report",
          "year": 2019,
          "note": "Burns describes tracking down Daniel Jones (the real-life Senate staffer behind the 6,700-page torture report) by cold-calling Dianne Feinstein's office, and giving him the pseudonym \"Neil Marcus\" during production for privacy Jones said he didn't need. Shot in 26 days, largely out of order."
        },
        {
          "title": "Wild Tales",
          "year": 2014,
          "note": "The anthology film Burns says he and Soderbergh both loved: its structure directly inspired The Laundromat."
        },
        {
          "title": "The Laundromat",
          "year": 2019,
          "note": "Burns and Soderbergh's Panama Papers comedy, turning the real law firm's founders into Wild Tales-style game-show-host narrators. Burns calls it a reaction against exhaustion from researching The Report."
        },
        {
          "title": "Contagion",
          "year": 2011,
          "note": "Named as one of several prior Burns-Soderbergh collaborations."
        },
        {
          "title": "The Informant!",
          "year": 2009,
          "note": "The earlier Burns-Soderbergh collaboration whose semi-farcical tone he originally wanted for The Report, before it became a straighter drama."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "Burns names it the last great thing he's seen, from a Telluride screening: Bong Joon-ho's most complete film, he says, and a spiritual companion to The Laundromat's income-inequality themes."
        }
      ]
    }
  ],
