{
  "slug": "the-stephen-king-movie-hall-of-fame",
  "title": "The Stephen King Movie Hall of Fame",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Matt Gourley",
    "Paul Rust"
  ],
  "published": "2022-05-13",
  "runtimeMin": 93,
  "format": "Sean Fennessey recruits the hosts of With Gourley and Rust to build a ten-film Stephen King Hall of Fame, arguing through five decades of adaptations from Carrie to It.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Stephen King never really goes away",
      "note": "with Matt Gourley and Paul Rust of With Gourley and Rust",
      "films": [
        {
          "title": "Firestarter",
          "year": 2022,
          "note": "The new Zac Efron adaptation opening this weekend is what kicked off the conversation; nobody argues it's good."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Stephen King Movie Hall of Fame",
      "note": "ten films, voted green, yellow, or red live on the show",
      "honoree": "Stephen King",
      "films": [
        {
          "title": "Carrie",
          "year": 1976,
          "note": "Brian De Palma's adaptation of King's first novel got Sissy Spacek and Piper Laurie both Oscar nominations. Matt's the outlier who doesn't love it."
        },
        {
          "title": "The Shining",
          "year": 1980,
          "note": "The one unanimous pick of the episode. King famously hated Kubrick's version; nobody here is bothered by that."
        },
        {
          "title": "Creepshow",
          "year": 1982,
          "note": "George Romero directs, King acts. Started as a yellow, then survived the final cut over Maximum Overdrive and The Running Man."
        },
        {
          "title": "The Dead Zone",
          "year": 1983,
          "note": "The favorite of a stacked 1983 class that also included Cujo and Christine, both of which missed the cut."
        },
        {
          "title": "Stand By Me",
          "year": 1986,
          "note": "King's first non-horror adaptation, and the one that introduced him to Rob Reiner, whose production company Castle Rock is named after a King setting."
        },
        {
          "title": "The Running Man",
          "year": 1987,
          "note": "Took the last open slot over Maximum Overdrive on a straight gut call from Matt Gourley."
        },
        {
          "title": "Misery",
          "year": 1990,
          "note": "The easiest yes of the episode. Kathy Bates, James Caan, a William Goldman script."
        },
        {
          "title": "The Shawshank Redemption",
          "year": 1994,
          "note": "In without debate, backlash-to-the-backlash notwithstanding."
        },
        {
          "title": "The Mist",
          "year": 2007,
          "note": "The episode's other unanimous pick. Frank Darabont's bleakest ending, in a filmography full of them."
        },
        {
          "title": "It",
          "year": 2017,
          "note": "Voted in on its own, separate from Chapter Two, which none of the three had actually finished."
        }
      ]
    }
  ],
