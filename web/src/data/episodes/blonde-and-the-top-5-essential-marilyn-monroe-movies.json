  ],
  "published": "2022-09-28",
  "runtimeMin": 64,
  "format": "Sean and Amanda pan Andrew Dominik's three-hour Marilyn Monroe biopic, then work through the films that actually made her.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Blonde’",
      "note": "the Netflix Marilyn Monroe biopic",
      "films": [
        {
          "title": "Blonde",
          "year": 2022,
          "note": "Andrew Dominik's NC-17 fictionalization of Marilyn's life, adapted from the Joyce Carol Oates novel with Ana de Armas as Marilyn. Both hosts admire the visual craft and the shot-for-shot recreations but read the film as relentless trauma porn that strips her of any agency. Sean lands on two stars; Amanda would give it none."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The essential Marilyn Monroe movies",
      "note": "the work behind the icon",
      "films": [
        {
          "title": "Some Like It Hot",
          "year": 1959,
          "note": "The Billy Wilder classic both hosts name as her best film and best performance — she goes toe to toe with Jack Lemmon, funny but a little heartbreaking."
        },
        {
          "title": "All About Eve",
          "year": 1950,
          "note": "A scene or two, but her looks and presence do the work; Sean calls it a movie that already understood Hollywood 30 years in."
        },
        {
          "title": "Niagara",
          "year": 1953,
          "note": "An overheated color noir Sean loves — she's the dame who makes everything go haywire, and she's well used in it."
        },
        {
          "title": "Gentlemen Prefer Blondes",
          "year": 1953,
          "note": "One of her two Jane Russell pictures from her early-'50s hot streak; the 'Diamonds Are a Girl's Best Friend' number Blonde recreates comes from here."
        },
        {
          "title": "How to Marry a Millionaire",
          "year": 1953,
          "note": "The other Jane Russell-era hit from the same peak stretch."
        },
        {
          "title": "River of No Return",
          "year": 1954,
          "note": "An Otto Preminger Western opposite Robert Mitchum; Sean watched it fresh and liked that she plays a real part, not the silly showgirl."
        },
        {
          "title": "Bus Stop",
          "year": 1956,
          "note": "Not a good movie, Sean says, but maybe her best performance because it's her least 'Marilyn' — brunette, a decent Southern accent, resisting the cowboy pursuing her."
        },
        {
          "title": "The Misfits",
          "year": 1961,
          "note": "John Huston directs an Arthur Miller script written for her, with Clark Gable and Montgomery Clift; impressionistic, not a success, and she's ravishing turning the corner on her beauty."
        },
        {
          "title": "The Asphalt Jungle",
          "year": 1950,
          "note": "One of her first parts, also directed by Huston, cited as the start of a career that ran through 10 of the era's major directors."
        },
        {
          "title": "The Seven Year Itch",
          "year": 1955,
          "note": "Source of the 30-foot cutout image the movie treats as her alter-ego superhero self."
        }
      ]
    }
  ],
