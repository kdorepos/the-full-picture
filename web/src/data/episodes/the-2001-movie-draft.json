  ],
  "published": "2023-06-13",
  "runtimeMin": 118,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan draft 2001 across six categories (Blockbuster, Drama, Comedy, Action Horror Thriller, Oscar Nominee, and Wildcard), from Mulholland Drive to Zoolander.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The 2001 Movie Draft",
      "draftOf": "2001 movies",
      "categories": [
        "Blockbuster",
        "Drama",
        "Comedy",
        "Action Horror Thriller",
        "Oscar Nominee",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Lord of the Rings: The Fellowship of the Ring",
              "year": 2001,
              "category": "Blockbuster",
              "note": "Sean's pick from what he calls a weak blockbuster field. He defends it as 'unimpeachable' after Amanda gives him a mocking thumbs up."
            },
            {
              "title": "Mulholland Drive",
              "year": 2001,
              "category": "Drama",
              "note": "David Lynch on Los Angeles, ambition, and stardom. Sean calls the diner scene maybe the scariest jump scare of the 21st century."
            },
            {
              "title": "Wet Hot American Summer",
              "year": 2001,
              "category": "Comedy",
              "note": "Barely released in theaters and became a cult object. David Wain directed, Michael Showalter co-wrote; Bradley Cooper's first movie and an early Amy Poehler role."
            },
            {
              "title": "Vanilla Sky",
              "year": 2001,
              "category": "Action Horror Thriller",
              "note": "Cameron Crowe's Lynchian swing with Tom Cruise, adapted from Abre los Ojos. Sean pairs it with Frankenheimer's Seconds as a spiritual cousin."
            },
            {
              "title": "A.I. Artificial Intelligence",
              "year": 2001,
              "category": "Oscar Nominee",
              "note": "Spielberg completing a project Kubrick left unfinished. Sean calls it one of the great Spielberg films and cites Haley Joel Osment's performance."
            },
            {
              "title": "In the Mood for Love",
              "year": 2001,
              "category": "Wildcard",
              "note": "Wong Kar-wai's film, shot by Christopher Doyle. Sean floats it as possibly the best movie of the year and admits he almost forgot to draft it."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Princess Diaries",
              "year": 2001,
              "category": "Blockbuster",
              "note": "Amanda's pick after reading through a long list of that year's blockbuster board. Anne Hathaway's debut and a returning Julie Andrews."
            },
            {
              "title": "The Royal Tenenbaums",
              "year": 2001,
              "category": "Drama",
              "note": "Amanda's category choice for a Wes Anderson film both she and Sean say could've gone comedy instead."
            },
            {
              "title": "Legally Blonde",
              "year": 2001,
              "category": "Comedy",
              "note": "Amanda didn't like it the first time she saw it with friends in high school; came around on a rewatch."
            },
            {
              "title": "Training Day",
              "year": 2001,
              "category": "Action Horror Thriller",
              "note": "The movie Amanda saw twice on consecutive days."
            },
            {
              "title": "Bridget Jones's Diary",
              "year": 2001,
              "category": "Oscar Nominee",
              "note": "Renée Zellweger's best actress nomination. The film's conference speech was a reading at Amanda's wedding."
            },
            {
              "title": "Zoolander",
              "year": 2001,
              "category": "Wildcard",
              "note": "Released weeks after 9/11 and flopped; became a heavy-rotation favorite in Amanda's freshman dorm."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Ocean's Eleven",
              "year": 2001,
              "category": "Blockbuster",
              "note": "Chris's first-overall pick and, by his account, one of the trio's three shared favorite movies (with Moneyball and The Social Network)."
            },
            {
              "title": "Memento",
              "year": 2001,
              "category": "Drama",
              "note": "Christopher Nolan's breakthrough. Chris says it's where his relationship with Nolan's films began."
            },
            {
              "title": "Jay and Silent Bob Strike Back",
              "year": 2001,
              "category": "Comedy",
              "note": "Kevin Smith's Clerks spinoff, which Chris saw on opening night in college."
            },
            {
              "title": "Heist",
              "year": 2001,
              "category": "Action Horror Thriller",
              "note": "David Mamet's con movie with Gene Hackman and Delroy Lindo. Chris rewatched it the day before taping and calls it excellent."
            },
            {
              "title": "Sexy Beast",
              "year": 2001,
              "category": "Oscar Nominee",
              "note": "Ben Kingsley's nomination; Chris argues Jonathan Glazer should have been nominated for directing instead of Ron Howard, who won for A Beautiful Mind."
            },
            {
              "title": "Ali",
              "year": 2001,
              "category": "Wildcard",
              "note": "Michael Mann's Muhammad Ali biopic with Will Smith and Jamie Foxx. Chris calls the opening ten minutes the best of any 21st-century film."
            }
          ]
        }
