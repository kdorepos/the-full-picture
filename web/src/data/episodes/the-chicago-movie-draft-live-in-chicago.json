{
  "slug": "the-chicago-movie-draft-live-in-chicago",
  "title": "The Chicago Movie Draft LIVE in Chicago!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan",
    "Tracy Letts"
  ],
  "published": "2025-07-22",
  "runtimeMin": 119,
  "format": "A live Chicago movie draft from the Steppenwolf Theatre, with playwright and Steppenwolf company member Tracy Letts as the fourth chair. After a Criterion-sponsored trivia round, Sean, Amanda, Chris Ryan, and Letts each fill a six-slot board (Drama, Oscar Nominee, Blockbuster, Action / Horror / Thriller, Comedy, Wildcard) while arguing over what counts as a Chicago movie. The room votes; Amanda wins.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "Chicago movies",
      "note": "Amanda Dobbins won the audience vote with 43%; Chris Ryan second (32%), Tracy Letts third (17%), Sean fourth (8%).",
      "categories": [
        "Drama",
        "Oscar Nominee",
        "Blockbuster",
        "Action / Horror / Thriller",
        "Comedy",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Eight Men Out",
              "year": 1988,
              "category": "Drama",
              "note": "John Sayles on the 1919 Black Sox; a show of hands put roughly 80% of the room as never having seen it."
            },
            {
              "title": "Primal Fear",
              "year": 1996,
              "category": "Oscar Nominee",
              "note": "Gregory Hoblit; Edward Norton's Oscar-nominated breakout, with John Mahoney as a Steppenwolf company member."
            },
            {
              "title": "The Dark Knight",
              "year": 2008,
              "category": "Blockbuster",
              "note": "Ryan's ruling: Begins is Mongolia, Dark Knight is Chicago, Rises is Pittsburgh."
            },
            {
              "title": "Thief",
              "year": 1981,
              "category": "Action / Horror / Thriller",
              "note": "First overall pick. Michael Mann's safecracker movie with James Caan; his favorite Chicago film, a Criterion title."
            },
            {
              "title": "The Sting",
              "year": 1973,
              "category": "Comedy",
              "note": "George Roy Hill, Newman and Redford; Best Picture winner. Ryan prefers it to Butch Cassidy and the Sundance Kid."
            },
            {
              "title": "Glengarry Glen Ross",
              "year": 1992,
              "category": "Wildcard",
              "note": "Mamet; drafted in honor of Letts, who has twice played Williamson on the Steppenwolf stage."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Risky Business",
              "year": 1983,
              "category": "Drama",
              "note": "Tangerine Dream score; the category-fraud pick the whole table contested as a comedy."
            },
            {
              "title": "The Fugitive",
              "year": 1993,
              "category": "Oscar Nominee",
              "note": "Andrew Davis; Tommy Lee Jones won Supporting Actor. Argued as the most Chicago-per-minute movie there is."
            },
            {
              "title": "The Color of Money",
              "year": 1986,
              "category": "Blockbuster",
              "note": "Scorsese; Newman and Cruise. 'Spiritually Chicago' before it moves on to Atlantic City."
            },
            {
              "title": "House of Games",
              "year": 1987,
              "category": "Action / Horror / Thriller",
              "note": "Mamet's con-man movie with Joe Mantegna and Ricky Jay; a film Sean's father showed him at ten."
            },
            {
              "title": "Wayne's World",
              "year": 1992,
              "category": "Comedy",
              "note": "Suburban, and roundly mocked for it. They do drive into the city."
            },
            {
              "title": "Transformers: Dark of the Moon",
              "year": 2011,
              "category": "Wildcard",
              "note": "Bay's moon-landing / JFK conspiracy entry; the joke pick that got its own printed placard."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "A League of Their Own",
              "year": 1992,
              "category": "Drama",
              "note": "Penny Marshall; Amanda insists on drama, citing the war telegram and the Cooperstown coda."
            },
            {
              "title": "Home Alone",
              "year": 1990,
              "category": "Oscar Nominee",
              "note": "Suburban, but the O'Hare sequence keeps it Chicago."
            },
            {
              "title": "My Best Friend's Wedding",
              "year": 1997,
              "category": "Blockbuster",
              "note": "Her most-watched Julia Roberts rom-com and a top-five in the genre for her; owned it on VHS."
            },
            {
              "title": "Widows",
              "year": 2018,
              "category": "Action / Horror / Thriller",
              "note": "Steve McQueen's Chicago-politics heist; the long Colin Farrell car shot from the poorest wards to his own block."
            },
            {
              "title": "Ferris Bueller's Day Off",
              "year": 1986,
              "category": "Comedy",
              "note": "Her favorite John Hughes movie, watched a thousand times on VHS."
            },
            {
              "title": "While You Were Sleeping",
              "year": 1995,
              "category": "Wildcard",
              "note": "Sandra Bullock on the L; occasion for Amanda's unprompted full-plot recap."
            }
          ]
        },
        {
          "host": "Tracy Letts",
          "picks": [
            {
              "title": "Medium Cool",
              "year": 1969,
              "category": "Drama",
              "note": "Haskell Wexler shot fiction into the real 1968 Chicago riots: 'Look out, Haskell, it's real.' The least-seen pick of the night."
            },
            {
              "title": "Hoop Dreams",
              "year": 1994,
              "category": "Oscar Nominee",
              "note": "Steve James; Letts's No. 1 pick and, to him, the best sports movie ever made."
            },
            {
              "title": "The Untouchables",
              "year": 1987,
              "category": "Blockbuster",
              "note": "De Palma, Morricone score; Letts notes it cast no Chicago actors except improv guru Del Close."
            },
            {
              "title": "Henry: Portrait of a Serial Killer",
              "year": 1986,
              "category": "Action / Horror / Thriller",
              "note": "John McNaughton; Michael Rooker on Lower Wacker, filmed as Letts arrived in town."
            },
            {
              "title": "The Blues Brothers",
              "year": 1980,
              "category": "Comedy",
              "note": "Belushi and Aykroyd, Aretha Franklin, and the record-setting police-car pileup."
            },
            {
              "title": "Love Jones",
              "year": 1997,
              "category": "Wildcard",
              "note": "Theodore Witcher's only feature; Larenz Tate and Nia Long, a Criterion edition."
            }
          ]
        }
