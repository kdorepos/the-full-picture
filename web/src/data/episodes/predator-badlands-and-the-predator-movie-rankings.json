{
  "slug": "predator-badlands-and-the-predator-movie-rankings",
  "title": "‘Predator: Badlands’ and the 'Predator' Movie Rankings",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessy",
    "Chris Ryan"
  ],
  "published": "2025-11-10",
  "runtimeMin": 76,
  "format": "Sean and a London-based Chris Ryan open with the remake news cycle, review Dan Trachtenberg's PG-13, human-free 'Predator: Badlands,' rank all nine Predator films, and close on Sydney Sweeney's box-office run.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The news: remakes, and where did Mark Wahlberg go",
      "note": "the opening rundown",
      "films": [
        {
          "title": "Thunderbolt and Lightfoot",
          "year": 1974,
          "note": "Ryan Reynolds is eyeing a remake of the Michael Cimino crime movie (Clint Eastwood, Jeff Bridges) with Amazon MGM. CR notes Reynolds made Mississippi Grind, so the taste isn't a stretch; the worry is a 'glib digital action farce.'"
        },
        {
          "title": "The Thomas Crown Affair",
          "year": 1968,
          "note": "Michael B. Jordan is directing and starring in a remake, script by Drew Pearce."
        },
        {
          "title": "Play Dirty",
          "year": 2025,
          "note": "The Shane Black / Mark Wahlberg / LaKeith Stanfield Amazon MGM streamer. Both suspect it was recut; Sean thought it 'quite poor,' CR had a soft time with the Parker dialogue."
        },
        {
          "title": "Mississippi Grind",
          "year": 2015
        },
        {
          "title": "The Gambler",
          "year": 2014,
          "note": "Cited as the last Wahlberg role he seemed to care about, 12-plus years ago."
        },
        {
          "title": "The Fighter",
          "year": 2010
        },
        {
          "title": "Father Stu",
          "year": 2022
        },
        {
          "title": "Spenser Confidential",
          "year": 2020,
          "note": "Occasion of the show's first-ever Hall of Fame, a Wahlberg one."
        },
        {
          "title": "Deepwater Horizon",
          "year": 2016
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Predator: Badlands’",
      "films": [
        {
          "title": "Predator: Badlands",
          "year": 2025,
          "note": "Dan Trachtenberg's ninth Predator film and a $40M opening. First one told through a Predator's eyes: Deck (Demetrius Schuster-Koloamatangi), the runt outcast, lands on a deadly planet to bag a Kalisk and pairs with Thea, a severed droid torso played by Elle Fanning. PG-13 and human-free, a 'recovering from trauma' movie with Marvel-ish, Buffy-adjacent jokes. CR calls it excellent genre filmmaking; Sean likes it a good deal but not in love, wary of how un-Predator the softness is, and credits Fanning and the IMAX scale for carrying it. The Weyland-Yutani reveal lands for the Alien faithful."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "The 'Predator' Movie Rankings",
      "note": "all nine, best to worst — CR's final call",
      "subject": "Predator",
      "ranked": true,
      "films": [
        {
          "title": "Predator",
          "year": 1987,
          "note": "No. 1 by a wide margin. A 'five-star masterpiece,' John McTiernan's lean, mean action peak, and a portrait of American military intervention."
        },
        {
          "title": "Predators",
          "year": 2010,
          "note": "No. 2, and CR's bold, contested pick. Nimrod Antal's Most Dangerous Game riff strands mercenaries on a hunting-ground planet; a bonkers cast (Brody, Goggins, Ali, Fishburne, Grace). Sean thinks it's 'sick on the page' but 'dumb as shit.'"
        },
        {
          "title": "Predator 2",
          "year": 1990,
          "note": "No. 3. Stephen Hopkins's coked-out L.A. sequel, 'the most satisfying,' propped up by Busey and Paxton. CR vows to rewatch it 38 more times."
        },
        {
          "title": "Prey",
          "year": 2022,
          "note": "No. 4. Trachtenberg's Comanche-era entry, agreed to be the most watertight of the modern films even as it lands below Predator 2 on pure rewatch love."
        },
        {
          "title": "Predator: Badlands",
          "year": 2025,
          "note": "No. 5. The new one; roughly tied in their heads with Killer of Killers."
        },
        {
          "title": "Predator: Killer of Killers",
          "year": 2025,
          "note": "No. 6. Trachtenberg's animated anthology (Vikings, samurai, WWII), more satisfying as a Predator movie, capped only by the animation style. 'NC-17 if it were live action.'"
        },
        {
          "title": "The Predator",
          "year": 2018,
          "note": "No. 7. Shane Black's much-recut, incoherent entry; good dialogue, a plot that goes off the rails with the autistic-kid-DNA turn."
        },
        {
          "title": "AVP: Alien vs. Predator",
          "year": 2004,
          "note": "No. 8. The Antarctica one; Paul W.S. Anderson, poorly made."
        },
        {
          "title": "Aliens vs Predator: Requiem",
          "year": 2007,
          "note": "Last. The Colorado-set sequel neither can defend."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Sydney Sweeney's box-office run",
      "note": "closing tangent",
      "films": [
        {
          "title": "Christy",
          "year": 2025,
          "note": "David Michôd biopic of boxer Christy Martin, out this weekend to soft numbers. Sean thought it fine and her performance good, the film rote."
        },
        {
          "title": "Night Teeth",
          "year": 2021,
          "note": "2021 Netflix vampire movie that didn't connect."
        },
        {
          "title": "Reality",
          "year": 2023,
          "note": "The Reality Winner HBO film; Sean's favorite Sweeney performance so far, 'a banger.'"
        },
        {
          "title": "Anyone But You",
          "year": 2023,
          "note": "The Glen Powell rom-com smash."
        },
        {
          "title": "Madame Web",
          "year": 2024,
          "note": "'Not her fault.'"
        },
        {
          "title": "Immaculate",
          "year": 2024,
          "note": "The nun-horror film they dug; modest business."
        },
        {
          "title": "Eden",
          "year": 2025,
          "note": "Ron Howard's, released this year; didn't do well."
        },
        {
          "title": "Echo Valley",
          "year": 2025,
          "note": "Straight-to-Apple-TV+ with Julianne Moore."
        },
        {
          "title": "Americana",
          "year": 2025,
          "note": "The gritty Paul Walter Hauser B-movie; premiered SXSW 2023, released this year."
        },
        {
          "title": "The Housemaid",
          "year": 2025,
          "note": "Paul Feig's upcoming thriller with Amanda Seyfried, tipped to be a big hit."
        }
      ]
    }
  ],
