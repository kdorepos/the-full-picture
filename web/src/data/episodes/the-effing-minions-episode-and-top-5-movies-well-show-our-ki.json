        {
          "title": "The Wizard of Oz",
          "year": 1939,
          "note": "No. 1 - the most important movie in his life; he's just not sure yet when the black-and-white-to-color switch will land for her."
        },
        {
          "title": "Beauty and the Beast",
          "year": 1991,
          "note": "No. 2 - he wasn't a fan at nine or ten, discovering Reservoir Dogs instead, but he's come around, and \"Be Our Guest\" already plays well in the house."
        },
        {
          "title": "The Red Balloon",
          "year": 1956,
          "note": "No. 3 - the strategic pick: 33 minutes, mostly wordless, and short enough that Alice might actually finish it."
        },
        {
          "title": "The Muppets Take Manhattan",
          "year": 1984,
          "note": "No. 4 - puppets over animation for him; he credits the Muppets with shaping his sense of humor."
        },
        {
          "title": "My Neighbor Totoro",
          "year": 1988,
          "note": "No. 5 (tied) - the most-recommended kids' film from his more cinematically inclined friends."
