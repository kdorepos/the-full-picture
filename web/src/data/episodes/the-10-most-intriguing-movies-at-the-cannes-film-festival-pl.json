{
  "slug": "the-10-most-intriguing-movies-at-the-cannes-film-festival-pl",
  "title": "The 10 Most Intriguing Movies at the Cannes Film Festival. Plus: ‘Warfare’ Is Hell, With Alex Garland and Ray Mendoza.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2025-04-11",
  "runtimeMin": 102,
  "format": "Sean and Amanda run through the 2025 Cannes lineup: what they're intrigued by, what surprises they expect, and who didn't make the cut. Then Sean and Chris Ryan dig into Alex Garland and Ray Mendoza's 'Warfare,' followed by Sean's interview with the two directors.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Cannes Film Festival lineup",
      "note": "with Amanda Dobbins",
      "films": [
        {
          "title": "Eddington",
          "year": 2025,
          "note": "Ari Aster's COVID-set 2020 drama, the movie Sean most wishes he were at Cannes for. The teaser paired buffalo going over a cliff with the tagline '2020 is hindsight.'"
        },
        {
          "title": "The History of Sound",
          "year": 2025,
          "note": "Oliver Hermanus's queer historical romance with Paul Mescal and Josh O'Connor, from a Ben Shattuck short story. Amanda's pick if forced to bet on one film from the lineup; Sean has heard mixed reports."
        },
        {
          "title": "The Mastermind",
          "year": 2025,
          "note": "The new Kelly Reichardt, also with Josh O'Connor. Sean loves her but won't predict a Best Picture run."
        },
        {
          "title": "Sentimental Value",
          "year": 2025,
          "note": "Joachim Trier reuniting with Renate Reinsve after 'The Worst Person in the World'; distributed by Mubi, who also has 'The History of Sound.'"
        },
        {
          "title": "The Secret Agent",
          "year": 2025,
          "note": "Kleber Mendonça Filho ('Bacurau'). Sean knows little about it beyond the title, which is enough to sell him."
        },
        {
          "title": "Alpha",
          "year": 2025,
          "note": "Julia Ducournau's follow-up to 'Titane,' from the former Palme d'Or winner behind 'Raw.'"
        },
        {
          "title": "Eleanor the Great",
          "year": 2025,
          "note": "Scarlett Johansson's directorial debut, starring June Squibb, in Un Certain Regard."
        },
        {
          "title": "Urchin",
          "year": 2025,
          "note": "Harris Dickinson's directorial debut, another entry in the year of the internet boyfriend."
        },
        {
          "title": "Highest 2 Lowest",
          "year": 2025,
          "note": "Spike Lee's Apple/A24 remake of Kurosawa's 'High and Low,' playing out of competition, which Sean and Amanda found a strange call for a Cannes staple."
        },
        {
          "title": "Mission: Impossible - The Final Reckoning",
          "year": 2025,
          "note": "Out of competition, but Tom Cruise on the Croisette, his third time at Cannes after 'Top Gun: Maverick.' The kind of Hollywood event movie that tends to open the festival."
        },
        {
          "title": "It Was Just an Accident",
          "year": 2025,
          "note": "The Jafar Panahi film people will watch closely (referred to on air as 'The Simple Accident')."
        },
        {
          "title": "Romería",
          "year": 2025,
          "note": "Carla Simón's new one, from the director of the 2022 'Alcarràs' Sean liked."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "‘Warfare’",
      "note": "with Chris Ryan",
      "films": [
        {
          "title": "Warfare",
          "year": 2025,
          "note": "Garland and Mendoza's SEAL-team combat drama, built entirely from the participants' memories of a 2006 Iraq surveillance mission gone wrong. No lead, no political context, shot in London in five weeks with a class-picture cast of young actors. Chris calls it about as upsetting a war movie as he's seen, effectively a horror movie, and doubts you'd ever need to make another war film after it. Seen at the veteran-run American Legion Theater in LA."
        },
        {
          "title": "Civil War",
          "year": 2024,
          "note": "Garland's prior film, which Mendoza also worked on; Amanda's favorite of 2024. Sean and Chris read 'Warfare' as its twin, another study of truth sought through skewed, fragmentary perspective."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Alex Garland and Ray Mendoza on",
      "films": [
        {
          "title": "Warfare",
          "year": 2025,
          "note": "The directors on total-fidelity filmmaking, cross-examining conflicting memories 'forensically,' casting experienced actors over unknowns for a fast five-week shoot, and the anti-war question. Garland thinks any accurate account of war is inevitably anti-war; Mendoza says he wasn't concerned with the why, only the what."
        }
      ]
    }
  ],
