{
  "slug": "top-10-movie-musicals-and-in-the-heights",
  "title": "Top 10 Movie Musicals and ‘In the Heights’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2021-06-11",
  "runtimeMin": 85,
  "format": "A review of Jon M. Chu's In the Heights, then Sean and Amanda each count down their top 10 movie musicals of all time.",
  "segments": [
    {
      "kind": "review",
      "heading": "In the Heights",
      "note": "in theaters and on HBO Max",
      "films": [
        {
          "title": "In the Heights",
          "year": 2021,
          "note": "Jon M. Chu's adaptation of the Lin-Manuel Miranda musical. Both call it a mixed bag that's transcendent when the big numbers hit — '96,000,' 'Paciencia y Fe,' 'Carnaval del Barrio' — and sags whenever it settles into the Nina-and-Benny subplot. Anthony Ramos is the star-making find; Olga Merediz is their Oscar-question-mark."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top 10 Movie Musicals",
      "note": "best to worst",
      "subject": "Movie musicals",
      "ranked": true,
      "films": [
        {
          "title": "Singin' in the Rain",
          "year": 1952,
          "note": "No. 1 for both hosts. Gene Kelly, Donald O'Connor, and Debbie Reynolds; she calls 'Make 'Em Laugh' and 'Good Morning' the ten best minutes of filmmaking there are."
        },
        {
          "title": "West Side Story",
          "year": 1961,
          "note": "Robert Wise's filming of the Jerome Robbins choreography — her pick for the high standard of movie-musical dance on screen. Her one deliberate repeat: also her director on Sound of Music."
        },
        {
          "title": "The Sound of Music",
          "year": 1965,
          "note": "Formative childhood viewing — she wanted to be a Von Trapp kid. Still stands up for 'Climb Every Mountain' two hours in."
        },
        {
          "title": "Cabaret",
          "year": 1972,
          "note": "Bob Fosse and Liza Minnelli. Her pick for how camera and choreography move together — a chair, a leg, a hip thrust."
        },
        {
          "title": "Grease",
          "year": 1978,
          "note": "Watched at six, wore a poodle skirt for Halloween. 'Terrible lessons for women, pretty campy movie,' but the songs and set pieces hold up."
        },
        {
          "title": "The Muppets Take Manhattan",
          "year": 1984,
          "note": "Backstage showbiz satire with a full-cast cameo dance number when they pitch the show."
        },
        {
          "title": "Funny Face",
          "year": 1957,
          "note": "Fred Astaire, Audrey Hepburn, Kay Thompson dancing around Paris. Her only Astaire pick and only Hepburn pick."
        },
        {
          "title": "Bye Bye Birdie",
          "year": 1963,
          "note": "Ann-Margret's electric debut. A satire of TV-manufactured teen idolatry that she thinks is sharper than what gets made for teens today."
        },
        {
          "title": "Meet Me in St. Louis",
          "year": 1944,
          "note": "The movie where Vincente Minnelli met Judy Garland, who debuts 'Have Yourself a Merry Little Christmas' here."
        },
        {
          "title": "Moulin Rouge!",
          "year": 2001,
          "note": "Her only pick made after 2000. Baz Luhrmann's jukebox spectacle, built around the 'Roxanne' tango and the 'Elephant Love Medley.'"
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top 10 Movie Musicals",
      "note": "best to worst",
      "subject": "Movie musicals",
      "ranked": true,
      "films": [
        {
          "title": "Singin' in the Rain",
          "year": 1952,
          "note": "No. 1 for both hosts. He bought the VHS at a Disneyland gift shop at age 11 without having seen it, then watched it that night in the hotel room."
        },
        {
          "title": "All That Jazz",
          "year": 1979,
          "note": "Bob Fosse's self-lacerating memoir-as-musical — the flip side of Cabaret, his other Fosse pick, this time turning the camera on himself."
        },
        {
          "title": "The Wizard of Oz",
          "year": 1939,
          "note": "The movie that made him fall in love with movies, on repeat in his house from age zero to ten. Amanda knew he'd put it on his list, so she left it off hers."
        },
        {
          "title": "The Umbrellas of Cherbourg",
          "year": 1964,
          "note": "Jacques Demy's sung-through romance — his only sung-through and only foreign-language pick. He calls it the biggest single influence on La La Land's color and design."
        },
        {
          "title": "The Nightmare Before Christmas",
          "year": 1993,
          "note": "His one animated pick. Danny Elfman wrote the songs; Henry Selick directed; Tim Burton produced."
        },
        {
          "title": "Nashville",
          "year": 1975,
          "note": "His self-described rule-breaker. Robert Altman had the cast write and perform their own songs against a political-convention backdrop."
        },
        {
          "title": "Hedwig and the Angry Inch",
          "year": 2001,
          "note": "John Cameron Mitchell's genderqueer East German rock singer, told almost entirely as on-stage performance, made outside the major-studio system."
        },
        {
          "title": "Little Shop of Horrors",
          "year": 1986,
          "note": "Howard Ashman's man-eating-plant musical, directed by Frank Oz. The plant is voiced by the Four Tops' Levi Stubbs."
        },
        {
          "title": "A Star Is Born",
          "year": 1954,
          "note": "Judy Garland and James Mason, directed by George Cukor. A late swap onto his list."
        },
        {
          "title": "It's Always Fair Weather",
          "year": 1955,
          "note": "His least-known pick. Stanley Donen and Gene Kelly's post-Singin'-in-the-Rain follow-up, about three war buddies reuniting a decade later; a Cyd Charisse boxing-ring number is the showstopper."
        }
      ]
    }
  ],
