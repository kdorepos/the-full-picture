{
  "slug": "speak-no-evil-and-the-top-five-get-me-the-f-out-of-here-movi",
  "title": "‘Speak No Evil’ and the Top Five “Get Me the F--- Out of Here” Movies, With James McAvoy!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2024-09-13",
  "runtimeMin": 129,
  "format": "Sean, Amanda, and Chris Ryan review James Watkins's 'Speak No Evil' remake against the 2022 Danish original, then each rank five 'get me out of here' movies. McAvoy and Watkins stop by.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Before the movie",
      "note": "fall-release housekeeping",
      "films": [
        {
          "title": "Juror #2",
          "year": 2024,
          "note": "Eastwood's latest, dated for a November 1 limited release closing the AFI festival. Sean pegs it between 'Cry Macho' and 'Richard Jewell,' and wonders whether it platforms wider for election week."
        },
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "A24 acquired Brady Corbet's VistaVision epic, prompting a running gag about hauling 70mm canisters cinema to cinema. Sean is in; Chris turned off the 45-minute Corbet explainer and won't apologize until he sees the film."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Speak No Evil’",
      "note": "the Watkins remake vs. the Danish original",
      "films": [
        {
          "title": "Speak No Evil",
          "year": 2024,
          "note": "A vacationing American couple (Scoot McNairy, Mackenzie Davis) accept a weekend invitation from a boisterous English pair (James McAvoy, Aisling Franciosi) and can't find a polite way out. The group agrees the film is more thriller than horror and best as a comedy of manners about toxic masculinity (McAvoy huge and charismatic) before it turns into a cat-and-mouse chase and a survivable ending."
        },
        {
          "title": "Speak No Evil (2022)",
          "note": "Christian Tafdrup's bleak Danish source film, which Sean has described on-air for years: a nihilist indictment of bourgeois complacency ending in the notorious 'because you let me.' The remake keeps many beats, then softens the third act for an American audience."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The Top Five “Get Me the F--- Out of Here” Movies",
      "note": "three separate ballots: Sean, Amanda, Chris",
      "picks": [
        {
          "title": "The Mist",
          "year": 2007,
          "by": "Sean",
          "note": "No. 1: nature gone feral outside, strangers packed into a general store inside, both halves of his nightmare at once."
        },
        {
          "title": "Green Room",
          "year": 2015,
          "by": "Sean",
          "note": "No. 2: Saulnier's punk band trapped in a Nazi bar, viscerally upsetting, still his favorite of the director's films."
        },
        {
          "title": "Locke",
          "year": 2013,
          "by": "Sean",
          "note": "No. 3: Tom Hardy alone in a car as his life comes apart over the phone, a pure work-anxiety nightmare."
        },
        {
          "title": "The Invitation",
          "year": 2015,
          "by": "Sean",
          "note": "No. 4: Kusama's Hollywood Hills dinner party you can't leave; the tonal cousin to 'Speak No Evil.'"
        },
        {
          "title": "The Truman Show",
          "year": 1998,
          "by": "Sean",
          "note": "No. 5: Weir's version of having it all and finding it fake: the one Sean figures he already lives in."
        },
        {
          "title": "Get Out",
          "year": 2017,
          "by": "Amanda",
          "note": "No. 1: no one else put it on the list, and the title says it all."
        },
        {
          "title": "Midsommar",
          "year": 2019,
          "by": "Amanda",
          "note": "No. 2: the European-vacation trap, guest of a guest, no way out, and a dopey boyfriend who's no help."
        },
        {
          "title": "The Stepford Wives",
          "year": 1975,
          "by": "Amanda",
          "note": "No. 3: the men turned the women into robots. She would like it on 4K UHD, please."
        },
        {
          "title": "Bridesmaids",
          "year": 2011,
          "by": "Amanda",
          "note": "No. 4: pure social dread, the dress fitting, the flight, a tragedy in Apatovian clothing."
        },
        {
          "title": "Picnic at Hanging Rock",
          "year": 1975,
          "by": "Amanda",
          "note": "No. 5: Weir again: a creepy boarding school and a natural wonder that explains nothing."
        },
        {
          "title": "Open Water 2: Adrift",
          "year": 2006,
          "by": "Chris",
          "note": "No. 1: everyone jumps off the yacht and nobody lowered the ladder; the baby is still aboard."
        },
        {
          "title": "The Blair Witch Project",
          "year": 1999,
          "by": "Chris",
          "note": "No. 2: his phobia of getting lost in the woods, plus a theatrical experience he calls religious."
        },
        {
          "title": "The Hurt Locker",
          "year": 2008,
          "by": "Chris",
          "note": "No. 3: he's clumsy, so cutting the red wire in a bulky bomb suit is a hard no."
        },
        {
          "title": "The Texas Chain Saw Massacre",
          "year": 1974,
          "by": "Chris",
          "note": "No. 4: the hitchhiker climbs into the van and put him off hitchhikers for life."
        },
        {
          "title": "Ready or Not",
          "year": 2019,
          "by": "Chris",
          "note": "No. 5: hunted on her wedding night, survival hinging on games he'd never learn the rules to."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "James McAvoy & James Watkins on",
      "films": [
        {
          "title": "Speak No Evil",
          "year": 2024,
          "note": "Watkins on relocating the Danish film to the UK and walking the line between comedy of manners and horror; McAvoy on finding Paddy's ego and menace within himself, and on getting the biggest and strongest he'd ever been after his second child, a physique that happened to fit the part."
        },
        {
          "title": "Challengers",
          "year": 2024,
          "by": "James Watkins",
          "note": "His last great thing: a multigenerational love-fest that had his whole family smiling out of the cinema."
        }
      ]
    }
  ],
