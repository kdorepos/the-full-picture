{
  "slug": "outlaw-king-is-netflixs-foray-into-prestige-did-it-work-the-",
  "title": "‘Outlaw King’ Is Netflix’s Foray Into Prestige. Did It Work? | The Oscars Show (Ep. 97)",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2018-11-13",
  "runtimeMin": 49,
  "format": "Sean and Amanda size up Netflix's prestige push through Outlaw King, Buster Scruggs, and Roma's theatrical test run, then move to The Front Runner, Green Book, Widows, and The Favorite.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Netflix's Prestige Push",
      "note": "Outlaw King, Buster Scruggs, and the theatrical test run",
      "films": [
        {
          "title": "Outlaw King",
          "year": 2018,
          "note": "Chris Pine as Robert the Bruce, directed by David McKenzie, picking up roughly where Braveheart leaves off. Amanda calls it a perfectly acceptable Friday-night battle movie; neither thinks it's a real Oscar contender."
        },
        {
          "title": "The Ballad of Buster Scruggs",
          "year": 2018,
          "note": "Six Coen brothers segments stitched together, released the same week as Outlaw King. Despite the pedigree of No Country for Old Men and True Grit, it isn't getting nearly the same awards buzz."
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "Alfonso Cuarón's film gets Netflix's first real theatrical run (New York, LA, and Mexico City) after Alamo Drafthouse balked at a longer window. Sean and Amanda saw it in theaters and think it's the strongest of Netflix's three awards plays."
        },
        {
          "title": "22 July",
          "year": 2018,
          "note": "Paul Greengrass's dramatization of the 2011 Norway attacks. Despite his Oscar history with United 93 and Captain Phillips, it wasn't well received."
        },
        {
          "title": "Bird Box",
          "year": 2018,
          "note": "Sandra Bullock, directed by Susanne Bier, still to come this December. Sean guesses it'll land closer to Bright than to actual awards fare."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock Down: The Front Runner",
      "films": [
        {
          "title": "The Front Runner",
          "year": 2018,
          "note": "Jason Reitman's Gary Hart movie, with Hugh Jackman playing the scandal-felled 1988 presidential candidate. Its Election Day release stunt backfired, and Sean and Amanda think its nuance is a bad fit for the current political mood."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Buzzword: Crowd-Pleaser",
      "note": "Green Book as this week's example",
      "films": [
        {
          "title": "Green Book",
          "year": 2018,
          "note": "Peter Farrelly's Deep South road movie with Viggo Mortensen and Mahershala Ali. Both hosts were won over despite themselves and expect Best Picture and acting nominations."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Best Supporting Actress: Widows and The Favorite",
      "films": [
        {
          "title": "Widows",
          "year": 2018,
          "note": "Steve McQueen's heist film, led by Viola Davis. Elizabeth Debicki and Cynthia Erivo are the two Sean and Amanda would actually nominate out of a crowded cast."
        },
        {
          "title": "Bad Times at the El Royale",
          "year": 2018,
          "note": "Erivo's other 2018 role, a Motown-style singer in a thriller that didn't land, though it's another physical showcase for her."
        },
        {
          "title": "The Favorite",
          "year": 2018,
          "note": "Yorgos Lanthimos's palace comedy. Olivia Colman is running lead, which leaves Rachel Weisz and Emma Stone splitting supporting-actress attention. Sean bets Stone edges out Weisz."
        }
      ]
    }
  ],
