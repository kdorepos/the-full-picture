{
  "slug": "best-picture-power-rankings-and-priscilla-with-sofia-coppola",
  "title": "Best Picture Power Rankings and ‘Priscilla’ With Sofia Coppola!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-11-07",
  "runtimeMin": 97,
  "format": "Sean and Amanda dig into Sofia Coppola's 'Priscilla,' run Amanda's top five wife movies, and review the Netflix swim drama 'Nyad.' Then they rank ten Best Picture contenders, and Sean sits down with Coppola.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Priscilla'",
      "note": "Sofia Coppola's Elvis-and-me biopic",
      "films": [
        {
          "title": "Priscilla",
          "year": 2023,
          "note": "Coppola's adaptation of Priscilla Presley's memoir 'Elvis and Me,' told entirely through Priscilla's eyes, from being scouted at 14 on a German air base to leaving Graceland in the '70s. Kaley Spaeny (introduced to Coppola by Kirsten Dunst) plays across 20 years; 6-foot-5 Jacob Elordi towers over her as Elvis. Sean calls it Coppola's best since 'Lost in Translation.' Denied the rights to Elvis's music, the film ends on Dolly Parton's 'I Will Always Love You' as Priscilla drives out the recreated Graceland gates (built to scale in Toronto). An anti-biopic that never moralizes."
        },
        {
          "title": "Lost in Translation",
          "year": 2003,
          "note": "Comes up again and again: another young woman in a closed space with a damaged older man; Sean rewatched it and notes how much of it is really about Bob's depression."
        },
        {
          "title": "Marie Antoinette",
          "year": 2006,
          "note": "Amanda's champion, in the middle of a reclamation; she frames 'Priscilla' as part of the same project, reinterpreting a misunderstood wife who speaks through clothes and images."
        },
        {
          "title": "The Virgin Suicides",
          "year": 1999,
          "note": "Cited for its imposing father (the James Woods character) and its male heartthrob; Sean compares Elordi's Elvis to Josh Hartnett's Trip Fontaine."
        },
        {
          "title": "Somewhere",
          "year": 2010,
          "note": "Sean's pick for Coppola's last tier-one film before the experiments."
        },
        {
          "title": "The Bling Ring",
          "year": 2013,
          "note": "One of the outliers; Sean likes that she tried it but says she can't be that crass even when she wants to."
        },
        {
          "title": "The Beguiled",
          "year": 2017,
          "note": "The other outlier from the core Coppola mode, pushed to the side relative to the rest."
        },
        {
          "title": "On the Rocks",
          "year": 2020,
          "note": "Filed with the mid-period experiments; fine but not top-tier."
        },
        {
          "title": "Elvis",
          "year": 2022,
          "note": "Baz Luhrmann's opulent version, the deliberate contrast: 'Priscilla' is smaller, claustrophobic, and finds Elvis more interesting for being less flattered."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Top Five Wife Movies",
      "note": "Amanda's list: can't be about the couple, only the experience of being a wife",
      "subject": "Wife movies",
      "ranked": true,
      "films": [
        {
          "title": "Rebecca",
          "year": 1940,
          "note": "No. 1: the Hitchcock version; whichever wife you are, it seems tough."
        },
        {
          "title": "The Stepford Wives",
          "year": 1975,
          "note": "No. 2: Amanda loves it, Paula Prentiss especially; hard to find on physical media, eventually located on Tubi."
        },
        {
          "title": "The First Wives Club",
          "year": 1996,
          "note": "No. 3: being a wife did suck, then they figured out how to be friends instead; Amanda's total-cinema hill to die on."
        },
        {
          "title": "Jackie",
          "year": 2016,
          "note": "No. 4: Amanda's 'famous wife' pick, the best version of Pablo Larraín's experiment."
        },
        {
          "title": "Priscilla",
          "year": 2023,
          "note": "No. 5: offered as the fifth slot (Maestro was the alternative, but it breaks the no-marriage rule)."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "'Nyad'",
      "note": "Chin & Vasarhelyi's Netflix swim drama",
      "films": [
        {
          "title": "Nyad",
          "year": 2023,
          "note": "Elizabeth Chai Vasarhelyi and Jimmy Chin's first feature, on Diana Nyad's Cuba-to-Florida swim. Annette Bening is grouchy for two hours; Jodie Foster cooks as coach Bonnie Stoll; Rhys Ifans is a welcome surprise. Sean calls it an eminently watchable two-and-a-half-star movie: a fine, perfect-for-the-holidays sports film undercut by trauma flashbacks that feel like a different movie and one CGI sequence that flipped him out of it. Shot by Claudio Miranda."
        }
      ]
    },
    {
