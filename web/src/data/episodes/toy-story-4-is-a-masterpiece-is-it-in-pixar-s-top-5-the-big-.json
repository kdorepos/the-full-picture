  "format": "Sean Fennessy and Ringer colleague (and dad of two) Rob Harvilla review Toy Story 4, then each draft a personal Pixar top five.",
  "segments": [
    {
      "kind": "review",
      "heading": "Toy Story 4",
      "note": "review",
      "films": [
        {
          "title": "Toy Story 4",
          "year": 2019,
          "note": "Josh Cooley's directorial debut for Pixar. Both hosts found it funnier and less emotionally punishing than Inside Out or Toy Story 3, thanks to Forky's trash/not-trash identity crisis, Gabby Gabby, and the Key-and-Peele-voiced Ducky and Bunny. Sean flags the strange juxtaposition of the film's warmth with its behind-the-scenes story: Rashida Jones and Will McCormick left the writing process citing a lack of openness to new voices, and the story-by credits still list John Lasseter."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Rob Harvilla's Pixar Top Five",
      "note": "best to worst",
      "subject": "Pixar",
      "ranked": true,
      "films": [
        {
          "title": "Coco",
          "year": 2017,
          "note": "His favorite movie of 2017 outright: the 'Remember Me' ending got both him and his son, which almost never happens with these movies."
        },
        {
          "title": "The Incredibles",
          "year": 2004,
          "note": "A sibling story before he had kids of his own, and a marriage story once Incredibles 2 arrived. The Elastigirl-in-the-lair door sequence is his favorite Pixar set piece."
        },
        {
          "title": "Up",
          "year": 2009,
          "note": "The opening marriage-and-loss montage got him: the first Pixar movie he actively cried at, on a date with his now-wife."
        },
        {
          "title": "Toy Story 3",
          "year": 2010,
          "note": "Lotso is his benchmark Pixar villain; the incinerator scene wrecked him before he even had kids."
        },
        {
          "title": "WALL·E",
          "year": 2008,
          "note": "The 'we can make a movie out of anything' pick, with long, near-silent stretches that felt more like Chaplin than a kids' movie."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessy's Pixar Top Five",
      "note": "best to worst",
      "subject": "Pixar",
      "ranked": true,
      "films": [
        {
          "title": "Toy Story",
          "year": 1995,
          "note": "Picked for the historical jolt as much as the story: a Technicolor-level leap for animation, and only 81 minutes."
        },
        {
          "title": "Finding Nemo",
          "year": 2003,
          "note": "Where the brand really solidified for him, with Albert Brooks and Randy Newman carrying the fear of losing a kid."
        },
        {
          "title": "The Incredibles",
          "year": 2004,
          "note": "Reads it as a sibling story, and credits Brad Bird as one of the best action stagers working, animated or not."
        },
        {
          "title": "Ratatouille",
          "year": 2007,
          "note": "About the tension between creation and criticism: Remy versus Anton Ego, who gets more empathy than critic characters usually do onscreen."
        },
        {
          "title": "Inside Out",
          "year": 2015,
          "note": "Grudging respect: the 'joyful kid becomes a sullen teenager' arc wrecked him while his own kid just thought Anger was funny."
        }
      ]
    }
