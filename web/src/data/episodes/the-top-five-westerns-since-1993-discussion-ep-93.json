  "format": "Red Dead Redemption 2's opening-weekend haul gets Sean and Chris arguing over the best Westerns since Unforgiven, and somehow Rango wins.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Setting Up: Why Westerns Never Go Away",
      "note": "the classics, before the modern stuff",
      "films": [
        {
          "title": "The Revenant",
          "year": 2015,
          "note": "Cited as the genre's colonial-guilt detour."
        },
        {
          "title": "Rio Bravo",
          "year": 1959,
          "note": "Chris's classic-era pick: the Hawks side of the Hawks/Ford split."
        },
        {
          "title": "The Searchers",
          "year": 1956,
          "note": "The Ford side of that split."
        },
        {
          "title": "Red River",
          "year": 1948,
          "note": "Chris takes this and Rio Bravo over The Searchers."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top Five Westerns Since 1993",
      "note": "best to worst",
      "subject": "Westerns Since 1993",
      "ranked": true,
      "films": [
        {
          "title": "The Assassination of Jesse James by the Coward Robert Ford",
          "year": 2007,
          "note": "No. 1: Chris's favorite thing he's maybe ever seen. Deakins, the Nick Cave/Warren Ellis score, Casey Affleck's fandom-as-obsession performance."
        },
        {
          "title": "Tombstone",
          "year": 1993,
          "note": "No. 2: Val Kilmer's Doc Holliday, an all-timer; the set was, by legend, actually run by Kurt Russell."
        },
        {
          "title": "No Country for Old Men",
          "year": 2007,
          "note": "No. 3: also Sean's No. 5, ranked higher here. Chris: could be No. 1 tomorrow."
        },
        {
          "title": "Unforgiven",
          "year": 1992,
          "note": "No. 4: Chris admits it's a year early. Eastwood and Gene Hackman take apart Eastwood's own violent-man mythology."
        },
        {
          "title": "Lone Star",
          "year": 1996,
          "note": "No. 5: John Sayles' border-town mystery, prime-era McConaughey used sparingly, as myth rather than star."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top Five Westerns Since 1993",
      "note": "best to worst",
      "subject": "Westerns Since 1993",
      "ranked": true,
      "films": [
        {
          "title": "Rango",
          "year": 2011,
          "note": "No. 1: Sean's self-described unhealthy obsession. A Gore Verbinski/Johnny Depp animated Western that knows every trope it's using."
        },
        {
          "title": "The Assassination of Jesse James by the Coward Robert Ford",
          "year": 2007,
          "note": "No. 2: also Chris's No. 1."
        },
        {
          "title": "Brokeback Mountain",
          "year": 2005,
          "note": "No. 3: Larry McMurtry and Diana Ossana's script, from Annie Proulx's story."
        },
        {
          "title": "The Hateful Eight",
          "year": 2015,
          "note": "No. 4: Sean argues it's aging better than Django Unchained."
        },
        {
          "title": "No Country for Old Men",
          "year": 2007,
          "note": "No. 5: the opener that kicks off a long Coens/McCarthy detour."
        }
      ]
    },
