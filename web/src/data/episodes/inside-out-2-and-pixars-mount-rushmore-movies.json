{
  "slug": "inside-out-2-and-pixars-mount-rushmore-movies",
  "title": "‘Inside Out 2’ and Pixar’s Mount Rushmore Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Charles Holmes"
  ],
  "published": "2024-06-14",
  "runtimeMin": 126,
  "format": "Inside Out 2, a four-film Pixar Mount Rushmore, and a conversation with documentarian Lance Oppenheim about Ren Faire.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Paramount stalls, Sony buys Alamo Drafthouse",
      "note": "the week's business",
      "films": [
        {
          "title": "Bad Boys: Ride or Die",
          "year": 2024,
          "note": "Cited alongside Anyone But You as evidence Sony has done better in theaters lately than most studios, which the hosts read as context for why it bought a theater chain."
        },
        {
          "title": "Anyone But You",
          "year": 2023,
          "note": "A recent Sony theatrical win; the hosts frame the Alamo deal less as monopoly than as a marketing experiment for a studio that has bet on theatrical and licenses out its streaming."
        },
        {
          "title": "Madame Web",
          "year": 2024,
          "note": "The Sony misfire named in the same breath ('the Madame Web of it all') as the counterweight to its recent theatrical hits."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Inside Out 2’",
      "note": "the big Pixar sequel",
      "films": [
        {
          "title": "Inside Out 2",
          "year": 2024,
          "note": "Directed by Kelsey Mann (Pete Docter, now Pixar's chief creative officer, produced but didn't direct), written by Meg LeFauve and Dave Holstein. Riley turns 13 and hits puberty at hockey camp as a new emotion, Anxiety (Maya Hawke), seizes the controls. Returning: Amy Poehler, Phyllis Smith, Lewis Black, Diane Lane, Kyle MacLachlan; Tony Hale replaces Bill Hader as Fear and Liza Lapira replaces Mindy Kaling as Disgust; Ayo Edebiri, Adèle Exarchopoulos, and Paul Walter Hauser are new. All three find it funny and clever but a step or two below the original. Sean calls it the Pixar film that most appeals to adults over kids; Amanda pegs it as the best 'therapy art' of the last five years, minus the jargon; Charles loves Anxiety as a character and a piece of drawing. The suppressed-character bit (Bloofy, voiced by Ron Funches; Pouchy; a Street Fighter-style video-game crush; Deep Dark Secret) reads to them as Pixar catching up to Wreck-It Ralph and the Spider-Verse films."
        },
        {
          "title": "Inside Out",
          "year": 2015,
          "note": "Pete Docter's original, which won Best Animated Feature. Amanda wept at Bing Bong and admires how animation can render an idea you couldn't shoot with people; Sean rates it high second-tier Pixar. Charles takes the contrarian line: his bottom rung of Pixar, and the start of the studio's creative midlife crisis."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "Pixar's Mount Rushmore",
      "note": "four films, four presidents",
      "honoree": "Pixar",
      "films": [
        {
          "title": "Toy Story",
          "year": 1995,
          "note": "George Washington: the founding blockbuster, the studio's first film and the one everyone agrees starts the whole thing."
        },
        {
          "title": "Ratatouille",
          "year": 2007,
          "note": "Thomas Jefferson: chosen for ingenuity and ideas. It's a rat who cooks in Paris, a movie about purpose that also flatters critics. Amanda's number one Pixar film."
        },
        {
          "title": "Finding Nemo",
          "year": 2003,
          "note": "Abraham Lincoln: the second most popular pick, the traumatic opening and mass appeal that raised the emotional bar. Charles's case: the movie that made the culture start expecting Pixar to tell it something about itself."
        },
        {
          "title": "The Incredibles",
          "year": 2004,
          "note": "Teddy Roosevelt: popular enough to be 're-elected' (Incredibles 2 made $1.1 billion), a transition into the modern, superhero-dominated era. Brad Bird's work-versus-family story, read as both progressive and traditional."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Lance Oppenheim on ‘Ren Faire’",
      "guest": "Lance Oppenheim on",
      "films": [
        {
          "title": "Some Kind of Heaven",
          "year": 2020,
          "note": "Oppenheim's debut feature, shot in The Villages retirement community in Florida while he was still in college. Started as a short he kept expanding. He admits he kept telling financiers he had enough footage before he did."
        },
        {
          "title": "Spermworld",
          "year": 2024,
          "note": "His other 2024 feature, about independent sperm donors, a subject that's vast and mostly lives online. Inspired by Bringing Out the Dead's idea of helping others as a way of searching for your own redemption."
        }
      ]
    }
  ],
