{
  "slug": "wicked-is-a-sensation-but-is-it-good-plus-the-top-five-21st-",
  "title": "‘Wicked’ Is a Sensation. But Is It Good? Plus: The Top Five 21st Century Musicals.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Juliette Littman"
  ],
  "published": "2024-11-25",
  "runtimeMin": 121,
  "format": "Sean Fennessey and Wicked superfan Juliette Littman argue over whether the biggest movie in the world is actually good, then each rank their five favorite movie musicals of the century. Plus a conversation with Malcolm Washington about adapting August Wilson's The Piano Lesson.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Wicked’",
      "note": "Sean Fennessey and Juliette Littman",
      "films": [
        {
          "title": "Wicked",
          "year": 2024,
          "note": "Jon M. Chu's Broadway adaptation, $110M-plus opening. Juliette, a musical-theater devotee, calls it a faithful crowd-pleaser saved by Ariana Grande and a Defying Gravity finale; Sean, who reveres The Wizard of Oz but has never seen the show, is put off by the desaturated color and the IP-franchise structure. Both flag the silent Elphaba/Glinda dance sequence as a low point."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five 21st Century Movie Musicals",
      "note": "revealed worst to best on air",
      "subject": "21st century movie musicals",
      "ranked": true,
      "films": [
        {
          "title": "Moana",
          "year": 2016,
          "note": "No. 1. A Lin-Manuel Miranda score he's watched 15-plus times, picked less for greatness than for the comfort and joy it gives him as a parent."
        },
        {
          "title": "West Side Story",
          "year": 2021,
          "note": "No. 2. Spielberg's remake, some of the best directing and choreography he's ever seen; he caught it in theaters twice."
        },
        {
          "title": "Popstar: Never Stop Never Stopping",
          "year": 2016,
          "note": "No. 3. A Lonely Island comedy The Ringer claimed on its launch weekend; a full-blown rewatchable. He'd first considered Dancer in the Dark here."
        },
        {
          "title": "O Brother, Where Art Thou?",
          "year": 2000,
          "note": "No. 4, tied with the Coens' Inside Llewyn Davis: a Depression-set Odyssey riff with a chart-topping soundtrack."
        },
        {
          "title": "Sing Street",
          "year": 2016,
          "note": "No. 5. John Carney's Dublin band-formation movie that he likes more the further he gets from it."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Juliette's Top Five 21st Century Movie Musicals",
      "note": "revealed worst to best on air",
      "subject": "21st century movie musicals",
      "ranked": true,
      "films": [
        {
          "title": "Walk the Line",
          "year": 2005,
          "note": "No. 1. Her favorite Reese Witherspoon performance; the film that opened up Johnny Cash's catalog for her."
        },
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "No. 2. Bradley Cooper and Lady Gaga, a movie whose reputation grew fast heading into the pandemic."
        },
        {
          "title": "Hairspray",
          "year": 2007,
          "note": "No. 3. The lone true book musical on her list; universally strong cast, well-done camp, anchored by Queen Latifah's number."
        },
        {
          "title": "Encanto",
          "year": 2021,
          "note": "No. 4. Her Lin-Manuel Miranda inclusion; the music sent her to the movie even without kids."
        },
        {
          "title": "Mamma Mia!",
          "year": 2008,
          "note": "No. 5. Once the UK's highest-grossing film. Flawed but a great time, and a career turn for Amanda Seyfried."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Malcolm Washington on",
      "films": [
        {
          "title": "The Piano Lesson",
          "year": 2024,
          "note": "His feature debut, adapting August Wilson's play for Netflix with brother John David Washington and Samuel L. Jackson. Talks about breaking the stage-bound form with genre and flashback, a 100-page reference book on Afro-surrealism and Black Southern faith, and Ray Fisher and Danielle Deadwyler's performances."
        }
      ]
    }
  ],
