{
  "slug": "spider-mans-mega-box-office-aaron-sorkins-being-the-ricardos",
  "title": "Spider-Man's Mega Box Office, Aaron Sorkin's 'Being the Ricardos,' and Best Picture Power Rankings",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2021-12-21",
  "runtimeMin": 94,
  "format": "Spider-Man's $260 million weekend, Aaron Sorkin's Being the Ricardos, Guillermo del Toro's Nightmare Alley, an early Best Picture power ranking, a hark for The Northman, and Sean Baker on Red Rocket.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Spider-Man's $260 Million Weekend",
      "note": "on the second-biggest opening in movie history",
      "films": [
        {
          "title": "Spider-Man: No Way Home",
          "year": 2021,
          "note": "Opened to $260 million in three and a half days, mid-pandemic surge and all. Sean calls it a confirmation of where moviegoing already was, not a turning point."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Being the Ricardos",
      "films": [
        {
          "title": "Being the Ricardos",
          "year": 2021,
          "note": "Aaron Sorkin's third film as director, a week-in-the-life of the 1952 I Love Lucy production. Sean thinks it's quite bad and kind of liked it anyway; Amanda wants Sorkin to stop directing his own scripts. Both agree Nicole Kidman and Javier Bardem are miscast as Lucy and Desi."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Nightmare Alley",
      "films": [
        {
          "title": "Nightmare Alley",
          "year": 2021,
          "note": "Del Toro's first film since The Shape of Water, adapted from William Lindsay Gresham's 1946 novel. Opened to under $3 million. Sean thinks the movie loses steam once Bradley Cooper's carny leaves the carnival for Cate Blanchett's femme fatale; Amanda never wanted to be there in the first place."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Best Picture Power Rankings",
      "note": "Sean's early power rankings for the 10 expected nominees, revealed worst-to-best on air",
      "subject": "Best Picture race",
      "ranked": true,
      "films": [
        {
          "title": "The Power of the Dog",
          "year": 2021,
          "note": "No. 1: Sean's pick to win, in a year where nobody's fully seen anything yet."
        },
        {
          "title": "Belfast",
          "year": 2021,
          "note": "No. 2: does everything Oscar wants, but neither host knows a single other person who's seen it."
        },
        {
          "title": "West Side Story",
          "year": 2021,
          "note": "No. 3: struggling at the box office; Amanda thinks Spielberg's name still gets it watched once it's on Netflix."
        },
        {
          "title": "Licorice Pizza",
          "year": 2021,
          "note": "No. 4: Sean's now convinced Paul Thomas Anderson wins Best Original Screenplay for it."
        },
        {
          "title": "Dune",
          "year": 2021,
          "note": "No. 5: should have done Spider-Man numbers; stuck behind HBO Max instead."
        },
        {
          "title": "King Richard",
          "year": 2021,
          "note": "No. 6: just left HBO Max, in the middle of a Guild-screening blitz."
        },
        {
          "title": "Coda",
          "year": 2021,
          "note": "No. 7: the Sundance success story, still finding its audience on Apple TV+."
        },
        {
          "title": "Being the Ricardos",
          "year": 2021,
          "note": "No. 8: Sorkin's pedigree keeps it in the race even with lukewarm reviews."
        },
        {
          "title": "Don't Look Up",
          "year": 2021,
          "note": "No. 9: hits Netflix in days; unclear whether the tone lands with a holiday audience."
        },
        {
          "title": "The Lost Daughter",
          "year": 2021,
          "note": "No. 10: barely seen yet, but Olivia Colman's in it, and you don't bet against Olivia Colman."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock Up: The Northman",
      "note": "Sean's hark for Robert Eggers' Viking epic",
      "films": [
        {
          "title": "The Northman",
          "year": 2022,
          "note": "Eggers' Viking epic starring Alexander Skarsgård, Anya Taylor-Joy, Nicole Kidman, Ethan Hawke, and Björk. Sean is fully sold after a spear-catch in the trailer."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Sean Baker on",
      "films": [
        {
          "title": "Red Rocket",
          "year": 2021,
          "note": "Baker's film about Mikey Saber, a washed-up porn actor drifting back into his Texas City hometown, played by Simon Rex. Sean's No. 8 film of the year. Born out of a shelved COVID-era project and years-old research into the adult-film archetype known as a 'suitcase pimp.'"
        },
        {
          "title": "The Florida Project",
          "year": 2017,
          "note": "Baker's previous film, the one that got Willem Dafoe's agency to send his name over for Red Rocket."
        },
        {
          "title": "Tangerine",
          "year": 2015,
          "note": "Shot on iPhones. The film Dafoe actually knew Baker's work from before signing on."
        },
        {
          "title": "Starlet",
          "year": 2012,
          "note": "The research trip for this film, into the adult-film world, is where the 'suitcase pimp' archetype behind Red Rocket first surfaced."
        },
        {
          "title": "Take Out",
          "year": 2004,
          "note": "Baker's second feature, about an undocumented immigrant: the start of his running interest in the underground economy."
        },
        {
          "title": "Jockey",
          "year": 2021,
          "note": "The last great thing Baker's seen in theaters; reminded him of the passion in his own early films."
        },
        {
          "title": "Titane",
          "year": 2021,
          "note": "The Palme d'Or winner, one of Baker's favorite films of the year."
        },
        {
          "title": "The Debut",
          "year": 1977,
          "note": "One of three films by Dutch director Nouchka van Brakel that Baker's been working through on Blu-ray."
        },
        {
          "title": "A Woman Like Eve",
          "year": 1979,
          "note": "Second of the Van Brakel run Baker's been watching."
        },
        {
          "title": "Cool Lakes of Death",
          "year": 1982,
          "note": "Third of the Van Brakel run."
        }
      ]
    }
  ],
