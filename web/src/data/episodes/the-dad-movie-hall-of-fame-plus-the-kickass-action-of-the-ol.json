{
  "slug": "the-dad-movie-hall-of-fame-plus-the-kickass-action-of-the-ol",
  "title": "The Dad Movie Hall of Fame. Plus: the Kickass Action of ‘The Old Guard’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Kevin Clark"
  ],
  "published": "2020-07-10",
  "runtimeMin": 98,
  "format": "Sean and Amanda run through the week's new streaming arrivals, then bring on The Ringer's Kevin Clark to build a Dad Movie Hall of Fame. Sean also talks to Gina Prince-Bythewood about turning from intimate dramas to hardcore action with 'The Old Guard.'",
  "segments": [
    {
      "kind": "discussion",
      "heading": "This Week's New Releases",
      "note": "a full slate hits streaming",
      "films": [
        {
          "title": "Palm Springs",
          "year": 2020,
          "note": "A Sundance sale to Neon and Hulu; both hosts loved it and won't say much beyond that."
        },
        {
          "title": "The Old Guard",
          "year": 2020,
          "note": "Gina Prince-Bythewood's turn to hardcore action, with Charlize Theron leading; Sean compares it to Extraction, minus the black box where characters should be."
        },
        {
          "title": "First Cow",
          "year": 2020,
          "note": "Kelly Reichardt's film reaches VOD after a one-week theatrical run cut short by the pandemic."
        },
        {
          "title": "Bloody Nose, Empty Pockets",
          "year": 2020,
          "note": "Bill and Turner Ross's staged documentary, set on the last night of a Las Vegas dive bar."
        },
        {
          "title": "Greyhound",
          "year": 2020,
          "note": "Tom Hanks's WWII naval drama moves to Apple TV+ after Sony sold off its theatrical release; the segue into the dad-movie conversation."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The Dad Movie Hall of Fame",
      "note": "three picks apiece from Sean, Amanda, and Kevin, plus a unanimous 10th",
      "picks": [
        {
          "title": "The Great Escape",
          "year": 1963,
          "by": "Kevin Clark",
          "note": "Steve McQueen did his own motorcycle jumps out of spite; Richard Attenborough gets in for the Attenborough Extended Universe."
        },
        {
          "title": "Bridge of Spies",
          "year": 2015,
          "by": "Kevin Clark",
          "note": "Cold War diplomacy, Spielberg, Hanks, and Mark Rylance hiding a message in a coin. \"Maximum Dad.\""
        },
        {
          "title": "Remember the Titans",
          "year": 2000,
          "by": "Kevin Clark",
          "note": "Denzel and football; along with Gladiator, one of the only two movies every NFL locker room has seen."
        },
        {
          "title": "Apollo 13",
          "year": 1995,
          "by": "Amanda Dobbins",
          "note": "Ron Howard and Tom Hanks; Amanda made her mother tour Cape Canaveral as a kid because of this movie."
        },
        {
          "title": "Catch Me If You Can",
          "year": 2002,
          "by": "Amanda Dobbins",
          "note": "DiCaprio's con man, Hanks's FBI agent, and Christopher Walken as the actual dad."
        },
        {
          "title": "Sully",
          "year": 2016,
          "by": "Amanda Dobbins",
          "note": "Clint Eastwood, Hanks, a tight runtime, and the line \"Can we get serious now?\""
        },
        {
          "title": "The Right Stuff",
          "year": 1983,
          "by": "Sean Fennessey",
          "note": "Adapted from Tom Wolfe; elite as a book and as a movie, unlike most nonfiction adaptations."
        },
        {
          "title": "The Untouchables",
          "year": 1987,
          "by": "Sean Fennessey",
          "note": "Brian De Palma, a David Mamet script, an Ennio Morricone score, and Sean Connery's pure-dad cop."
        },
        {
          "title": "Lincoln",
          "year": 2012,
          "by": "Sean Fennessey",
          "note": "Spielberg, Daniel Day-Lewis, Tony Kushner's script, adapted from Doris Kearns Goodwin's \"Team of Rivals.\""
        },
        {
          "title": "Saving Private Ryan",
          "year": 1998,
          "by": "unanimous",
          "note": "Left off last year's Hanks Hall of Fame, to the audience's fury; voted in here as the WWII dad movie's summation."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Gina Prince-Bythewood on",
      "films": [
        {
          "title": "The Old Guard",
          "year": 2020,
          "note": "She pitched Skydance with a custom hip-hop/old-world-instrument demo track built the night before the meeting."
        },
        {
          "title": "Logan",
          "year": 2017,
          "note": "Her model for an action movie that also makes her cry."
        },
        {
          "title": "Black Panther",
          "year": 2018,
          "note": "Cited alongside Logan as proof the genre could move past one-upping stunt sequences."
        },
        {
          "title": "Mad Max: Fury Road",
          "year": 2015,
          "note": "Says only \"I loved Mad Max\"; resolved to Fury Road since that's Theron's sole entry in the franchise."
        },
        {
          "title": "If Beale Street Could Talk",
          "year": 2018,
          "note": "Where she first saw Kiki Layne and, by her own admission, wrongly assumed Layne was \"too soft\" to play a soldier."
        },
        {
          "title": "Love & Basketball",
          "year": 2000,
          "note": "Her debut; Skydance sent her the Old Guard script partly because of the character work in it."
        },
        {
          "title": "Beyond the Lights",
          "year": 2014,
          "note": "Cited alongside Love & Basketball as evidence she writes believable characters."
        },
        {
          "title": "The Secret Life of Bees",
          "year": 2008,
          "note": "Sean brings up Roger Ebert's review of it, the line about \"feeling superior to your emotions.\""
        },
        {
          "title": "The Rookie",
          "year": 2002,
          "note": "A sports movie she loves, with Dennis Quaid."
        },
        {
          "title": "Hoop Dreams",
          "year": 1994,
          "note": "Says she's seen it a thousand times."
        },
        {
          "title": "Bend It Like Beckham",
          "year": 2002,
          "note": "One of the few sports movies she can name with women at the center."
        },
        {
          "title": "A League of Their Own",
          "year": 1992,
          "note": "Same list, same enthusiasm."
        },
        {
          "title": "King Richard",
          "year": 2021,
          "note": "The then-unreleased Serena Williams-adjacent biopic; she notes it's named for the father, not Serena."
        }
      ]
    }
  ],
