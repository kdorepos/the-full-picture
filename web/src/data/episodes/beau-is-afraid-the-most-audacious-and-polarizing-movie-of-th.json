  "format": "Sean Fennessey and Adam Nayman work through Ari Aster's three-hour anxiety picaresque, then Aster joins to talk gag machines, Joaquin Phoenix, and the shot he never expected to get.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The most debated movie of the year",
      "note": "Sean Fennessey and Adam Nayman",
      "films": [
        {
          "title": "Beau Is Afraid",
          "year": 2023,
          "note": "Ari Aster's 179-minute Odyssey-shaped picaresque, Joaquin Phoenix's Beau dodging his way home to his mother. Nayman reads it as a parade of alienation effects that gets it from both sides; Fennessey found it his funniest and most imperfect Aster film, held back only by the CGI-heavy finale."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Ari Aster on",
      "films": [
        {
          "title": "Beau Is Afraid",
          "year": 2023,
          "note": "Aster grew it from a 2011 apartment-shoot idea into an intuitively built world he calls a gag machine turned up on the dial, and says it feels more like him than anything he's made."
        },
        {
          "title": "No Bears",
          "year": 2022,
          "note": "Aster's last-great pick is Jafar Panahi's film, which he calls magnificent and haunting and says has been nagging at him since December."
        }
      ]
    }
