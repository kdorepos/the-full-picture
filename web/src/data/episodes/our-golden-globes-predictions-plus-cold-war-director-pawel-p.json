    {
      "kind": "discussion",
      "heading": "The rest of the show",
      "note": "the host-less Oscars, Netflix's numbers, and one animated-feature standoff",
      "films": [
        {
          "title": "Bird Box",
          "year": 2018,
          "note": "Netflix says 45 million accounts streamed it in seven days. Sean wants a whole podcast to unpack that number and isn't sure it signifies success or just consumption."
        },
        {
          "title": "The Godfather",
          "year": 1972,
          "note": "Sean's reference for a host-free ceremony: the 45th Academy Awards used a handful of actors to shepherd the show, which is roughly what Bill Simmons keeps proposing for the Oscars."
        },
        {
          "title": "Spider-Man: Into the Spider-Verse",
          "year": 2018,
          "note": "Sean's pick to break Pixar's Oscar grip; Amanda, who won't watch animation, holds for Incredibles 2."
        },
        {
          "title": "Incredibles 2",
          "year": 2018,
          "note": "The Brad Bird juggernaut and the safe Academy vote: one of two animated films Amanda has actually seen."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Pawel Pawlikowski on",
      "films": [
        {
          "title": "Cold War",
          "year": 2018,
          "note": "A love story loosely drawn from his own parents, shot in high-contrast black and white and built around three folk tunes that recur as jazz, chanson, and cheesy pop as the couple moves through countries and time."
        },
        {
          "title": "Ida",
          "year": 2013,
          "note": "The static, meditative film that gave him the confidence (and the money, though only about 20%) to make Cold War. Pawlikowski says it's a Paul Schrader favorite, but a smaller influence on First Reformed than Bresson and Bergman."
        }
      ]
    }
