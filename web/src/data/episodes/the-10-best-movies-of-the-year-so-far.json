{
  "slug": "the-10-best-movies-of-the-year-so-far",
  "title": "The 10 Best Movies of the Year ... So Far",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-07-01",
  "runtimeMin": 124,
  "format": "The end-of-June halftime check-in. Sean and Amanda work through a rotating cast of Ringer colleagues, and each one makes the case for a single 2025 movie they've loved most so far. The running bit: Rob Mahoney answers the group text fastest and keeps sniping everyone's number one.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The state of the movie year",
      "note": "box office, trailers, and grading the mid-year predictions game",
      "films": [
        {
          "title": "F1",
          "year": 2025,
          "note": "Opened to about $57M, Warner Bros.' fifth straight movie they marketed hard and got people to show up for. Brad Pitt's third big-June hit of a decade after Mr. & Mrs. Smith and World War Z."
        },
        {
          "title": "Project Hail Mary",
          "year": 2026,
          "note": "The Lord and Miller / Drew Goddard adaptation of Andy Weir; their first directed feature since 22 Jump Street. The trailer that lit up the group chat 14 months out."
        },
        {
          "title": "Thunderbolts*",
          "year": 2025,
          "note": "The predictions game's easy one: they were close on both counts, ~$190M and a 68 Metacritic."
        },
        {
          "title": "Final Destination Bloodlines",
          "year": 2025,
          "note": "The bust that beat them both ways, $136M and a 73, well over their box-office and score guesses."
        },
        {
          "title": "Lilo & Stitch",
          "year": 2025,
          "note": "The one Sean whiffed on hardest, guessing ~$180M against a $395M actual."
        },
        {
          "title": "Superman",
          "year": 2025,
          "note": "The second-half wild card they're nervous about, tracking high on the strength of one word."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The picks",
      "note": "one critic, one film",
      "picks": [
        {
          "by": "Rob Mahoney",
          "title": "Sinners",
          "year": 2025,
          "note": "Grabbed first before anyone else could. Ryan Coogler's Delta-blues vampire movie, which Mahoney says changes what you look for in every other movie. A newcomer who transforms into a Mississippi bluesman on screen."
        },
        {
          "by": "Van Lathan",
          "title": "Companion",
          "year": 2025,
          "note": "His pick once Sinners was off the board. Drew Hancock's twisty sci-fi with a villain turn from Jack Quaid and Sophie Thatcher holding it down. Van's read: a lean, smartly directable first script to actually shoot."
        },
        {
          "by": "Chris Ryan",
          "title": "Materialists",
          "year": 2025,
          "note": "The great mid-year freakout. Chris makes the case for Celine Song's divisive love-triangle movie as an idea movie worth arguing about, closer to Whit Stillman than Nancy Meyers, with the New York background noise zeroed out."
        },
        {
          "by": "Joanna Robinson",
          "title": "Black Bag",
          "year": 2025,
          "note": "Soderbergh's 90-minute spy-marriage movie: Cate Blanchett, Michael Fassbender, wigs and turtlenecks. Joanna's lament is that it should have felt like an event and audiences didn't show. Sniped from her, again, by Mahoney."
        },
        {
          "by": "Charles Holmes",
          "title": "Friendship",
          "year": 2025,
          "note": "Tim Robinson as a middle-aged man who doesn't know the rules. Charles reads it as a sociological text on how hard it is to make friends past 30, the dark version of I Love You, Man."
        },
        {
          "by": "Mallory Rubin",
          "title": "28 Years Later",
          "year": 2025,
          "note": "Boyle and Garland reunited. Mallory on Alfie Williams as Spike, Ralph Fiennes in the Bone Temple, and a movie whose real horror is the rest of the world quarantining Britain and walking away."
        },
        {
          "by": "Adam Nayman",
          "title": "Caught by the Tides",
          "year": 2025,
          "note": "The arthouse pick. Jia Zhangke remixing 20 years of his own footage into a near-silent chronicle of a changing China. Adam's other favorites (The Shrouds, 28 Years Later, Friendship) were already taken."
        },
        {
          "by": "Grace Fennessey",
          "title": "Thunderbolts*",
          "year": 2025,
          "note": "Sean's sister and resident MCU watcher calls it a return to form, a found-family team-up that fixes Marvel's habit of introducing characters and dropping them. Lewis Pullman's Sentry the standout."
        },
        {
          "by": "Jack Sanders",
          "title": "F1",
          "year": 2025,
          "note": "Producer Jack's defense: a lesser Brad Pitt performance, a $350M commercial, formulaic, and none of it matters because the racing is hypnotic. Kosinski building set pieces up there with Nolan and Villeneuve."
        },
        {
          "by": "Amanda Dobbins",
          "title": "The Phoenician Scheme",
          "year": 2025,
          "note": "Amanda would have taken Black Bag, and instead banged the table for Wes Anderson, arguing the diorama complaints undersell the ideas. Benicio del Toro as the undersung performance of the year."
        },
        {
          "by": "Sean Fennessey",
          "title": "Warfare",
          "year": 2025,
          "note": "Garland and ex-soldier Ray Mendoza co-directing a punishing real-time combat film. Sean's angle: two collaborators who see war differently, making something out of the friction."
        }
      ]
    }
  ],
