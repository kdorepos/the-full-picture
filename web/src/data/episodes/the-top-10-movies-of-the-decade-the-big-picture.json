{
  "slug": "the-top-10-movies-of-the-decade-the-big-picture",
  "title": "The Top 10 Movies of the Decade | The Big Picture",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2019-11-26",
  "runtimeMin": 83,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan each rank their ten best movies of the 2010s, and land, independently, on the same No. 1.",
  "segments": [
    {
      "kind": "ranking",
      "heading": "Amanda Dobbins's Top 10",
      "note": "best to worst",
      "subject": "Amanda Dobbins",
      "ranked": true,
      "films": [
        {
          "title": "The Social Network",
          "year": 2010,
          "note": "No. 1 - all three hosts landed here independently. A movie that predicts everything from Facebook's rise to the way we connect now."
        },
        {
          "title": "Lady Bird",
          "year": 2017,
          "note": "No. 2 - the best experience she had watching a movie all decade; a mother-daughter story that's both intensely specific to Greta Gerwig and pretty universal."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "No. 3 - kept off some lists for recency bias, but the movie she'll remember from this political moment, even though it's Korean, not American."
        },
        {
          "title": "Moneyball",
          "year": 2011,
          "note": "No. 4 - turns sports and spreadsheets, neither of which interest her, into a movie-star vehicle for Brad Pitt."
        },
        {
          "title": "Phantom Thread",
          "year": 2017,
          "note": "No. 5 - the decade's rare real love story, and Paul Thomas Anderson's tightest movie."
        },
        {
          "title": "Skyfall",
          "year": 2012,
          "note": "No. 6 - proof a movie can gross a billion dollars and still have ideas."
        },
        {
          "title": "Frances Ha",
          "year": 2013,
          "note": "No. 7 - Baumbach's most hopeful movie, released the year she was Frances's age and living in New York herself."
        },
        {
          "title": "Arrival",
          "year": 2016,
          "note": "No. 8 - a rewatch the night before recording moved her as much as her first three trips to the theater in 2016."
        },
        {
          "title": "Magic Mike",
          "year": 2012,
          "note": "No. 9 - anticipated a decade of movies that live as much online as in the theater. Also, Channing Tatum dances."
        },
        {
          "title": "Fast Five",
          "year": 2011,
          "note": "No. 10 - the gut-check pick: a dumb, amazing movie about dragging a safe through Rio."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Chris Ryan's Top 10",
      "note": "best to worst",
      "subject": "Chris Ryan",
      "ranked": true,
      "films": [
        {
          "title": "The Social Network",
          "year": 2010,
          "note": "No. 1 - the movie of the decade, and nobody's really directed a better-looking one since."
        },
        {
          "title": "The Wolf of Wall Street",
          "year": 2013,
          "note": "No. 2 - he'd written it off back in 2013; a rewatch convinced him it explains America and how screwed everything got."
        },
        {
          "title": "Lady Bird",
          "year": 2017,
          "note": "No. 3 - Greta Gerwig telling her own story."
        },
        {
          "title": "Arrival",
          "year": 2016,
          "note": "No. 4 - the best of a stacked Denis Villeneuve decade that also included Prisoners, Enemy, Sicario, and Blade Runner 2049."
        },
        {
          "title": "Before Midnight",
          "year": 2013,
          "note": "No. 5 - the most co-authored entry in the trilogy: Jesse's kind of a dick in it, and nothing gets fully resolved."
        },
        {
          "title": "Drive",
          "year": 2011,
          "note": "No. 6 - the movie that made Los Angeles feel new to him the year he moved there."
        },
        {
          "title": "Mad Max: Fury Road",
          "year": 2015,
          "note": "No. 7 - a real case for best-made movie of the decade, and proof sequels don't have to be bad."
        },
        {
          "title": "Minding the Gap",
          "year": 2018,
          "note": "No. 8 - a skateboarding documentary so intimate you feel like you know these people."
        },
        {
          "title": "The Master",
          "year": 2012,
          "note": "No. 9 - one of the most haunting movies he's ever seen; he caught it at a midnight screening the week it opened."
        },
        {
          "title": "Once Upon a Time in Hollywood",
          "year": 2019,
          "note": "No. 10 - ranked low mostly because it's brand new; he expects it to climb on further watches."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Sean Fennessey's Top 10",
      "note": "best to worst",
      "subject": "Sean Fennessey",
      "ranked": true,
      "films": [
        {
          "title": "The Social Network",
          "year": 2010,
          "note": "No. 1 - not close. His pod, his call, and the movie all three hosts landed on without comparing notes."
        },
        {
          "title": "The Master",
          "year": 2012,
          "note": "No. 2 - the most mesmeric movie on the list; he still can't explain why it holds his attention."
        },
        {
          "title": "Inside Llewyn Davis",
          "year": 2013,
          "note": "No. 3 - the first Coen brothers movie since A Serious Man that belongs in their canon: a love letter to the ones who don't quite make it."
        },
        {
          "title": "Whiplash",
          "year": 2014,
          "note": "No. 4 - a cautionary tale for anyone too online and too obsessed with their own work, i.e. everyone."
        },
        {
          "title": "Once Upon a Time in Hollywood",
          "year": 2019,
          "note": "No. 5 - his favorite director of the decade making his LA movie, in his safest place."
        },
        {
          "title": "Get Out",
          "year": 2017,
          "note": "No. 6 - a tightly orchestrated horror movie that went from theater to part of the culture's vocabulary almost overnight."
        },
        {
          "title": "Frances Ha",
          "year": 2013,
          "note": "No. 7 - also on Amanda's list; Baumbach and Gerwig's black-and-white ode to broke New York twenty-somethings."
        },
        {
          "title": "Mad Max: Fury Road",
          "year": 2015,
          "note": "No. 8 - the critical-consensus pick for action filmmaking of the decade, one spot lower than on Chris's list."
        },
        {
          "title": "O.J.: Made in America",
          "year": 2016,
          "note": "No. 9 - the best movie about the arc of time he's seen: what happens to a person once they go inside the machine."
        },
        {
          "title": "Spider-Man: Into the Spider-Verse",
          "year": 2018,
          "note": "No. 10 - the rare animated movie that actually pushes the medium forward."
        }
      ]
    }
  ],
