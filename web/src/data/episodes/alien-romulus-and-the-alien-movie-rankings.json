        {
          "title": "A Woman Under the Influence",
          "year": 1974,
          "note": "Discussed after her death at 94 as the high point of the Cassavetes-Rowlands collaborations; Chris calls the scene where she waits for her kids' bus one of his most treasured moviegoing memories."
        },
        {
          "title": "Opening Night",
          "year": 1977,
          "note": "Named alongside 'A Woman Under the Influence' as the peak of her work with Cassavetes."
        },
