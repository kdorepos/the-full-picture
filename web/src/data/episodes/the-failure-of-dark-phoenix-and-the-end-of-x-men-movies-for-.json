{
  "slug": "the-failure-of-dark-phoenix-and-the-end-of-x-men-movies-for-",
  "title": "The Failure of 'Dark Phoenix' and the End of X-Men Movies ... For Now | Exit Survey",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2019-06-07",
  "runtimeMin": 53,
  "format": "Sean Fennessey and Chris Ryan review 'Dark Phoenix', panned by critics, and use it as an excuse to go through the entire 20-year X-Men franchise: the mismanaged timelines, the actors who outgrew the material, and what Fox's sale to Disney means for whatever comes next.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Dark Phoenix'",
      "films": [
        {
          "title": "Dark Phoenix",
          "year": 2019,
          "note": "Writer-director Simon Kinberg's debut and the franchise's supposed send-off, savaged by critics (reviews in the 20s on Rotten Tomatoes) for a humorless second act that doesn't match its slapped-on first act or its confusing train-set third act. Sean and Chris single out Jessica Chastain's bizarre villain performance and note Sophie Turner gets blown off the screen playing Jean Grey/Phoenix."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The X-Men Franchise, 20 Years Later",
      "note": "on the eve of the Disney-Fox merger",
      "films": [
        {
          "title": "X-Men",
          "year": 2000,
          "note": "The movie that proved CGI had caught up enough to make a comic book movie work; Sean argues it set the template the MCU would later follow."
        },
        {
          "title": "X2",
          "year": 2003,
          "note": "Both hosts call it radical for its time, before Spider-Man or the MCU existed; Chris reads it as a coded story about coming out of the closet."
        },
        {
          "title": "X-Men: The Last Stand",
          "year": 2006,
          "note": "Brett Ratner's version, made after Bryan Singer backed out; fuses the Dark Phoenix and 'gifted' storylines and gets more credit from Chris on rewatch than he remembered giving it."
        },
        {
          "title": "X-Men Origins: Wolverine",
          "year": 2009,
          "note": "David Benioff's original script got reworked by Skip Woods into more of a straight action movie, one of several times the studio overruled the writer's original take."
        },
        {
          "title": "X-Men: First Class",
          "year": 2011,
          "note": "Both call it the series' creative high point: Matthew Vaughn and Jane Goldman's script and a stacked young cast (Fassbender, McAvoy, Lawrence) reset the timeline and the franchise's confidence."
        },
        {
          "title": "X-Men: Days of Future Past",
          "year": 2014,
          "note": "Singer's return; Sean argues it could have been a top-five superhero movie had Vaughn stayed on to direct it instead."
        },
        {
          "title": "X-Men: Apocalypse",
          "year": 2016,
          "note": "Kinberg's first directing-adjacent writing credit on the series; both note Fassbender and McAvoy are already visibly better than the material by this point."
        },
        {
          "title": "Deadpool",
          "year": 2016,
          "note": "The outlier: the one X-Men-adjacent movie in this stretch where a director got to make a specific, funny movie on its own terms."
        },
        {
          "title": "Logan",
          "year": 2017,
          "note": "The consensus best of the whole series for both hosts, and, per Chris, the only entry with a consistent tone start to finish, earned by James Mangold and Hugh Jackman fighting for an R rating."
        },
        {
          "title": "The New Mutants",
          "year": 2020,
          "note": "Josh Boone's spinoff, already delayed multiple times as of this recording; neither host is confident what role, if any, it'll end up playing."
        }
      ]
    }
  ],
