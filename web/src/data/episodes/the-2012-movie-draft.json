  ],
  "published": "2020-09-29",
  "runtimeMin": 126,
  "format": "Sean, Amanda, and Chris Ryan re-run the movie draft, six categories deep, with new rules written in the wake of last time's scandal. Billy Ray joins after to talk The Comey Rule.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The 2012 Movie Draft",
      "note": "Sean, Amanda, and Chris Ryan, snake draft, six categories",
      "draftOf": "2012 movies",
      "categories": [
        "Drama",
        "Comedy or Horror",
        "Blockbuster",
        "Animated or Foreign Language",
        "Wildcard",
        "Sequel"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Master",
              "year": 2012,
              "category": "Drama",
              "note": "Paul Thomas Anderson's film; Sean says he's returned to it at the Arclight more than once."
            },
            {
              "title": "The Avengers",
              "year": 2012,
              "category": "Blockbuster",
              "note": "By his own count, not even a top-five MCU movie for him. Amanda calls it a weird pick."
            },
            {
              "title": "Prometheus",
              "year": 2012,
              "category": "Sequel",
              "note": "Ruled eligible as a prequel; Ridley Scott's first Alien-franchise film in almost 35 years."
            },
            {
              "title": "Moonrise Kingdom",
              "year": 2012,
              "category": "Wildcard",
              "note": "Wes Anderson, with Bill Murray, Frances McDormand, Edward Norton, and Bruce Willis."
            },
            {
              "title": "Sinister",
              "year": 2012,
              "category": "Comedy or Horror",
              "note": "Scott Derrickson and Ethan Hawke, before Derrickson went off to direct Doctor Strange."
            },
            {
              "title": "It's Such a Beautiful Day",
              "year": 2012,
              "category": "Animated or Foreign Language",
              "note": "Don Hertzfeldt's stick-figure trilogy, released as one film this year."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Skyfall",
              "year": 2012,
              "category": "Sequel",
              "note": "One of her favorite movies of the decade; she rewatched it the night before the draft."
            },
            {
              "title": "21 Jump Street",
              "year": 2012,
              "category": "Comedy or Horror",
              "note": "A studio comedy she says has made her laugh consistently for a decade."
            },
            {
              "title": "Anna Karenina",
              "year": 2012,
              "category": "Drama",
              "note": "Joe Wright's stage-bound adaptation, with Keira Knightley and Alicia Vikander."
            },
            {
              "title": "Amour",
              "year": 2012,
              "category": "Animated or Foreign Language",
              "note": "Michael Haneke; she saw it at BAM early on with the man she'd go on to marry."
            },
            {
              "title": "The Hunger Games",
              "year": 2012,
              "category": "Blockbuster",
              "note": "Calls it Jennifer Lawrence's better 2012 performance, over Silver Linings Playbook."
            },
            {
              "title": "Argo",
              "year": 2012,
              "category": "Wildcard",
              "note": "That year's Best Picture winner, picked last, with no apologies."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Django Unchained",
              "year": 2012,
              "category": "Drama",
              "note": "Filed under drama despite calling it a stretch; he also calls it very funny and an action movie."
            },
            {
              "title": "Magic Mike",
              "year": 2012,
              "category": "Blockbuster",
              "note": "Steven Soderbergh; one of his favorite films of the decade."
            },
            {
              "title": "The Bourne Legacy",
              "year": 2012,
              "category": "Sequel",
              "note": "Loves Jeremy Renner and especially Edward Norton: 'putting your hand on a train track.'"
            },
            {
              "title": "Looper",
              "year": 2012,
              "category": "Wildcard",
              "note": "Rian Johnson; wonders what could've happened between this and Knives Out."
            },
            {
              "title": "V/H/S",
              "year": 2012,
              "category": "Comedy or Horror",
              "note": "The horror anthology from Ti West, Adam Wingard, David Bruckner, and others."
            },
            {
              "title": "Rust and Bone",
              "year": 2012,
              "category": "Animated or Foreign Language",
              "note": "Marion Cotillard, in a category he says is 'full of pain' next to Amour."
            }
          ]
        }
