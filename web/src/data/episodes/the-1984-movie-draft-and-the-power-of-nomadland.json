{
  "slug": "the-1984-movie-draft-and-the-power-of-nomadland",
  "title": "The 1984 Movie Draft and the Power of ‘Nomadland’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2021-02-23",
  "runtimeMin": 88,
  "format": "Sean and Amanda break down Nomadland's Hulu arrival with Chris Ryan, then the three of them draft 1984, Amanda's birth year, across six categories: drama, comedy, horror, action, sequel/franchise, and blockbuster.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Power of 'Nomadland'",
      "note": "Chloe Zhao's Frances McDormand film arrives on Hulu",
      "films": [
        {
          "title": "Nomadland",
          "year": 2020,
          "note": "Sean and Amanda first saw it at a drive-in screening outside the Rose Bowl; Chris catches up on Hulu and calls it a rare movie \"rooted in the actual real world.\" David Strathairn gets a shoutout."
        },
        {
          "title": "I Care a Lot",
          "year": 2020,
          "note": "Rosamund Pike's Netflix thriller, released the same weekend, comes up as a heavily designed, almost inhuman counterpoint to Nomadland's rawness."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The 1984 Movie Draft",
      "note": "a six-category snake draft, decided by fan vote for Amanda's birth year",
      "draftOf": "1984 movies",
      "categories": [
        "Drama",
        "Comedy",
        "Horror",
        "Action",
        "Sequel/Franchise",
        "Blockbuster"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Terminator",
              "year": 1984,
              "category": "Action",
              "note": "Sean's first overall pick. James Cameron's debut, slower than modern action fare but, he argues, the announcement of a major visionary."
            },
            {
              "title": "Ghostbusters",
              "year": 1984,
              "category": "Sequel/Franchise",
              "note": "Sean apologizes to Chris before taking it, calling it the movie that permeated 80s pop culture wholesale."
            },
            {
              "title": "Blood Simple",
              "year": 1984,
              "category": "Drama",
              "note": "The Coen brothers' debut, a Texas noir loosely indebted to Dashiell Hammett, with Frances McDormand's first film role and John Getz as its lead."
            },
            {
              "title": "This Is Spinal Tap",
              "year": 1984,
              "category": "Comedy",
              "note": "Rob Reiner's mockumentary, which Sean calls the movie every future comedy writer went off and studied."
            },
            {
              "title": "Gremlins",
              "year": 1984,
              "category": "Horror",
              "note": "Joe Dante's horror-comedy; Sean says it's really a beautiful film about small-town American life, gremlins aside."
            },
            {
              "title": "The Karate Kid",
              "year": 1984,
              "category": "Blockbuster",
              "note": "Sean's Long Island pride pick (Ralph Macchio grew up near him), with a nod to its Cobra Kai revival."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Amadeus",
              "year": 1984,
              "category": "Drama",
              "note": "Milos Forman's Best Picture winner, which her father sat her down to watch as a kid alongside her piano lessons."
            },
            {
              "title": "The Muppets Take Manhattan",
              "year": 1984,
              "category": "Comedy",
              "note": "Picked the same weekend Donald Trump Jr. called the Muppets \"canceled\" over a Disney+ content disclaimer."
            },
            {
              "title": "A Nightmare on Elm Street",
              "year": 1984,
              "category": "Horror",
              "note": "Amanda, a self-described horror novice, texted New York Times critic Gilbert Cruz for backup before picking Wes Craven's original."
            },
            {
              "title": "Romancing the Stone",
              "year": 1984,
              "category": "Action",
              "note": "Robert Zemeckis's Michael Douglas/Kathleen Turner romantic-adventure comedy, which Amanda didn't discover until her 20s."
            },
            {
              "title": "Ghostbusters",
              "year": 1984,
              "category": "Sequel/Franchise",
              "note": null
            },
            {
              "title": "Purple Rain",
              "year": 1984,
              "category": "Blockbuster",
              "note": "Amanda's Prince pick, made $68 million at the box office; the group calls it strange and formative."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Beverly Hills Cop",
              "year": 1984,
              "category": "Sequel/Franchise",
              "note": "Chris grew up on Eddie Murphy's stand-up before this; he says he can still recite most of the dialogue."
            },
            {
              "title": "Paris, Texas",
              "year": 1984,
              "category": "Drama",
              "note": "Wim Wenders's Harry Dean Stanton drama, taken early; Chris calls it the movie that made him think about film as art."
            },
            {
              "title": "Repo Man",
              "year": 1984,
              "category": "Comedy",
              "note": "Alex Cox's L.A. punk odyssey with Emilio Estevez and Harry Dean Stanton, Chris's gateway into punk culture as a teenager."
            },
            {
              "title": "Indiana Jones and the Temple of Doom",
              "year": 1984,
              "category": "Action",
              "note": "Chris calls it problematic and colonialist but also part horror movie, part musical, part buddy comedy, and still excellent."
            },
            {
              "title": "Children of the Corn",
              "year": 1984,
              "category": "Horror",
              "note": "The Stephen King adaptation that permanently soured Chris on kids standing by the side of the road."
            },
            {
              "title": "The Natural",
              "year": 1984,
              "category": "Blockbuster",
              "note": "Barry Levinson's Robert Redford baseball fable, singled out for Randy Newman's score and the closing home-run sequence."
            }
          ]
        }
      ],
