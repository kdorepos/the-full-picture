{
  "slug": "the-1982-movie-draft",
  "title": "The 1982 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2025-03-21",
  "runtimeMin": 134,
  "format": "A four-person snake draft of 1982 movies: Sean Fennessey, Chris Ryan, and Amanda Dobbins joined by returning champion Tracy Letts, each filling a six-category roster. Then a long run through the year's cult horror, exploitation, and comedy.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "the movies of 1982",
      "categories": [
        "Drama",
        "Comedy",
        "Thriller / Action / Horror / Sci-Fi",
        "Blockbuster",
        "Oscar Nominee",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "First Blood",
              "year": 1982,
              "category": "Drama",
              "note": "The Stallone Vietnam-vet character study, taken in drama on the argument that it isn't the later Rambo movies. The room half-accepted the call."
            },
            {
              "title": "The World According to Garp",
              "year": 1982,
              "category": "Comedy",
              "note": "George Roy Hill's John Irving adaptation; Robin Williams playing low-key, Glenn Close and John Lithgow both Oscar-nominated."
            },
            {
              "title": "The Thing",
              "year": 1982,
              "category": "Thriller / Action / Horror / Sci-Fi",
              "note": "The first overall pick. Carpenter's film, with Rob Bottin's practical effects, Kurt Russell, and Keith David's first film role."
            },
            {
              "title": "Poltergeist",
              "year": 1982,
              "category": "Blockbuster",
              "note": "Tobe Hooper's haunted-suburbia hit and the year's 8th-highest grosser. Sean says the Spielberg-shadow-director rumor has been debunked."
            },
            {
              "title": "Das Boot",
              "year": 1982,
              "category": "Oscar Nominee",
              "note": "Wolfgang Petersen's submarine epic; one of Sean's two West German picks."
            },
            {
              "title": "Fitzcarraldo",
              "year": 1982,
              "category": "Wild Card",
              "note": "Herzog dragging a steamship over a mountain; Sean's favorite of a full Herzog rewatch, shot the same year as the making-of doc Burden of Dreams."
            }
          ]
        },
        {
          "host": "Tracy Letts",
          "picks": [
            {
              "title": "The Verdict",
              "year": 1982,
              "category": "Drama",
              "note": "The clear drama No. 1: Newman, Mamet's best screenplay, Lumet directing."
            },
            {
              "title": "Tootsie",
              "year": 1982,
              "category": "Comedy",
              "note": "Pollack's cross-dressing comedy; Tracy on how the reveal played for minutes of screaming theater laughter."
            },
            {
              "title": "The Road Warrior",
              "year": 1982,
              "category": "Thriller / Action / Horror / Sci-Fi",
              "note": "Miller's Mad Max 2, which Tracy calls the greatest action movie ever made."
            },
            {
              "title": "Star Trek II: The Wrath of Khan",
              "year": 1982,
              "category": "Blockbuster",
              "note": "The film that saved the franchise; Montalbán eating the drapes. Tracy once projected it and let the screen go dark for 20 minutes."
            },
            {
              "title": "Missing",
              "year": 1982,
              "category": "Oscar Nominee",
              "note": "Costa-Gavras with Jack Lemmon and Sissy Spacek; a Spacek appreciation follows."
            },
            {
              "title": "Eating Raoul",
              "year": 1982,
              "category": "Wild Card",
              "note": "Paul Bartel's LA black comedy; Tracy tells of Bartel taking him to lunch years later after seeing his play Killer Joe."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "The Draughtsman's Contract",
              "year": 1982,
              "category": "Drama",
              "note": "Peter Greenaway's period sex-and-class puzzle; Chris worked with its lead, Anthony Higgins, on a London play."
            },
            {
              "title": "Fast Times at Ridgemont High",
              "year": 1982,
              "category": "Comedy",
              "note": "Heckerling directs Crowe's script; Chris argues it's about 70 percent drama under the comedy."
            },
            {
              "title": "Halloween III: Season of the Witch",
              "year": 1982,
              "category": "Thriller / Action / Horror / Sci-Fi",
              "note": "The no-Michael-Myers entry (Silver Shamrock) that Chris and Sean rank as their second-favorite Halloween."
            },
            {
              "title": "48 Hrs.",
              "year": 1982,
              "category": "Blockbuster",
              "note": "Walter Hill; Eddie Murphy's screen debut, a template for the '80s buddy-cop movie."
            },
            {
              "title": "E.T. the Extra-Terrestrial",
              "year": 1982,
              "category": "Oscar Nominee",
              "note": "Third overall, taken in Oscar partly for category scarcity."
            },
            {
              "title": "Personal Best",
              "year": 1982,
              "category": "Wild Card",
              "note": "Robert Towne's track-and-field love story with Mariel Hemingway and Scott Glenn; a deep cut from a Towne rewatch."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Diner",
              "year": 1982,
              "category": "Drama",
              "note": "Barry Levinson's ensemble, the famous movie her father sat 7-year-old Amanda down for."
            },
            {
              "title": "Deathtrap",
              "year": 1982,
              "category": "Comedy",
              "note": "The other 1982 Lumet, a whodunit sendup with Christopher Reeve and Dyan Cannon; Amanda's puzzle-box pick."
            },
            {
              "title": "Blade Runner",
              "year": 1982,
              "category": "Thriller / Action / Horror / Sci-Fi",
              "note": "Ridley Scott; Amanda rewatched The Final Cut, her second-favorite Ridley after Alien."
            },
            {
              "title": "Annie",
              "year": 1982,
              "category": "Blockbuster",
              "note": "The John Huston musical; one of Amanda's first movie musicals, Carol Burnett and Albert Finney and Tim Curry."
            },
            {
              "title": "An Officer and a Gentleman",
              "year": 1982,
              "category": "Oscar Nominee",
              "note": "Taylor Hackford; Richard Gere, Debra Winger, and an Oscar-winning Louis Gossett Jr."
            },
            {
              "title": "Evil Under the Sun",
              "year": 1982,
              "category": "Wild Card",
              "note": "Guy Hamilton's Peter Ustinov-as-Poirot Agatha Christie mystery; Amanda's favorite movie of the year."
            }
          ]
        }
      ],
