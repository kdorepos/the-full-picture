      "heading": "Army of the Dead",
      "note": "Zack Snyder · Netflix",
      "films": [
        {
          "title": "Army of the Dead",
          "year": 2021,
          "note": "Snyder's Las Vegas zombie heist. All three agree it peaks in the opening-credits montage and coasts from there."
        },
        {
          "title": "Dawn of the Dead (2004)",
          "year": 2004,
          "note": "Snyder's remake that launched his career; the yardstick for how far his style has drifted since."
        },
        {
          "title": "Zack Snyder's Justice League",
          "year": 2021,
          "note": "The Snyder Cut whose discourse still overshadowed this release."
        },
        {
          "title": "Blade Runner 2049",
          "year": 2017,
          "note": "Bautista's small, oddly touching turn (the little glasses)."
        },
        {
          "title": "Dune",
          "year": 2021,
          "note": "Bautista again, inside Villeneuve's rogues' gallery."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Sixty years of zombie movies",
      "note": "the genre roundtable",
      "films": [
        {
          "title": "Day of the Dead",
          "year": 1985,
          "note": "Romero in the Reagan '80s."
        },
        {
          "title": "Land of the Dead",
          "year": 2005,
          "note": "Romero's post-9/11, divided-America entry."
        },
        {
          "title": "Diary of the Dead",
          "year": 2007,
          "note": "Romero's found-footage self-tribute, down to the girl losing her shoe in the woods."
        },
        {
          "title": "The Amusement Park",
          "year": 1975,
          "note": "Long-lost Romero elder-abuse nightmare, arriving on Shudder that summer."
        },
        {
          "title": "The Crazies (1973)",
          "year": 1973,
          "note": "Romero's true quarantine movie; Sean's near-miss pick, closer to infection than zombie."
        },
        {
          "title": "The Crazies (2010)",
          "year": 2010,
          "note": "Breck Eisner's remake: not bad, kind of pointless."
        },
        {
          "title": "World War Z",
          "year": 2013,
          "note": "Contagion-scale procedural; Adam rates it, partly for the source book."
        },
        {
          "title": "Resident Evil",
          "year": 2002,
          "note": "Paul W.S. Anderson's series; Adam rates how it handles space and geography."
        },
        {
          "title": "Rabid",
          "year": 1977,
          "note": "Cronenberg, cited on the fine line between infection and zombiedom."
        },
        {
          "title": "One Cut of the Dead",
          "year": 2017,
          "note": "Shinichiro Ueda's making-of-a-zombie-movie comedy; long a Shudder staple."
        },
        {
          "title": "From Beyond",
          "year": 1986,
          "note": "The other Gordon/Combs Lovecraft picture."
        },
        {
          "title": "Zombie",
          "year": 1979,
          "note": "Fulci's most famous zombie picture, name-checked alongside The Beyond."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top Five Zombie Movies",
      "note": "his picks, loosely counted",
      "subject": "Zombie movies",
      "ranked": false,
      "films": [
        {
          "title": "28 Days Later",
          "year": 2002,
          "note": "No. 1. Boyle's fast-zombie reset; Garland script, Eccleston's Colonel Kurtz turn."
        },
        {
          "title": "[REC]",
          "year": 2007,
          "note": "No. 2. Found-footage outbreak in a sealed Spanish apartment block: nerve endings through a cheese grater."
        },
        {
          "title": "Dawn of the Dead (1978)",
          "year": 1978,
          "note": "No. 3 (both versions); Snyder's remake covered up in the review."
        },
        {
          "title": "Zombieland",
          "year": 2009,
          "note": "No. 4. Road-movie zom-com, cast right before Eisenberg/Stone/Harrelson went supernova."
        },
        {
          "title": "Dead Snow",
          "year": 2009,
          "note": "No. 5. Norwegian Nazi-zombie B-movie: reanimate people you already hate."
        },
        {
          "title": "The Return of the Living Dead",
          "year": 1985,
          "note": "Chris's zom-com bracket (raised as a No. 3 before he landed on Dawn of the Dead). Dan O'Bannon's; best in a packed house."
        },
        {
          "title": "Evil Dead II",
          "year": 1987,
          "note": "Chris's zom-com bracket. Homage to Tex Avery and the Marx Brothers more than to zombies."
        },
        {
          "title": "Shaun of the Dead",
          "year": 2004,
          "note": "Chris's zom-com bracket. Self-aware and loving; did the Scream trick for zombies."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Adam Nayman's Top Five Zombie Movies",
      "note": "his strict no-fun policy",
      "subject": "Zombie movies",
      "ranked": false,
      "films": [
        {
          "title": "I Walked with a Zombie",
          "year": 1943,
          "note": "No. 1. Jacques Tourneur's Caribbean plantation mood piece; a horror movie almost without gore."
        },
        {
          "title": "Dawn of the Dead (1978)",
          "year": 1978,
          "note": "No. 2. Romero's mall: the setting as the character."
        },
        {
          "title": "Re-Animator",
          "year": 1985,
          "note": "No. 3. Stuart Gordon; Jeffrey Combs deadpan, gleeful Lovecraft splatter."
        },
        {
          "title": "Night of the Living Dead",
          "year": 1968,
          "note": "No. 4. Romero's origin; images you've seen a thousand times without knowing the source."
        },
        {
          "title": "Deathdream",
          "year": 1974,
          "note": "No. 5 (joint). Bob Clark's Vietnam-grief zombie, paired with Joe Dante's Masters of Horror episode Homecoming."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top Five Zombie Movies",
      "note": "his No. 3 went unstated on air",
