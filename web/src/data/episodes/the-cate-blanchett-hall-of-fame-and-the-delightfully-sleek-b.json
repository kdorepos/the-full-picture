{
  "slug": "the-cate-blanchett-hall-of-fame-and-the-delightfully-sleek-b",
  "title": "The Cate Blanchett Hall of Fame and the Delightfully Sleek ‘Black Bag’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-03-14",
  "runtimeMin": 105,
  "format": "Soderbergh's married-spies thriller 'Black Bag,' then a 10-film Cate Blanchett Hall of Fame that walks her whole filmography from Paradise Road to Borderlands.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Black Bag’",
      "note": "Steven Soderbergh, 2025",
      "films": [
        {
          "title": "Black Bag",
          "year": 2025,
          "note": "Soderbergh's 36th feature and second of 2025. Married intelligence agents; one is suspected of treason, the other has to decide whether to protect them. Slick, witty, 93 minutes: more Fassbender's movie than Blanchett's. Sean's best film of the year so far; Amanda's verdict: 'no notes.'"
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Cate Blanchett Hall of Fame",
      "note": "10 in; six of them supporting turns",
      "honoree": "Cate Blanchett",
      "films": [
        {
          "title": "Elizabeth",
          "year": 1998,
          "note": "The breakthrough. An unknown opposite Shekhar Kapoor's camera; nominated, won the Globe, and was a Hollywood fixture overnight."
        },
        {
          "title": "The Talented Mr. Ripley",
          "year": 1999,
          "note": "A small part she loads with under-the-surface calculation. 'No small parts.'"
        },
        {
          "title": "The Lord of the Rings: The Fellowship of the Ring",
          "year": 2001,
          "note": "Galadriel. Picked to represent the whole trilogy: her most screen time as the elf queen came here."
        },
        {
          "title": "The Life Aquatic with Steve Zissou",
          "year": 2004,
          "note": "The pregnant journalist on Zissou's boat. Daffy and soft but still emotional, a no-brainer for both."
        },
        {
          "title": "The Aviator",
          "year": 2004,
          "note": "Her first Oscar, as Katharine Hepburn. Old-Hollywood cosplay, perfectly cast."
        },
        {
          "title": "Notes on a Scandal",
          "year": 2006,
          "note": "May December before May December. Makes a role that could be a nothing-burger into a real, believable person opposite Judi Dench."
        },
        {
          "title": "I'm Not There",
          "year": 2007,
          "note": "Jude Quinn, the London-era Dylan. Per Sean, the best Bob Dylan performance ever put on film."
        },
        {
          "title": "Hanna",
          "year": 2011,
          "note": "Marissa Wiegler, the CIA attaché. The villain-part pick and Amanda's dark horse over Blue Jasmine."
        },
        {
          "title": "Carol",
          "year": 2015,
          "note": "Todd Haynes. Maybe her best movie: withholding, mysterious, with a Christmas ache running under it."
        },
        {
          "title": "Tár",
          "year": 2022,
          "note": "Lydia Tár. The obvious best of the ten; they set it aside first and built the rest of the list around it."
        }
      ]
    }
  ],
