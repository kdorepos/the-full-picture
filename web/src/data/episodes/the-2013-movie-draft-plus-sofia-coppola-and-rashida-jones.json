          "picks": [
            {
              "title": "Iron Man 3",
              "year": 2013,
              "category": "Sequel",
              "note": "His No. 1 overall pick, to loud objections from Sean and Amanda; a Shane Black-directed favorite and, he says, Downey's best performance in the role."
            },
            {
              "title": "Inside Llewyn Davis",
              "year": 2013,
              "category": "Drama",
              "note": "Went in expecting a Coen ensemble romp and got one of the saddest movies he's seen; grown on him since."
            },
            {
              "title": "This Is the End",
              "year": 2013,
              "category": "Blockbuster",
              "note": "A personal pick over a horror-category slot; calls it an overlooked comedy of its moment."
            },
            {
              "title": "You're Next",
              "year": 2013,
              "category": "Comedy/Horror",
              "note": "Adam Wingard's home-invasion movie; the apex, per Chris and Sean, of the era's indie horror wave."
            },
            {
              "title": "Prisoners",
              "year": 2013,
              "category": "Wildcard",
              "note": "One of his favorite Jake Gyllenhaal performances; a hit despite a bleak ending he doesn't fully endorse the politics of."
            },
            {
              "title": "Drug War",
              "year": 2013,
              "category": "Animated/Foreign Language",
              "note": "Johnnie To's cop-and-gangster film, a late discovery; praises the shootout choreography."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Wolf of Wall Street",
              "year": 2013,
              "category": "Blockbuster",
              "note": "His favorite rewatch of the three of them; taken as a blockbuster since it cleared the $100 million bar."
            },
            {
              "title": "Before Midnight",
              "year": 2013,
              "category": "Sequel",
              "note": "The third Linklater/Hawke/Delpy film; he's aged into Jesse's age since seeing it, which changed how it plays."
            },
            {
              "title": "Gravity",
              "year": 2013,
              "category": "Drama",
              "note": "Picked for the theatrical experience above all; singles out the Bullock/Clooney separation sequence."
            },
            {
              "title": "The Conjuring",
              "year": 2013,
              "category": "Comedy/Horror",
              "note": "Calls it one of the best horror movies of the decade and the start of its own franchise."
            },
            {
              "title": "The Counselor",
              "year": 2013,
              "category": "Wildcard",
              "note": "Ridley Scott/Cormac McCarthy; a pick he'd been saving all draft. Cast includes Cameron Diaz, Bardem, Brad Pitt, Penelope Cruz, Michael Fassbender, Natalie Dormer."
