  "published": "2024-01-16",
  "runtimeMin": 122,
  "format": "The first auction of 2024: Sean, Amanda, and Chris each spend $1,000 on a five-film slate of movies that aren't out yet. New this year: category triggers (two $100M-domestic hits, one film with two Oscar nods, one 85-Metacritic score, and no more than two sequels across the year), plus a recap of how the 2023 slates actually landed. Then Sean talks to Jake Johnson about his solo directing debut, Self-Reliance.",
  "segments": [
    {
      "kind": "auction",
      "heading": "The paddles",
      "note": "each host, five films, $1,000",
      "saleLabel": "First-half sale · 2024",
      "previousSaleLabel": "Last year's 2023 slate",
      "slates": [
        {
          "host": "Amanda Dobbins",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "Blitz",
              "year": 2024,
              "price": 385,
              "note": "Steve McQueen's WWII London film, Saoirse Ronan and Harris Dickinson. Her top lot, the one she'd have cried over losing. The pick she trusts most for Oscars."
            },
            {
              "title": "Twisters",
              "year": 2024,
              "price": 350,
              "note": "Lee Isaac Chung's storm-chaser sequel, Glen Powell and Daisy Edgar-Jones. Her big-box-office bet."
            },
            {
              "title": "Challengers",
              "year": 2024,
              "price": 150,
              "note": "Luca Guadagnino's tennis love triangle, Zendaya, Josh O'Connor, Mike Faist. Her most-anticipated film of the year, back in the pool after Sean released it."
            },
            {
              "title": "MaXXXine",
              "year": 2024,
              "price": 75,
              "note": "Ti West and Mia Goth close out the trilogy, Maxine as an aspiring star in '80s Los Angeles. Nobody else really wanted it."
            },
            {
              "title": "The Bikeriders",
              "year": 2024,
              "price": 40,
              "note": "Jeff Nichols, Austin Butler; delayed out of 2023. Sean couldn't draft it: he'd already seen it."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "spent": 999,
          "budgetLeft": 1,
          "picks": [
            {
              "title": "Furiosa: A Mad Max Saga",
              "year": 2024,
              "price": 375,
              "note": "George Miller's Fury Road prequel, Anya Taylor-Joy and Chris Hemsworth. Won in a long bidding war against Chris, who was trying to run up the price."
            },
            {
              "title": "Megalopolis",
              "year": 2024,
              "price": 345,
              "note": "Coppola's self-financed passion project, Adam Driver. Grabbed the rest of his budget for it 'as a sign of respect' after nearly taking it for $1."
            },
            {
              "title": "Hit Man",
              "year": 2024,
              "price": 275,
              "note": "Carried over from 2023 (original $175 plus the $100 surcharge). Richard Linklater and Glen Powell; headed to Netflix."
            },
            {
              "title": "Mickey 17",
              "year": 2025,
              "price": 3,
              "note": "Bong Joon Ho and Robert Pattinson, then delayed by Warner Bros. Slipped to 2025."
            },
            {
              "title": "Nosferatu",
              "year": 2024,
              "price": 1,
              "note": "Robert Eggers' vampire reimagining, Bill Skarsgård and Lily-Rose Depp. A dollar and out."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "Gladiator II",
              "year": 2024,
              "price": 380,
              "note": "Ridley Scott's sequel, Paul Mescal, Denzel Washington, Pedro Pascal, Connie Nielsen. He 'free-soloed' the bidding and got there."
            },
            {
              "title": "We Live in Time",
              "year": 2024,
              "price": 375,
              "note": "John Crowley (Brooklyn), Andrew Garfield and Florence Pugh. His chance-taking pick, 'the past lives of 2024.'"
            },
            {
              "title": "Dune: Part Two",
              "year": 2024,
              "price": 243,
              "note": "Carried over from 2023. His one likely box-office-and-Oscars two-fer."
            },
            {
              "title": "Speak No Evil",
              "year": 2024,
              "price": 1,
              "note": "James Watkins' remake of the Danish horror film, James McAvoy and Mackenzie Davis. His 'Black Phone zone' flyer."
            },
            {
              "title": "Horizon: An American Saga - Chapter 1",
              "year": 2024,
              "price": 1,
              "note": "Kevin Costner's self-funded Western epic: original, so no sequel penalty. A dollar for the CR faithful."
            }
          ]
        }
