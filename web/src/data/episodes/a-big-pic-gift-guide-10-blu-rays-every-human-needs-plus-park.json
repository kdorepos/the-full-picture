{
  "slug": "a-big-pic-gift-guide-10-blu-rays-every-human-needs-plus-park",
  "title": "A 'Big Pic' Gift Guide: 10 Blu-rays Every Human Needs. Plus: Park Chan-wook!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Tim Simons"
  ],
  "published": "2022-12-09",
  "runtimeMin": 121,
  "format": "Sean Fennessey and 'Veep' actor Tim Simons make the case for physical media: pawn-shop Blu-ray hauls, region-free players, and the boutique labels (Criterion, Arrow, Vinegar Syndrome, Indicator, Eureka) worth collecting. Then each names discs everyone should own. Plus: Park Chan-wook on 'Decision to Leave.'",
  "segments": [
    {
      "kind": "list",
      "heading": "10 Blu-rays every human needs",
      "note": "Sean's and Tim's picks",
      "picks": [
        {
          "title": "Sorcerer",
          "year": 1977,
          "by": "Tim Simons",
          "note": "His guiding rule: buy your favorite movie. Friedkin's remake of 'The Wages of Fear,' with Roy Scheider; on and off Tim's favorite film, and one he had to hunt down a Blu-ray of on Amazon."
        },
        {
          "title": "The Raid",
          "year": 2011,
          "by": "Tim Simons",
          "note": "One he revisits constantly, paired with the sequel."
        },
        {
          "title": "The Raid 2",
          "year": 2014,
          "by": "Tim Simons",
          "note": "Sold separately from the first; blu-ray.com is where he checks region and transfer quality before buying."
        },
        {
          "title": "Rad",
          "year": 1986,
          "by": "Tim Simons",
          "note": "Vinegar Syndrome's 4K of the small-town BMX movie (Lori Loughlin, directed by a stuntman) he watched three times a day for a week home from ear surgery. The gateway to Vinegar Syndrome for him."
        },
        {
          "title": "Cloak & Dagger",
          "year": 1984,
          "by": "Tim Simons",
          "note": "Arrow's release of the Richard Franklin kid-spy thriller (Henry Thomas, Dabney Coleman) about a boy, his dad, and a video-game cartridge hiding spy-plane plans."
        },
        {
          "title": "Warner Bros. Best of 50",
          "by": "Sean Fennessey",
          "note": "Starter box set, around $175 for 50 films: 'Wizard of Oz,' 'Goodfellas,' 'Unforgiven,' '2001,' 'The Shining' and more. Sean's pick for building a library from nothing."
        },
        {
          "title": "Apocalypse Now",
          "year": 1979,
          "by": "Sean Fennessey",
          "note": "The Final Cut 4K: Coppola's latest recut, bundled with the 'Hearts of Darkness' documentary."
        },
        {
          "title": "The Matrix",
          "year": 1999,
          "by": "Sean Fennessey",
          "note": "The first DVD he ever owned, in the fold-out cardboard case. Holds up loud and sharp at home."
        },
        {
          "title": "To Live and Die in L.A.",
          "year": 1985,
          "by": "Tim Simons",
          "note": "Friedkin crime film with no US release; the reason to own a region-free player, via Arrow."
        },
        {
          "title": "Blackhat",
          "year": 2015,
          "by": "Tim Simons",
          "note": "His Michael Mann love object; he owns the theatrical cut and a self-burned copy of the FX director's cut."
        },
        {
          "title": "Thief",
          "year": 1981,
          "by": "Tim Simons",
          "note": "The Criterion, worth it for the Mann interviews alone."
        },
        {
          "title": "Heat",
          "year": 1995,
          "by": "Tim Simons",
          "note": "The other Mann to keep on the shelf."
        },
        {
          "title": "Star Wars",
          "year": 1977,
          "by": "Tim Simons",
          "note": "The fan Despecialized Edition: you track down the files and burn your own Blu-ray, cover included."
        },
        {
          "title": "Malcolm X",
          "year": 1992,
          "by": "Tim Simons",
          "note": "The Criterion 4K, bought from Spike Lee's shop and autographed by Spike for about $50. One buy he doesn't regret."
        },
        {
          "title": "Alfred Hitchcock: The Masterpiece Collection",
          "by": "Sean Fennessey",
          "note": "Around $85 for fourteen Hitchcocks with extras: 'Vertigo,' 'Psycho,' 'Rear Window,' 'The Birds' and on. A whole-filmography starter set."
        },
        {
          "title": "Interstellar",
          "year": 2014,
          "by": "Tim Simons",
          "note": "On the list, in his words, because it bangs."
        },
        {
          "title": "Double Indemnity",
          "year": 1944,
          "by": "Tim Simons",
          "note": "The new Criterion 4K of a movie he returns to; watch it and you realize everything stole from it."
        },
        {
          "title": "Who Framed Roger Rabbit",
          "year": 1988,
          "by": "Tim Simons",
          "note": "A kid entry point that holds up, and smuggles in film-noir tropes for later."
        },
        {
          "title": "Spirited Away",
          "year": 2001,
          "by": "Tim Simons",
          "note": "Part of the Miyazaki-for-kids argument; he grabbed a few Ghibli steelbooks."
        },
        {
          "title": "My Neighbor Totoro",
          "year": 1988,
          "by": "Tim Simons",
          "note": "Via Amazon's exclusive collected-Miyazaki box (about $150). Watching his kids watch it, he says, taught him the movie."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Park Chan-wook on",
      "films": [
        {
          "title": "Decision to Leave",
          "year": 2022,
          "note": "Park set out to make a romance that dialed down the sex and violence his earlier films are known for, so the love story could show through. A detective with insomnia and a murder suspect; a translation app, texting, and a mountain climb built out of match cuts. The idea started from a song called 'Mist' and an image of a man peering into fog for a lover who left."
        },
        {
          "title": "Oldboy",
          "year": 2003,
          "note": "His example of the single large reversal; here he wanted a run of smaller reversals instead."
        },
        {
          "title": "Nightmare Alley",
          "year": 2021,
          "note": "His answer to the show's closing question, the last great thing he saw: Guillermo del Toro's."
        }
      ]
    }
  ],
