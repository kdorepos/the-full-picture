      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Social Network",
              "year": 2010,
              "category": "Drama",
              "note": "the first overall pick; 'the best film of 2010 and of the 2010s.'"
            },
            {
              "title": "Scott Pilgrim vs. the World",
              "year": 2010,
              "category": "Comedy or Horror",
              "note": "filed as comedy; 'subtly operates as five or six other genres.'"
            },
            {
              "title": "Inception",
              "year": 2010,
              "category": "Blockbuster",
              "note": "the known 'Inception hater' takes it anyway: 'I like it just fine.'"
            },
            {
              "title": "Dogtooth",
              "year": 2009,
              "category": "Animated or Foreign Language",
              "note": "Lanthimos's breakout; funny and upsetting at once, 'one of the quarantine movies of our time.'"
            },
            {
              "title": "Exit Through the Gift Shop",
              "year": 2010,
              "category": "Wild Card",
              "note": "Banksy's documentary-form prank; a peak stunt movie for a stunt-movie year."
            },
            {
              "title": "Wall Street: Money Never Sleeps",
              "year": 2010,
              "category": "Sequel",
              "note": "not good, but 'incredibly well-made' Oliver Stone; 'funniest movie title of the decade.'"
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Never Let Me Go",
              "year": 2010,
              "category": "Drama",
              "note": "Romanek's Ishiguro adaptation; Mulligan, Knightley, Garfield. 'It wrecked me.'"
            },
            {
              "title": "Jackass 3D",
              "year": 2010,
              "category": "Comedy or Horror",
              "note": "'one of the all-time greatest experiences I've ever had in a movie theater.'"
            },
            {
              "title": "Shutter Island",
              "year": 2010,
              "category": "Blockbuster",
              "note": "a recency-bias pick after an overnight rewatch, up until 2 a.m., 'absolutely stunning.'"
            },
            {
              "title": "A Prophet",
              "year": 2009,
              "category": "Animated or Foreign Language",
              "note": "Audiard's prison epic; Tahar Rahim. 'One of the best crime films of the decade.'"
            },
            {
              "title": "Monsters",
              "year": 2010,
              "category": "Wild Card",
              "note": "Gareth Edwards's near-solo sci-fi; Scoot McNairy on a road trip through Mexico."
            },
            {
              "title": "Robin Hood",
              "year": 2010,
              "category": "Sequel",
              "note": "a reboot, not a sequel; Ridley Scott's stacked-cast Russell Crowe vehicle: 'is this a good movie? I don't know.'"
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Town",
              "year": 2010,
              "category": "Drama",
              "note": "Affleck's Boston heist, 'this movie rules,' with Renner, and robbing Fenway."
            },
            {
              "title": "Easy A",
              "year": 2010,
              "category": "Comedy or Horror",
              "note": "Emma Stone's breakout; an '80s-literate teen comedy with Tucci and Clarkson as the parents."
            },
            {
              "title": "Toy Story 3",
              "year": 2010,
              "category": "Blockbuster",
              "note": "a spite block so Sean couldn't have it: the 'known animated-movie disliker' takes it anyway."
            },
            {
              "title": "I Am Love",
              "year": 2009,
              "category": "Animated or Foreign Language",
              "note": "Guadagnino; Tilda Swinton. Seen alone at BAM, the score washing over her."
            },
            {
              "title": "Somewhere",
              "year": 2010,
              "category": "Wild Card",
              "note": "Sofia Coppola's Chateau Marmont drift; Stephen Dorff and Elle Fanning."
            },
            {
              "title": "Harry Potter and the Deathly Hallows: Part 1",
              "year": 2010,
              "category": "Sequel",
              "note": "the dark, adult-stakes one; the two-part finale that predicted IP culture."
            }
          ]
