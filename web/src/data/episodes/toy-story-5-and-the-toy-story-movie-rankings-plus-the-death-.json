{
  "slug": "toy-story-5-and-the-toy-story-movie-rankings-plus-the-death-",
  "title": "‘Toy Story 5’ and the ‘Toy Story’ Movie Rankings. Plus: ‘The Death of Robin Hood’ and the Top Five Robin Hoods.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2026-06-19",
  "runtimeMin": 91,
  "format": "Sean Fennessey and Amanda Dobbins open with movie news, review Michael Sarnoski's 'The Death of Robin Hood' and run through the cinematic Robin Hoods, then review Pixar's 'Toy Story 5' and rank all five 'Toy Story' movies.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Movie news",
      "note": "the week's headlines",
      "films": [
        {
          "title": "Artificial",
          "year": 2026,
          "note": "Luca Guadagnino's Social Network-style Sam Altman biopic, with Andrew Garfield as Altman. Amazon MGM is offloading it, seemingly over an OpenAI partnership."
        },
        {
          "title": "After the Hunt",
          "year": 2025,
          "note": "Guadagnino's recent one, cited as the fiasco that soured Amazon on working with him again."
        },
        {
          "title": "The Social Reckoning",
          "year": 2026,
          "note": "Sony's Social Network follow-up, raised as already occupying the same anti-tech lane as Artificial."
        },
        {
          "title": "The Parlay",
          "note": "Daniel Kaluuya reteams with Judas and the Black Messiah director Shaka King on a crime thriller for Amazon MGM; Teyana Taylor circling."
        },
        {
          "title": "Together",
          "year": 2025,
          "note": "Michael Shanks's Alison Brie/Dave Franco horror, name-checked because Shanks is directing Kaluuya's 'Hotel' film next."
        },
        {
          "title": "In Search of Darkness: 1990-1994",
          "year": 2024,
          "note": "The six-hour horror doc Sean is slowly chipping away at."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘The Death of Robin Hood’",
      "note": "the new release",
      "films": [
        {
          "title": "The Death of Robin Hood",
          "year": 2025,
          "note": "Michael Sarnoski directs Hugh Jackman as a dying, regretful Robin Hood, with Jodie Comer, Bill Skarsgård, Murray Bartlett and Noah Jupe. Both hosts were let down: a gnarly, violent first 30 minutes gives way to a long slow downshift, and the film ends up meaning to distrust the myth without ever engaging it. Jackman doing the anguished thing he already did better in Logan and Prisoners."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The cinematic Robin Hoods",
      "note": "the adaptations they ran through",
      "films": [
        {
          "title": "Robin Hood (Fairbanks)",
          "year": 1922,
          "note": "Allan Dwan's silent, with Douglas Fairbanks. Sean watched it on Tubi; he credits it with establishing the cinematic Robin Hood tropes."
        },
        {
          "title": "The Adventures of Robin Hood",
          "year": 1938,
          "note": "Michael Curtiz and Errol Flynn, the Technicolor swashbuckler and Claude Rains's Prince John. Curtiz's last before Casablanca; the version everything downstream riffs on."
        },
        {
          "title": "Robin Hood (Disney)",
          "year": 1973,
          "note": "The animated fox that codified Robin Hood for a couple of moviegoing generations."
        },
        {
          "title": "Robin and Marian",
          "year": 1976,
          "note": "Richard Lester's late-life version with Sean Connery and Audrey Hepburn."
        },
        {
          "title": "Robin Hood (Bergin)",
          "year": 1991,
          "note": "Patrick Bergin's version, released the same year as Prince of Thieves."
        },
        {
          "title": "Robin Hood: Prince of Thieves",
          "year": 1991,
          "note": "Kevin Costner, home of what Sean calls the worst accent in the history of movies, but an entertaining-enough blockbuster."
        },
        {
          "title": "Robin Hood: Men in Tights",
          "year": 1993,
          "note": "Mel Brooks's parody, clearly riffing on Prince of Thieves; the bookend to the 1938-to-1993 stretch that fixed the idea of Robin Hood."
        },
        {
          "title": "Robin Hood (Ridley Scott)",
          "year": 2010,
          "note": "Russell Crowe in Ridley Scott's grim, black-leather take, which Sean pitches as Robin Hood: Gladiator."
        },
        {
          "title": "Robin Hood (Egerton)",
          "year": 2018,
          "note": "Taron Egerton's, which Sean found very unsuccessful."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Toy Story 5’",
      "note": "the new release",
      "films": [
        {
          "title": "Toy Story 5",
          "year": 2026,
          "note": "Andrew Stanton co-writes and directs. Really Jessie's movie: Bonnie, now eight, gets a frog-tablet called LilyPad (Greta Lee) and the toys are sidelined by screens. Sean was moved to tears by its take on kids and friendship; Amanda admired it but flagged the rickety plotting and the craven 'bad tech equals bad people' shortcut, capped by a climax that hinges on an iOS update."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "The ‘Toy Story’ movie rankings",
      "note": "Sean's ranking, best first",
      "subject": "Toy Story",
      "ranked": true,
      "films": [
        {
          "title": "Toy Story",
          "year": 1995,
          "note": "No. 1: the original, and the one that blew everyone away in 1995."
        },
        {
          "title": "Toy Story 3",
          "year": 2010,
          "note": "A masterpiece, and Sean's clear No. 2."
        },
        {
          "title": "Toy Story 2",
          "year": 1999,
          "note": "No. 3: the fan favorite Sean has never quite loved; he keeps getting yelled at about it and admits he needs a rewatch."
        },
        {
          "title": "Toy Story 5",
          "year": 2026,
          "note": "No. 4: the new one moved Sean, and he figures the diehards will be on board; he slots it above 4."
        },
        {
          "title": "Toy Story 4",
          "year": 2019,
          "note": "Last: Sean was high on it in 2019, but on reflection found Duke Caboom and the rest less memorable than he'd thought."
        }
      ]
    }
