{
  "slug": "five-new-films-to-stream-top-gun-maverick-for-best-picture-a",
  "title": "Five New Films to Stream, ‘Top Gun: Maverick’ for Best Picture, and a Summer Movie Mailbag",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Bobby Wagner"
  ],
  "published": "2022-08-02",
  "runtimeMin": 80,
  "format": "A quiet August episode. Sean Fennessey runs down streaming and theatrical picks for a slow movie month, led by Ethan Hawke's Newman/Woodward doc series The Last Movie Stars, then he and producer Bobby Wagner work through a summer listener mailbag.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "New to stream and in theaters",
      "note": "Sean's August recommendations",
      "films": [
        {
          "title": "Not Okay",
          "year": 2022,
          "note": "Hulu satire with Zoey Deutch as a woman who fakes a Paris trip and then poses as a survivor of an attack. Sean files it under a subgenre he calls 'Zillennial panic'; solid, not great."
        },
        {
          "title": "The Sea Beast",
          "year": 2022,
          "note": "Netflix animated feature from Big Hero 6 director Chris Williams; a throwback sea-monster-hunter adventure with a young female lead. Sean recommends it for kids."
        },
        {
          "title": "Marcel the Shell with Shoes On",
          "year": 2022,
          "note": "Dean Fleischer Camp's A24 stop-motion feature, expanded from the Jenny Slate viral shorts; short, sweet, and a possible Best Animated Feature wild card."
        },
        {
          "title": "Fire of Love",
          "year": 2022,
          "note": "Sara Dosa's Nat Geo documentary on volcanologists Katia and Maurice Krafft; Sean calls the footage some of the most beautiful he's seen in years."
        },
        {
          "title": "Resurrection",
          "year": 2022,
          "note": "Andrew Semans thriller with Rebecca Hall and Tim Roth as a menacing figure from her past; unnerving and under-the-skin, in theaters and on VOD."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Summer movie mailbag",
      "note": "with producer Bobby Wagner",
      "films": [
        {
          "title": "Killers of the Flower Moon",
          "year": 2023,
          "note": "The Scorsese/DiCaprio film's move to 2023 (and a Cannes bow) is Sean's most-anticipated delayed title."
        },
        {
          "title": "Mission: Impossible - Dead Reckoning Part One",
          "year": 2023,
          "note": "His other big 2023 casualty from the schedule shuffle."
        },
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "Runs through the episode as the practical-effects counterexample to VFX bloat and a genuine Best Picture contender; Amanda's brand energy, per Sean."
        },
        {
          "title": "Nope",
          "year": 2022,
          "note": "Jordan Peele's satire of the urge to capture everything; Sean and Bobby agree it's funnier and more entertaining than the heady discourse suggests."
        },
        {
          "title": "Predator",
          "year": 1987,
          "note": "Sean's example of a film he rates sincerely, not ironically, for the 'movies we like but won't call good' question, timed to the Prey prequel."
        },
        {
          "title": "Turning Red",
          "year": 2022,
          "note": "His pick for present-day animation that's taken for granted now and may be reappraised as a golden-age work."
        },
        {
          "title": "Halloween",
          "year": 1978,
          "note": "Jamie Lee Curtis's debut; top of Sean's list of first films that would make an actor's hall of fame."
        },
        {
          "title": "Primal Fear",
          "year": 1996,
          "note": "Edward Norton's Oscar-nominated debut on the same list."
        },
        {
          "title": "Citizen Kane",
          "year": 1941,
          "note": "Orson Welles's debut, closing out the hall-of-fame-debuts bit."
        },
        {
          "title": "Mank",
          "year": 2020,
          "note": "The running gag: everything, including Citizen Kane, is 'based on' Mank, the alpha and the omega film."
        },
        {
          "title": "Jackass Forever",
          "year": 2022,
          "note": "Sean's easy answer for funniest film of the year so far, especially in a theater."
        },
        {
          "title": "Oppenheimer",
          "year": 2023,
          "note": "Sean's prepping a 'nuclear panic' episode; watched The Day After Trinity and The Atomic Cafe as homework."
        },
        {
          "title": "The Fabelmans",
          "year": 2022,
          "note": "His guess for a 2022 Movie Draft first pick a decade out: Spielberg's memoiristic 'his Roma.'"
        },
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "The other candidate for a future cult classic, pending what the Daniels do next."
        },
        {
          "title": "Tár",
          "year": 2022,
          "note": "Todd Field/Cate Blanchett dark horse Sean is eyeing at the fall festivals as a possible film of the year."
        },
        {
          "title": "Men",
          "year": 2022,
          "note": "Sean's pick to represent himself; he liked it and regrets talking Chris Ryan out of watching it."
        },
        {
          "title": "The Northman",
          "year": 2022,
          "note": "Also him, per the personality question: furiously outlining while Alexander Skarsgård kills people."
        },
        {
          "title": "Black Panther: Wakanda Forever",
          "year": 2022,
          "note": "Weighed as a blockbuster Best Picture possibility alongside Maverick and Avatar 2."
        },
        {
          "title": "Pulp Fiction",
          "year": 1994,
          "note": "Sean rented a theater for his 40th to watch it; the movie that changed how he thinks about movies."
        },
        {
          "title": "The Third Man",
          "year": 1949,
          "note": "His go-to 'favorite movie' answer for the fluid-favorites question."
        },
        {
          "title": "X",
          "year": 2022,
          "note": "Ti West's horror film, with its already-shooting prequel Pearl, as an example of chasing things while they're fresh."
        },
        {
          "title": "Pearl",
          "year": 2022,
          "note": "The X prequel West revealed on this show; Sean is more excited to champion it than to relitigate old Marvel entries."
        },
        {
          "title": "The Batman",
          "year": 2022,
          "note": "Bobby's answer for putting Mets slugger Pete Alonso in a movie: 'the hero we deserve.'"
        }
      ]
    }
  ],
