{
  "slug": "the-lawyer-movie-draft-with-griffin-newman-and-david-sims-of",
  "title": "The Lawyer Movie Draft With Griffin Newman and David Sims of 'Blank Check'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan",
    "Griffin Newman",
    "David Sims"
  ],
  "published": "2023-10-24",
  "runtimeMin": 135,
  "format": "Sean and Amanda expand a legal-thrillers draft into a full lawyer-movie draft with Blank Check's Griffin Newman and David Sims: a five-way snake draft across six categories for thirty movies, plus a running argument over what actually counts as a lawyer movie.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The Lawyer Movie Draft",
      "draftOf": "lawyer movies",
      "categories": [
        "Drama",
        "Comedy",
        "Thriller",
        "Oscar Winner",
        "Movie Lawyer",
        "John Grisham Adaptation"
      ],
      "teams": [
        {
          "host": "Griffin Newman",
          "picks": [
            {
              "title": "Michael Clayton",
              "year": 2007,
              "category": "Thriller",
              "note": "First overall pick, no hesitation. Tilda Swinton's Oscar-winning turn; Clooney's fixer is his favorite cinematic lawyer even though he never sets foot in a courtroom."
            },
            {
              "title": "Legally Blonde",
              "year": 2001,
              "category": "Comedy",
              "note": "His backup once My Cousin Vinny went off the board. Argues Reese Witherspoon should have gotten an Oscar nomination for it."
            },
            {
              "title": "Philadelphia",
              "year": 1993,
              "category": "Oscar Winner",
              "note": "Denzel Washington and Tom Hanks as opposing lawyers in a discrimination suit. Says the movie has quietly slipped out of the culture since its sweep of Oscar wins."
            },
            {
              "title": "The Rainmaker",
              "year": 1997,
              "category": "John Grisham Adaptation",
              "note": "His true number-one Grisham pick, held back because he figured no one else would fight him for it. Coppola directing, with DeVito, Mickey Rourke, and Claire Danes."
            },
            {
              "title": "Spotlight",
              "year": 2015,
              "category": "Movie Lawyer",
              "note": "Takes Stanley Tucci's Mitchell Garabedian over any lead. World-weary, eating a sandwich on a bench, is his real idea of a lawyer worth hiring."
            },
            {
              "title": "Bridge of Spies",
              "year": 2015,
              "category": "Drama",
              "note": "His last pick. Tom Hanks negotiating a Cold War prisoner swap; Mark Rylance's quiet performance beat Sylvester Stallone's Creed for the Oscar that year."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "A Few Good Men",
              "year": 1992,
              "category": "Movie Lawyer",
              "note": "Drafts Lieutenant Daniel Kaffee rather than the movie itself, to keep the category open for someone else's film. Cruise's cross-examination of Jack Nicholson closes the case."
            },
            {
              "title": "My Cousin Vinny",
              "year": 1992,
              "category": "Comedy",
              "note": "Cites lawyers who've told him it's the most procedurally accurate courtroom movie they've seen, funny as it is."
            },
            {
              "title": "The Social Network",
              "year": 2010,
              "category": "Oscar Winner",
              "note": "Argues it counts as a lawyer movie because the entire structure is deposition and negotiated settlement, even with no courtroom scene."
            },
            {
              "title": "A Time to Kill",
              "year": 1996,
              "category": "John Grisham Adaptation",
              "note": "Last of the four major Grisham adaptations left on the board. Schumacher directing Samuel L. Jackson, Sandra Bullock, and Matthew McConaughey."
            },
            {
              "title": "Fracture",
              "year": 2007,
              "category": "Thriller",
              "note": "Off his own letterboxd list of lawyer movies, sorted by popularity: the highest-ranked one he hadn't seen yet. Anthony Hopkins and Ryan Gosling."
            },
            {
              "title": "Anatomy of a Murder",
              "year": 1959,
              "category": "Drama",
              "note": "Re-drafted here after an earlier attempt to take it as a thriller got contested by the table. Preminger's Jimmy Stewart courtroom drama."
            }
          ]
        },
        {
          "host": "David Sims",
          "picks": [
            {
              "title": "The Firm",
              "year": 1993,
              "category": "John Grisham Adaptation",
              "note": "Admits he'd never seen it before prepping for this draft. Tom Cruise, Gene Hackman, and what he calls the deepest character-actor bench in the genre."
            },
            {
              "title": "The Verdict",
              "year": 1982,
              "category": "Drama",
              "note": "His favorite movie in the whole category. Paul Newman's best performance, and, he argues, the best screen depiction of Boston despite being shot entirely in New York."
            },
            {
              "title": "To Kill a Mockingbird",
              "year": 1962,
              "category": "Movie Lawyer",
              "note": "Takes Gregory Peck's Atticus Finch as the classic movie lawyer, the version before Go Set a Watchman complicated the character."
            },
            {
              "title": "The Devil's Advocate",
              "year": 1997,
              "category": "Thriller",
              "note": "Calls it the best elevator pitch in movie history: a young lawyer's new boss turns out to be Satan. Pacino and Reeves."
            },
            {
              "title": "Intolerable Cruelty",
              "year": 2003,
              "category": "Comedy",
              "note": "One of his favorite, most underrated Coen brothers movies. Clooney and Catherine Zeta-Jones dueling over a prenup."
            },
            {
              "title": "Chicago",
              "year": 2002,
              "category": "Oscar Winner",
              "note": "Takes the musical as the broader lawyer-movie play. Notes director Rob Marshall never made a good movie again after it."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "The Pelican Brief",
              "year": 1993,
              "category": "John Grisham Adaptation",
              "note": "Drafts this exact movie against Amanda for the second time, to her visible frustration. Julia Roberts and Denzel Washington, though he comes to it for Stanley Tucci."
            },
            {
              "title": "Primal Fear",
              "year": 1996,
              "category": "Thriller",
              "note": "A heavy HBO-rotation favorite from childhood. Richard Gere's Martin Vail gets fooled by a fake stutter and a sob story."
            },
            {
              "title": "JFK",
              "year": 1991,
              "category": "Oscar Winner",
              "note": "Takes Kevin Costner's Jim Garrison for the closing argument alone. The summation runs something like forty minutes."
            },
            {
              "title": "Defending Your Life",
              "year": 1991,
              "category": "Comedy",
              "note": "Albert Brooks's afterlife courtroom comedy, with Rip Torn and Lee Grant as opposing counsel. Says Brooks has turned down the podcast six times."
            },
            {
              "title": "In the Name of the Father",
              "year": 1993,
              "category": "Drama",
              "note": "Jim Sheridan's Guildford Four film. Cites the closing courtroom scene, with Emma Thompson and Daniel Day-Lewis, as one of the more cathartic endings in the genre."
            },
            {
              "title": "Inherit the Wind",
              "year": 1960,
              "category": "Movie Lawyer",
              "note": "Spencer Tracy's Scopes-trial stand-in for Clarence Darrow, taken over Orson Welles playing the real Darrow in Compulsion."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Presumed Innocent",
              "year": 1990,
              "category": "Thriller",
              "note": "Pakula directing Harrison Ford at peak stressed-out-early-90s Ford. Says she was actually eyeing Raul Julia's lawyer for the Movie Lawyer category."
            },
            {
              "title": "Erin Brockovich",
              "year": 2000,
              "category": "Oscar Winner",
              "note": "Julia Roberts, Soderbergh directing. Points out it was a box-office hit and an Oscar winner the same year Soderbergh also released Traffic."
            },
            {
              "title": "The Client",
              "year": 1994,
              "category": "John Grisham Adaptation",
              "note": "Hasn't seen it in twenty years but calls it her favorite Grisham behind The Firm. Susan Sarandon, Brad Renfro, peak Joel Schumacher."
            },
            {
              "title": "Marriage Story",
              "year": 2019,
              "category": "Drama",
              "note": "Noah Baumbach's divorce film, picked for Laura Dern's shark of a divorce lawyer, who sets off most of the plot's damage."
            },
            {
              "title": "Miracle on 34th Street",
              "year": 1947,
              "category": "Comedy",
              "note": "The original only. Santa on trial for being Santa; was on The Big Picture's own courtroom-movies list."
            },
            {
              "title": "Adam's Rib",
              "year": 1949,
              "category": "Movie Lawyer",
              "note": "Katharine Hepburn's Amanda Bonner, opposite Spencer Tracy as her husband and opposing counsel in a domestic-violence case."
            }
          ]
        }
      ],
