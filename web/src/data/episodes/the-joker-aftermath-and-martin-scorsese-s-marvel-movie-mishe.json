{
  "slug": "the-joker-aftermath-and-martin-scorsese-s-marvel-movie-mishe",
  "title": "The 'Joker' Aftermath and Martin Scorsese's Marvel Movie Mishegas | The Oscars Show",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2019-10-07",
  "runtimeMin": 102,
  "format": "Sean, Amanda, and Chris Ryan sort through the Joker backlash-to-the-backlash and Martin Scorsese's Marvel comments, run down the Best Actor race, then Sean talks movies and dog ownership with Shea Serrano about his new book.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The 'Joker' Aftermath",
      "note": "Venice win, backlash, a $93.5 million opening",
      "films": [
        {
          "title": "Joker",
          "year": 2019,
          "note": "Won the Golden Lion at Venice, then went through a full backlash-to-the-backlash cycle before opening to $93.5 million, an October record, with no violent incidents at screenings. The panel thinks the first two-thirds are claustrophobic and confused but the last half hour works, and that it's less a comic book movie than a very well-marketed one."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Martin Scorsese vs. Marvel",
      "note": "his Empire magazine comments on comic book movies",
      "films": [
        {
          "title": "The Irishman",
          "year": 2019,
          "note": "Scorsese was on the press trail for this when he told Empire that Marvel movies are 'not cinema,' calling them 'theme parks' rather than films about human beings. James Gunn fired back on Twitter; Samuel L. Jackson shrugged it off. The panel mostly sides with Scorsese while granting Marvel movies their own value."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Pain and Glory",
      "note": "Pedro Almodóvar's autofiction, and the case for Antonio Banderas",
      "films": [
        {
          "title": "Pain and Glory",
          "year": 2019,
          "note": "Almodóvar's roman à clef, with Banderas playing a version of the director. Amanda calls it a quiet, withdrawn physical performance, the opposite of Joaquin Phoenix's, and thinks it could put Banderas in the Best Actor conversation for the first time in a career mostly spent as an American action star."
        },
        {
          "title": "The Laundromat",
          "year": 2019,
          "note": "Steven Soderbergh's Panama Papers movie, also playing in a single L.A. theater that week and headed to Netflix. Sean and Amanda liked it more than the reviews suggested."
        }
      ]
    },
    {
      "kind": "awards",
      "heading": "The Best Actor Race",
      "note": "who's in it, who gets squeezed out",
      "categories": [
