{
  "slug": "the-2025-dumpuary-extravaganza-plus-steven-soderbergh-return",
  "title": "The 2025 Dumpuary Extravaganza. Plus: Steven Soderbergh Returns!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Yasi Salik",
    "Chris Ryan"
  ],
  "published": "2025-01-27",
  "runtimeMin": 133,
  "format": "January's dumped-into-the-landfill releases, section by section. Yasi Salik joins Sean and Amanda on the CGI-chimpanzee Robbie Williams biopic Better Man; Sean and Amanda take the Cameron Diaz and Jamie Foxx Netflix comedy Back in Action; Chris Ryan runs three dumpuary titles: Wolf Man, Flight Risk, Presence; then Steven Soderbergh talks Presence, his 35th feature.",
  "segments": [
    {
      "kind": "review",
      "heading": "Better Man",
      "note": "Yasi Salik, in studio, with Sean and Amanda",
      "films": [
        {
          "title": "Better Man",
          "year": 2024,
          "note": "The Robbie Williams biopic in which Williams is played by a CGI chimpanzee. Michael Gracey (The Greatest Showman) directs on a $110M budget; it made about a million domestic on 1,200 screens. Yasi's most-anticipated dumpuary title. The room splits on whether the monkey conceit carries any feeling, given that Williams barely registers as a star in the US."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Back in Action",
      "note": "Sean and Amanda",
      "films": [
        {
          "title": "Back in Action",
          "year": 2025,
          "note": "Cameron Diaz's first film in 11 years, opposite Jamie Foxx as retired-CIA spies who are also married and get pulled back in. Seth Gordon directs; Glenn Close does a British accent. Sean files it under 'wink action' and 'Walbergalia': weightless wallpaper the stars are too good for. Amanda watched half of it in the bath."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Dumpuary, with Chris Ryan",
      "note": "Sean and Chris Ryan on three January titles",
      "films": [
        {
          "title": "Wolf Man",
          "year": 2025,
          "note": "Leigh Whannell's follow-up to Upgrade and The Invisible Man, from the Universal monster canon. Christopher Abbott turns slowly; Julia Garner plays his wife. Chris can make the case for it as a drama about not screwing up your kids; both agree it isn't scary and the transformation never goes full wolf."
        },
        {
          "title": "Flight Risk",
          "year": 2025,
          "note": "Mel Gibson's first studio film since Hacksaw Ridge. Mark Wahlberg is a hitman posing as the pilot on a four-seater carrying a witness (Topher Grace) and a marshal (Michelle Dockery). Visible AI, a shaved head that reads as a bald cap, threats not in the blacklist script. Bad, and neither of them could look away."
        },
        {
          "title": "Presence",
          "year": 2024,
          "note": "Soderbergh's ghost story shot entirely from the ghost's POV inside one suburban house; written by David Koepp, with Lucy Liu, Chris Sullivan, and Julia Fox. Chris calls it moving and rock-solid: the horror is being a family."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Steven Soderbergh on 'Presence'",
      "guest": "Steven Soderbergh on",
      "films": [
        {
          "title": "Presence",
          "year": 2024,
          "note": "His 35th feature. Soderbergh walks through the Sony a7-on-a-Ronin rig and the rubber-gripped ninja slippers he wore to move silently as the ghost. He also gets into the cut-to-black timing that encodes how much time has passed, and why a theatrical release still makes audiences treat a movie as 'real.' Second of three Koepp scripts, after Kimi and before Black Bag."
        }
      ]
    }
  ],
