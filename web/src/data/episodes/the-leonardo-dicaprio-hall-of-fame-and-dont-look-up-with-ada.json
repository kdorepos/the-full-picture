{
  "slug": "the-leonardo-dicaprio-hall-of-fame-and-dont-look-up-with-ada",
  "title": "The Leonardo DiCaprio Hall of Fame and ‘Don’t Look Up’ With Adam McKay",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2021-12-14",
  "runtimeMin": 91,
  "format": "Sean Fennessey and Amanda Dobbins review Adam McKay's climate satire 'Don't Look Up,' build a 10-film Leonardo DiCaprio hall of fame for his 30th year in movies, then McKay joins to talk about making the film and previews HBO's 'Winning Time.'",
  "segments": [
    {
      "kind": "review",
      "heading": "Don't Look Up",
      "films": [
        {
          "title": "Don't Look Up",
          "year": 2021,
          "note": "Adam McKay's satire about an extinction-level comet, a thin metaphor for the climate crisis. Both hosts think it half-works: funny in the Jonah Hill and Cate Blanchett/Tyler Perry morning-show scenes, closer to docudrama elsewhere. DiCaprio plays Dr. Randall Mindy, an anxious astronomer, against his usual leading-man type, though Amanda notes he still 'gets his network moment.'"
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Leonardo DiCaprio Hall of Fame",
      "note": "his 30th feature film, 30 years into his career: 10 films chosen chronologically from a 30-movie filmography",
      "honoree": "Leonardo DiCaprio",
      "films": [
        {
          "title": "What's Eating Gilbert Grape",
          "year": 1993,
          "note": "His first Oscar nomination, as Arnie, Johnny Depp's developmentally disabled younger brother. In on the strength of the nomination and the performance; neither host has rewatched it since."
        },
        {
          "title": "Romeo + Juliet",
          "year": 1996,
          "note": "Baz Luhrmann's teen-heartthrob breakout. In with no debate. Amanda threatened to quit the podcast if it didn't make the cut, and credits it with priming a teen audience for 'Titanic' the following year."
        },
        {
          "title": "Titanic",
          "year": 1997,
          "note": "Jack Dawson. In, no discussion needed."
        },
        {
          "title": "Catch Me If You Can",
          "year": 2002,
          "note": "Spielberg's con artist Frank Abagnale Jr., one of the last times DiCaprio convincingly plays a teenager before moving into grizzled leading-man roles."
        },
        {
          "title": "The Departed",
          "year": 2006,
          "note": "William Costigan. Called undeniable, no debate: one of his truly great performances."
        },
        {
          "title": "Shutter Island",
          "year": 2010,
          "note": "Sean fights hardest for this one, calling it one of the greatest movies of the last 15 years and one of the most damaged psychological portraits he's seen."
        },
        {
          "title": "Inception",
          "year": 2010,
          "note": "Christopher Nolan's dream-heist blockbuster. In without argument. Solidified him as a box-office draw working with major auteurs."
        },
        {
          "title": "The Wolf of Wall Street",
          "year": 2013,
          "note": "Jordan Belfort. No discussion needed. Sean calls it DiCaprio at the top of his powers."
        },
        {
          "title": "Once Upon a Time in Hollywood",
          "year": 2019,
          "note": "Tarantino's Rick Dalton, and the trailer meltdown scene both hosts expect to headline his eventual Lifetime Achievement reel."
        },
        {
          "title": "Django Unchained",
          "year": 2012,
          "note": "Calvin Candie, one of the more villainous figures on screen in the last 20 years. Wins the last spot over 'The Aviator': he wasn't even Oscar-nominated for it; Christoph Waltz won instead."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Adam McKay on Don't Look Up",
      "guest": "Adam McKay on",
      "films": [
        {
          "title": "Don't Look Up",
          "year": 2021,
          "note": "McKay traces the idea to a comment from journalist David Sirota: 'it's like the comet is coming towards Earth and no one cares.' He rewrote DiCaprio's climate-crisis speech 15 times, and says the comet-mining subplot he invented as satire turned out to already be real: NASA has a program for it."
        }
      ]
    }
  ],
