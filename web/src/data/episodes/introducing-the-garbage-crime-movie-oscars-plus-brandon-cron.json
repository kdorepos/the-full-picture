          "nominees": [
            {
              "title": "Easy Money",
              "year": 2010,
              "person": "Joel Kinnaman",
              "note": "The Snabba Cash trilogy: Kinnaman's on-ramp into the American system, and a nod to the genre's easily translatable international wing."
            }
          ]
        },
        {
          "name": "Best Actress",
          "winner": "Triple 9",
          "nominees": [
            {
              "title": "Triple 9",
              "year": 2016,
              "person": "Kate Winslet",
              "note": "A Russian-Israeli mafioso, Hannibal Lecter meets Michael Corleone. The most gifted person to ever appear in one of these."
            },
            {
              "title": "The Purge: Anarchy",
              "year": 2014,
              "person": "Carmen Ejogo"
            },
            {
              "title": "Mile 22",
              "year": 2018,
              "person": "Lauren Cohan"
            },
            {
              "title": "Sabotage",
              "year": 2014,
              "person": "Mireille Enos",
              "note": "Cast against type as one of the most evil people in any of these movies."
            },
            {
              "title": "Unknown",
              "year": 2011,
              "person": "Diane Kruger & January Jones"
            }
          ]
        },
        {
          "name": "Best Actor",
          "winner": "Brooklyn's Finest",
          "nominees": [
            {
              "title": "Brooklyn's Finest",
              "year": 2009,
              "person": "Ethan Hawke",
              "note": "Where the genre starts. 'I don't want God's forgiveness, I want his help.'"
            },
            {
              "title": "Den of Thieves",
              "year": 2018,
              "person": "Gerard Butler & Pablo Schreiber",
              "note": "Pantheon-level; truly believes."
            },
            {
              "title": "Triple 9",
              "year": 2016,
              "person": "Casey Affleck"
            },
            {
              "title": "Shot Caller",
              "year": 2017,
              "person": "Nikolaj Coster-Waldau",
              "note": "Pivoted out of Game of Thrones into full-blown VOD lord."
            },
            {
              "title": "Non-Stop",
              "year": 2014,
              "person": "Liam Neeson"
            },
            {
              "title": "21 Bridges",
              "year": 2019,
              "person": "Chadwick Boseman",
              "note": "Restrained Charles Bronson cool, the '70s version of a leading man. He'd have made eight more of these."
            }
          ]
        },
        {
          "name": "Lifetime Achievement Award",
          "winner": "Ricochet",
          "nominees": [
            {
              "title": "Ricochet",
              "year": 1991,
              "person": "Denzel Washington",
              "note": "Best at elevating this stuff, and at capping it so it's never too good. Ricochet is the favorite bad one."
            }
          ]
        },
        {
