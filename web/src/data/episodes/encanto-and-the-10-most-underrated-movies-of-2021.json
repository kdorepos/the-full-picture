{
  "slug": "encanto-and-the-10-most-underrated-movies-of-2021",
  "title": "‘Encanto’ and the 10 Most Underrated Movies of 2021",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey"
  ],
  "published": "2021-12-28",
  "runtimeMin": 104,
  "format": "Sean Fennessey closes out 2021 with three guests: Andy Greenwald on ‘Encanto,’ Chris Ryan on ‘Benedetta,’ and Adam Naiman on the year’s most underrated films.",
  "segments": [
    {
      "kind": "interview",
      "heading": "‘Encanto,’ with Andy Greenwald",
      "note": "plus a long detour on parenting and kids’ movies",
      "guest": "Andy Greenwald on",
      "films": [
        {
          "title": "Encanto",
          "year": 2021,
          "note": "The Disney movie Greenwald Twitter-shamed Sean into watching: villainless, princess-less, no special power at the end, and carried by Lin-Manuel Miranda songs he calls dangerously sticky. Praise for Stephanie Beatriz and the film's turn inward where a traditional script would go broad."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "‘Benedetta,’ with Chris Ryan",
      "guest": "Chris Ryan on",
      "films": [
        {
          "title": "Benedetta",
          "year": 2021,
          "note": "Paul Verhoeven's lesbian-nun film, which Ryan snuck away from his mom to watch. More papal politics than the 'sexy nuns' billing suggests; Virginie Efira 'understood the assignment,' with Charlotte Rampling and Lambert Wilson. Verhoeven as a late-career provocateur the culture has moved past being scandalized by."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The 10 Most Underrated Movies of 2021",
      "note": "with Adam Naiman — recommendations, not a ranking",
      "picks": [
        {
          "title": "The Scary of Sixty-First",
          "year": 2021,
          "by": "Adam Naiman",
          "note": "Dasha Nekrasova's lo-fi Epstein-apartment horror. Not sure it's good, but he credits its guts against something like 'Last Night in Soho' — a rare movie about doom-scrolling brain."
        },
        {
          "title": "Agnes",
          "year": 2021,
          "by": "Sean Fennessey",
          "note": "Mickey Reese's low-budget possession film that shifts halfway into something self-reflexive and trauma-poking. Strong turn from Molly Quinn."
        },
        {
          "title": "Procession",
          "year": 2021,
          "by": "Sean Fennessey & Adam Naiman",
          "note": "On both lists. Robert Greene's collaborative documentary in which adult survivors of clergy sexual abuse stage recreations of what happened to them; the artifice deconstructs psychology."
        },
        {
          "title": "Bad Luck Banging or Loony Porn",
          "year": 2021,
          "by": "Adam Naiman",
          "note": "Radu Jude's Romanian comedy: a teacher's sex tape leaks, then a masked pandemic-era school-board tribunal. Structurally unlike anything Sean's seen; Katia Pascariu is brilliant."
        },
        {
          "title": "Anne at 13,000 Ft.",
          "year": 2021,
          "by": "Adam Naiman",
          "note": "Local pick — Kazik Radwanski's Toronto film, drawn from that city's DIY scene. Dara Campbell as a daycare worker in an unstable stretch of her life; the film refuses to name her disorder."
        },
        {
          "title": "The Novice",
          "year": 2021,
          "by": "Sean Fennessey",
          "note": "Lauren Hadaway's Fincherian, sound-driven Whiplash-adjacent debut about a college rower driving herself past reason. Isabelle Fuhrman (the 'Orphan' kid, grown up) at the center."
        },
        {
          "title": "Wife of a Spy",
          "year": 2020,
          "by": "Adam Naiman",
          "note": "Kiyoshi Kurosawa's WWII espionage film, co-written by Ryusuke Hamaguchi. From a horror master, so the revelations land as frightening even though it isn't genre."
        },
        {
          "title": "Woodlands Dark and Days Bewitched: A History of Folk Horror",
          "year": 2021,
          "by": "Sean Fennessey",
          "note": "Kier-La Janisse's three-and-a-half-hour folk-horror documentary. Immersive, hypnotic, and it'll hand you 10 to 500 titles to chase."
        },
        {
          "title": "The Voyeurs",
          "year": 2021,
          "by": "Sean Fennessey",
          "note": "A late-'90s-erotic-thriller homage with Sydney Sweeney. Not a great film, a fun Saturday-night one — a holdover until Adrian Lyne's 'Deep Water' is freed."
        },
        {
          "title": "The Harder They Fall",
          "year": 2021,
          "by": "Sean Fennessey",
          "note": "The film listeners most asked him to cover. Jeymes Samuel's revisionist, 'Avengers-ized' Western with a dynamite young Black cast (Jonathan Majors, Regina King, Delroy Lindo). Stylish maybe to a fault — more construction than ideas."
        },
        {
          "title": "The Inheritance",
          "year": 2021,
          "by": "Sean Fennessey",
          "note": "His near-No. 1. Ephraim Asili's static-shot comedy set in a Black Marxist Philadelphia collective in the shadow of the MOVE bombing — a wry, brilliant archive of Black thought."
        },
        {
          "title": "The Humans",
          "year": 2021,
          "by": "Sean Fennessey",
          "note": "Stephen Karam's adaptation of his own play, dumped straight to Showtime by A24. A holiday-apartment horror of decency dissolving; Richard Jenkins, Amy Schumer, Steven Yeun, and Beanie Feldstein against type."
        },
        {
          "title": "Titane",
          "year": 2021,
          "by": "Sean Fennessey & Adam Naiman",
          "note": "The Palme d'Or winner they close on. Julia Ducournau after 'Raw,' but trying to be so many things it flies apart — Adam finds it more pinboard than movie."
        }
      ]
    }
  ],
