    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Shea Serrano on",
      "note": "his new book, 'Movies and Other Things'",
      "films": [
        {
          "title": "John Wick",
          "year": 2014,
          "note": "One of three tough-guys-and-their-dogs movies in the book's opening chapter."
        },
        {
          "title": "The Drop",
          "year": 2014,
          "note": "Tom Hardy's Bob Saginowski and his dog Rocco, the second leg of that chapter."
        },
        {
          "title": "I Am Legend",
          "year": 2007,
          "note": "Will Smith's Robert Neville rounds out the trio."
        },
        {
          "title": "Selena",
          "year": 1997,
          "note": "The chapter Serrano says was locked in from day one and never at risk of being cut, unlike six or seven others."
        },
        {
          "title": "Booksmart",
          "year": 2019,
          "note": "Added after the book was already turned in: he watched it on vacation, emailed his editor that night, and turned in the chapter with art two days later."
        },
        {
          "title": "Get Out",
          "year": 2017,
          "note": "His bar for a movie showing up and grabbing everyone's attention."
        },
        {
          "title": "Us",
          "year": 2019,
          "note": "Not as good as Get Out, still fun to pick apart."
        },
        {
          "title": "Mean Girls",
          "year": 2004,
          "note": "The Regina George cafeteria-table chapter, his personal favorite in the book."
        },
        {
          "title": "Clueless",
          "year": 1995,
          "note": "Brittany Murphy's character gets a seat at that table."
        },
        {
          "title": "Boyz n the Hood",
          "year": 1991,
          "note": "Cuba Gooding Jr.'s character also gets a seat."
        },
        {
          "title": "American Graffiti",
          "year": 1973,
          "note": "Richard Dreyfuss's character makes the cut too."
        },
        {
          "title": "Dazed and Confused",
          "year": 1993,
          "note": "Randall 'Pink' Floyd is Serrano's first pick for the table."
        },
        {
          "title": "John Wick: Chapter 3 - Parabellum",
          "year": 2019,
          "note": "One of his two best movies of the year, alongside Booksmart."
        },
        {
          "title": "Hustlers",
          "year": 2019,
          "note": "He likes the phone-interrogation joke and thinks Jennifer Lopez deserves the Oscar attention Selena never got her."
        },
        {
          "title": "Rambo: Last Blood",
          "year": 2019,
          "note": "His verdict: don't go see it."
        },
        {
          "title": "First Blood",
          "year": 1982,
          "note": "Still great, unlike Last Blood."
        },
        {
          "title": "The Farewell",
          "year": 2019,
          "note": "He hadn't caught it yet and wasn't sure it had played San Antonio."
        },
        {
          "title": "Hobbs & Shaw",
          "year": 2019,
          "note": "Fun, but he doesn't count it as a real Fast and Furious movie without Dom in it."
        },
        {
          "title": "Furious 7",
          "year": 2015,
          "note": "Calls it a genre masterpiece and the high bar the franchise has struggled to clear since."
        },
        {
          "title": "The Fate of the Furious",
          "year": 2017,
          "note": "Fine overall, though he could've done without the scene where Charlize Theron's character shoots a mother in front of her baby."
        }
      ]
    }
