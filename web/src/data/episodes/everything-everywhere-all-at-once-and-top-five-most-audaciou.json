{
  "slug": "everything-everywhere-all-at-once-and-top-five-most-audaciou",
  "title": "‘Everything Everywhere All at Once’ and Top Five Most Audacious Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Adam Nayman",
    "Joanna Robinson"
  ],
  "published": "2022-04-14",
  "runtimeMin": 84,
  "format": "The Daniels' multiverse maximalist gets the two-viewing treatment, then Sean, Adam, and Joanna each count down five movies that had no business getting greenlit.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Everything Everywhere All at Once’",
      "note": "the Daniels' multiverse movie",
      "films": [
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "Adam likens its overextension to the Coens' Hudsucker Proxy: talented guys doing everything at once. Joanna reads it the other way, a big loud movie anchored by a human story. Michelle Yeoh, Ke Huy Quan's comeback, Stephanie Hsu, Jamie Lee Curtis, James Hong. The trio circles nihilism, the everything bagel, and whether a movie can be sentimental and sincere at the same time."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Adam Nayman's Five",
      "note": "most audacious movies",
      "subject": "Most audacious movies",
      "ranked": true,
      "films": [
        {
          "title": "Zardoz",
          "year": 1974,
          "note": "No. 1 - John Boorman's insane follie: a flying stone head, Sean Connery in red briefs, a culture founded on a misreading of The Wizard of Oz. Ben Wheatley's favorite film."
        },
        {
          "title": "Repo Man",
          "year": 1984,
          "note": "No. 2 - Alex Cox's deadpan LA sci-fi. 'Let's get sushi and not pay.' A Chris Ryan favorite."
        },
        {
          "title": "Being John Malkovich",
          "year": 1999,
          "note": "No. 3 - Adam prizes how minimalist Spike Jonze keeps it: camera in the middle distance, letting the crazy idea sit as the most reasonable thing possible."
        },
        {
          "title": "Crank",
          "year": 2006,
          "note": "No. 4 - Neveldine/Taylor's B-movie carnage as video game; the apotheosis of Jason Statham. The sequel is too much of a good thing."
        },
        {
          "title": "Detention",
          "year": 2011,
          "note": "No. 5 - Joseph Kahn's horror-satire mashup, self-financed for $10 million to make a movie nobody was going to like."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Joanna Robinson's Five",
      "note": "most audacious movies",
      "subject": "Most audacious movies",
      "ranked": true,
      "films": [
        {
          "title": "Brazil",
          "year": 1985,
          "note": "No. 1 - Terry Gilliam's analog-clutter dystopia; the basic-but-canonical pick she felt someone had to make."
        },
        {
          "title": "Sorry to Bother You",
          "year": 2018,
          "note": "No. 2 - Boots Riley's anti-capitalist swing, anchored by Lakeith Stanfield; maybe the wrong side of messy, but she loves the feeling that anything could happen."
        },
        {
          "title": "The Science of Sleep",
          "year": 2006,
          "note": "No. 3 - Michel Gondry's loose, out-of-control follow-up to Eternal Sunshine, forgiven its frustrating protagonist thanks to Gael García Bernal. Bumped up from her No. 2."
        },
        {
          "title": "The Adventures of Buckaroo Banzai Across the 8th Dimension",
          "year": 1984,
          "note": "No. 4 - W.D. Richter's sci-fi vibe machine, a Pauline Kael favorite she used to beat up on Star Wars."
        },
        {
          "title": "Kung Fu Hustle",
          "year": 2004,
          "note": "No. 5 - Stephen Chow's 'Looney Tune cinema'; the most confident, polished film in his run. Bumped Tarsem's The Fall."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Five",
      "note": "most audacious movies",
      "subject": "Most audacious movies",
      "ranked": true,
      "films": [
        {
          "title": "2001: A Space Odyssey",
          "year": 1968,
          "note": "No. 1 - the boring-but-necessary pick; foretold the whole CGI industry with almost none of it, and half of its genius was lucky accidents. Overtly referenced in Everything Everywhere."
        },
        {
          "title": "Playtime",
          "year": 1967,
          "note": "No. 2 - Jacques Tati spent $3.5 million of his own money to build Tativille; a beautiful, intoxicating capitalist critique."
        },
        {
          "title": "Eternal Sunshine of the Spotless Mind",
          "year": 2004,
          "note": "No. 3 - the 'heart' to Adam's 'head' (Malkovich) and Joanna's 'head and heart' (Science of Sleep); a movie he calls near-perfect."
        },
        {
          "title": "Annihilation",
          "year": 2018,
          "note": "No. 4 - Alex Garland taking an already-weird novel and making it weirder; the last 25 minutes made Sean wonder how they let him do it."
        },
        {
          "title": "Mother!",
          "year": 2017,
          "note": "No. 5 - Aronofsky knowingly fucking with everyone, biblical allegory with Jennifer Lawrence; one of only ~14 F CinemaScores ever."
        }
      ]
    }
  ],
