{
  "slug": "lightyear-and-five-signs-of-the-streaming-movie-apocalypse",
  "title": "‘Lightyear’ and Five Signs of the Streaming Movie Apocalypse",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2022-06-21",
  "runtimeMin": 80,
  "format": "Sean and Amanda review the lone new movie in theaters, then work through a week's worth of films dumped to streaming and what it says about the business.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Lightyear’",
      "note": "in theaters",
      "films": [
        {
          "title": "Lightyear",
          "year": 2022,
          "note": "The Chris Evans-voiced origin story of the movie Andy loved, not the toy. Sean rates it C-tier Pixar: a boy-centric, time-travel plot too complex and too scary for the four-year-olds it's aimed at. Opened to $51M against a projected $70M. Sox the robot cat rated fun."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Five Signs of the Streaming Movie Apocalypse",
      "note": "a week of films that skipped theaters",
      "films": [
        {
          "title": "Cha Cha Real Smooth",
          "year": 2022,
          "note": "On Apple TV+. Cooper Raiff's follow-up to Shithouse; Apple paid $15M at Sundance. Dakota Johnson as a divorced New Jersey mom. 'Sundance Mad Libs': the Raiff character charms, everyone around him is undercooked. Manohla Dargis used it in the Times to indict indie cinema."
        },
        {
          "title": "Father of the Bride",
          "year": 2022,
          "note": "On HBO Max, directed by Gary Alazraki. A Cuban-Mexican remake with Andy Garcia and Gloria Estefan as parents heading for divorce. Amanda will watch every version; both agree the divorce subplot and Chloe Fineman's influencer wedding planner keep it from being funny."
        },
        {
          "title": "Good Luck to You, Leo Grande",
          "year": 2022,
          "note": "On Hulu via Searchlight. Emma Thompson as a widow who hires a young sex worker (Daryl McCormack). A two-hander chamber piece, very COVID. Thompson is very good; the ideas get stated rather than argued. A rules change makes her Oscar-ineligible."
        },
        {
          "title": "Fire Island",
          "year": 2022,
          "note": "On Hulu. Andrew Ahn directs, Joel Kim Booster writes and stars: a Pride and Prejudice transposed one-for-one onto gay Fire Island. Amanda's favorite of the batch; Sean was taken with Conrad Ricamora as the Darcy. 'A modern spin on an old story,' like Clueless."
        },
        {
          "title": "Mad God",
          "year": 2022,
          "note": "On Shudder. Phil Tippett (Star Wars, RoboCop, Jurassic Park) animated it largely alone across 30-plus years. Stop-motion, not for kids: 'Coraline gone to hell.' Sean's pick of the week; explicitly not for Amanda."
        },
        {
          "title": "Jerry and Marge Go Large",
          "year": 2022,
          "note": "On Paramount+, directed by David Frankel. Bryan Cranston and Annette Bening as retirees working a lottery loophole. Pleasant, forgettable: Sean's example of two geniuses shelved into 'the cupboard of content.'"
        },
        {
          "title": "Halftime",
          "year": 2022,
          "note": "On Netflix. The Jennifer Lopez documentary tracking the Hustlers awards run and Super Bowl prep. A-Rod and Ben Affleck almost entirely excised. Both are riveted by the Golden Globe-loss scene, a rare document of how badly a star wants the award she was denied."
        }
      ]
    }
  ],
