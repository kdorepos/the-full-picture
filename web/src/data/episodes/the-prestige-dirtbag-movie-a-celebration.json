    {
      "kind": "discussion",
      "heading": "The Prestige Dirtbag Movie: A Celebration",
      "note": "coined via the card counter, traced back to the mid-'70s",
      "films": [
        {
          "title": "Midnight Cowboy",
          "year": 1969,
          "note": "Ratso Rizzo, an early ancestor of the type."
        },
        {
          "title": "Dog Day Afternoon",
          "year": 1975,
          "note": "Sonny, the other mid-'70s ancestor."
        },
        {
          "title": "Heat",
          "year": 1995,
          "note": "The genre's core text; Neil McCauley's \"I am alone, I am not lonely\" is the thesis statement."
        },
        {
          "title": "Killing Them Softly",
          "year": 2012,
          "note": "Brad Pitt is the prestige dirtbag; Ben Mendelsohn is the ruling example of the messier cousin, the prestige scumbag."
        },
        {
          "title": "Drive",
          "year": 2011,
          "note": "The viewer gets preferred seating into Driver's head that Carey Mulligan's character never does."
        },
        {
          "title": "The Gambler",
          "year": 2014
        },
        {
          "title": "The Counselor",
          "year": 2013
        },
        {
          "title": "Donnie Brasco",
          "year": 1997,
          "note": "The reference case for the prestige scumbag, the dirtbag's grubbier cousin."
        },
        {
          "title": "25th Hour",
          "year": 2002,
          "note": "Cited as the template for the one-last-day-before-the-fall structure."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Malignant",
