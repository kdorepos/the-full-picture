            {
              "title": "The Warriors",
              "year": 1979,
              "category": "Action / Horror / Thriller",
              "note": "The long ride home to Coney Island, forced to wait on the train."
            },
            {
              "title": "Dog Day Afternoon",
              "year": 1975,
              "category": "Oscar Winner",
              "note": "Lumet; the city as a character. Won Best Original Screenplay."
            },
            {
              "title": "When Harry Met Sally...",
              "year": 1989,
              "category": "Blockbuster",
              "note": "Ephron; shot by Barry Sonnenfeld, full of locations no one could get today."
            },
            {
              "title": "Spider-Man 2",
