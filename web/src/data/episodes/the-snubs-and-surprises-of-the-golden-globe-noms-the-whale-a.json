    {
      "kind": "discussion",
      "heading": "Emancipation and the End of Will Smith's Comeback Tour",
      "note": "Will Smith's first project since the Oscars slap, and his Globes shutout",
      "films": [
        {
          "title": "Emancipation",
          "year": 2022,
          "note": "Will Smith as a man named Peter who flees a Louisiana plantation, loosely based on the real Gordon and the photographs of his scarred back. Antoine Fuqua directing a prestige swing; the panel calls it visceral and sludgy, a two-and-a-half-star movie carried by an alligator fight and a battlefield sequence."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "The Whale",
      "note": "Darren Aronofsky's adaptation of Samuel D. Hunter's play",
      "films": [
        {
          "title": "The Whale",
          "year": 2022,
          "note": "Brendan Fraser as a reclusive, obese English teacher reconnecting with his daughter near the end of his life. The panel splits: strong on Fraser's performance, cool on the film itself, calling out the Ahab/Moby-Dick allegory as a mismatch for a story about confinement."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Brendan Fraser Hall of Fame",
      "note": "with guest Zach Barron, who profiled Fraser for GQ",
      "honoree": "Brendan Fraser",
      "films": [
        {
          "title": "Encino Man",
          "year": 1992,
          "note": "The debut. Sold on Pauly Shore's fame, not Fraser's. Went in without an argument."
        },
        {
          "title": "School Ties",
          "year": 1992,
          "note": "Fraser as a Jewish student facing antisemitism at a 1950s prep school, alongside Matt Damon, Chris O'Donnell, and Ben Affleck."
        },
        {
          "title": "Airheads",
          "year": 1994,
          "note": "Fraser, Steve Buscemi, and Adam Sandler as a rock band taking a radio station hostage. A childhood rewatch favorite for the whole panel."
        },
        {
          "title": "The Scout",
          "year": 1994,
          "note": "Fraser as Steve Nebraska, a phenom scouted for the Yankees, in an Albert Brooks/Andrew Bergman script. Beat out With Honors for the last open slot."
        },
        {
          "title": "George of the Jungle",
          "year": 1997,
          "note": "The live-action cartoon template that defines two decades of his screen persona: shirtless and bewildered, forever bumping into things."
        },
        {
          "title": "Gods and Monsters",
          "year": 1998,
          "note": "Fraser opposite Ian McKellen's James Whale. Proof he could do the dramatic register, even if the film itself doesn't fully land."
        },
        {
          "title": "Blast from the Past",
          "year": 1999,
          "note": "Basically Encino Man again, with Fraser hiding in a bomb shelter since the Cuban Missile Crisis instead of emerging from a cave."
        },
        {
          "title": "The Mummy",
          "year": 1999,
          "note": "The one that endures. A swashbuckling precursor to the modern Marvel formula, minus the sound-stage sheen, shot on location in Morocco."
        },
        {
          "title": "Bedazzled",
          "year": 2000,
          "note": "The wish-fulfillment remake with Elizabeth Hurley. A late, contested add. The panel calls it their nostalgia pick."
        },
        {
          "title": "The Whale",
          "year": 2022,
          "note": "Twenty-two years later, back in on the strength of an Oscar-caliber comeback performance."
        }
      ]
    }
  ],
