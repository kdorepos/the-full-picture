{
  "slug": "the-horror-movie-draft",
  "title": "The Horror Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan",
    "Alex Ross Perry"
  ],
  "published": "2022-10-14",
  "runtimeMin": 127,
  "format": "A three-way horror snake draft for Halloween season: Sean and Chris Ryan bring in six-time returning champion Alex Ross Perry to fill six categories, Amanda watching from the sidelines with veto power on Twitter.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Before the draft",
      "note": "childhood scares, and what even counts as horror",
      "films": [
        {
          "title": "Arachnophobia",
          "year": 1990,
          "note": "Alex's first scary movie, watched at a friend's house at six; he hid behind the couch and slept with a trash can by his bed for years after."
        },
        {
          "title": "Shocker",
          "year": 1989,
          "note": "Chris snuck into it at 12; rewatched it recently and found Wes Craven's psychic-killer movie 'hysterical,' Pete Berg and Timothy Leary and all."
        },
        {
          "title": "Candyman",
          "year": 1992,
          "note": "Sean's gateway, seen on cable, tangled up with the schoolyard mirror-chant myth before he understood it was any good."
        },
        {
          "title": "Gremlins",
          "year": 1984,
          "note": "Amanda's benchmark for how far she'll go with a horror movie: turn it off once Gizmo's dry and it's just a Christmas movie about a family and a pet."
        },
        {
          "title": "The Omen",
          "year": 1976,
          "note": "Amanda can handle the stately ambassador setup but checks out once the gross-out kills start; the group can't agree on whether it's the nanny or the priest who gets impaled."
        },
        {
          "title": "Alien",
          "year": 1979,
          "note": "The episode's longest-running argument: Alex says it's not a horror movie because Amanda's seen and liked it, Sean insists it belongs given the tagline alone."
        },
        {
          "title": "Predator",
          "year": 1987,
          "note": "Floated as horror-adjacent to Alien and waved off as an action movie."
        },
        {
          "title": "The Silence of the Lambs",
          "year": 1991,
          "note": "Debated as both a sequel (to Manhunter) and a horror movie; the table lands on neither, which is why nobody drafts it."
        },
        {
          "title": "Se7en",
          "year": 1995,
          "note": "Cited alongside Silence of the Lambs as a thriller that borrows horror's tonality without qualifying as one."
        },
        {
          "title": "Barbarian",
          "year": 2022,
          "note": "Amanda's crash course in the genre via the guys walking her through it scene by scene."
        },
        {
          "title": "Speak No Evil",
          "year": 2022,
          "note": "Amanda was hooked by the Airbnb-vacation-friends setup until the plot description turned dark."
        },
        {
          "title": "The Strangers",
          "year": 2008,
          "note": "Chris's masked-strangers-on-the-porch classic; Amanda now pictures it every time she hears something outside at night."
        },
        {
          "title": "Pearl",
          "year": 2022,
          "note": "Named with Barbarian as evidence horror's had an unusually healthy run the last six weeks."
        },
        {
          "title": "The Night House",
          "year": 2020,
          "note": "Alex's pick for one of the best horror movies of the 2020s so far."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "horror movies",
      "categories": [
        "Slasher",
        "Sequel",
        "Blockbuster",
        "Classical Era",
        "Foreign Language or British",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "The Texas Chain Saw Massacre",
              "year": 1974,
              "category": "Slasher",
              "note": "First overall pick. Chris first saw it at 1 a.m. in a beat-up group house in Boston and stayed up all night afterward; still 'the apex of horror' to him."
            },
            {
              "title": "Scream 2",
              "year": 1997,
              "category": "Sequel",
              "note": "Picked for variety over a movie he'd rate higher; likes the meta college-set sequel talk and Timothy Olyphant's masquerading villain."
            },
            {
              "title": "The Blair Witch Project",
              "year": 1999,
              "category": "Blockbuster",
              "note": "His favorite theater experience ever, from a sold-out Ritz East show at 15; rewatched last year with a group of 12-to-14-year-olds who got fully swept up."
            },
            {
              "title": "Night of the Living Dead",
              "year": 1968,
              "category": "Classical Era",
              "note": "A Philly rep-house and midnight-movie staple growing up; taken over his real favorite, Dawn of the Dead, already spent in Sequel."
            },
            {
              "title": "[Rec]",
              "year": 2007,
              "category": "Foreign Language or British",
              "note": "The Spanish found-footage outbreak movie he and his wife have rewatched three times and chased through every sequel; the late blackout stretch is the highlight."
            },
            {
              "title": "The Thing",
              "year": 1982,
              "category": "Wildcard",
              "note": "Argued it's a monster movie, not sci-fi ('it wouldn't rent in sci-fi'); one of four films he'd locked into Wildcard along with Hellraiser, The Shining, and The Fly."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Halloween",
              "year": 1978,
              "category": "Slasher",
              "note": "Sat at No. 1 on his list; John Carpenter's original, taken with visible relief that it survived to his pick."
            },
            {
              "title": "Evil Dead II",
              "year": 1987,
              "category": "Sequel",
              "note": "Argued it splits the atom on horror comedy, being a horror movie and a comedy at once rather than one dressed as the other; Amanda calls it not her thing."
            },
            {
              "title": "The Exorcist",
              "year": 1973,
              "category": "Blockbuster",
              "note": "The genre's highest-grossing film and one of the most frenzied moviegoing events in American history; Sean keeps a Pazuzu statue in his backyard."
            },
            {
              "title": "Rosemary's Baby",
              "year": 1968,
              "category": "Classical Era",
              "note": "Made $33.4 million unadjusted, short of the $75 million Blockbuster line, which is why it fell to him here."
            },
            {
              "title": "Deep Red",
              "year": 1975,
              "category": "Foreign Language or British",
              "note": "Dario Argento's Profondo Rosso, the movie that opened Sean up to horror past Scream and Blair Witch, via a VHS-collecting older friend named Ben."
            },
            {
              "title": "The Shining",
              "year": 1980,
              "category": "Wildcard",
              "note": "Doesn't fit Slasher, Blockbuster (it underperformed for a Kubrick/Nicholson film), Classical, or Foreign, so Wildcard is the only place it could go."
            }
          ]
        },
        {
          "host": "Alex Ross Perry",
          "picks": [
            {
              "title": "Psycho",
              "year": 1960,
              "category": "Slasher",
              "note": "His No. 2 pick overall after losing Texas Chain Saw; first saw it as a kid at Philadelphia's Prince Theatre, driven in by his dad, going in blind."
            },
            {
              "title": "Dawn of the Dead",
              "year": 1978,
              "category": "Sequel",
              "note": "Romero's zombie-mall movie, his No. 1 in the category over Day of the Dead, which he says he actually prefers on any given day."
            },
            {
              "title": "The Amityville Horror",
              "year": 1979,
              "category": "Blockbuster",
              "note": "Alex grew up 25-30 minutes from the real house; calls the original underrated and the Italian-made sequel, Amityville II: The Possession, nearly as good."
            },
            {
              "title": "Freaks",
              "year": 1932,
              "category": "Classical Era",
              "note": "Tod Browning's carnival film, intermittently banned for decades; Alex noticed its Toy Story homage while sitting in a doctor's office with his daughter."
            },
            {
              "title": "28 Days Later",
              "year": 2002,
              "category": "Foreign Language or British",
              "note": "Danny Boyle's rage-virus movie, a huge hit in the UK; made $85.7 million worldwide, just clearing the Blockbuster line no one thought it hit."
            },
            {
              "title": "Hellraiser",
              "year": 1987,
              "category": "Wildcard",
              "note": "Clive Barker's S&M-inflected demon movie; one of four films (with The Thing, The Shining, and The Fly) Alex felt couldn't fit anywhere else."
            }
          ]
        }
      ],
