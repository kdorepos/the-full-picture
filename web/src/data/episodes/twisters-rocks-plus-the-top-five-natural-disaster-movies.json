{
  "slug": "twisters-rocks-plus-the-top-five-natural-disaster-movies",
  "title": "‘Twisters’ Rocks! Plus, the Top Five Natural Disaster Movies.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2024-07-19",
  "runtimeMin": 72,
  "format": "Sean and Amanda review 'Twisters,' the movie of the summer as far as they're concerned, then each rank their top five natural disaster movies. The original 'Twister' is disqualified for kicking off the whole genre.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Twisters’",
      "note": "the movie of the summer",
      "films": [
        {
          "title": "Twisters",
          "year": 2024,
          "note": "Lee Isaac Chung's back-to-basics sequel, which both hosts call the movie of the summer. Daisy Edgar-Jones as a New York meteorologist pulled back to Oklahoma, Glen Powell as a cowboy-hatted YouTube 'tornado wrangler.' Diaper-polymer science, a rodeo evacuation, and a climax where a tornado tears the screen out of a movie theater."
        },
        {
          "title": "Twister",
          "year": 1996,
          "note": "The Jan de Bont original, back in rotation on Max and the Rewatchables. Sean thought it was a letdown in 1996 and rates the sequel higher; the Dorothy sensor pod carries over. Disqualified from the top five for starting the whole cycle."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five Natural Disaster Movies",
      "note": "revealed No. 5 up to No. 1",
      "subject": "natural disaster movies",
      "ranked": true,
      "films": [
        {
          "title": "The Birds",
          "year": 1963,
          "note": "No. 1. Hitchcock's birds-turn-on-humanity nightmare; the lack of any explanation is what makes it play like an uncontrollable weather event."
        },
        {
          "title": "Children of Men",
          "year": 2006,
          "note": "No. 2. Cuarón's global-infertility ensemble, which Sean argues is a '70s-style disaster movie wearing prestige clothes."
        },
        {
          "title": "Deep Impact",
          "year": 1998,
          "note": "No. 3. Mimi Leder's more emotional asteroid movie, picked over Armageddon after a late-night hotel-cable rewatch left him in tears."
        },
        {
          "title": "Only the Brave",
          "year": 2017,
          "note": "No. 4. Joseph Kosinski's hotshot-firefighter drama with Josh Brolin and Miles Teller, based on a true story. Sean rules that walking into the disaster on purpose doesn't disqualify it."
        },
        {
          "title": "The Poseidon Adventure",
          "year": 1972,
          "note": "No. 5. His nod to the Irwin Allen '70s cycle; an undersea earthquake and tsunami capsize the liner, so it qualifies."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top Five Natural Disaster Movies",
      "note": "revealed No. 5 up to No. 1",
      "subject": "natural disaster movies",
      "ranked": true,
      "films": [
        {
          "title": "Melancholia",
          "year": 2011,
          "note": "No. 1. Lars von Trier's end of the world by planet, not meteor, where no one even tries to stop it. Kirsten Dunst."
        },
        {
          "title": "Armageddon",
          "year": 1998,
          "note": "No. 2. Bay's oil-riggers-turned-astronauts; Amanda cried harder at 14 than at any movie before or since."
        },
        {
          "title": "Force Majeure",
          "year": 2014,
          "note": "No. 3. Östlund's avalanche-at-a-ski-resort marriage autopsy, which she notes is meaner than the American remake."
        },
        {
          "title": "The Perfect Storm",
          "year": 2000,
          "note": "No. 4. Petersen's Gloucester fishing-boat disaster; rewatched the morning of taping, in honor of Chris Ryan and George Clooney's John Deere hat."
        },
        {
          "title": "Dante's Peak",
          "year": 1997,
          "note": "No. 5. The Pierce Brosnan and Linda Hamilton volcano B-movie. Not good, she admits, but the best volcano she could come up with."
        }
      ]
    }
  ],
