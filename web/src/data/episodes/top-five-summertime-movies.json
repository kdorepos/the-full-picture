{
  "slug": "top-five-summertime-movies",
  "title": "Top Five Summertime Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2020-07-17",
  "runtimeMin": 77,
  "format": "With the real summer movie season canceled and Tenet in limbo, Sean Fennessey, Amanda Dobbins, and Chris Ryan invent their own, each counting down five movies that capture the feeling of summer, then somehow all agreeing on the same No. 2.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "No Tenet, no Summer of Nolan",
      "note": "before the lists",
      "films": [
        {
          "title": "Tenet",
          "year": 2020,
          "note": "Word breaks mid-taping that it won't open August 12 after all. The three debate why Christopher Nolan and Warner Bros. wouldn't just push it a year rather than tie its whole identity to reopened theaters."
        },
        {
          "title": "Inception",
          "year": 2010,
          "note": "Its 10th anniversary landed during the shutdown; Chris admits he missed the Rewatchables tribute."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top Five Summertime Movies",
      "note": "best to worst",
      "subject": "summertime movies",
      "ranked": true,
      "films": [
        {
          "title": "Adventureland",
          "year": 2009,
          "note": "No. 1. Chris's most personal pick: Jesse Eisenberg killing a post-college summer at a Pittsburgh amusement park. He pairs it with Dazed and Confused as a coming-of-age touchstone and calls the soundtrack one of the best ever assembled."
        },
        {
          "title": "Do the Right Thing",
          "year": 1989,
          "note": "No. 2, and the one unanimous pick of the whole episode: all three hosts had it in the same spot."
        },
        {
          "title": "Die Hard with a Vengeance",
          "year": 1995,
          "note": "No. 3. Chris's all-in-one-day, all-in-one-hangover New York movie. He notes it started life as an unrelated script called Simon Says before being reworked into the Die Hard franchise, and singles out Samuel L. Jackson's chemistry with Bruce Willis."
        },
        {
          "title": "Bull Durham",
          "year": 1988,
          "note": "No. 4. Chris grew up with baseball as his summer's organizing principle; he calls the romance between Susan Sarandon and Kevin Costner the ultimate summer romance."
        },
        {
          "title": "Rear Window",
          "year": 1954,
          "note": "No. 5. Chris admits it's arguably a top-30-all-time film rather than merely a top-five summer one. James Stewart's heatwave-bound voyeurism hit differently after months of quarantine nosiness about his own neighbors."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda Dobbins's Top Five Summertime Movies",
      "note": "best to worst",
      "subject": "summertime movies",
      "ranked": true,
      "films": [
        {
          "title": "Dirty Dancing",
          "year": 1987,
          "note": "No. 1. A Catskills resort, Jennifer Grey's Baby coming into her own, and Patrick Swayze as, in Amanda's telling, most of her sex education."
        },
        {
          "title": "Do the Right Thing",
          "year": 1989,
          "note": "No. 2, unanimous across all three lists. Amanda calls it the ultimate New York summer movie: you can feel the heat and the tempers rising in real time."
        },
        {
          "title": "Something's Gotta Give",
          "year": 2003,
          "note": "No. 3. Nancy Meyers's Hamptons beach house, with Diane Keaton and Jack Nicholson (and Keanu Reeves) making the case for summer romance well past your twenties."
        },
        {
          "title": "Call Me by Your Name",
          "year": 2017,
          "note": "No. 4. Luca Guadagnino's Italy, all lazy pool afternoons and long bike rides. It's a summer love story that ends bittersweet rather than happy."
        },
        {
          "title": "Now and Then",
          "year": 1995,
          "note": "No. 5. Amanda's \"Stand By Me, but for girls\": four women recall the childhood summer of 1970 that made them friends."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top Five Summertime Movies",
      "note": "best to worst",
      "subject": "summertime movies",
      "ranked": true,
      "films": [
        {
          "title": "Jaws",
          "year": 1975,
          "note": "No. 1, which Sean calls \"really a collective number one.\" Amity's need for summer dollars, he argues, is the template the summer blockbuster never left."
        },
        {
          "title": "Do the Right Thing",
          "year": 1989,
          "note": "No. 2, unanimous. Sean credits cinematographer Ernest Dickerson with making Brooklyn's heat visible on screen, down to the red paint on the walls."
        },
        {
          "title": "Summer School",
          "year": 1987,
          "note": "No. 3. Carl Reiner's Mark Harmon comedy ran on cable constantly during Sean's childhood; he calls it the stand-in for a whole genre of '80s summer comedies."
        },
        {
          "title": "Risky Business",
          "year": 1983,
          "note": "No. 4. Paul Brickman's Reagan-era satire, with Tom Cruise at peak charm. Sean argues it's more subtle and artful than its sunglasses-and-Bob-Seger reputation suggests."
        },
        {
          "title": "Big Wednesday",
          "year": 1978,
          "note": "No. 5. Sean's \"pointy-headed\" pick: John Milius's tribute to surfing friendship, made by the same movie-brat generation as Scorsese and Spielberg."
        }
      ]
    }
  ],
