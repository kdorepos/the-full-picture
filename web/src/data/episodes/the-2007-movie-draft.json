  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan draft 2007 across six categories (Oscar Winner, Drama, Comedy or Horror, Sequel, Blockbuster, and Wildcard), from There Will Be Blood to Ratatouille.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The 2007 Movie Draft",
      "draftOf": "2007 movies",
      "categories": [
        "Oscar Winner",
        "Drama",
        "Comedy or Horror",
        "Sequel",
        "Blockbuster",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "There Will Be Blood",
              "year": 2007,
              "category": "Oscar Winner",
              "note": "Sean's favorite movie of the 21st century and the only 2007 movie he rewatched before the draft. Paul Thomas Anderson's Daniel Plainview story, scored by Jonny Greenwood."
            },
            {
              "title": "Zodiac",
              "year": 2007,
              "category": "Drama",
              "note": "Sean calls it the second-best movie of the year, David Fincher's meticulous docudrama about the hunt for the Zodiac Killer. He grabbed it after Chris took Superbad instead of it."
            },
            {
              "title": "Hot Fuzz",
              "year": 2007,
              "category": "Comedy or Horror",
              "note": "Sean's pick, the second-to-last of Edgar Wright's Cornetto trilogy with Simon Pegg and Nick Frost, spoofing Lethal Weapon-style buddy-cop movies."
            },
            {
              "title": "28 Weeks Later",
              "year": 2007,
              "category": "Sequel",
              "note": "After stalling between this and Elizabeth: The Golden Age, Sean took the 28 Days Later sequel, calling it a pretty good follow-up to a movie that didn't need one."
            },
            {
              "title": "Transformers",
              "year": 2007,
              "category": "Blockbuster",
              "note": "Sean covered the premiere for Vibe Magazine in 2007 and calls it the last Michael Bay movie he genuinely liked until 6 Underground."
            },
            {
              "title": "Death Proof",
              "year": 2007,
              "category": "Wildcard",
              "note": "Tarantino's standalone half of Grindhouse. Sean saw it opening night with a hardcore Tarantino crowd and calls it slept-on."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Michael Clayton",
              "year": 2007,
              "category": "Oscar Winner",
              "note": "Amanda's number-one movie of the year and her first overall pick. Tilda Swinton won best supporting actress for it."
            },
            {
              "title": "Gone Baby Gone",
              "year": 2007,
              "category": "Drama",
              "note": "Ben Affleck's directorial debut, adapted from Dennis Lehane's novel."
            },
            {
              "title": "Knocked Up",
              "year": 2007,
              "category": "Comedy or Horror",
              "note": "Amanda calls it a genuine phenomenon at the time, with mixed feelings now about how its comedy and politics have aged. She says she'd have felt silly taking Walk Hard while this was still on the board."
            },
            {
              "title": "Ocean's Thirteen",
              "year": 2007,
              "category": "Sequel",
              "note": "Amanda's actual favorite sequel of all time is Ocean's Twelve, but she took Thirteen here."
            },
            {
              "title": "Ratatouille",
              "year": 2007,
              "category": "Blockbuster",
              "note": "Amanda calls it a strategic act of aggression aimed at Sean; she'd watched it again the day before taping."
            },
            {
              "title": "I'm Not There",
              "year": 2007,
              "category": "Wildcard",
              "note": "Todd Haynes's fractured Bob Dylan biopic, with different actors playing different facets of Dylan."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "No Country for Old Men",
              "year": 2007,
              "category": "Oscar Winner",
              "note": "Adapted from Cormac McCarthy's novel, the year's Best Picture winner, with Javier Bardem's supporting-actor win. On rewatch, Chris singles out Tommy Lee Jones."
            },
            {
              "title": "The Assassination of Jesse James by the Coward Robert Ford",
              "year": 2007,
              "category": "Drama",
              "note": "Chris's pick, a movie with a famously troubled production that became a cult favorite, shot by Roger Deakins."
            },
            {
              "title": "Walk Hard: The Dewey Cox Story",
              "year": 2007,
              "category": "Comedy or Horror",
              "note": "Chris still loves the Judd Apatow/Jake Kasdan music-biopic spoof, which he notes has become the more cult-adored pick next to Knocked Up."
            },
            {
              "title": "The Bourne Ultimatum",
              "year": 2007,
              "category": "Sequel",
              "note": "Chris calls it his third-favorite Bourne movie but still a strong pick from the original trilogy."
            },
            {
              "title": "Superbad",
              "year": 2007,
              "category": "Blockbuster",
              "note": "Chris's strategic pick in a weak blockbuster year, crediting Seth Rogen, Evan Goldberg, and Michael Cera."
            },
            {
              "title": "Sunshine",
              "year": 2007,
              "category": "Wildcard",
              "note": "Danny Boyle's sci-fi movie with Cillian Murphy, Rose Byrne, and Chris Evans. Chris saw it in a nearly empty ArcLight theater alongside Drew Barrymore."
            }
          ]
        }
      ],
