{
  "slug": "the-harrison-ford-hall-of-fame",
  "title": "The Harrison Ford Hall of Fame",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2023-06-27",
  "runtimeMin": 114,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan build a 10-film Harrison Ford Hall of Fame on the eve of 'Indiana Jones and the Dial of Destiny,' running his filmography chronologically in green, yellow, and red.",
  "segments": [
    {
      "kind": "halloffame",
      "heading": "The Harrison Ford Hall of Fame",
      "note": "chosen chronologically, green/yellow/red, across his full filmography",
      "honoree": "Harrison Ford",
      "films": [
        {
          "title": "American Graffiti",
          "year": 1973,
          "note": "His breakthrough as Bob Falfa, a smug young drag racer George Lucas shoots close and lit while his more prominent costars sit in shadow. Yellowed on the first pass, then traded back in for the final 10 over 'Last Crusade' as, in Chris's words, the first big-ticket movie he appears in."
        },
        {
          "title": "Star Wars",
          "year": 1977,
          "note": "Han Solo, directed by George Lucas. Automatic green. Nobody even had to argue for it. Amanda's own yearbook quote comes from this movie."
        },
        {
          "title": "The Empire Strikes Back",
          "year": 1980,
          "note": "Automatic green, largely on the strength of the carbonite-freezing scene and its 'I love you' / 'I know.'"
        },
        {
          "title": "Raiders of the Lost Ark",
          "year": 1981,
          "note": "Automatic green, no discussion needed."
        },
        {
          "title": "Blade Runner",
          "year": 1982,
          "note": "Automatic green. Sean: regardless of which cut you watch, 'he is just still fucking Humphrey Bogart in this movie and it works.' Chris connects the film's LA to his own decision to move there."
        },
        {
          "title": "Witness",
          "year": 1985,
          "note": "Peter Weir's Amish-country thriller, and Ford's only Oscar nomination. The barn-raising scene, and Ford's genuine joy hammering nails, gets singled out as one of his best physical performances."
        },
        {
          "title": "Working Girl",
          "year": 1988,
          "note": "Mike Nichols's comedy, with Ford as Jack Trainer, a supporting player to Melanie Griffith and Sigourney Weaver. Amanda's favorite movie on the list; initially yellowed, then swapped in for the final 10 over 'Last Crusade.'"
        },
        {
          "title": "Presumed Innocent",
          "year": 1990,
          "note": "Alan Pakula's adaptation of Scott Turow's legal thriller, with Raul Julia, Bonnie Bedelia, and Brian Dennehy. Greenlit as the announcement of the suits-and-lawyers phase of his career; made $220 million and finished 12th at the 1990 box office."
        },
        {
          "title": "The Fugitive",
          "year": 1993,
          "note": "Called 'the chartreuse,' the greenest green of the bunch. Dr. Richard Kimball. Amanda's own introduction to Harrison Ford as a kid."
        },
        {
          "title": "Clear and Present Danger",
          "year": 1994,
          "note": "Jack Ryan again, this time preferred over 'Patriot Games.' Greenlit without much debate."
        }
      ]
    }
  ],
