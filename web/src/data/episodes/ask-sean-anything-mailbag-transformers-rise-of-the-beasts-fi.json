      "heading": "‘Transformers: Rise of the Beasts’",
      "note": "Amanda sat this one out",
      "films": [
        {
          "title": "Transformers: Rise of the Beasts",
          "year": 2023,
          "note": "The seventh live-action Transformers, directed by Steven Caple Jr., set in 1994 New York. For 40 minutes it plays as a '90s hip-hop movie before turning into a proper robot war with the Maximals; Sean loved it and can't fully explain why."
        },
        {
          "title": "Bumblebee",
          "year": 2018,
          "note": "The 1987-set predecessor this is a sequel to; a John Hughes-style coming-of-age take with Hailee Steinfeld."
        },
        {
          "title": "Juice",
          "year": 1992,
          "note": "One of the '90s New York movies Rise of the Beasts is a sanitized homage to."
        },
        {
          "title": "New Jack City",
          "year": 1991
        },
        {
          "title": "King of New York",
          "year": 1990
        },
        {
          "title": "Clockers",
          "year": 1995
        },
        {
          "title": "Above the Rim",
          "year": 1994,
          "note": "Sean begged his mom to see Tupac in it at 13."
        },
        {
          "title": "Poetic Justice",
          "year": 1993,
          "note": "A John Singleton poster hangs in Noah's room."
        },
        {
          "title": "Fast X",
          "year": 2023,
          "note": "The comparison everyone in the mailbag drew; Sean found it ham-fisted and badly made, unlike this."
        }
      ]
    },
    {
