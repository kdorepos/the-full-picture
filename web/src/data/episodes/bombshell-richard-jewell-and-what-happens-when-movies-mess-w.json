{
  "slug": "bombshell-richard-jewell-and-what-happens-when-movies-mess-w",
  "title": "'Bombshell,' 'Richard Jewell,' and What Happens When Movies Mess With the Media | The Oscar Show",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2019-12-17",
  "runtimeMin": 101,
  "format": "Sean and Amanda, joined by the Ringer's Bryan Curtis, on two films that reenact real journalists, 'Bombshell' and 'Richard Jewell', and the liberties each takes. Then the Oscar shortlists, the Best Director gender gap, and Sean's interview with 'Bombshell' director Jay Roach.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "When the media meets the movies",
      "note": "with Bryan Curtis of The Press Box",
      "films": [
        {
          "title": "Richard Jewell",
          "year": 2019,
          "note": "Clint Eastwood's account of the security guard wrongly suspected in the 1996 Centennial Park bombing. The panel's objection is the reporter Kathy Scruggs, played by Olivia Wilde as trading sex with an FBI agent for the tip: a real, non-famous, and dead journalist depicted that way with no source. Paul Walter Hauser as Jewell and Kathy Bates as his mother draw the praise."
        },
        {
          "title": "Bombshell",
          "year": 2019,
          "note": "Jay Roach's Fox News film, written by 'Big Short' co-writer Charles Randolph. Charlize Theron's Megyn Kelly, Nicole Kidman's Gretchen Carlson, and Margot Robbie's composite producer against John Lithgow's Roger Ailes. Amanda's hesitation: it makes Kelly the hero of a story that isn't hers."
        },
        {
          "title": "Spotlight",
          "year": 2015,
          "note": "Cited as the version where a media movie works out well."
        },
        {
          "title": "All the President's Men",
          "year": 1976,
          "note": "The other benchmark for journalism done right on screen."
        },
        {
          "title": "Shattered Glass",
          "year": 2003,
          "note": "Written and directed by Billy Ray, who also wrote 'Richard Jewell' (one of the more realistic films about the business, which the hosts find ironic)."
        },
        {
          "title": "American Sniper",
          "year": 2014,
          "note": "Eastwood's true-story hit; the comp for a conservative audience that 'Richard Jewell' never found."
        },
        {
          "title": "The 15:17 to Paris",
          "year": 2018
        },
        {
          "title": "Sully",
          "year": 2016
        },
        {
          "title": "The Mule",
          "year": 2018,
          "note": "Eastwood's take on a Sam Dolnick New York Times story, part of his run of lone-figure-versus-the-machine films."
        },
        {
          "title": "Vice",
          "year": 2018,
          "note": "Bryan's fear going in: that you can't see past the actors playing people you know. Bombshell is the awards-season comp."
        },
        {
          "title": "Dick",
          "year": 1999,
          "note": "Named by accident while reaching for 'Vice.'"
        },
        {
          "title": "The Big Short",
          "year": 2015,
          "note": "Randolph co-wrote it; Bombshell shares its many-narrators, near-satirical approach."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Hark: movies need better names",
      "note": "Amanda argues for movie SEO",
      "films": [
        {
          "title": "The Lion King",
          "year": 2019,
          "note": "Held up as a title that already is the keyword."
        },
        {
          "title": "Doctor Sleep",
          "year": 2019,
          "note": "Should have leaned on its predecessor's name, per Amanda."
        },
        {
          "title": "The Shining",
          "year": 1980
        },
        {
          "title": "Motherless Brooklyn",
          "year": 2019,
          "note": "'No one knows what that is': the pitch is a Robert Moses angle or 'a mystery, and Edward Norton's in it.'"
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock up, stock down",
      "films": [
        {
          "title": "Uncut Gems",
          "year": 2019,
          "note": "Broke A24's opening per-screen record: $105,000 on five screens in two and a half days."
        },
        {
          "title": "A Hidden Life",
          "year": 2019,
          "note": "Bombed; a Malick film that didn't work for either host, and why they haven't covered it."
        },
        {
          "title": "The Tree of Life",
          "year": 2011,
          "note": "Sean's favorite Malick, a return he's planning before year's end."
        }
      ]
    },
