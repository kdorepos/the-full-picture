    },
    {
      "kind": "review",
      "heading": "'28 Years Later: The Bone Temple'",
      "note": "gut-ripping and gut-wrenching",
      "films": [
        {
          "title": "28 Years Later: The Bone Temple",
          "year": 2026,
          "note": "Nia DaCosta takes over from Danny Boyle on Alex Garland's script, with cinematographer Sean Bobbitt. Spike (Alfie Williams) is inducted into Jimmy Crystal's (Jack O'Connell) cult of acrobatic killers while Dr. Kelson (Ralph Fiennes) treats the alpha Samson with morphine and starts hunting a cure. A pure-horror, funny-games-gnarly installment; the coda brings back Cillian Murphy's Jim. Chris almost loved it as much as the first."
        },
        {
          "title": "28 Years Later",
          "year": 2025,
          "note": "Boyle and Garland's franchise reboot, Chris's No. 1 of 2025 and the direct setup for this film."
        },
        {
          "title": "28 Days Later",
          "year": 2002,
          "note": "The 2002 original; the Bone Temple coda echoes its long-lens final shot and its score."
        },
        {
          "title": "Candyman",
          "year": 2021,
          "note": "DaCosta's horror reboot, cited as why she handles this film's genre mechanics so fluently."
        },
        {
          "title": "Hedda",
          "year": 2025,
          "note": "DaCosta's 'Hedda Gabler' reimagining, on Prime; the hosts point to its anyone-can-die-at-any-moment charge as a shared strength."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Ralph Fiennes Hall of Fame",
      "note": "an ad-hoc induction, ten deep",
      "honoree": "Ralph Fiennes",
      "films": [
        {
          "title": "Schindler's List",
          "year": 1993,
          "note": "The breakthrough, as Amon Goeth. A stone-cold lock to open the list."
        },
        {
          "title": "The English Patient",
          "year": 1996,
          "note": "Another automatic pick."
        },
        {
          "title": "Harry Potter and the Deathly Hallows: Part 2",
          "year": 2011,
          "note": "Voldemort's final confrontation; the Potter entry they settled on."
        },
        {
          "title": "The Grand Budapest Hotel",
          "year": 2014,
          "note": "Wes Anderson's M. Gustave, a lock."
        },
        {
          "title": "Conclave",
          "year": 2024,
          "note": "He elevates it; a part that could have gone flat and didn't."
        },
        {
          "title": "A Bigger Splash",
          "year": 2015,
          "note": "The dancing scene alone; a Big Picture-world favorite."
        },
        {
          "title": "28 Years Later: The Bone Temple",
