    {
      "kind": "draft",
      "heading": "The 2009 Movie Draft",
      "draftOf": "2009 movies",
      "note": "snake draft, six categories, draft order set by a scrabble-tile pull: Amanda, Chris, Sean",
      "categories": [
        "Drama",
        "Comedy",
        "Oscar Nominee",
        "Action Horror Thriller",
        "Blockbuster ($100M+)",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "An Education",
              "year": 2009,
              "category": "Drama",
              "note": "Lone Scherfig's coming-of-age drama, adapted by Nick Hornby. Carey Mulligan's breakout as a teenager courted by an older man (Peter Sarsgaard); Amanda singles out Rosamund Pike's underrated comic turn as the ditzy girlfriend."
            },
            {
              "title": "In the Loop",
              "year": 2009,
              "category": "Comedy",
              "note": "Armando Iannucci's Thick of It spinoff. Amanda says it's the hardest she's ever laughed at a movie. Jamie MacDonald's (Paul Higgins) introduction is the scene she wants replayed on the pod."
            },
            {
              "title": "Inglourious Basterds",
              "year": 2009,
              "category": "Oscar Nominee",
              "note": "Tarantino's WWII revenge fantasy, her favorite of his films. It's the pick she wanted most, and the No. 1 overall slot let her get it."
            },
            {
              "title": "State of Play",
              "year": 2009,
              "category": "Action Horror Thriller",
              "note": "Kevin Macdonald's newsroom thriller with Russell Crowe, Rachel McAdams, Ben Affleck, and Helen Mirren, adapted from the BBC miniseries. A late pick in a category she hadn't prepped for; made $90 million domestic."
            },
            {
              "title": "It's Complicated",
              "year": 2009,
              "category": "Blockbuster ($100M+)",
              "note": "Nancy Meyers' divorced-parents comedy with Meryl Streep, Alec Baldwin, and Steve Martin. Her favorite Meyers movie, not the best one, mostly for the Santa Barbara kitchen. Made $110 million."
            },
            {
              "title": "I Am Love",
              "year": 2009,
              "category": "Wildcard",
              "note": "Luca Guadagnino's Tilda Swinton drama, first in his loose Italian trilogy. A pick for her father, who calls it one of his favorite films of the year."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Adventureland",
              "year": 2009,
              "category": "Drama",
              "note": "The movie he's rewatched most this year outside of Basterds. Jesse Eisenberg and Kristen Stewart, plus a great Ryan Reynolds turn."
            },
            {
              "title": "The Hangover",
              "year": 2009,
              "category": "Comedy",
              "note": "Todd Phillips' Vegas comedy; Chris admits it isn't as rewarding a rewatch as it was a theatrical experience, and singles out the closing-credits photo montage."
            },
            {
              "title": "The Hurt Locker",
              "year": 2009,
              "category": "Oscar Nominee",
              "note": "Kathryn Bigelow's Iraq bomb-squad thriller, his target pick from the start. Jeremy Renner and Anthony Mackie; the Ralph Fiennes sequence gets a specific shoutout."
            },
            {
              "title": "Zombieland",
              "year": 2009,
              "category": "Action Horror Thriller",
              "note": "Ruben Fleischer's Woody Harrelson/Jesse Eisenberg horror-comedy, written by that week's guests Rhett Reese and Paul Wernick."
            },
            {
              "title": "Up",
              "year": 2009,
              "category": "Blockbuster ($100M+)",
              "note": "A surprise pick from someone who opened the episode claiming he'd blacked out most of 2009. He insists he cried in a theater during the opening montage; the other two don't fully buy it."
            },
            {
              "title": "A Perfect Getaway",
              "year": 2009,
              "category": "Wildcard",
              "note": "David Twohy's Hawaii thriller with Steve Zahn, Timothy Olyphant, Milla Jovovich, and an early Chris Hemsworth."
            }
          ]
        },
        {
          "host": "Sean Fennessy",
          "picks": [
            {
              "title": "A Serious Man",
              "year": 2009,
              "category": "Drama",
              "note": "The Coens' Job riff, Sean's favorite of their filmography, earmarked before the draft even started."
            },
            {
              "title": "The Informant!",
              "year": 2009,
              "category": "Comedy",
              "note": "Soderbergh's second movie of 2009 (with The Girlfriend Experience). A very funny Matt Damon performance as a lying ADM whistleblower, cast heavy with stand-up comedians."
            },
            {
              "title": "Fantastic Mr. Fox",
              "year": 2009,
              "category": "Oscar Nominee",
              "note": "Wes Anderson's stop-motion Dahl adaptation, voiced by George Clooney and Meryl Streep. Sean says a rewatch alongside The French Dispatch made him like it even more."
            },
            {
              "title": "Avatar",
              "year": 2009,
              "category": "Action Horror Thriller",
              "note": "His first pick overall. Cameron's motion-capture blockbuster dominated the year's box-office conversation the way Titanic did in '97. He saw it on the Lincoln Square IMAX."
            },
            {
              "title": "Taken",
              "year": 2009,
              "category": "Blockbuster ($100M+)",
              "note": "Liam Neeson's action reinvention. Sean jokes it created a market inefficiency in Eastern European travel."
            },
            {
              "title": "Ponyo",
              "year": 2009,
              "category": "Wildcard",
              "note": "Miyazaki's underwater riff on The Little Mermaid, watched this weekend with his daughter Alice."
            }
          ]
        }
      ],
