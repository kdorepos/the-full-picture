            {
              "title": "The Bridge on the River Kwai",
              "year": 1957,
              "category": "1950s",
              "note": "David Lean's first Best Picture win."
            },
            {
              "title": "The Sting",
              "year": 1973,
              "category": "1970s",
              "note": "A 'cuck pick' over The Deer Hunter, the one he's rewatched most."
            },
            {
              "title": "Unforgiven",
              "year": 1992,
              "category": "1990s",
              "note": "His second-favorite winner, after Silence of the Lambs."
            },
            {
              "title": "Argo",
              "year": 2012,
              "category": "2010s",
              "note": "Took it too early and got roasted; likes it more than Spotlight."
            },
            {
              "title": "Goodfellas",
              "year": 1990,
