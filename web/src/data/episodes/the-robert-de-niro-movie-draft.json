{
  "slug": "the-robert-de-niro-movie-draft",
  "title": "The Robert De Niro Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-05-23",
  "runtimeMin": 107,
  "format": "Sean Fennessey and Amanda Dobbins bring in Chris Ryan for a snake draft of Robert De Niro's career, six categories deep, timed to All About My Father and De Niro turning 80 this year.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The Robert De Niro Draft",
      "note": "snake draft, six categories",
      "draftOf": "Robert De Niro's filmography",
      "categories": [
        "Drama",
        "Comedy",
        "Action/Horror/Thriller",
        "Supporting Role",
        "Oscar Nominee",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Goodfellas",
              "year": 1990,
              "category": "Drama",
              "note": "First overall pick. She'd told her brother Zach beforehand that Goodfellas would be her pick if she got first; his response was 'what do you know about Goodfellas?'"
            },
            {
              "title": "The Intern",
              "year": 2015,
              "category": "Comedy",
              "note": "Directed by Nancy Meyers. De Niro as a retired widower interning at Anne Hathaway's startup; sets off a long tangent about the plot mid-draft."
            },
            {
              "title": "Midnight Run",
              "year": 1988,
              "category": "Action/Horror/Thriller",
              "note": "Taken from under Chris Ryan, who wanted it and objects that it's a comedy, not action. Amanda credits Charles Grodin as much as De Niro."
            },
            {
              "title": "The Untouchables",
              "year": 1987,
              "category": "Supporting Role",
              "note": "De Niro as Al Capone, including the baseball-bat scene. Also the first De Niro movie Chris Ryan ever saw."
            },
            {
              "title": "The Irishman",
              "year": 2019,
              "category": "Oscar Nominee",
              "note": "A sentimental, personal pick. Amanda and Sean were both at the premiere, seated across the theater from each other."
            },
            {
              "title": "Analyze This",
              "year": 1999,
              "category": "Wildcard",
              "note": "Possibly the first De Niro movie Amanda ever saw, thanks to her aunt Betty's impression of him."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "The Deer Hunter",
              "year": 1978,
              "category": "Drama",
              "note": "One of five movies CR says will 'live forever.' Also the movie Amanda's dad had at No. 1 and No. 2 on his own De Niro top five, prepared for the episode."
            },
            {
              "title": "Jackie Brown",
              "year": 1997,
              "category": "Comedy",
              "note": "As Louis Gara, just out of prison and pulling a heist with his old partner Ordell. CR calls it a performance that plays into De Niro's taciturn public image."
            },
            {
              "title": "Cape Fear",
              "year": 1991,
              "category": "Action/Horror/Thriller",
              "note": "Picked over Limitless; CR says the De Niro performance here outweighs the other film."
            },
            {
              "title": "Cop Land",
              "year": 1997,
              "category": "Supporting Role",
              "note": "Picked over Backdraft. De Niro and Harvey Keitel share a diner scene."
            },
            {
              "title": "Taxi Driver",
              "year": 1976,
              "category": "Oscar Nominee",
              "note": "CR calls it maybe the pick he'd have made first overall if categories didn't exist."
            },
            {
              "title": "Casino",
              "year": 1995,
              "category": "Wildcard",
              "note": "The Rewatchables episode about this movie is the one where Bill Simmons forgot to plug in CR's microphone."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Raging Bull",
              "year": 1980,
              "category": "Drama",
              "note": "The Oscar-winning performance Sean calls the signal, post-Brando lesson in great acting for actors of his generation."
            },
            {
              "title": "The King of Comedy",
              "year": 1982,
              "category": "Comedy",
              "note": "One of Sean's five favorite Scorsese movies. He calls it maybe the cleverest movie of the 1980s about fame."
            },
            {
              "title": "Heat",
              "year": 1995,
              "category": "Action/Horror/Thriller",
              "note": "Taken over Chris Ryan's objections, which he holds a grudge about for the rest of the episode."
            },
            {
              "title": "Mean Streets",
              "year": 1973,
              "category": "Supporting Role",
              "note": "De Niro's breakthrough as Johnny Boy in Scorsese's directorial debut, and the pick Sean calls the one that changed the trajectory of American movies."
            },
            {
              "title": "The Godfather Part II",
              "year": 1974,
              "category": "Oscar Nominee",
              "note": "One of two picks Sean makes back to back. Calls it one of the greatest films of all time."
            },
            {
              "title": "Once Upon a Time in America",
              "year": 1984,
              "category": "Wildcard",
              "note": "Sergio Leone's final film. Sean saw a rough cut of it in 1984 at Anthology Film Archives, with John Cage playing a live score."
            }
          ]
        }
      ],
