  "runtimeMin": 80,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan draft the best comedies of the 1980s across six categories, after a quick verdict on the new Confess Fletch.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Confess Fletch",
      "note": "in theaters and on VOD this weekend",
      "films": [
        {
          "title": "Confess Fletch",
          "year": 2022,
          "note": "Jon Hamm as a sardonic, un-Chevy-Chase-like Fletch, directed by Greg Mottola; a faithful adaptation of the novels that both hosts went in low on and came out liking."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "1980s comedies",
      "categories": [
        "Teen Comedy",
        "Rom-Com",
        "Oscar Nominee",
        "Action / Horror / Sci-Fi Comedy",
        "Blockbuster",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Heathers",
              "year": 1989,
              "category": "Teen Comedy",
              "note": "an obsessive artifact of his school years; Winona Ryder and Christian Slater in a black comedy about bullying."
            },
            {
              "title": "Say Anything",
              "year": 1989,
              "category": "Rom-Com",
              "note": "the movie he says was his gateway to discovering music."
            },
            {
              "title": "Broadcast News",
              "year": 1987,
              "category": "Oscar Nominee",
              "note": "the first overall pick; James L. Brooks with William Hurt, Holly Hunter, and Albert Brooks."
            },
            {
              "title": "Midnight Run",
              "year": 1988,
              "category": "Action / Horror / Sci-Fi Comedy",
              "note": "his most-quoted movie ('surf and turf'); De Niro and Grodin, with Philip Baker Hall and Dennis Farina in support."
            },
            {
              "title": "Trading Places",
              "year": 1983,
              "category": "Blockbuster",
              "note": "his favorite Eddie Murphy comedy; Aykroyd and Murphy, set in Philadelphia."
            },
            {
              "title": "Fletch",
              "year": 1985,
              "category": "Wild Card",
              "note": "left on the board until the final pick; Chevy Chase at his most quotable."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Breakfast Club",
              "year": 1985,
              "category": "Teen Comedy",
              "note": "the archetypal John Hughes movie, shown to her in a high school English class."
            },
            {
              "title": "Working Girl",
              "year": 1988,
              "category": "Rom-Com",
              "note": "Mike Nichols; Melanie Griffith and Sigourney Weaver, plus the Carly Simon theme."
            },
            {
              "title": "Moonstruck",
              "year": 1987,
              "category": "Oscar Nominee",
              "note": "her mother's favorite movie to show her, after Goodfellas; Cher and Nicolas Cage."
            },
            {
              "title": "The Princess Bride",
              "year": 1987,
              "category": "Action / Horror / Sci-Fi Comedy",
              "note": "Rob Reiner; Cary Elwes and Mandy Patinkin, watched a thousand times."
            },
            {
              "title": "When Harry Met Sally",
              "year": 1989,
              "category": "Blockbuster",
              "note": "her most important romantic comedy of the last 40 years; Nora Ephron sets the template for the genre."
            },
            {
              "title": "Ghostbusters",
              "year": 1984,
              "category": "Wild Card",
              "note": "possibly the earliest a film has gone in Wild Card in the show's history; she turned down a trade for Ferris Bueller's Day Off."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Ferris Bueller's Day Off",
              "year": 1986,
              "category": "Teen Comedy",
              "note": "owned on VHS as a kid; John Hughes, with Matthew Broderick and Alan Ruck."
            },
            {
              "title": "Bull Durham",
              "year": 1988,
              "category": "Rom-Com",
              "note": "Ron Shelton; Costner, Sarandon, and Tim Robbins."
            },
            {
              "title": "Big",
              "year": 1988,
              "category": "Oscar Nominee",
              "note": "Penny Marshall directs Tom Hanks as an adolescent boy whose wish to grow up is granted."
            },
            {
              "title": "Back to the Future",
              "year": 1985,
              "category": "Action / Horror / Sci-Fi Comedy",
              "note": "picked despite Amanda's teasing over whether it counts as funny."
            },
            {
              "title": "Beverly Hills Cop",
              "year": 1984,
              "category": "Blockbuster",
              "note": "discussed alongside Lethal Weapon as a template-setter for the action-comedy."
            },
            {
              "title": "Planes, Trains and Automobiles",
              "year": 1987,
              "category": "Wild Card",
              "note": "the last pick of the draft, taken over This Is Spinal Tap; John Hughes and John Candy."
            }
          ]
        }
