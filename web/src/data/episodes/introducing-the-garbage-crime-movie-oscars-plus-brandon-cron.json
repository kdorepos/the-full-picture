{
  "slug": "introducing-the-garbage-crime-movie-oscars-plus-brandon-cron",
  "title": "Introducing the Garbage Crime Movie Oscars. Plus: Brandon Cronenberg!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2020-11-10",
  "runtimeMin": 101,
  "format": "Sean Fennessey and Chris Ryan coin 'garbage crime' (the mid-budget, B-minus crime picture), hand out its first awards, then Sean talks to Brandon Cronenberg about Possessor.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "What is garbage crime?",
      "note": "the mid-budget B-minus crime picture, defined",
      "films": [
        {
          "title": "Den of Thieves",
          "year": 2018,
          "note": "The platonic ideal. Butler thinks he's doing Richard III; the whole genre traces back to the feeling you get 20 minutes in."
        },
        {
          "title": "S.W.A.T.",
          "year": 2003,
          "note": "Shitty IP plus a charismatic ensemble solving a pedestrian crime: Ryan's early tell that the wave was coming."
        },
        {
          "title": "Jack Reacher: Never Go Back",
          "year": 2016,
          "note": "A sequel reaching for respectable that lands in the bin. Kind of sucks, deeply watchable."
        },
        {
          "title": "Sicario: Day of the Soldado",
          "year": 2018,
          "note": "Takes the highfalutin idea of Sicario and finds the repeatable model: Brolin and Del Toro on the road."
        },
        {
          "title": "The Purge: Anarchy",
          "year": 2014,
          "note": "An out-of-genre franchise that pivoted into a pure all-night firefight movie."
        },
        {
          "title": "The Dark Knight Rises",
          "year": 2012,
          "note": "Garbage crime up to the point the football stadium explodes. Same plot machinery as 21 Bridges."
        },
        {
          "title": "Prisoners",
          "year": 2013,
          "note": "The inverse: a where-are-my-kids setup that Villeneuve elevates into Lynchian dread."
        },
        {
          "title": "The Town",
          "year": 2010,
          "note": "Too good to qualify. It has the Heat masks, but you'd recommend it to your mother-in-law."
        },
        {
          "title": "Nocturnal Animals",
          "year": 2016,
          "note": "A misfire dragged down into the bin. Fennessey calls it absolute trash and means it fondly."
        },
        {
          "title": "Blackhat",
          "year": 2015,
          "note": "Mann's incomprehensible hacker picture, complete with a visible Getty stock photo."
        },
        {
          "title": "The Accountant",
          "year": 2016,
          "note": "Affleck doing his Don Siegel homage."
        },
        {
          "title": "Spenser Confidential",
          "year": 2020,
          "note": "Wahlberg carries garbage crime into the streaming era: the future of mid-budget movies."
        },
        {
          "title": "Mile 22",
          "year": 2018,
          "note": "Incomprehensible in a theater, far better as a disposable Netflix watch."
        },
        {
          "title": "21 Bridges",
          "year": 2019,
          "note": "The perfect cable movie; Boseman doing a restrained '70s character-actor lead."
        },
        {
          "title": "The Informer",
          "year": 2019,
          "note": "The week's exemplar: Kinnaman picking up different cell phones and sweating, shelved since 2018."
        }
      ]
    },
    {
      "kind": "awards",
      "heading": "The First Annual Garbage Crime Oscars",
      "note": "Fennessey nominates, Ryan picks the winners",
      "ceremony": "1st Annual Garbage Crime Oscars",
      "categories": [
        {
          "name": "Best Supporting Actor",
          "winner": "Snitch",
          "nominees": [
            {
              "title": "Snitch",
              "year": 2013,
              "person": "Barry Pepper",
              "note": "One of the all-time great goatees; the DEA scene with the Rock and Sarandon feels like a drug."
            },
            {
              "title": "Sleepless",
              "year": 2017,
              "person": "Scoot McNairy",
              "note": "Slick-back hair and a goatee are canon."
            },
            {
              "title": "Contraband",
              "year": 2012,
              "person": "Giovanni Ribisi"
            },
            {
              "title": "The Gunman",
              "year": 2015,
              "person": "Mark Rylance"
            },
            {
              "title": "A Walk Among the Tombstones",
              "year": 2014,
              "person": "Dan Stevens"
            }
          ]
        },
        {
          "name": "Best Supporting Actress",
          "winner": "The Informer",
          "nominees": [
            {
              "title": "The Informer",
              "year": 2019,
              "person": "Rosamund Pike",
              "note": "Wins on the windbreakers alone. Special achievement in windbreakers."
            },
            {
              "title": "21 Bridges",
              "year": 2019,
              "person": "Sienna Miller",
              "note": "The most turned-up New York accent a British person has attempted."
            },
            {
              "title": "The Accountant",
