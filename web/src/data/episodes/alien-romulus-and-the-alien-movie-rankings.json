        },
        {
          "title": "The Notebook",
          "year": 2004,
          "note": "The film she's best known to a wide audience for, directed by her son Nick Cassavetes."
        },
        {
          "title": "BlackBerry",
          "year": 2023,
          "note": "Matt Johnson, who made it, is set to direct an A24 Anthony Bourdain biopic starring Dominic Sessa; the hosts hope he upends the hagiographic-biopic template the way he did here."
        },
        {
          "title": "Mufasa: The Lion King",
          "year": 2024,
          "note": "Sean saw the trailer with his daughter, a 'guardian of the Lion King lore'; he pitches it as 'Once Upon a Time in Hollywood, but for the Pride Lands.'"
        },
        {
          "title": "Longlegs",
          "year": 2024,
          "note": "Nicolas Cage, freshly cast as John Madden in a David O. Russell biopic, is coming off this hit; part of a Cage-aissance the hosts are on board with."
        },
        {
          "title": "Pig",
          "year": 2021,
          "note": "Filed with 'Dream Scenario' as evidence Cage can do straight-to-VOD and auteurist work at once."
        },
        {
          "title": "Dream Scenario",
          "year": 2023,
          "note": "Sean thought it was underrated."
        },
        {
          "title": "Amsterdam",
          "year": 2022,
