{
  "slug": "the-horror-oscars-and-the-exorcist-believer",
  "title": "The Horror Oscars and ‘The Exorcist: Believer’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2023-10-06",
  "runtimeMin": 94,
  "format": "Sean Fennessey and Chris Ryan take on 'The Exorcist: Believer,' the Blumhouse legacy sequel that brings Ellen Burstyn back for a movie with too many priests and not enough Chris McNeil. Then: 'Saw X,' the Argentinian creeper 'When Evil Lurks,' a stack of October releases, and five years of overdue Horror Oscars.",
  "segments": [
    {
      "kind": "review",
      "heading": "The Exorcist: Believer",
      "note": "a direct sequel to the 1973 original, planned as the first of a trilogy",
      "films": [
        {
          "title": "The Exorcist: Believer",
          "year": 2023,
          "note": "Leslie Odom Jr.'s daughter and her friend get possessed after a woods ritual gone wrong; Ellen Burstyn's Chris McNeil is brought in to help, then sidelined for 45 minutes. A promising opening act - Haitian earthquake prologue aside - gives way to an overcrowded, interfaith exorcism that both hosts found a big disappointment."
        },
        {
          "title": "The Exorcist",
          "year": 1973,
          "note": "The comparison point throughout the episode: a single mother's arc from cynicism to belief, and the uncrowded, single-location tension the new film can't replicate."
        },
        {
          "title": "Halloween",
          "year": 1978,
          "note": "Cited alongside the original Exorcist as proof that stripping a story down to its scariest idea beats overpopulating it."
        },
        {
          "title": "Halloween Kills",
          "year": 2021,
          "note": "The 'mob justice' entry in Green's trilogy - Laurie Strode spends nearly the whole movie in a hospital bed, which Chris compares to Chris McNeil's fate here."
        },
        {
          "title": "Halloween Ends",
          "year": 2022,
          "note": "The trilogy closer; Sean says the advance buzz on Green turned around by the time this one came out."
        },
        {
          "title": "Halloween III: Season of the Witch",
          "year": 1982,
          "note": "The one they actually love, precisely because it drops Michael Myers entirely."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "David Gordon Green, shape-shifter",
      "note": "from Malick disciple to comedy guy to legacy-sequel director",
      "films": [
        {
          "title": "George Washington",
          "year": 2000,
          "note": "Green's breakout - the film that got him compared to Terrence Malick out of Sundance."
        },
        {
          "title": "All the Real Girls",
          "year": 2003
        },
        {
          "title": "Pineapple Express",
          "year": 2008,
          "note": "The start of the Danny McBride/Rough House comedy run and the Apatow-universe pivot."
        },
        {
          "title": "The Sitter",
          "year": 2011,
          "note": "Green as for-hire comedy director, with Jonah Hill."
        },
        {
          "title": "Manglehorn",
          "year": 2014
        },
        {
          "title": "Our Brand Is Crisis",
          "year": 2015,
          "note": "One of a run of star-driven, contemporary-set dramas that didn't connect with audiences before Green pivoted to horror."
        },
        {
          "title": "Stronger",
          "year": 2017,
          "note": "Chris calls it one of Jake Gyllenhaal's best performances, even though the movie didn't find an audience."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "When Evil Lurks",
      "note": "Chris's homework assignment for Sean, playing in theaters and hitting Shudder Oct. 27",
      "films": [
        {
          "title": "When Evil Lurks",
          "year": 2023,
          "note": "Argentinian film from Damian Rugna: a demon is about to be born inside a resident of a small, feudal rural town, and it's taken as a given from minute one that this is real. Both hosts call it one of the year's most upsetting, effective horror movies - Sean's calling it this year's 'Speak No Evil.'"
        },
        {
          "title": "Terrified",
          "year": 2017,
          "note": "Rugna's previous film."
        },
        {
          "title": "Speak No Evil",
          "year": 2022,
          "note": "The comparison point for the slow-dread structure of 'When Evil Lurks.'"
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Saw X",
      "note": "the events take place between Saw and Saw II",
      "films": [
        {
          "title": "Saw X",
          "year": 2023,
          "note": "Tobin Bell's Jigsaw travels to Mexico for a scam cancer cure, then traps the scammers. Sean: not really a good movie, but a new thing for the franchise - it wants you to feel for Jigsaw, and mostly gets there."
        },
        {
          "title": "Saw",
          "year": 2004,
          "note": "Chris's stopping point in the franchise."
        },
        {
          "title": "Spiral: From the Book of Saw",
          "year": 2021,
          "note": "The other Saw movie Chris has seen - 'the Chris Rock one.'"
        },
        {
          "title": "The Firm",
          "year": 1993,
          "note": "Tobin Bell trivia: he's the guy who shoots Gary Busey."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Horror on deck",
      "note": "trailers, VOD drops, and the rest of October",
      "films": [
        {
          "title": "Thanksgiving",
          "year": 2023,
          "note": "Eli Roth's holiday slasher, starring Addison Rae and Patrick Dempsey - built out of the fake trailer from 'Grindhouse.'"
        },
        {
          "title": "The Beekeeper",
          "year": 2024,
          "note": "Jason Statham as a vengeance-seeking beekeeper going after scammers, directed by David Ayer."
        },
        {
          "title": "Silent Night",
          "year": 2023,
          "note": "John Woo's dialogue-free, extremely violent lone-man-vengeance movie."
        },
        {
          "title": "V/H/S/85",
          "year": 2023,
          "note": "The sixth VHS anthology, framed around 1985; segments from Scott Derrickson and Mike P. Nelson were the hosts' favorites."
        },
        {
          "title": "Five Nights at Freddy's",
          "year": 2023,
          "note": "Another Blumhouse release, day-and-date in theaters and on Peacock - 'what if Chuck E. Cheese was a haunted hellhole,' starring Josh Hutcherson."
        },
        {
          "title": "Pet Sematary: Bloodlines",
          "year": 2023,
          "note": "Day-and-date on Paramount+, which Sean reads as a bad sign."
        },
        {
          "title": "Dark Harvest",
          "year": 2023,
          "note": "David Slade's film, shelved for three and a half years before its VOD release."
        },
        {
          "title": "The Caine Mutiny Court-Martial",
          "year": 2023,
          "note": "William Friedkin's final film, also landing on Paramount+, starring Kiefer Sutherland."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Studio horror's James Wan problem",
      "note": "when everyone copies his style but not his eye",
      "films": [
        {
          "title": "The Nun II",
          "year": 2023,
          "note": "Sean's example of the post-James Wan cloudiness that afflicts a lot of studio horror - CGI and set dressing you can feel."
        },
        {
          "title": "The Creator",
          "year": 2023,
          "note": "Gareth Edwards's counterexample: a purposeful, practical-feeling look achieved by shooting on a $3,500 prosumer camera and keeping VFX spending down."
        },
        {
          "title": "Werewolf by Night",
          "year": 2022,
          "note": "Marvel's one horror detour - a 50-minute Michael Giacchino-directed special dumped straight to Disney+."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "2023 horror they hadn't gotten to",
      "films": [
        {
          "title": "Bad Things",
          "year": 2023,
          "note": "Stuart Thorndike's queer riff on 'The Shining,' set at an inherited motel frozen in the '80s. Sean singles out Gayle Rankin's central performance."
        },
        {
          "title": "Influencer",
          "year": 2023,
          "note": "Curtis David Harder's satire of Instagram/TikTok lifestyle influencers, with a lure-and-subsume premise. Chris's Shudder shout-out."
        },
        {
          "title": "Cobweb",
          "year": 2023,
          "note": "Lizzy Caplan as an overprotective, maybe-monstrous mother - part haunted house, part Stephen King bullied-kid story."
        }
      ]
    },
