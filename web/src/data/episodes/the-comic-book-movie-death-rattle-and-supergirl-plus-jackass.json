{
  "slug": "the-comic-book-movie-death-rattle-and-supergirl-plus-jackass",
  "title": "The Comic Book Movie Death Rattle and ‘Supergirl.’ Plus: ‘Jackass: Best and Last’ Goes Out With a Bang.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2026-06-26",
  "runtimeMin": 83,
  "format": "Sean and Amanda run through the summer's movie news, then use 'Supergirl' to mark the end of the comic-book-movie era. Chris Ryan joins to send off 'Jackass: Best and Last.'",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The news",
      "note": "distributors, adaptations, and Tom Cruise",
      "films": [
        {
          "title": "The Debut",
          "year": 2026,
          "note": "Jesse Eisenberg's A24 follow-up to 'A Real Pain,' which he wrote and directed and for which he also wrote the songs. Julianne Moore and Paul Giamatti star; the plot, a middle-aged woman finding herself in community theater, reminds Sean of the Simpsons episode 'A Streetcar Named Marge.' Pegged as a fall-festival, likely-Telluride title."
        },
        {
          "title": "Artificial",
          "year": 2026,
          "note": "Luca Guadagnino's Sam Altman movie, with Andrew Garfield, still had no distributor as of June 21: Netflix, A24, and Focus reportedly passed, Mubi and Neon were circling. Sean and Amanda work through which studios are compromised enough by tech money to pass on a negative film about OpenAI, and figure whoever takes it will get a discount, the way a team eats salary to move a bad contract."
        },
        {
          "title": "Sense and Sensibility",
          "year": 2026,
          "note": "Georgia Oakley's new adaptation, with Daisy Edgar-Jones, George MacKay, Caitríona Balfe, and Frank Dillane. Amanda recuses herself: she's too close to the Ang Lee/Emma Thompson 1995 version, her comfort film during the CinemaCon ticketing all-nighters."
        },
        {
          "title": "Digger",
          "year": 2026,
          "note": "Iñárritu's apocalyptic Tom Cruise comedy, out in October. A 3.5-minute clip reel of Cruise highlights got passed around by Glen Powell, J.J. Abrams, and Michael Mann, with maybe 20 seconds of actual 'Digger' footage. Sean's read: they're selling Tom Cruise, not the movie, and that's probably wise."
        },
        {
          "title": "Coyote vs. Acme",
          "year": 2026,
          "note": "The Looney Tunes movie Warner Bros. shelved, now rescued by Ketchup Entertainment. Cited as proof of how thin the pool of distributors willing to take on an orphaned film has gotten."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Supergirl’",
      "note": "the comic-book-movie death rattle",
      "films": [
        {
          "title": "Supergirl",
          "year": 2026,
          "note": "Craig Gillespie directs Millie Alcock as Kara Zor-El, with Matthias Schoenaerts as the villain Krem, Eve Ridley as Ruthie, and Jason Momoa as Lobo; David Corenswet returns as Superman. Loosely from Tom King's 'Woman of Tomorrow.' Sean and Amanda call it tropey, unspecific, and technically poor ('the brownest movie of the year'), and say the best scene is the one where Supergirl doesn't speak. Sean uses it to declare the era when comic-book movies dominated our lives over, though not the genre itself."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Jackass: Best and Last’",
      "note": "with Chris Ryan",
      "films": [
        {
          "title": "Jackass: Best and Last",
          "year": 2026,
          "note": "The fifth installment, roughly 40% new stunts and 60% retrospective, and the most scatological of the bunch now that the crew has aged into colonoscopy-prep gags. Knoxville, Steve-O, Pontius, Danger Ehren, and Dave England downshift into what their bodies still allow; Bam Margera returns, Ryan Dunn is memorialized, and Spike Jonze turns up in the control room. All three agree it's barely a movie, but call it one of the best times they've had at a theater this year."
        }
      ]
    }
  ],
