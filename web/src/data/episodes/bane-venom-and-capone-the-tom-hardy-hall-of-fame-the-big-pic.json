{
  "slug": "bane-venom-and-capone-the-tom-hardy-hall-of-fame-the-big-pic",
  "title": "Bane, Venom, and 'Capone': The Tom Hardy Hall of Fame | The Big Picture",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-05-14",
  "runtimeMin": 87,
  "format": "Sean, Amanda, and Chris Ryan sit through Josh Trank's 'Capone,' then build a 10-film Tom Hardy Hall of Fame.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Capone'",
      "note": "Tom Hardy's new release",
      "films": [
        {
          "title": "Capone",
          "year": 2020,
          "note": "Josh Trank's return from director jail: Al Capone at the end of his life, dementia and decay under six inches of makeup. Amanda's a hard no, Chris sees a better movie buried in it, and even Sean can't fully zag on the poop-and-mania of it. Nobody puts it in the Hall of Fame."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Tom Hardy Hall of Fame",
      "note": "10 films, plus the Bane wing",
      "honoree": "Tom Hardy",
      "films": [
        {
          "title": "RocknRolla",
          "year": 2008,
          "note": "Handsome Bob in Guy Ritchie's Russian-money crime ensemble. Evidence of the heartthrob Hardy could have been. Chris keeps it over The Drop because he rewatches it more."
        },
        {
          "title": "Bronson",
          "year": 2008,
          "note": "Nicolas Winding Refn's theatrical account of Michael Peterson, the British inmate who renamed himself Charles Bronson. Hardy plays half of it straight into camera; for a lot of people it was their introduction to him."
        },
        {
          "title": "Inception",
          "year": 2010,
          "note": "Eames, the forger. On screen eight minutes and the movie should be about him. Amanda's peak Hardy; a faded Graham Greene diplomat calling everyone darling."
        },
        {
          "title": "Tinker Tailor Soldier Spy",
          "year": 2011,
          "note": "Ricki Tarr, the emotional center of the Le Carre adaptation and the last time Hardy really lets a character show you feeling. Only the wig gets in the way."
        },
        {
          "title": "Warrior",
          "year": 2011,
          "note": "Fewer than 20 lines as one of two estranged MMA brothers opposite Joel Edgerton and Nick Nolte. Sean's best sports movie of the 2010s: a physical force that stays vulnerable and raw."
        },
        {
          "title": "The Dark Knight Rises",
          "year": 2012,
          "note": "Bane. Redubbed into a mutant-dandy purr, eight monologues, huge and unnerving, funny despite itself. The Bane wing exists because of this."
        },
        {
          "title": "Locke",
          "year": 2013,
          "note": "90 minutes in a car, a Welsh concrete manager working the phones through one bad night. First real collaboration with Steven Knight. Proof a movie star can carry a whole film alone."
        },
        {
          "title": "Mad Max: Fury Road",
          "year": 2015,
          "note": "The title role, voice dubbed and half-masked, fitted into George Miller's chaos in eight-second pieces. The best action movie of the 2010s, and one of the great mask performances."
        },
        {
          "title": "Dunkirk",
          "year": 2017,
          "note": "The RAF pilot, mostly masked, acting with his eyes while flying a vintage plane. That last shot on the beach is the whole case."
        },
        {
          "title": "Venom",
          "year": 2018,
          "note": "Eddie Brock doing id-versus-superego with himself, willing a slapstick alien-suit comedy into his biggest standalone hit. Not really good, and Sean doesn't care."
        }
      ]
    }
  ],
