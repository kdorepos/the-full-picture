  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-12-29",
  "runtimeMin": 118,
  "format": "Sean and Amanda run three holiday wide releases through a fuck, marry, kill: the erotic thriller 'The Housemaid,' the meta creature-comedy 'Anaconda,' and the Neil Diamond musical 'Song Sung Blue.' Then Sean talks to 'Song Sung Blue' director Craig Brewer about regionalism, Hugh Jackman, and becoming a Mets fan.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The 2026 trailers",
      "note": "before the movies",
      "films": [
        {
          "title": "The Odyssey",
          "year": 2026,
          "note": "Nolan's Homer adaptation. The practical rowing shots and the glimpse of the Cyclops sold Sean; he expects a full 'one battle after another' cycle of coverage on it."
        },
        {
          "title": "Avengers: Doomsday",
          "year": 2026,
          "note": "Riffed on via a made-up teaser: Chris Evans holding a baby, pan up, 'Steve Rogers will return.' Sean says it's reasonable to be worried."
        },
        {
          "title": "The Mandalorian and Grogu",
          "year": 2026,
          "note": "Sean's son was excited; Sean thinks the trailer is bad but the movie will be great."
        },
        {
          "title": "Avatar: Fire and Ash",
          "year": 2025,
          "note": "Sean's son knows the full title from ads and shouts 'Fire and ash!' but can never see it: too many guns."
        },
        {
          "title": "Zootopia 2",
          "year": 2025,
          "note": "Sean saw it with his kid and napped once it hit Zootopia; a thumbs down and, he says, a shameful act."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘The Housemaid’",
      "note": "the fuck",
      "films": [
        {
          "title": "The Housemaid",
          "year": 2025,
          "note": "Paul Feig directs Sydney Sweeney and Amanda Seyfried in a Frida McFadden adaptation set in Great Neck. Sean calls it a post-'Fifty Shades' polish chasing 'Gone Girl,' coming up junky: a long wait for a disappointing twist. Amanda was entertained but not sure what kind of time she had. The obvious fuck: you at least give it a shot."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Anaconda’",
      "note": "the kill",
      "films": [
        {
          "title": "Anaconda",
          "year": 2025,
          "note": "Tom Gormican directs Paul Rudd and Jack Black as friends trying to remake the 1997 'Anaconda.' A metatextual joke about IP that also is IP, the same joke told 40 times. Sean can't get past casting two 56-year-olds as a midlife crisis; Amanda finds Jack Black to be black licorice. Both laughed a few times; both would kill it."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Song Sung Blue’",
      "note": "the marry",
      "films": [
        {
          "title": "Song Sung Blue",
          "year": 2025,
          "note": "Craig Brewer adapts the documentary about a Milwaukee Neil Diamond tribute duo, played by Hugh Jackman and Kate Hudson. A charming first hour, then a 'Million Dollar Baby' turn into amputation, addiction, and recovery. Sean liked the throwback and got interested in Neil Diamond; both praised Jackman and a risk-taking Hudson."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation: Craig Brewer",
      "guest": "Craig Brewer on",
      "films": [
        {
          "title": "Song Sung Blue",
          "year": 2025,
          "note": "Brewer on wanting the audience to fall in love before the gut-punch, casting Jackman first (there was no list), and finding Hudson again after Hugh flagged a CBS Sunday Morning segment."
        },
        {
          "title": "Hustle & Flow",
          "year": 2005,
          "note": "The Memphis breakout Brewer self-financed with John Singleton: houses put up as collateral, four years on Hollywood couches. Won him an Academy Award."
        },
        {
          "title": "Black Snake Moan",
          "year": 2006,
          "note": "How Brewer first met Kate Hudson, ~20 years earlier, playing blues at her house."
        },
        {
          "title": "Dolemite Is My Name",
          "year": 2019,
          "note": "Cited in the intro as part of a career of regional, music-soaked filmmaking."
        }
