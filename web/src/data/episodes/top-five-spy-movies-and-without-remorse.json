  "runtimeMin": 93,
  "format": "Sean, Amanda, and Chris Ryan rank their favorite spy movies to mark 'Without Remorse,' then Sean talks to director Stefano Sollima about entering the Clancyverse.",
  "tmdbOverrides": {
    "Without Remorse": 567189
  },
  "segments": [
    {
      "kind": "review",
      "heading": "‘Without Remorse’",
      "note": "Sean Fennessey, Amanda Dobbins, and Chris Ryan",
      "films": [
        {
          "title": "Without Remorse",
          "year": 2021,
          "note": "Expected a spy movie, got a revenge-origin action movie about John Kelly, the meaner, brawnier flip side of Jack Ryan. Chris says it plays like an '80s action movie, true to the Cold War-era Clancy source; Amanda says the punching is the point and the international intrigue barely registers."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The State of the Spy Movie",
      "note": "genre chat before the lists",
      "films": [
        {
          "title": "Tinker Tailor Soldier Spy",
          "year": 2011,
          "note": "Beautifully shot, Chris says, but plays like a trailer for the novel; the BBC original with Alec Guinness is the one that's page-for-page."
        },
        {
          "title": "The Constant Gardener",
          "year": 2005,
          "note": "Chris argues it only reads as a spy movie because Le Carré wrote the source novel."
        },
        {
          "title": "The Spy Who Came in From the Cold",
          "year": 1965,
          "note": "The Richard Burton adaptation Sean says captures the Le Carré vibe but lacks energy."
        },
        {
          "title": "A Most Wanted Man",
          "year": 2014
        },
        {
          "title": "Our Kind of Traitor",
          "year": 2016
        },
        {
          "title": "The Hunt for Red October",
          "year": 1990,
          "note": "Chris's marker for the pre-internet, spy-as-expertise era of the genre."
        },
        {
          "title": "Enemy of the State",
          "year": 1998,
          "note": "The shift from scholarly expertise to guys in a van hacking phones, per Chris."
        },
        {
          "title": "Atomic Blonde",
          "year": 2017,
          "note": "A spy movie mostly as an excuse to watch Charlize Theron punch people, Sean says."
        },
        {
          "title": "Red Sparrow",
          "year": 2018
        },
        {
          "title": "The Courier",
          "year": 2020
        },
        {
          "title": "Tenet",
          "year": 2020,
          "note": "Teased as the group's next watch-along; cited as the rare spy story without a clean answer at the end."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five Spy Movies",
      "subject": "Spy Movies",
      "ranked": true,
      "films": [
        {
          "title": "The Third Man",
          "year": 1949,
          "note": "Sean's favorite movie ever made: Carol Reed, Graham Greene, Orson Welles, postwar Vienna, the zither score."
        },
        {
          "title": "Mission: Impossible",
          "year": 1996,
          "note": "His entry point into spy movies at 14, and the reason he never fell for Bond."
        },
        {
          "title": "The Conformist",
          "year": 1970,
          "note": "Bertolucci's study of a fascist-era spy's psychology, and one of the best-looking movies ever made."
        },
        {
          "title": "The Parallax View",
          "year": 1974,
          "note": "The scariest movie of the '70s, Sean says on rewatch, with Warren Beatty in the middle of Pakula's paranoia trilogy."
        },
        {
          "title": "The IPCRESS File",
          "year": 1965,
          "note": "Michael Caine's working-class answer to Bond, from the same producers and composer."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top Five Spy Movies",
      "subject": "Spy Movies",
      "ranked": true,
      "films": [
        {
          "title": "North by Northwest",
          "year": 1959,
          "note": "An accidental-spy Bond movie before Bond existed, Amanda says."
        },
        {
          "title": "The Lives of Others",
          "year": 2006,
          "note": "A Stasi surveillance drama about complicity, the un-fun kind of spy movie."
        },
        {
          "title": "Mission: Impossible",
          "year": 1996,
          "note": "Her entry point too, at 12."
        },
        {
          "title": "Argo",
          "year": 2012,
          "note": "The Best Picture win made people hold it to an unfair standard; it's just a fun, well-made spy movie."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top Five Spy Movies",
      "subject": "Spy Movies",
      "ranked": true,
      "films": [
        {
          "title": "The Third Man",
          "year": 1949
        },
        {
          "title": "Three Days of the Condor",
          "year": 1975,
          "note": "Chris's admitted cheat: grouped with Sneakers and Spy Game as a Redford spy trilogy. The most harrowing of the three."
        },
        {
          "title": "The Bourne Legacy",
          "year": 2012,
          "note": "The best spy movie of the Bourne franchise, per Chris, for its web of interdepartmental agencies with no clear boss."
        },
        {
          "title": "From Russia With Love",
          "year": 1963,
          "note": "The platonic ideal of a pre-Craig Bond movie."
        },
        {
          "title": "Ronin",
          "year": 1998,
          "note": "John Frankenheimer's Paris/Nice chase movie, David Mamet script, two of the best car chases Chris has ever seen."
        }
      ]
