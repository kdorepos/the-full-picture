  "runtimeMin": 106,
  "format": "Sean, Amanda, and Chris Ryan draft five second-half-of-2023 movies apiece with a $1,000 budget, snake-style, 30 seconds a bid. Plus, remembering Alan Arkin, and what Mattel's Hollywood ambitions mean for movies like Barbie.",
  "segments": [
    {
      "kind": "halloffame",
      "heading": "Remembering Alan Arkin",
      "note": "The four-time Oscar nominee died last week at 89",
      "honoree": "Alan Arkin",
      "films": [
        {
          "title": "The In-Laws",
          "year": 1979,
          "note": "One of the funniest movies of the 1970s; recently the subject of a three-way movie swap on the show."
        },
        {
          "title": "Argo",
          "year": 2012,
          "note": "Amanda's pick, an underrated late performance."
        },
        {
          "title": "Little Miss Sunshine",
          "year": 2006,
          "note": "The role he won his Oscar for; a Bill Simmons favorite."
        },
        {
          "title": "So I Married an Axe Murderer",
          "year": 1993,
          "note": "Part of Sean's introduction to Arkin: reliably great for six scene-stealing minutes."
        },
        {
          "title": "Grosse Pointe Blank",
          "year": 1997,
          "note": "Same era, same trick."
        },
        {
          "title": "Glengarry Glen Ross",
          "year": 1992,
          "note": "Sean's favorite: George Aronow, on the receiving end of Alec Baldwin's speech."
        },
        {
          "title": "Catch-22",
          "year": 1970,
          "note": "Mike Nichols' film is due for reconsideration; Arkin plays Yossarian."
        },
        {
          "title": "Freebie and the Bean",
          "year": 1974,
          "note": "New to Amanda: James Caan and Arkin as two extremely immoral cops."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Mattel, Barbie, and the future of IP filmmaking",
      "note": "Prompted by a New Yorker profile of Mattel's push into Hollywood and blunt quotes from a UTA agent about Greta Gerwig's career",
      "films": [
        {
          "title": "Barbie",
          "year": 2023,
          "note": "Greta Gerwig's adaptation of Mattel IP, the film at the center of the profile."
        },
        {
          "title": "Jurassic Park",
          "year": 1993,
          "note": "Sean's counterpoint: it became merchandise after starting as a story, rather than starting as a toy line."
        }
      ]
    },
    {
      "kind": "auction",
      "heading": "The paddles",
      "saleLabel": "Mid-year sale · 2023",
      "slates": [
        {
          "host": "Sean Fennessey",
          "spent": 972,
          "budgetLeft": 28,
          "picks": [
            {
              "title": "Hit Man",
              "year": 2024,
              "price": 175,
              "note": "Richard Linklater directs; Glen Powell, who also co-wrote, and Adria Arjona."
            },
            {
              "title": "The Holdovers",
              "year": 2023,
              "price": 185,
              "note": "Alexander Payne's first film in six years, reuniting with Sideways star Paul Giamatti as a boarding-school teacher stuck babysitting over Christmas break; Da'Vine Joy Randolph, Carrie Preston."
            },
            {
              "title": "The Creator",
              "year": 2023,
              "price": 300,
              "note": "Gareth Edwards (Rogue One) directs; John David Washington as an ex-special-forces agent hunting a sentient AI, with Gemma Chan, Ken Watanabe, Allison Janney."
            },
            {
              "title": "The Iron Claw",
              "year": 2023,
              "price": 311,
              "note": "Sean Durkin's Von Erich wrestling-dynasty biopic; Zac Efron, Jeremy Allen White, Harris Dickinson, Stanley Simons, Holt McCallany."
            },
            {
              "title": "The Boy and the Heron",
              "year": 2023,
              "price": 1,
              "note": "Hayao Miyazaki's reportedly final film, released with almost no marketing in Japan under the working title How Do You Live?"
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "The Zone of Interest",
              "year": 2023,
              "price": 160,
              "note": "Jonathan Glazer's Auschwitz-commandant drama out of Cannes; Sandra Hüller and Christian Friedel."
            },
            {
              "title": "Priscilla",
              "year": 2023,
              "price": 727,
              "note": "Sofia Coppola adapts Priscilla Presley's memoir; Cailee Spaeny as Priscilla, Jacob Elordi as Elvis. The bulk of Amanda's budget."
            },
            {
              "title": "All of Us Strangers",
              "year": 2023,
              "price": 20,
              "note": "Andrew Haigh; Andrew Scott and Paul Mescal, with Claire Foy and Jamie Bell."
            },
            {
              "title": "Passages",
              "year": 2023,
              "price": 20,
              "note": "Ira Sachs; Franz Rogowski's filmmaker upends his marriage to Ben Whishaw by falling for Adèle Exarchopoulos."
            },
            {
              "title": "May December",
              "year": 2023,
              "price": 73,
              "note": "Todd Haynes; Natalie Portman plays an actress shadowing the real-life inspiration, played by Julianne Moore, for a role loosely modeled on the Mary Kay Letourneau story."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "The Bikeriders",
              "year": 2024,
              "price": 250,
              "note": "Jeff Nichols' first film in seven years, following a 1960s Midwestern motorcycle club; Tom Hardy, Austin Butler, Jodie Comer, Michael Shannon, Boyd Holbrook, Norman Reedus."
            },
            {
              "title": "Anyone But You",
              "year": 2023,
              "price": 225,
              "note": "Sydney Sweeney and Glen Powell in a will-they-won't-they wedding rom-com; Will Gluck (Easy A) directs."
            },
            {
              "title": "Nickel Boys",
              "year": 2024,
              "price": 80,
              "note": "RaMell Ross adapts Colson Whitehead's novel about two boys at a brutal Florida reform school."
            },
            {
              "title": "Apartment 7A",
              "year": 2024,
              "price": 100,
              "note": "Natalie Erica James' Rosemary's Baby prequel; Julia Garner."
            },
            {
              "title": "Quicksand",
              "year": 2023,
              "price": 345,
              "note": "A Shudder original: a married couple gets trapped in quicksand in the Colombian rainforest while their marriage falls apart around them. Spent his entire remaining budget."
            }
          ]
        }
