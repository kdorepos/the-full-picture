    {
      "kind": "review",
      "heading": "‘Bridget Jones: Mad About the Boy’",
      "note": "streaming on Peacock",
      "films": [
        {
          "title": "Bridget Jones: Mad About the Boy",
          "year": 2025,
          "note": "Fourth film, first directed by a man (Michael Morris). A movie about grief and middle-age single parenthood; the two romances aren't the center. Chiwetel Ejiofor is the new Darcy; Leo Woodall the younger fling. Long for the genre."
        },
        {
          "title": "Bridget Jones's Diary",
          "year": 2001,
          "note": "The 2001 original: a light Pride and Prejudice, and Hugh Grant right after Notting Hill. The 'I like you just as you are' speech was read at a wedding."
        },
        {
          "title": "Bridget Jones: The Edge of Reason",
          "year": 2004,
          "note": "The one they rate Mad About the Boy 'on par with.'"
        },
        {
          "title": "Bridget Jones's Baby",
          "year": 2016,
          "note": "Nine years ago; ends with Mark Darcy alive and a 'publisher found alive' newspaper gag that set up film four."
        },
        {
          "title": "Babygirl",
          "year": 2024,
          "note": "Floated as a double feature: a Harris Dickinson / age-gap 'very French' movie that played bigger in Europe."
        },
        {
          "title": "To Leslie",
          "year": 2022,
          "note": "Michael Morris's earlier film, of the surprise Andrea Riseborough call-in campaign."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Paddington in Peru’",
      "films": [
        {
          "title": "Paddington in Peru",
          "year": 2024,
          "note": "Third film, first not directed by Paul King (Dougal Wilson takes over). An adventure back to Peru, called the 'Apocalypse Now of Paddington movies.' Anti-capitalist, pro-immigration; Sally Hawkins recast with Emily Mortimer, unacknowledged. Olivia Colman as a suspicious nun."
        },
        {
          "title": "Paddington",
          "year": 2014,
          "note": "The 2014 original, drawing WWII-evacuee parallels not in the slim source book."
        },
        {
          "title": "Paddington 2",
          "year": 2017,
          "note": "Called one of the most beloved movies of the 21st century, the reputation the third had to live up to."
        }
      ]
    },
