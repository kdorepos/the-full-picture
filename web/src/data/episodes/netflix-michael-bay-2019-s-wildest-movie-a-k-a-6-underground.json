{
  "slug": "netflix-michael-bay-2019-s-wildest-movie-a-k-a-6-underground",
  "title": "Netflix + Michael Bay = 2019's Wildest Movie a.k.a ‘6 Underground’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2019-12-13",
  "runtimeMin": 101,
  "format": "Sean Fennessey and Amanda Dobbins bring in Chris Ryan for Michael Bay's Netflix debut '6 Underground': the vulgar-auteur case for it, the sheer excess of it, and whether it only works on the biggest screen you own. Then the SAG nominations and the Oscar race, and Sean's interview with Paul Walter Hauser on 'Richard Jewell.'",
  "segments": [
    {
      "kind": "review",
      "heading": "‘6 Underground’",
      "note": "with Chris Ryan",
      "films": [
        {
          "title": "6 Underground",
          "year": 2019,
          "note": "Bay's Netflix debut: a billionaire (Ryan Reynolds) fakes six operatives' deaths to run an off-books vigilante squad against warlords and dictators. The hosts call it vulgar-auteurism at full unfiltered volume: a 17-minute Florence car chase, an explosion every few seconds, reportedly $150M (they guess closer to $300M). It's morally bankrupt and incoherent, and thrilling anyway; Ryan Reynolds is essentially playing Deadpool as Bruce Wayne, with Melanie Laurent the standout."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The SAG nominations",
      "note": "reading the Oscar race",
      "films": [
        {
          "title": "Bombshell",
          "year": 2019,
          "note": "The surprise: an ensemble nod plus Theron, Robbie, and Kidman. Amanda kicks herself for letting the Golden Globes talk her off it."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "Got the ensemble nomination, only the second foreign-language film to do so after Life Is Beautiful. They read it as locked for a Best Picture nod."
        },
        {
          "title": "Jojo Rabbit",
          "year": 2019,
          "note": "Back in the race on the actors' love of transformation; Scarlett Johansson double-nominated, here and for Marriage Story."
        },
        {
          "title": "Marriage Story",
          "year": 2019,
          "note": "No ensemble nod, but Driver, Johansson, and Dern all landed individually; Laura Dern looks like the supporting-actress winner."
        },
        {
          "title": "Once Upon a Time in Hollywood",
          "year": 2019,
          "note": "Ensemble nominee, assumed to do well."
        },
        {
          "title": "Little Women",
          "year": 2019,
          "note": "Shut out of ensemble; a Christmas release and period-adaptation fatigue working against it, with Ronan missing in lead actress."
        },
        {
          "title": "1917",
          "year": 2019,
          "note": "No ensemble nod, but going by Shape of Water and Green Book, that hasn't stopped recent Best Picture winners."
        },
        {
          "title": "Ford v Ferrari",
          "year": 2019,
          "note": "Christian Bale back in the mix; actors love him even playing an elevated version of himself."
        },
        {
          "title": "The Two Popes",
          "year": 2019,
          "note": "No nods for Pryce or Hopkins, a bad sign for the Telluride sleeper."
        },
        {
          "title": "The Farewell",
          "year": 2019,
          "note": "Left out; Sean was always dubious of its reach in the big race."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Paul Walter Hauser on ‘Richard Jewell’",
      "guest": "Paul Walter Hauser on",
      "films": [
        {
          "title": "Richard Jewell",
          "year": 2019,
          "note": "Clint Eastwood cast him off a photo printed beside the real Jewell; Hauser turned down a more lucrative limited series for a verbal offer. On grounding the performance for one- or two-take Clint and softening Jewell's cartoonishly strong accent."
        },
        {
          "title": "I, Tonya",
          "year": 2017,
          "note": "The role that put him on the map; he improvised the 'shouldn't even be saying his name, Derek' line."
        },
        {
          "title": "BlacKkKlansman",
          "year": 2018,
          "note": "Part of the comic-character run that got Eastwood's attention."
        },
        {
          "title": "The Last Black Man in San Francisco",
          "year": 2019,
          "note": "One of the last great things, he says, and he praises his Spike Lee co-star Jonathan Majors."
        },
        {
          "title": "Honey Boy",
          "year": 2019,
          "note": "Another one of the last great things: Shia LaBeouf writing himself a new lease on his career."
        }
      ]
    }
  ],
