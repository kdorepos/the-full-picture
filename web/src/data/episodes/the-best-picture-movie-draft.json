  "format": "Sean, Amanda, and Chris draft Best Picture winners across five decades: the 1930s, '50s, '70s, '90s, and 2010s, plus a Best Picture loser.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Before the draft: the state of Best Picture",
      "note": "the shrinking box office of a winner",
      "films": [
        {
          "title": "Anora",
          "year": 2024,
          "note": "This year's front-runner; if it wins it would be the lowest-grossing Best Picture winner since at least the 1960s."
        },
        {
          "title": "The Hurt Locker",
          "year": 2008,
          "note": "Lowest-grossing winner to date at $17M domestic; beat Avatar."
        },
        {
          "title": "Slumdog Millionaire",
          "year": 2008,
          "note": "$140M domestic, $385M worldwide: the kind of phenomenon winner that's rare now."
        },
        {
          "title": "Oppenheimer",
          "year": 2023,
          "note": "One of only five post-2004 winners to top $100M domestic."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The draft",
