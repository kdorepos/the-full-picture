    {
      "kind": "interview",
      "heading": "The Halloween mega-mailbag",
      "guest": "Alex Ross Perry on",
      "note": "horror, the strike, and why movies don't get made",
      "films": [
        {
          "title": "The Sweet East",
          "year": 2023,
          "note": "Perry produced it: Sean Price Williams's directing debut, out Dec. 1 after a Cannes premiere. The peg for his tour of indie-film economics."
        },
        {
          "title": "Her Smell",
          "year": 2018,
          "note": "His 2018 feature, made for about $2.5 million; the five-year-later question he uses to explain why that model barely still exists."
        },
        {
          "title": "Cat Person",
          "year": 2023,
          "note": "His case study in Sundance hype gone cold: a title everyone chased in January, quietly dumped to a roughly $400 opening."
        },
        {
          "title": "Fairyland",
          "year": 2023,
          "note": "Another Sundance movie, Sofia Coppola producing, that he figures will never really be seen."
        },
        {
          "title": "Eileen",
          "year": 2023,
          "note": "The counter-example: an Anne Hathaway thriller that took time to sell but landed at Neon, so it reads as a 'real' movie."
        },
        {
          "title": "Messiah of Evil",
          "year": 1974,
          "note": "The Imprint Blu-ray he just watched, proof that a '70s deep cut is now easier to buy than a dead-stock studio title."
        },
        {
          "title": "The Church",
          "year": 1989,
          "note": "Michele Soavi horror, produced and co-written by Dario Argento; the Kim's Video tape he'd watched two nights before and loved."
        },
        {
          "title": "Cemetery Man",
          "year": 1994,
          "note": "Soavi's better-known film, name-checked to place The Church in his filmography."
        },
        {
          "title": "Jane Austen in Manhattan",
          "year": 1980,
          "note": "Merchant Ivory's out-of-print experimental-theater film, a 1970s New York curio he calls the discovery of his year."
        }
      ]
    }
  ],
