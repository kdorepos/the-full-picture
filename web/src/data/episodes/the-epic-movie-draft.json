{
  "slug": "the-epic-movie-draft",
  "title": "The Epic Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2026-07-14",
  "runtimeMin": 112,
  "format": "In honor of The Odyssey, Sean, Amanda, and Chris Ryan draft epic movies across seven categories. First, a movie-news roundup: the live-action Moana's flop, a Sam Neill tribute, and the Dune: Part Three trailer.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The news",
      "note": "before the draft",
      "films": [
        {
          "title": "Tenet",
          "year": 2020,
          "note": "Screened in Toronto ahead of the crew's live draft."
        },
        {
          "title": "Moana",
          "year": 2026,
          "note": "The live-action remake of the 2016 animated film. A $43M domestic opening and a reported ~$125M loss; the Rock reprising Maui."
        },
        {
          "title": "Digger",
          "note": "Alejandro González Iñárritu's Tom Cruise satire about an oilman in the cabinet, with Riz Ahmed and Sandra Hüller; the trailer just dropped, and Sean was cool on the comedy."
        },
        {
          "title": "Disclosure Day",
          "note": "Already past $100M, so Sean feels no obligation to see it."
        },
        {
          "title": "Dune: Part Three",
          "note": "The Dune Messiah adaptation; the trailer premiered in Toronto after their Tenet screening."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The picks",
      "note": "seven categories, three drafters",
      "draftOf": "epic movies",
      "categories": [
        "Odyssey-inspired epic",
        "Epic Best Picture winner",
        "Biblical epic",
        "Romantic or war epic",
        "Biopic epic",
        "Movies over three hours",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Lawrence of Arabia",
              "year": 1962,
              "category": "Movies over three hours",
              "note": "David Lean; the No. 1 seed. Aqaba, the desert vistas, and the intimate scenes he's grown to love with age."
            },
            {
              "title": "The Last of the Mohicans",
              "year": 1992,
              "category": "Romantic or war epic",
              "note": "Michael Mann's James Fenimore Cooper adaptation; the Day-Lewis/Stowe romance under Wes Studi's Magua."
            },
            {
              "title": "Malcolm X",
              "year": 1992,
              "category": "Biopic epic",
              "note": "Spike Lee; Denzel taking a life cradle-to-grave without it ever feeling like Wikipedia."
            },
            {
              "title": "The Searchers",
              "year": 1956,
              "category": "Odyssey-inspired epic",
              "note": "John Ford; Ethan's costly journey out and back, back in the news via One Battle After Another."
            },
            {
              "title": "The Bridge on the River Kwai",
              "year": 1957,
              "category": "Epic Best Picture winner",
              "note": "The second Lean of the draft; Holden, Guinness, and Hawkins building a bridge they shouldn't."
            },
            {
              "title": "Kingdom of Heaven",
              "year": 2005,
              "category": "Biblical epic",
              "note": "Ridley Scott's director's cut, which had a one-theater LA roadshow. Ruled eligible over Amanda's protest."
            },
            {
              "title": "Carlos",
              "year": 2010,
              "category": "Wildcard",
              "note": "Olivier Assayas; Edgar Ramírez as the Jackal, a film/miniseries hybrid with a post-punk soundtrack."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Last Temptation of Christ",
              "year": 1988,
              "category": "Biblical epic",
              "note": "Scorsese; the outer-borough Jesus and Judas accents Nolan name-checked."
            },
            {
              "title": "The Lord of the Rings: The Return of the King",
              "year": 2003,
              "category": "Epic Best Picture winner",
              "note": "The rare fantasy that fits the bill. Third-best of the trilogy, he says, but still."
            },
            {
              "title": "O Brother, Where Art Thou?",
              "year": 2000,
              "category": "Odyssey-inspired epic",
              "note": "The Coens' literal Odyssey; the pick he'd long overlooked, his Darjeeling for the brothers."
            },
            {
              "title": "The Deer Hunter",
              "year": 1978,
              "category": "Romantic or war epic",
              "note": "Cimino; a war epic defined by everything around the battlefield."
            },
            {
              "title": "Amadeus",
              "year": 1984,
              "category": "Biopic epic",
              "note": "Miloš Forman; Salieri's jealousy and F. Murray Abraham's Oscar."
            },
            {
              "title": "Seven Samurai",
              "year": 1954,
              "category": "Movies over three hours",
              "note": "Kurosawa; the most movie he ever made, past 200 minutes."
            },
            {
              "title": "Kill Bill: The Whole Bloody Affair",
              "year": 2011,
              "category": "Wildcard",
              "note": "Tarantino's two films spliced into one; an Odyssey-coded trip to retrieve a daughter."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Wizard of Oz",
              "year": 1939,
              "category": "Odyssey-inspired epic",
              "note": "A girl getting home; a Campbellian hero's journey, and her favorite movie."
            },
            {
              "title": "The Godfather Part II",
              "year": 1974,
              "category": "Epic Best Picture winner",
              "note": "Multi-generational, time-jumping; she takes it over Part I for the Sicily flashbacks."
            },
            {
              "title": "Ben-Hur",
              "year": 1959,
              "category": "Biblical epic",
              "note": "The chariot race, plus a film she found shockingly homoerotic."
            },
            {
              "title": "The English Patient",
              "year": 1996,
              "category": "Romantic or war epic",
              "note": "Anthony Minghella; the one Seinfeld's Elaine hated and Amanda loves."
            },
            {
              "title": "Reds",
              "year": 1981,
              "category": "Biopic epic",
              "note": "Warren Beatty; Diane Keaton alone on the tundra."
            },
            {
              "title": "JFK",
              "year": 1991,
              "category": "Movies over three hours",
              "note": "Oliver Stone; a fever dream she took here rather than in biopic."
            },
            {
              "title": "Barry Lyndon",
              "year": 1975,
              "category": "Wildcard",
              "note": "Kubrick by candlelight; Sean tried to block it on a technicality."
            }
          ]
        }
      ],
