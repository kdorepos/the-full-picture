{
  "slug": "the-denzel-washington-draft",
  "title": "The Denzel Washington Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-09-12",
  "runtimeMin": 109,
  "format": "Sean Fennessey and Amanda Dobbins bring in Chris Ryan, Van Lathan, and Bill Simmons for a snake draft of Denzel Washington's filmography, six categories deep, sparked by the release of Equalizer 3.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The Denzel Washington Draft",
      "note": "snake draft, six categories, Blockbuster threshold $90M domestic",
      "draftOf": "Denzel Washington's filmography",
      "categories": [
        "Drama",
        "Action or Thriller",
        "Spike Lee or Tony Scott Movie",
        "Blockbuster",
        "Oscar Nominee",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Bill Simmons",
          "picks": [
            {
              "title": "Courage Under Fire",
              "year": 1996,
              "category": "Drama",
              "note": "Bill's pick over Devil in a Blue Dress; plays cooler as a courtroom investigation than a straight war movie, he says, and Meg Ryan's performance holds up."
            },
            {
              "title": "Out of Time",
              "year": 2003,
              "category": "Action or Thriller",
              "note": "Denzel as a cop hiding an affair with Sanaa Lathan while investigating his own crime; Bill calls it sweaty and underrated."
            },
            {
              "title": "He Got Game",
              "year": 1998,
              "category": "Spike Lee or Tony Scott Movie",
              "note": "Ray Allen plays the son; the group's advice on rewatch is to fast-forward the Milla Jovovich subplot."
            },
            {
              "title": "The Equalizer",
              "year": 2014,
              "category": "Blockbuster",
              "note": "A late-career reset that the group says worked out better than Neeson's Taken."
            },
            {
              "title": "Training Day",
              "year": 2001,
              "category": "Oscar Nominee",
              "note": "Denzel's second Best Actor win, playing a dirty cop; Van and CR debate whether it was really a makeup Oscar for Malcolm X."
            },
            {
              "title": "Ricochet",
              "year": 1991,
              "category": "Wildcard",
              "note": "Pre-Malcolm X psycho-stalker thriller with John Lithgow; Bill says it ran on cable for years."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Preacher's Wife",
              "year": 1996,
              "category": "Drama",
              "note": "Whitney Houston's last stretch before things got rough, per the group; Amanda insists it counts as drama despite Wikipedia calling it a Christmas comedy."
            },
            {
              "title": "The Taking of Pelham 123",
              "year": 2009,
              "category": "Action or Thriller",
              "note": "Amanda's husband put it on during COVID; she rates Denzel good and Travolta 'atrocious.'"
            },
            {
              "title": "Unstoppable",
              "year": 2010,
              "category": "Spike Lee or Tony Scott Movie",
              "note": "The runaway-train movie with Chris Pine, the last of five Denzel-Tony Scott collaborations."
            },
            {
              "title": "The Pelican Brief",
              "year": 1993,
              "category": "Blockbuster",
              "note": "Bill and Van pass on it out of loyalty to Amanda; the group spends more time on the studio-mandated cut sex scene with Julia Roberts than the plot."
            },
            {
              "title": "Malcolm X",
              "year": 1992,
              "category": "Oscar Nominee",
              "note": "Van calls it the role Denzel 'should have won his first Best Actor for.'"
            },
            {
              "title": "Much Ado About Nothing",
              "year": 1993,
              "category": "Wildcard",
              "note": "Kenneth Branagh's Shakespeare adaptation, with Keanu Reeves and Emma Thompson."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Philadelphia",
              "year": 1993,
              "category": "Drama",
              "note": "Overshadowed by Tom Hanks's Oscar, but CR calls Denzel's performance courageous for confronting his character's own prejudice head-on."
            },
            {
              "title": "The Siege",
              "year": 1998,
              "category": "Action or Thriller",
              "note": "Denzel against Bruce Willis and Annette Bening; the group notes it got semi-canceled at release over its depiction of a Muslim internment camp."
            },
            {
              "title": "Man on Fire",
              "year": 2004,
              "category": "Spike Lee or Tony Scott Movie",
              "note": "Called 'the most Tony Scott of the Tony Scott movies' and CR's favorite of Denzel's avenging-angel roles."
            },
            {
              "title": "The Magnificent Seven",
              "year": 2016,
              "category": "Blockbuster",
              "note": "CR stands by it over Book of Eli, to general disbelief from the table."
            },
            {
              "title": "Flight",
              "year": 2012,
              "category": "Oscar Nominee",
              "note": "CR almost took it a round earlier; the last great Robert Zemeckis movie, per the group."
            },
            {
              "title": "Mississippi Masala",
              "year": 1991,
              "category": "Wildcard",
              "note": "A blind spot CR only closed the weekend before taping; Mira Nair's interracial romance."
            }
          ]
        },
        {
          "host": "Van Lathan",
          "picks": [
            {
              "title": "American Gangster",
              "year": 2007,
              "category": "Drama",
              "note": "Van admits the movie itself falls short but says the Frank Lucas/Blue Magic story and closing shot make it worth defending anyway."
            },
            {
              "title": "The Equalizer 2",
              "year": 2018,
              "category": "Action or Thriller",
              "note": "Has Van's favorite Denzel line reading, the 'I'm only going to be able to do it once' monologue."
            },
            {
              "title": "Déjà Vu",
              "year": 2006,
              "category": "Spike Lee or Tony Scott Movie",
              "note": "Time-travel thriller shot in New Orleans; Van's one-line review is 'a noble failure.'"
            },
            {
              "title": "Remember the Titans",
              "year": 2000,
              "category": "Blockbuster",
              "note": "Personally significant to Van; one of the rare Denzel films where he isn't carrying every scene, with a young Ryan Gosling in the ensemble."
            },
            {
              "title": "Fences",
              "year": 2016,
              "category": "Oscar Nominee",
              "note": "August Wilson adaptation opposite Viola Davis, who won her own Oscar for the role."
            },
            {
              "title": "Mo' Better Blues",
              "year": 1990,
              "category": "Wildcard",
              "note": "Van's favorite film of all time, full stop; a Spike Lee joint about a jazz trumpeter."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Devil in a Blue Dress",
              "year": 1995,
              "category": "Drama",
              "note": "Carl Franklin's Easy Rawlins noir; Sean's biggest Denzel regret is that no sequels got made."
            },
            {
              "title": "The Manchurian Candidate",
              "year": 2004,
              "category": "Action or Thriller",
              "note": "Jonathan Demme's remake, reworked around PTSD and post-9/11 paranoia."
            },
            {
              "title": "Inside Man",
              "year": 2006,
              "category": "Spike Lee or Tony Scott Movie",
              "note": "Sean calls Spike and Tony the two directors Denzel performs best with, and ranks this second only to Man on Fire."
            },
            {
              "title": "Crimson Tide",
              "year": 1995,
              "category": "Blockbuster",
              "note": "Submarine standoff with Gene Hackman, plus an uncredited script polish from Quentin Tarantino."
            },
            {
              "title": "Glory",
              "year": 1989,
              "category": "Oscar Nominee",
              "note": "Denzel's first Oscar win; Sean was shown it in sixth-grade social studies."
            },
            {
              "title": "Fallen",
              "year": 1998,
              "category": "Wildcard",
              "note": "Gregory Hoblitt's demonic-possession thriller with John Goodman and Elias Koteas."
            }
          ]
        }
      ],
