    {
      "kind": "interview",
      "heading": "In conversation",
      "note": "Halina Reijn on ‘Babygirl’",
      "guest": "Halina Reijn on",
      "films": [
        {
          "title": "Babygirl",
          "year": 2024,
          "note": "Reijn wrote it about self-love and shame ('can you love yourself completely?') as a sexual comedy in conversation with, and against, the sexist erotic thrillers she grew up on. Father Figure was on the page before Kidman was cast; the rave (her climax) was scored by Dutch DJs Yellow Claw."
        },
        {
          "title": "Bodies Bodies Bodies",
          "year": 2022,
          "note": "Her A24 breakout, where she discovered humor as a weapon; A24 then encouraged her to write in English."
        },
        {
          "title": "Triangle of Sadness",
          "year": 2022,
          "note": "She saw its New York premiere and locked onto Harris Dickinson: 'who is this creature?'"
        },
        {
          "title": "Beach Rats",
          "year": 2017,
          "note": "Watched the same night; it convinced her Dickinson had the vulnerability and unusual masculinity she needed for Samuel."
        },
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "Her pick for the last great thing she saw. She knows Brady Corbet and Mona Fastvold, and loved every second despite dreading the runtime."
        }
      ]
    }
