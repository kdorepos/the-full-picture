{
  "slug": "the-2022-movie-draft",
  "title": "The 2022 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2025-12-17",
  "runtimeMin": 86,
  "format": "Chris Ryan, Sean Fennessey, and Amanda Dobbins draft the movies of 2022 across six categories, a year they agree runs high at the very top and thin most everywhere else. Chris's last episode of the year.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "the movies of 2022",
      "categories": [
        "Drama",
        "Action / Horror / Thriller",
        "Oscar Nominee",
        "Sequel",
        "Blockbuster",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "The Banshees of Inisherin",
              "year": 2022,
              "category": "Drama",
              "note": "McDonagh's most satisfying film since In Bruges, and a chess move to thin the Oscar category."
            },
            {
              "title": "Ambulance",
              "year": 2022,
              "category": "Action / Horror / Thriller",
              "note": "Michael Bay's one-crazy-day-in-LA heist; the front half wants to be Heat, the back half is one of the century's best chase movies."
            },
            {
              "title": "Top Gun: Maverick",
              "year": 2022,
              "category": "Oscar Nominee",
              "note": "took it in Oscar rather than Blockbuster; calls the coffin-run stretch near-perfect cinema."
            },
            {
              "title": "Confess, Fletch",
              "year": 2022,
              "category": "Sequel",
              "note": "Greg Mottola's undersung revival with Jon Hamm as Fletch; buried on streaming, wants three more."
            },
            {
              "title": "The Batman",
              "year": 2022,
              "category": "Blockbuster",
              "note": "Reeves' fully-built Gotham, a solid Pattinson, and the Dano-behind-the-glass meme."
            },
            {
              "title": "Emily the Criminal",
              "year": 2022,
              "category": "Wild Card",
              "note": "John Patton Ford's Straight Time-adjacent crime portrait; Aubrey Plaza against type."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Babylon",
              "year": 2022,
              "category": "Drama",
              "note": "Chazelle's near-masterpiece; a box-office bomb Sean helped build a fan hive around. His peace-offering pick to leave Tár on the board."
            },
            {
              "title": "Barbarian",
              "year": 2022,
              "category": "Action / Horror / Thriller",
              "note": "Zach Cregger's debut and a new director he'll follow for 25 years; still waiting on the 4K."
            },
            {
              "title": "Avatar: The Way of Water",
              "year": 2022,
              "category": "Oscar Nominee",
              "note": "Cameron's return 13 years on; moved him, though he swears no tears were shed."
            },
            {
              "title": "Prey",
              "year": 2022,
              "category": "Sequel",
              "note": "Trachtenberg's largely silent Predator prequel; stunned Chris left it on the board."
            },
            {
              "title": "Nope",
              "year": 2022,
              "category": "Blockbuster",
              "note": "his favorite film of the year and favorite Peele, seen on 70mm at the Egyptian."
            },
            {
              "title": "Everything Everywhere All at Once",
              "year": 2022,
              "category": "Wild Card",
              "note": "likes it as a genre mashup and immigrant-family portrait, apart from the awards spin cycle that he thinks hurt it."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Fabelmans",
              "year": 2022,
              "category": "Drama",
              "note": "Spielberg's under-celebrated self-portrait, written with Tony Kushner; Gabriel LaBelle standing out."
            },
            {
              "title": "Pearl",
              "year": 2022,
              "category": "Action / Horror / Thriller",
              "note": "Ti West and Mia Goth's lockdown-born prequel; watched to complete the X trilogy and was charmed."
            },
            {
              "title": "Tár",
              "year": 2022,
              "category": "Oscar Nominee",
              "note": "Sean's peace offering; her co-favorite of the year for going for capital-C cinema."
            },
            {
              "title": "Downton Abbey: A New Era",
              "year": 2022,
              "category": "Sequel",
              "note": "the best of the Downton movies: a straight Singin' in the Rain crib on the French Riviera."
            },
            {
              "title": "Minions: The Rise of Gru",
              "year": 2022,
              "category": "Blockbuster",
              "note": "spent more airtime recapping the Minions choir than she did on Tár."
            },
            {
              "title": "Halftime",
              "year": 2022,
              "category": "Wild Card",
              "note": "the Jennifer Lopez doc she's thought about third-most all year, for the backstage Golden Globe meltdown."
            }
          ]
        }
      ],
