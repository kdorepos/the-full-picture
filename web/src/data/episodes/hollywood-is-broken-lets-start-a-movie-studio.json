    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Chris Nash on",
      "films": [
        {
          "title": "In a Violent Nature",
          "year": 2024,
          "note": "His first feature at 40: no score, Academy ratio, and a POV slasher he wasn't sure would work."
        },
        {
          "title": "Gerry",
          "year": 2002,
          "note": "The Gus Van Sant film that seeded the idea: characters dictating the pace, the camera following voyeuristically."
        },
        {
