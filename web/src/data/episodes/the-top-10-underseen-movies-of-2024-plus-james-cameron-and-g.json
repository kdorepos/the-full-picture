{
  "slug": "the-top-10-underseen-movies-of-2024-plus-james-cameron-and-g",
  "title": "The Top 10 Underseen Movies of 2024. Plus: James Cameron and Gale Anne Hurd on ‘The Terminator’ at 40!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Bobby Wagner"
  ],
  "published": "2024-12-18",
  "runtimeMin": 160,
  "format": "The year-end cleanup: Sean and a rotating crew of Ringer colleagues make the case for 2024 releases most people missed, after a run through the Oscar shortlist and before a 40th-anniversary talk with James Cameron and Gale Anne Hurd about ‘The Terminator.’",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Oscar Shortlist",
      "note": "Sean and Bobby Wagner on the Academy's December cut",
      "films": [
        {
          "title": "Emilia Pérez",
          "year": 2024,
          "note": "Showed up on five shortlists, six times overall; the front-runner nobody who sees it seems to love."
        },
        {
          "title": "Wicked",
          "year": 2024,
          "note": "Made four lists; its below-the-line chances grow by the day, though its score should arguably be ineligible as a Broadway adaptation."
        },
        {
          "title": "The Substance",
          "year": 2024,
          "note": "Made makeup and hairstyling but not visual effects, a sign the branch is at least watching it."
        },
        {
          "title": "Civil War",
          "year": 2024,
          "note": "CR's favorite of the year; recognized in visual effects but snubbed in sound, which Sean finds unnerving."
        },
        {
          "title": "Furiosa: A Mad Max Saga",
          "year": 2024,
          "note": "Shut out entirely. Bobby, president of Furiosa Hater Nation, maintains it's a 7 out of 10."
        },
        {
          "title": "Dune: Part Two",
          "year": 2024,
          "note": "Hans Zimmer's score ruled ineligible for reusing material from Part One."
        },
        {
          "title": "Saturday Night",
          "year": 2024,
          "note": "Likely gone: Jon Batiste's score wasn't shortlisted."
        },
        {
          "title": "Alien: Romulus",
          "year": 2024,
          "note": "On the list three times; a solid 3.5-star scare with genuinely impressive CG."
        },
        {
          "title": "The Wild Robot",
          "year": 2024,
          "note": "On three lists, including Chris Bowers's score; the stiffest competition for Flow in Best Animated."
        },
        {
          "title": "Gladiator II",
          "year": 2024
        },
        {
          "title": "I Saw the TV Glow",
          "year": 2024,
          "note": "Its original songs, Phoebe Bridgers included, missed the cut, a snub aimed straight at guys like Bobby."
        },
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "Daniel Blumberg's score, now on Spotify, keeps Sean going bananas; a slow rollout could still work in the film's favor."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Underseen Picks",
      "note": "the host's own five",
      "subject": "Sean's underseen movies of 2024",
      "ranked": true,
      "films": [
        {
          "title": "Christmas Eve in Miller's Point",
          "year": 2024,
          "note": "No. 1. Tyler Taormina's Long Island Christmas-party movie; a roving, Altman-esque ensemble (Michael Cera, Francesca Scorsese, Greg Turkington) and the most Long Island thing to ever happen in movies. On AMC+ and VOD."
        },
        {
          "title": "Hundreds of Beavers",
          "year": 2024,
          "note": "Mike Cheslik's black-and-white slapstick epic: Buster Keaton by way of Jackass and Looney Tunes, with actors in giant beaver suits. Finally on Tubi."
        },
        {
          "title": "Femme",
          "year": 2023,
          "note": "A drag performer connects with the man who attacked him; a sustained thriller and a companion piece to Red Rooms. On Hulu."
        },
        {
          "title": "The Remarkable Life of Ibelin",
          "year": 2024,
          "note": "Benjamin Ree's doc about a young man with muscular dystrophy who built a deep community inside World of Warcraft. On Netflix."
        },
        {
          "title": "What You Wish For",
          "year": 2023,
          "note": "A grimy, Twilight Zone-style crime piece with Nick Stahl as a down-on-his-luck chef who takes a dead friend's job. On Hulu."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The Ringer All-Stars' Picks",
      "note": "one contributor, one underseen movie",
      "picks": [
        {
          "title": "Carry On",
          "year": 2024,
          "by": "Chris Ryan",
          "note": "Jaume Collet-Serra's LAX Christmas thriller: Die Hard by way of Phone Booth, with Taron Egerton and a phoned-in Jason Bateman, plus one of the best car crashes in a decade. No. 1 on Netflix in a day."
        },
        {
          "title": "Flow",
          "year": 2024,
          "by": "Mallory Rubin",
          "note": "Gints Zilbalodis's dialogue-free Latvian animation about a cat and its companions after a flood; the most beautiful thing she's ever seen, and stressful enough to make her want to hold a stranger's hand."
        },
        {
          "title": "The Shadow Strays",
          "year": 2024,
          "by": "Charles Holmes",
          "note": "Timo Tjahjanto's Indonesian action-horror; too long at 2.5 hours but every set piece is crazier than the last, in the John Wick lineage with the violence left in frame."
        },
        {
          "title": "Rap World",
          "year": 2024,
          "by": "Charles Holmes",
          "note": "Connor O'Malley and Danny Scharar's hour-long found-footage comedy about suburban Pennsylvania kids trying to make a rap album in 2008. Free on YouTube."
        },
        {
          "title": "Hayao Miyazaki and the Heron",
          "year": 2024,
          "by": "Charles Holmes",
          "note": "A making-of process doc that reframes The Boy and the Heron: the aging master outliving his collaborators and building a soccer field the local kids finally use."
        },
        {
          "title": "Y2K",
          "year": 2024,
          "by": "Yasi Salek",
          "note": "Kyle Mooney's directorial debut: a Can't Hardly Wait New Year's Eve that turns into a machine-uprising horror comedy, wall-to-wall with 1999 needle drops and a scene-stealing Fred Durst."
        },
        {
          "title": "Dìdi",
          "year": 2024,
          "by": "Rob Mahoney",
          "note": "Sean Wang's 2008-set coming-of-age film about a Taiwanese American skater kid; a MySpace-era strike zone Rob happily calls himself the perfect audience for."
        },
        {
          "title": "Between the Temples",
          "year": 2024,
          "by": "Joanna Robinson",
          "note": "Nathan Silver's indie love story: a cantor who's lost his faith (Jason Schwartzman) and a woman looking to convert (Carol Kane), plus a mean, unforgettable Dolly de León."
        },
        {
          "title": "Good One",
          "year": 2024,
          "by": "Bobby Wagner",
          "note": "India Donaldson's debut: a 17-year-old (Lily Collias) on a Catskills hike with her father and his friend; almost nothing happens, and the two-thirds turn changes everything."
        },
        {
          "title": "Martha",
          "year": 2024,
          "by": "Amanda Dobbins",
          "note": "R.J. Cutler's Martha Stewart doc, delivered by voice note; the testy interview and the orange-knife dressing-down haunted Amanda. Martha hated the classical score."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "‘The Terminator’ at 40",
      "note": "the director and producer, four decades on",
      "guest": "James Cameron & Gale Anne Hurd on",
      "films": [
        {
          "title": "The Terminator",
          "year": 1984,
          "note": "The 40th anniversary. A ~$6.4M independent film pieced together from HBO, Hemdale, and Orion's foreign side; casting Arnold as the heavy pivoted the whole undercover-assassin concept on a dime. Shot guerrilla-style in an Olympics-emptied Los Angeles."
        },
        {
          "title": "Aliens",
          "year": 1986,
          "note": "Cameron had signed on before The Terminator; the six-month Arnold delay gave him time to write it, drawn to Ripley as an elevated last-girl story."
        },
        {
          "title": "The Abyss",
          "year": 1989
        }
      ]
    }
  ],
