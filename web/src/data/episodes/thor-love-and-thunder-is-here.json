{
  "slug": "thor-love-and-thunder-is-here",
  "title": "‘Thor: Love and Thunder’ Is Here!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Joanna Robinson"
  ],
  "published": "2022-07-08",
  "runtimeMin": 91,
  "format": "Sean and Joanna dig into Taika Waititi's tonally scattered 'Thor: Love and Thunder,' remember James Caan, and Sean sits down with Claire Denis to talk 'Both Sides of the Blade.'",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Remembering James Caan",
      "note": "the hosts pay tribute before getting to Thor",
      "films": [
        {
          "title": "The Godfather",
          "year": 1972,
          "note": "Caan's Sonny Corleone. Sean caught the restored print at Paramount, with Coppola and Talia Shire on hand, just months before Caan's death."
        },
        {
          "title": "Rollerball",
          "year": 1975,
          "note": "Sean cites Caan's believability as an athlete on screen."
        },
        {
          "title": "El Dorado",
          "year": 1966,
          "note": "Caan with John Wayne under Howard Hawks."
        },
        {
          "title": "Bottle Rocket",
          "year": 1996,
          "note": "Caan lending his name to an unknown Wes Anderson and the then-unknown Wilson brothers on their first feature."
        },
        {
          "title": "Hide in Plain Sight",
          "year": 1980,
          "note": "Caan's own directorial effort."
        },
        {
          "title": "Misery",
          "year": 1990,
          "note": "Caan as Paul Sheldon, recently the subject of a Rewatchables episode."
        },
        {
          "title": "The Gambler",
          "year": 1974
        },
        {
          "title": "Freebie and the Bean",
          "year": 1974
        },
        {
          "title": "Elf",
          "year": 2003,
          "note": "Probably how younger viewers know him best, as Buddy's dad."
        },
        {
          "title": "Honeymoon in Vegas",
          "year": 1992
        },
        {
          "title": "Slither",
          "year": 1973,
          "note": "One of the ornery, hard-to-find '70s character studies Sean recommends seeking out."
        },
        {
          "title": "T.R. Baskin",
          "year": 1971
        },
        {
          "title": "Cinderella Liberty",
          "year": 1973
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "‘Thor: Love and Thunder’",
      "note": "Taika Waititi's follow-up to Ragnarok",
      "films": [
        {
          "title": "Thor: Love and Thunder",
          "year": 2022,
          "note": "Joanna liked it more than Sean did. Both single out Christian Bale's Gorr the God Butcher as the highlight and note a tone that swings between six different kinds of movie (romance, kids-in-peril adventure, meta superhero satire, gothic horror, and cancer drama) inside one 119-minute runtime."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Taika Waititi, ranked",
      "note": "where to start with his filmography",
      "films": [
        {
          "title": "Eagle vs Shark",
          "year": 2007,
          "note": "Sean finds it too twee, though it's a Napoleon Dynamite-adjacent Jemaine Clement vehicle that got Miramax's attention off a trailer alone."
        },
        {
          "title": "Boy",
          "year": 2010,
          "note": "Sean's pick for the skeleton key to Taika's sincerity: a loosely autobiographical story about a boy and his convict father, with Taika playing the dad."
        },
        {
          "title": "What We Do in the Shadows",
          "year": 2014
        },
        {
          "title": "Hunt for the Wilderpeople",
          "year": 2016,
          "note": "Both hosts' favorite. Joanna calls it possibly a top-tier all-time favorite, and both credit Sam Neill and the film's tone balance."
        },
        {
          "title": "Jojo Rabbit",
          "year": 2019,
          "note": "Won Taika an Oscar; both hosts remain a little mystified by that, and credit it partly to goodwill from Ragnarok."
        },
        {
          "title": "Next Goal Wins",
          "year": 2023,
          "note": "Michael Fassbender-led soccer film, completed but not yet released as of this episode."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Claire Denis on",
      "note": "'Both Sides of the Blade,' shot during the pandemic",
      "films": [
        {
          "title": "Both Sides of the Blade",
          "year": 2022,
          "note": "Made during Covid with a tiny cast and crew in Paris apartments and cars; Denis says the film wouldn't exist without the pandemic."
        },
        {
          "title": "Stars at Noon",
          "year": 2022,
          "note": "The Nicaragua-set Denis Johnson adaptation she paused to make Both Sides of the Blade; production later moved to Panama."
        },
        {
          "title": "High Life",
          "year": 2018,
          "note": "Her English-language film with Robert Pattinson, made on what she says was actually a modest budget."
        },
        {
          "title": "Trouble Every Day",
          "year": 2001,
          "note": "Denis on being asked to make a horror movie and instead 'diving into a sort of horror.'"
        },
        {
          "title": "Bastards",
          "year": 2013,
          "note": "The film Sean says Both Sides of the Blade most reminded him of."
        },
        {
          "title": "White Material",
          "year": 2010,
          "note": "Her last film shot in Africa, roughly 15 years before this conversation."
        },
        {
          "title": "Memoria",
          "year": 2021,
          "note": "Denis's answer to the closing question: the last great thing she saw, watching it in a Paris theater."
        }
      ]
    }
  ],
