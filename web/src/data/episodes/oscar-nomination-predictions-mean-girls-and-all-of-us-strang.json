      "kind": "discussion",
      "heading": "‘Mean Girls’",
      "note": "the musical remake of the musical of the movie",
      "films": [
        {
          "title": "Mean Girls",
          "year": 2024,
          "note": "Samantha Jayne and Arturo Perez Jr.'s adaptation of Tina Fey's musical. Sean and Amanda were both charmed; Renée Rapp's Regina stops the movie cold for pop-star numbers, while it plays the 2004 lines near-verbatim."
        },
        {
          "title": "Mean Girls",
          "year": 2004,
          "note": "The original Amanda has memorized. The Lindsay Lohan-Rachel McAdams anti-chemistry is the bar the new cast keeps getting measured against."
        }
      ]
    },
