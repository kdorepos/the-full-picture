{
  "slug": "the-best-movies-of-the-year-so-far-plus-15-we-missed",
  "title": "The Best Movies of the Year … So Far. Plus: 15 We Missed!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2026-03-30",
  "runtimeMin": 161,
  "format": "Sean and Amanda clear the awards-season backlog: early-2026 releases they missed, from a Colleen Hoover melodrama to two near-identical Satanist horror movies to Christian Petzold's smallest film yet. Then each reads out a top five. Sean closes with Ben David Grabinski on his time-travel buddy comedy Mike and Nick and Nick and Alice.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "15 We Missed",
      "note": "the awards-season backlog, in the order they hit it",
      "films": [
        {
          "title": "Reminders of Him",
          "year": 2026,
          "note": "The third Colleen Hoover adaptation, with Maika Monroe as an ex-convict trying to reach the daughter she gave up and Tyriq Withers as her dead boyfriend's best friend. Sean's read: a straight-line melodrama, almost Douglas Sirk, and the least lurid and least memorable of the Hoover films."
        },
        {
          "title": "Paul McCartney: Man on the Run",
          "year": 2026,
          "note": "Morgan Neville's post-Beatles McCartney documentary, made with Paul as an executive producer. Watchable and slickly assembled; Sean, deep in his Ram-era Paul study, wanted a tighter focus and less pro-Paul management of the John Lennon story."
        },
        {
          "title": "Ready or Not 2: Here I Come",
          "year": 2026,
          "note": "Radio Silence's sequel picks up with Samara Weaving still in the bloody wedding dress and widens the Satanist-in-laws world. Kathryn Newton, Sarah Michelle Gellar and Elijah Wood join; the exploding-bodies gag that made the first one land gets run into the ground."
        },
        {
          "title": "They Will Kill You",
          "year": 2026,
          "note": "Kirill Sokolov's near-identical twin to Ready or Not 2: a maid walks into a Satanist co-op that needs sacrifices. Zazie Beetz is a surprisingly good action lead; more Kill Bill by way of Looney Tunes than horror, and thin on plot at 94 minutes."
        },
        {
          "title": "Midwinter Break",
          "year": 2026,
          "note": "Polly Findlay adapts the novel; Lesley Manville plays half of an empty-nester couple whose Amsterdam trip surfaces old wounds. Amanda found it a well-acted movie about Irish Catholic guilt she couldn't connect to."
        },
        {
          "title": "The AI Doc: Or How I Became an Apocaloptimist",
          "year": 2026,
          "note": "Daniel Roher (post-Navalny) and Charlie Tyrell's survey documentary, framed by Roher's impending fatherhood. An effective 'AI for dummies' that boils the field down to five men racing to AGI by stripping out safety; Sam Altman sits for it near the end."
        },
        {
          "title": "A Private Life",
          "year": 2026,
          "note": "Rebecca Zlotowski's Paris-set drama with Jodie Foster acting mostly in French as a psychiatrist looking into a patient's death. Shaggy and charming, more Woody-Allen-in-Paris than thriller; Sean thinks Foster may be the one miscast note."
        },
        {
          "title": "Good Luck, Have Fun, Don't Die",
          "year": 2026,
          "note": "Gore Verbinski's first film since A Cure for Wellness: a time-traveler (Sam Rockwell) recruits misfits to stop an AI apocalypse. Sean, a big Verbinski fan, found it under-lit and more gag than stakes, with Rockwell grating."
        },
        {
          "title": "Undertone",
          "year": 2026,
          "note": "A first-time director's sub-$500K one-location horror, bought by A24 after the festival circuit: a call-in-show podcast host alone in a house with her ailing mother. Great sound design, some cheap jump scares, and a very smart piece of business for A24."
        },
        {
          "title": "Our Hero, Balthazar",
          "year": 2026,
          "note": "Oscar Boyson's feature: a wealthy teen (Jaeden Martell) posts gun-control videos to impress a crush, then drives to Texas to confront a troll he's convinced is a mass shooter. Both hosts agree the movie comes alive when Asa Butterfield turns up as the Texas kid."
        },
        {
          "title": "Redux Redux",
          "year": 2026,
          "note": "The McManus siblings' lo-fi parallel-universe indie: Michaela McManus's grieving mother kills her daughter's murderer across timelines, over and over, and gets addicted to it. A great core idea, occasionally draggy; Sean's most enthusiastic recommendation of the batch."
        },
        {
          "title": "Peaky Blinders: The Immortal Man",
          "year": 2026,
          "note": "Tom Harper's feature capper to the Netflix series, with Cillian Murphy, Rebecca Ferguson and a Nazi-financier Tim Roth. Neither host has seen the show; they clock it as a well-made period crime piece doing Oppenheimer-adjacent Cillian Murphy, fine on its own terms."
        },
        {
          "title": "GOAT",
          "year": 2026,
          "note": "The animated sports hit produced by Stephen Curry: a pygmy goat breaks into 'Roarball,' a multi-species basketball. Better than Sean expected, with a Nick Kroll Komodo dragon; he's convinced the Jet character is a subtle shot at LeBron James."
        },
        {
          "title": "Miroirs No. 3",
          "year": 2025,
          "note": "Christian Petzold's stripped-down, 87-minute Hitchcock riff, with Paula Beer taken in by a family after a fatal crash. Sean's pick for one of the year's best and most modest films."
        },
        {
          "title": "Marc by Sofia",
          "year": 2026,
          "note": "Sofia Coppola's A24 documentary on her friend Marc Jacobs, closer to a fashion music video than a fashion doc. Amanda had a great time; pure '90s and 2000s nostalgia, completely without conflict."
        },
        {
          "title": "Fantasy Life",
          "year": 2026,
          "note": "Matthew Shear writes, directs and stars opposite Amanda Peet as a laid-off paralegal nannying for a fading rock star (Alessandro Nivola) and an actress in crisis. Very Baumbach and Woody Allen; a self-lacerating Peet performance Sean would love to see get an awards push."
        }
      ]
    },
