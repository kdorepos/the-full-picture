    {
      "kind": "review",
      "heading": "'28 Years Later'",
      "note": "one of the year's best",
      "films": [
        {
          "title": "28 Years Later",
          "year": 2025,
          "note": "Boyle and Garland reunite 23 years on. Shot on iPhone 15 Pro Max, scored by Young Fathers: a father-son hunting rite (Aaron Taylor-Johnson, newcomer Alfie Williams as Spike) that turns into coming-of-age folk horror. Ralph Fiennes as a bone-temple doctor, Jodie Comer as the dying mother. A fallen-empire Brexit allegory with plenty of gore, and all three hosts have it as a favorite of the year."
        },
        {
          "title": "28 Days Later",
          "year": 2002,
          "note": "The Boyle-Garland original, shot on low-res digital video. Amanda rewatched it alongside the sequel this week."
        },
        {
          "title": "28 Weeks Later",
          "year": 2007,
          "note": "The 2007 sequel, quietly retconned here: the new film says continental Europe contained the virus and moved on."
        }
      ]
    }
