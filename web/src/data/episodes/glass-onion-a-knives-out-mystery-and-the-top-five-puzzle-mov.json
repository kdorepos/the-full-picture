{
  "slug": "glass-onion-a-knives-out-mystery-and-the-top-five-puzzle-mov",
  "title": "‘Glass Onion: A Knives Out Mystery’ and the Top Five Puzzle Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2022-12-27",
  "runtimeMin": 72,
  "format": "A full-spoiler talk on Rian Johnson's Benoit Blanc sequel, then two ranked lists of favorite puzzle movies.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Glass Onion: A Knives Out Mystery’",
      "note": "full spoilers",
      "films": [
        {
          "title": "Glass Onion: A Knives Out Mystery",
          "year": 2022,
          "note": "Rian Johnson's sequel to Knives Out, Daniel Craig back as Benoit Blanc among six friends on tech billionaire Miles Bron's (Edward Norton) Greek island. Sean and Amanda read it as roughly 65% puzzle movie, 35% murder mystery, broader and zanier than the first. High points: Craig getting most of the good lines, Janelle Monáe's twin-sister doubling as Andi/Helen, and the string of cameos. Sean's big reading is the burned Mona Lisa as Johnson flipping off Netflix: the tech money that paid for his future while gutting theaters. Both flag the flimsy premise that these six very different people were ever friends, and that the garish island house isn't much of an escape."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five Puzzle Movies",
      "note": "No. 1 last on air",
      "subject": "puzzle movies",
      "ranked": true,
      "films": [
        {
          "title": "The Game",
          "year": 1997,
          "note": "No. 1. David Fincher's mean-spirited puzzle, hard to solve because the film keeps you locked inside Michael Douglas's experience. The taxi hurtling into the bay is his favorite bit."
        },
        {
          "title": "Nine Queens",
          "year": 2000,
          "note": "No. 2. Fabián Bielinski's Argentine con-man film with Ricardo Darín; one of Sean's first art-house experiences. Skip the U.S. remake with John C. Reilly and Diego Luna."
        },
        {
          "title": "House of Games",
          "year": 1987,
          "note": "No. 3. David Mamet's con-artist film with Joe Mantegna and Lindsay Crouse: a psychiatrist who thinks she's a step ahead of the grifters and is a step behind. Sean's detective dad showed it to him young."
        },
        {
          "title": "The Sixth Sense",
          "year": 1999,
          "note": "No. 4. Like Memento, a twist movie that rewards a walk back through the steps once you know Bruce Willis's character is a ghost."
        },
        {
          "title": "Memento",
          "year": 2000,
          "note": "No. 5. Christopher Nolan told in reverse. The pieces snap together as it unfurls, and unlike Inception it actually makes sense. Sean's Nolan pick over Amanda's Inception."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top Five Puzzle Movies",
      "note": "No. 1 last on air; No. 2 gifted by Sean mid-episode",
      "subject": "puzzle movies",
      "ranked": true,
      "films": [
        {
          "title": "Arrival",
          "year": 2016,
          "note": "No. 1. One of Amanda's favorite movies of the century, marrying puzzle and story: time working differently, some things seen not yet happened. She hasn't rewatched since having a kid and isn't sure she can."
        },
        {
          "title": "Donnie Darko",
          "year": 2001,
          "note": "No. 2. Amanda was stuck at two; Sean handed it to her as a Christmas present off his honorable-mentions list."
        },
        {
          "title": "Eternal Sunshine of the Spotless Mind",
          "year": 2004,
          "note": "No. 3. The only context in which Amanda likes the movie: a puzzle about why a relationship didn't work and whether it can again. She thinks the answer is that both characters are annoying, but calls the premise clever."
        },
        {
          "title": "Inside Man",
          "year": 2006,
          "note": "No. 4. Spike Lee heist where the heist is a puzzle you don't see coming; Sean wishes Lee had two or three more like it. Great Denzel, great New York movie."
        },
        {
          "title": "Inception",
          "year": 2010,
          "note": "No. 5. Amanda's Nolan pick. She admits she doesn't fully understand it and treats it as a literal folding puzzle, but has fun with it. Sean dislikes it: too busy explaining how it fits when it doesn't."
        }
      ]
    }
  ],
