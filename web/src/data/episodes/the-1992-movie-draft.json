            },
            {
              "title": "White Men Can't Jump",
              "year": 1992,
              "category": "Comedy",
              "note": "The movie that hooked 15-year-old Chris on basketball and hip-hop at the same time."
            },
            {
              "title": "Scent of a Woman",
              "year": 1992,
              "category": "Oscar Nominee",
              "note": "Pacino's makeup Oscar; Chris says Glengarry Glen Ross was his real favorite Pacino performance that year."
            },
            {
              "title": "One False Move",
              "year": 1992,
              "category": "Action/Horror/Thriller",
              "note": "Billy Bob Thornton co-wrote and starred; Chris saw it in theaters and thought it was the best movie he'd ever seen."
            },
            {
              "title": "The Last of the Mohicans",
              "year": 1992,
              "category": "Blockbuster",
              "note": "Michael Mann and Daniel Day-Lewis; made just over the $75 million blockbuster threshold."
            },
            {
              "title": "Sneakers",
              "year": 1992,
              "category": "Wildcard",
