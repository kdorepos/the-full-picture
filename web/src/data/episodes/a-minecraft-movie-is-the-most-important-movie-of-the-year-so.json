{
  "slug": "a-minecraft-movie-is-the-most-important-movie-of-the-year-so",
  "title": "‘A Minecraft Movie’ Is the Most Important Movie of the Year So Far. And These Flicks Are the Best …",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-04-07",
  "runtimeMin": 90,
  "format": "Sean argues that a bad Minecraft movie is the best news cinema has had all year, then walks Amanda through the first quarter's actual highlights.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘A Minecraft Movie’ and the State of Cinema",
      "note": "the important, not good, movie",
      "films": [
        {
          "title": "A Minecraft Movie",
          "year": 2025,
          "note": "Jared Hess directs Jack Black and Jason Momoa; $301M opening weekend. Sean calls it borderline bad but essential: a chicken-jockey phenomenon that got kids losing their minds in theaters again. The peg for a long talk about kids' movies, the death of the middle, and TV briefly beating film."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Best Movies of the Year So Far",
      "note": "a grim Q1, salvaged",
      "films": [
        {
          "title": "Black Bag",
          "year": 2025,
          "note": "Soderbergh's spy-marriage puzzle; Sean's easy pointer for the year's best. Loves the lie-detector set piece, cools on the final five minutes and Regé-Jean Page's tell."
        },
        {
          "title": "Misericordia",
          "year": 2024,
          "note": "Alain Guiraudie's French drama about a drifter who returns home and starts killing. Sean calls it a movie for the sickos: closer to real murder than movie murder."
        },
        {
          "title": "The Ballad of Wallis Island",
          "year": 2025,
          "note": "Tim Key and Tom Basden wrote and star; Carey Mulligan supports. A superfan flies a folk musician to a deserted island. Sweeter than the creepy setup suggests."
        },
        {
          "title": "The Assessment",
          "year": 2024,
          "note": "Soft sci-fi with Alicia Vikander playing a fertility assessor who acts like a toddler in Elizabeth Olsen and Himesh Patel's home. Sean, a parent of a three-year-old, was floored by Vikander's performance."
        },
        {
          "title": "Seven Veils",
          "year": 2025,
          "note": "Atom Egoyan reunites with Amanda Seyfried, here a theater director. Mixed, but Sean recommends it for Seyfried."
        },
        {
          "title": "On Becoming a Guinea Fowl",
          "year": 2024,
          "note": "Rungano Nyoni's Zambian film about a woman who finds her uncle's body in the road; absurdist streaks under the grief. Saw it with a packed Vidiots house."
        },
        {
          "title": "One of Them Days",
          "year": 2025,
          "note": "Lawrence Lamont directs SZA (film debut) and Keke Palmer; Issa Rae produces. Sean's pick for second-best studio movie of the year, in a Friday lineage."
        },
        {
          "title": "Presence",
          "year": 2024,
          "note": "Soderbergh's second on the list, shot entirely from the ghost's POV, with Soderbergh himself on camera in grippy socks."
        },
        {
          "title": "The Dead Thing",
          "year": 2024,
          "note": "Elric Kane's directorial debut, on Shudder. A dating-app parable dressed as an ambient anxiety thriller."
        },
        {
          "title": "The Rule of Jenny Pen",
          "year": 2025,
          "note": "James Ashcroft's retirement-home horror with John Lithgow terrorizing a bedridden Geoffrey Rush via a possessed doll. Lithgow in full monster mode, with a dance number."
        },
        {
          "title": "Mickey 17",
          "year": 2025,
          "note": "Bong Joon Ho's sci-fi comedy. Not his best, buried under Warner Bros. release-delay angst, but Sean liked it. Robert Pattinson forever."
        },
        {
          "title": "Kinda Pregnant",
          "year": 2025,
          "note": "Amy Schumer's Netflix comedy. She steals a fake bump and fakes a pregnancy. Better than expected; all the bits land."
        }
      ]
    }
  ],
