{
  "slug": "the-monster-movie-hall-of-fame-and-the-invisible-man-the-big",
  "title": "The Monster Movie Hall of Fame and 'The Invisible Man'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Adam Nayman"
  ],
  "published": "2020-02-28",
  "runtimeMin": 84,
  "format": "Sean and critic Adam Nayman build a Monster Movie Hall of Fame, five picks apiece, running chronologically from King Kong to The Mist. Then Leigh Whannell on turning The Invisible Man into a stalker thriller told from the victim's side.",
  "segments": [
    {
      "kind": "halloffame",
      "heading": "The Monster Movie Hall of Fame",
      "honoree": "Monster movies",
      "note": "five picks each, chronological",
      "films": [
        {
          "title": "King Kong",
          "year": 1933,
          "note": "Adam's pick. Monster as pure spectacle: stop-motion built for a giant screen, and somehow still sympathetic even as he's smashing people into paste."
        },
        {
          "title": "Cat People",
          "year": 1942,
          "note": "Adam's pick. A Val Lewton production directed by Jacques Tourneur, working the suggestion-over-effects route his low budgets forced on him."
        },
        {
          "title": "Creature from the Black Lagoon",
          "year": 1954,
          "note": "Adam's pick, directed by Jack Arnold. The underwater-stalking template Jaws would run with. Per Adam, it's also the movie Guillermo del Toro's Shape of Water waters down."
        },
        {
          "title": "Jaws",
          "year": 1975,
          "note": "Sean's pick, and by his own account his favorite movie period. His case: the shark doesn't mean anything, and that's exactly why it works."
        },
        {
          "title": "Dawn of the Dead",
          "year": 1978,
          "note": "Sean's pick. George Romero's consumerism satire, with Tom Savini's gore effects doing as much talking as the metaphor."
        },
        {
          "title": "Alien",
          "year": 1979,
          "note": "Sean's pick. H.R. Giger's design work on a creature Adam calls monster as lack of character: there's no reading its motives, only its shape."
        },
        {
          "title": "The Evil Dead",
          "year": 1981,
          "note": "Adam's pick, Sam Raimi's debut. The monster here is a book (the Necronomicon), not a body. Edited by a pre-Blood Simple Joel Coen."
        },
        {
          "title": "The Thing",
          "year": 1982,
          "note": "Sean's pick, John Carpenter's remake. Rob Bottin's transformation effects opened the same summer as E.T. and got buried for it."
        },
        {
          "title": "The Fly",
          "year": 1986,
          "note": "Sean's pick. David Cronenberg and Jeff Goldblum, produced by Mel Brooks. It's the one on the list that gets Sean, by his own admission."
        },
        {
          "title": "The Mist",
          "year": 2007,
          "note": "Adam's closing pick. Frank Darabont's Stephen King adaptation. Both hosts prefer watching it in the black-and-white cut."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Leigh Whannell on 'The Invisible Man'",
      "guest": "Leigh Whannell on",
      "films": [
        {
          "title": "The Invisible Man",
          "year": 2020,
          "note": "Writer-director Leigh Whannell moves the story to the victim's point of view, with Elisabeth Moss carrying it. The invisibility effects mix CGI with 1930s-style practical tricks: a stunt performer in a green suit, a crew member pulling a wire from inside a cabinet."
        }
      ]
    }
  ],
