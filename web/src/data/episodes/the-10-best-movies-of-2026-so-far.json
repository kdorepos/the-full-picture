{
  "slug": "the-10-best-movies-of-2026-so-far",
  "title": "The 10 Best Movies of 2026 … So Far",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2026-06-29",
  "runtimeMin": 160,
  "type": "list",
  "spotifyEpisodeId": "3ihApo7QbcIq3cK9tzC4pk",
  "format": "The mid-year check-in: Sean and Amanda gather a roster of Ringer critics, and each one champions a single favorite film of 2026 so far — blockbusters, indies, and one controversial pick. A running bit: whoever answered the group text last lost their #1 to Rob Mahoney. It closes with Sean's conversation with John Early about his directorial debut.",
  "picks": [
    {
      "by": "Chris Ryan",
      "title": "28 Years Later: The Bone Temple",
      "year": 2026,
      "note": "Nia DaCosta's follow-up to Danny Boyle — a grief-soaked Ralph Fiennes / Jack O'Connell two-hander that trades kinetics for dread."
    },
    {
      "by": "Joanna Robinson",
      "title": "Project Hail Mary",
      "year": 2026,
      "note": "Lord & Miller; Ryan Gosling and Rocky the puppet. The year's 'movies are back' hit, with a real supporting-actor case for its puppeteer."
    },
    {
      "by": "Charles Holmes",
      "title": "The Furious",
      "year": 2026,
      "note": "A $20M martial-arts set-piece machine — the choreography is the story, building to a delirious five-way split-frame finale."
    },
    {
      "by": "Mallory Rubin",
      "title": "Disclosure Day",
      "year": 2026,
      "note": "Spielberg's divisive UFO movie — less about aliens than about what haunts a kid into adulthood. A knockout Emily Blunt."
    },
    {
      "by": "Van Lathan",
      "title": "Masters of the Universe",
      "year": 2026,
      "note": "His real #1 (The Drama) got sniped, so: a flawed, earnest He-Man that lands 'I have the power' hard enough to move him anyway."
    },
    {
      "by": "Adam Nayman",
      "title": "Maddie's Secret",
      "year": 2026,
      "note": "John Early's debut — Douglas Sirk by way of a Lifetime movie, camp with real feeling. Sincere and satirical at once."
    },
    {
      "by": "Yasi Salek",
      "title": "Backrooms",
      "year": 2026,
      "note": "A24's post-language liminal-space horror born from a 4chan meme — a Rorschach test that rewards not knowing the lore."
    },
    {
      "by": "Rob Mahoney",
      "title": "The Drama",
      "year": 2026,
      "note": "The episode's 'villain,' who stole nearly everyone's pick — a gall-filled anti-rom-com about the unknowability of a partner."
    },
    {
      "by": "Jack Sanders",
      "title": "Blue Heron",
      "year": 2026,
      "note": "Sophie Romvari's tender debut about a family and its difficult kid, told through a younger sister's memory. Extraordinary sound design."
    },
    {
      "by": "Amanda Dobbins",
      "title": "Obsession",
      "year": 2026,
      "note": "The $300M horror phenomenon — funnier and smarter than she expected, and an education in what the genre can be. A titanic Indy Navarrete."
    },
    {
      "by": "Sean Fennessey",
      "title": "Nirvana the Band the Show the Movie",
      "year": 2026,
      "note": "Matt Johnson's absurdist, secretly poignant comedy about looking back at who you used to be. His movie of the year, seen three times."
    }
  ],
  "interview": {
    "guest": "John Early",
    "title": "Maddie's Secret",
    "note": "Sean sits down with the writer-director about his feature debut — its Sirk / Todd Haynes / John Waters DNA, the freedom of making a movie with no notes, and why he wants to prioritize filmmaking going forward."
  },
