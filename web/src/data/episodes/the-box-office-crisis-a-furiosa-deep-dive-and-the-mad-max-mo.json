  "published": "2024-05-28",
  "runtimeMin": 91,
  "format": "Sean Fennessey opens on the worst Memorial Day box office in 30 years, then Chris Ryan and Joanna Robinson join for a spoiler-heavy 'Furiosa' postmortem and a ranking of all five Mad Max movies.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The box office crisis",
      "note": "Sean, solo, on the worst Memorial Day since 1995",
      "films": [
        {
          "title": "The Garfield Movie",
          "year": 2024,
          "note": "The weekend's other wide release; the two new films combined for about $62M over four days."
        },
        {
          "title": "The Fall Guy",
          "year": 2024,
          "note": "$145M worldwide on a reported $140M budget, headed to VOD 17 days after opening. Sean's case study for shrinking windows."
        },
        {
          "title": "Hit Man",
          "year": 2024,
          "note": "The Linklater/Glen Powell crowd-pleaser no studio would buy; Netflix paid about $20M and it lands on streaming instead of the theater it was built for."
        },
        {
          "title": "Civil War",
          "year": 2024,
          "note": "Crossed $100M, close to a miracle for A24."
        },
        {
          "title": "Challengers",
          "year": 2024,
          "note": "Past $80M despite already being available at home."
        },
        {
          "title": "Dune: Part Two",
          "year": 2024,
          "note": "$700M worldwide, the counterexample to the doom."
        },
        {
          "title": "Anyone but You",
          "year": 2023,
          "note": "The recent mini-phenomenon with young moviegoers."
        },
        {
          "title": "Anora",
          "year": 2024,
          "note": "Sean Baker's Palme d'Or winner, the first American film to take it since The Tree of Life, reportedly an homage to Pretty Woman."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "A 'Furiosa' deep dive",
      "note": "with Chris Ryan and Joanna Robinson, full spoilers",
      "films": [
        {
          "title": "Furiosa: A Mad Max Saga",
          "year": 2024,
          "note": "All three like it, none love it. Praise for the war-rig chase and the Bulltown ambush; complaints about a missing arc for Furiosa, the skipped 40-day war, and Dementus (Chris Hemsworth's nose splitting the room)."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "The Mad Max movie rankings",
      "note": "Sean and Chris's consensus order, best to worst",
      "subject": "Mad Max",
      "ranked": true,
      "films": [
        {
          "title": "Mad Max: Fury Road",
          "year": 2015,
          "note": "No. 1 and not close. Sean compares it to Lawrence of Arabia; no one would trade it for three more Mel Gibson sequels."
        },
        {
          "title": "Mad Max 2",
          "year": 1981,
          "note": "The Road Warrior. Joanna's No. 1 and the group's clear runner-up, the grimy outback original everyone remembers."
        },
        {
          "title": "Furiosa: A Mad Max Saga",
          "year": 2024,
          "note": "No. 3 for Sean and Chris; Chris actually slots it below Thunderdome as a 'born in the '70s' call."
        },
        {
          "title": "Mad Max",
          "year": 1979,
          "note": "The raw, Straw Dogs-dark black-and-white sketch of everything that followed. Admired, rarely rewatched."
        },
        {
          "title": "Mad Max Beyond Thunderdome",
          "year": 1985,
          "note": "Last. Half of it works (Bartertown, trial by combat); the kids sink the rest."
        }
      ]
    }
