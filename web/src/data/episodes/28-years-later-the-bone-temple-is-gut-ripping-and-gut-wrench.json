    {
      "kind": "discussion",
      "heading": "'The Testament of Ann Lee'",
      "note": "before the Mona Fastvold interview",
      "films": [
        {
          "title": "The Testament of Ann Lee",
          "year": 2025,
          "note": "Mona Fastvold and Brady Corbet's 'forced musical' about the Shaker founder, with Amanda Seyfried in the lead role. Sean and Amanda both liked it; Sean clicked with it most of the three Corbet/Fastvold films."
        },
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "The obvious companion piece, written after 'Ann Lee' but released first; both are about trauma, faith, and immigrating to America."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Mona Fastvold on",
      "films": [
        {
          "title": "The Testament of Ann Lee",
          "year": 2025,
          "note": "Fastvold on finding Ann Lee via Shaker hymns, the 'speculative retelling' of an illiterate figure, using a hand-painted matte and a real Swedish tall ship to keep the epic on an indie budget, and on Amanda Seyfried's year of accent, dance, and singing prep. Distributed by Searchlight."
        },
        {
          "title": "The World to Come",
          "year": 2020,
          "note": "Fastvold's earlier film; researching its 1856 setting led her to the Shakers and Ann Lee."
        },
        {
          "title": "The Lovers on the Bridge",
          "year": 1991,
          "note": "Leos Carax's film, Fastvold's last-great-thing; she presented a print in Sag Harbor and it moved her to tears."
