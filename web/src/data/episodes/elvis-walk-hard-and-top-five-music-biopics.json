{
  "slug": "elvis-walk-hard-and-top-five-music-biopics",
  "title": "‘Elvis,’ ‘Walk Hard’ and Top Five Music Biopics",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Adam Nayman"
  ],
  "published": "2022-06-24",
  "runtimeMin": 79,
  "format": "Sean and Amanda review Baz Luhrmann's Elvis, then Adam Nayman joins to make the case for Walk Hard and each host ranks a top five music biopics.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Elvis’",
      "note": "Sean and Amanda",
      "films": [
        {
          "title": "Elvis",
          "year": 2022,
          "note": "Baz Luhrmann's first film since Gatsby, and his most maximalist: 2 hours 40 minutes that both drag and blur past. Austin Butler is the reason to see it; Tom Hanks' accent-heavy Colonel Parker framing turns Elvis into a supporting player and, both hosts agree, sinks the movie."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "‘Walk Hard’ and the state of the music biopic",
      "note": "with Adam Nayman",
      "films": [
        {
          "title": "Walk Hard: The Dewey Cox Story",
          "year": 2007,
          "note": "A $20M box-office flop turned cult object; a note-for-note demolition of Walk the Line and Ray with real affection. The songs (Dan Bern and Mike Viola of the Candy Butchers, plus Marshall Crenshaw) are good enough to pass as the real thing. Elvis even restages the shirt-ripping scene Walk Hard already parodied."
        },
        {
          "title": "This Is Spinal Tap",
          "year": 1984,
          "note": "Nayman's spiritual sibling to Walk Hard: a band with no principles that becomes whatever the decade demands."
        },
        {
          "title": "Popstar: Never Stop Never Stopping",
          "year": 2016,
          "note": "The Lonely Island's millennial take; Spinal Tap → Walk Hard → Popstar as an 'instructive little trilogy' about the packaging of pop."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top Five Music Biopics",
      "subject": "music biopics",
      "ranked": true,
      "films": [
        {
          "title": "Walk the Line",
          "year": 2005,
          "note": "No. 1 - straight down the middle, cradle to grave, and it works; Phoenix and Witherspoon do their own singing."
        },
        {
          "title": "Amadeus",
          "year": 1984,
          "note": "No. 2 - shared with Sean. Conveys the genius, not the man; Salieri's envy carries it."
        },
        {
          "title": "Love & Mercy",
          "year": 2014,
          "note": "No. 3 - two Brian Wilsons (Paul Dano, John Cusack) that dodge the Wikipedia through-line."
        },
        {
          "title": "La Vie en Rose",
          "year": 2007,
          "note": "No. 4 - Marion Cotillard as Édith Piaf; a pure incarnation piece."
        },
        {
          "title": "Selena",
          "year": 1997,
          "note": "No. 5 - Gregory Nava's film, and the breakout that gave us Jennifer Lopez."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five Music Biopics",
      "subject": "music biopics",
      "ranked": true,
      "films": [
        {
          "title": "I'm Not There",
          "year": 2007,
          "note": "No. 1 - Todd Haynes' seven Dylans; deconstruction over reconstruction, with Cate Blanchett the best of the seven."
        },
        {
          "title": "Amadeus",
          "year": 1984,
          "note": "No. 2 - shared with Amanda."
        },
        {
          "title": "Sid and Nancy",
          "year": 1986,
          "note": "No. 3 - Adam's No. 1; Gary Oldman and Chloe Webb, harrowing."
        },
        {
          "title": "24 Hour Party People",
          "year": 2002,
          "note": "No. 4 - shared with Adam."
        },
        {
          "title": "Behind the Candelabra",
          "year": 2013,
          "note": "No. 5 - Soderbergh's Liberace; skips the rise and lives entirely in the excess."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Adam Nayman's Top Five Music Biopics",
      "subject": "music biopics",
      "ranked": true,
      "films": [
        {
          "title": "Sid and Nancy",
          "year": 1986,
          "note": "No. 1 - Alex Cox; the last 15 minutes are almost unwatchable, and it gets away with it completely."
        },
        {
          "title": "I'm Not There",
          "year": 2007,
          "note": "No. 2 - shared with Sean."
        },
        {
          "title": "Bird",
          "year": 1988,
          "note": "No. 3 - Eastwood's Charlie Parker; Forest Whitaker won Best Actor at Cannes."
        },
        {
          "title": "24 Hour Party People",
          "year": 2002,
          "note": "No. 4 - Winterbottom and Coogan; an annotated, self-mocking Manchester scene film."
        },
        {
          "title": "Coal Miner's Daughter",
          "year": 1980,
          "note": "No. 5 - Sissy Spacek as Loretta Lynn, doing her own singing."
        }
      ]
    }
