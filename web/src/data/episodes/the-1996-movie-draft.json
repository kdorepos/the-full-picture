            {
              "title": "Happy Gilmore",
              "year": 1996,
              "category": "Comedy",
              "note": "a comedy Sean has loved since 14 and still does."
            },
            {
              "title": "That Thing You Do!",
              "year": 1996,
              "category": "Oscar Nominee",
