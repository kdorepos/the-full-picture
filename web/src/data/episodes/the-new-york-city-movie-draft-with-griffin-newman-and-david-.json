            {
              "title": "Michael Clayton",
              "year": 2007,
              "category": "Oscar Winner",
              "note": "Tilda Swinton, the film's lone Oscar."
            },
            {
              "title": "You've Got Mail",
              "year": 1998,
              "category": "Blockbuster",
              "note": "Ephron; the Upper West Side and the Barnes & Noble that eats the small bookstore."
            },
            {
              "title": "Frances Ha",
              "year": 2013,
              "category": "Subway",
              "note": "Baumbach; the subway scene where Sophie says she's moving out."
            }
          ]
        },
        {
          "host": "Griffin Newman",
          "picks": [
            {
              "title": "Sully",
              "year": 2016,
              "category": "Drama",
              "note": "Eastwood; a handwritten card, drafted from the heart. The five days he's stuck in the city."
            },
            {
              "title": "The Muppets Take Manhattan",
              "year": 1984,
              "category": "Comedy",
              "note": "Small-town Muppets come to town and get their asses kicked, then regroup."
