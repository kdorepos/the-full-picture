{
  "slug": "the-evil-in-longlegs-and-the-serial-killer-movie-canon",
  "title": "The Evil in ‘Longlegs’ and the Serial Killer Movie Canon",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Rob Mahoney"
  ],
  "published": "2024-07-12",
  "runtimeMin": 104,
  "format": "Sean Fennessey and Rob Mahoney review Osgood Perkins's 'Longlegs,' then build a 10-film serial-killer-movie canon. Sean closes with Perkins on Nicolas Cage, the shadow of his father's 'Psycho,' and hiding something true inside a horror movie.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Longlegs'",
      "note": "Osgood Perkins's serial-killer movie, with Rob Mahoney",
      "films": [
        {
          "title": "Longlegs",
          "year": 2024,
          "note": "Perkins's fourth feature: Maika Monroe as a 1990s FBI agent working a Clarice Starling-style case, Nicolas Cage as the titular killer, with Alicia Witt as Lee's mother and Blair Underwood. Sean and Rob call it a serial-killer thriller that subverts itself, a dread machine that wrong-foots its own puzzle-solving and turns out to be about parenthood, about what a mother will hide. Cage plays him as a pathetic glam-rock creep rather than a Hannibal Lecter; the killer is almost incidental to the movie named after him. A week later Sean woke in the night seeing Cage's face."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The serial killer movie canon",
      "note": "10 films, roughly by era, not ranked",
      "subject": "serial killer movies",
      "films": [
        {
          "title": "M",
          "year": 1931,
          "note": "Fritz Lang's, Peter Lorre as a child murderer hunted through Germany. One of the films the whole genre is built on."
        },
        {
          "title": "Psycho",
          "year": 1960,
          "note": "Hitchcock's, starring Perkins's father Anthony Perkins. Famous for a flimsy psychiatrist-explains-it-all ending the movie outlives on craft alone, and still referenced everywhere seven decades on."
        },
        {
          "title": "Klute",
          "year": 1971,
          "note": "Alan Pakula's, a killer stalking a prostitute and the man trying to protect her, with Donald Sutherland (RIP) and a deeply uncomfortable turn from Charles Cioffi. Sean's under-seen pick: more influential than popular, a clear line to Demme and Fincher."
        },
        {
          "title": "Henry: Portrait of a Serial Killer",
          "year": 1986,
          "note": "John McNaughton's, Michael Rooker as a man compelled to kill. Little seen, hugely influential, and gets under your skin more than Longlegs does. The version where you spend the whole time with the killer."
        },
        {
          "title": "The Silence of the Lambs",
          "year": 1991,
          "note": "The best pure serial-killer movie ever made, per Sean. A lock."
        },
        {
          "title": "Se7en",
          "year": 1995,
          "note": "Fincher's, and probably the most influential of all of these on what the modern version of the genre looks like. A lock."
        },
        {
          "title": "Funny Games",
          "year": 1997,
          "note": "Haneke's original Austrian version, two polite punks in gloves torturing a family and then starting over with the next one. The home-invasion, elbow-in-the-ribs entry."
        },
        {
          "title": "American Psycho",
          "year": 2000,
          "note": "Mary Harron's, the gonzo-satire slot alongside Funny Games and Natural Born Killers. Smashes desire and violence together and tells you you're gross for watching."
        },
        {
          "title": "Memories of Murder",
          "year": 2003,
          "note": "Bong Joon-ho's investigation drama, hugely influential on Zodiac. The pass-the-baton partner to Fincher, and about what solving these crimes does to the people who try."
        },
        {
          "title": "Zodiac",
          "year": 2007,
          "note": "Fincher again, less about the kills than the toll of the case. Sean rates the picnic murder among the scariest things he's seen; the second Fincher the canon couldn't avoid."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Oz Perkins on 'Longlegs'",
      "note": "the director, in conversation",
      "guest": "Osgood Perkins on",
      "films": [
        {
          "title": "Longlegs",
          "year": 2024,
          "note": "Perkins on approaching it like a crossword, aping Silence of the Lambs as an 'admit-one ticket' before turning left; Cage reading the script and insisting on doing every word as written, then meeting him on the T. Rex idea. The design was easy, he says, the killer built as a gross nobody the devil found through the amp, not an omniscient force. Underneath: a movie about a parent hiding a huge thing from a child, unlocked years earlier watching 'Eraserhead' as a new father."
        },
        {
          "title": "The Blackcoat's Daughter",
          "year": 2017,
          "note": "His debut, which he hated until the sound mix saved it. About losing your parents."
        },
        {
          "title": "I Am the Pretty Thing That Lives in the House",
          "year": 2016,
          "note": "About wanting to know someone who's gone, and how hard that is once they are."
        },
        {
          "title": "Gretel & Hansel",
          "year": 2020,
          "note": "The one he didn't write and feels he missed, a chance to make a movie about a mother who deceives a child out of love."
        },
        {
          "title": "The Monkey",
          "year": 2025,
          "note": "His Stephen King movie with the Longlegs crew, bought by Neon out of a Cannes bidding war. Three features in fifteen months."
        }
      ]
    }
  ],
