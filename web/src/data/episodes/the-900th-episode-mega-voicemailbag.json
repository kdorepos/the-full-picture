    {
      "kind": "review",
      "heading": "You, Me, and Tuscany",
      "note": "Amanda saw it; Sean skipped it",
      "films": [
        {
          "title": "You, Me, and Tuscany",
          "year": 2026,
          "note": "Kat Coiro; Halle Bailey and Regé-Jean Page in a fake-engagement-in-Tuscany rom-com. Amanda: shot in Tuscany but 'otherwise really is a Hallmark movie,' with no chemistry or imagination and a filmed-for-TV look. A streaming movie put in theaters."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "The Christophers",
      "note": "the new Soderbergh",
      "films": [
        {
          "title": "The Christophers",
          "year": 2026,
          "note": "Ian McKellen as an aging artist, Michaela Coel as the forger his estranged kids hire to finish his paintings. Ed Solomon script. Amanda's art-caper wheelhouse; Sean muter: 'a little iterative,' the latest trapped-in-a-house Soderbergh."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Blue Heron",
      "note": "Sean's favorite movie of 2026 so far",
      "films": [
        {
          "title": "Blue Heron",
          "year": 2026,
          "note": "Sophy Romvari's autobiographical debut on Vancouver Island, an 8-year-old's-eye family drama that takes a structural swing at the midpoint. Sean's favorite of 2026 so far; Amanda 'quite moved,' still thinking about it in her own life."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Sophy Romvari on Blue Heron",
      "note": "the writer-director on her debut",
      "guest": "Sophy Romvari on",
      "films": [
        {
          "title": "Blue Heron",
          "year": 2026,
          "note": "The feature: naturalism via a long zoom lens shot from a distance, a phone-to-phone cut that jumps 20 years forward, and a brother, Jeremy, deliberately unlike her own."
        },
        {
          "title": "Ponette",
          "year": 1996,
          "note": "A childhood-grief film her parents showed her too young, the kind of art film that opened up what movies could be."
        },
        {
          "title": "La Cérémonie",
          "year": 1995,
          "note": "Chabrol; her parents' Huppert and Bonnaire fandom."
        },
        {
          "title": "Symbiopsychotaxiplasm",
          "year": 1968,
          "note": "A documentary/fiction-blur influence: deconstruction inside the film itself."
        },
        {
          "title": "Chronicle of a Summer",
          "year": 1961,
          "note": "Rouch; an early influence on her interest in the access to authenticity."
        },
        {
          "title": "Still Processing",
          "note": "Her short 'made for my parents'; Blue Heron's second half fictionalizes the making of it."
        },
        {
          "title": "Pumpkin Movie",
          "note": "Budget: 'literally 2 pumpkins,' shot in a friend's apartment over Skype."
        },
        {
          "title": "Norman Norman",
          "note": "A short about her aging dog, filmed in a couple of hours."
        },
        {
          "title": "To the West, in Zapata",
          "note": "The Cuban doc (David Bim) her jury gave a festival's top prize, her 'last great thing.'",
          "year": 2025
        }
      ]
    }
