{
  "slug": "the-five-most-important-movies-at-sundance-the-big-picture",
  "title": "The Five Most Important Movies at Sundance",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-01-31",
  "runtimeMin": 77,
  "format": "Sean Fennessey and Amanda Dobbins sort what they saw at the 2020 Sundance Film Festival into five recurring types of Sundance movie, run through what sold and what flopped, then Sean talks to Never Rarely Sometimes Always director Eliza Hittman.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The family drama",
      "note": "the first Sundance archetype",
      "films": [
        {
          "title": "Winter's Bone",
          "year": 2010,
          "note": "A 'more severe' precedent for the archetype."
        },
        {
          "title": "Fruitvale Station",
          "year": 2013,
          "note": "Another severe precedent."
        },
        {
          "title": "Affliction",
          "year": 1997,
          "note": "Another severe precedent."
        },
        {
          "title": "Big Night",
          "year": 1996,
          "note": "The 'lighthearted' precedent."
        },
        {
          "title": "Take Shelter",
          "year": 2011,
          "note": "The 'genre-fied' precedent."
        },
        {
          "title": "Minari",
          "year": 2020,
          "note": "Lee Isaac Chung's A24 film about a Korean American family moving to Arkansas in the 1980s, starring Steven Yeun and Han Ye-ri, with Will Patton as a local farmhand named Paul. Both hosts call it one of the best films of the festival, singling out the child performance from Alan Kim and the film's specificity and restraint."
        },
        {
          "title": "The Farewell",
          "year": 2019,
          "note": "Raised as a comparison for Minari's three-generations, culture-clash story."
        },
        {
          "title": "Burning",
          "year": 2018,
          "note": "Steven Yeun's prior lead role, floated as a thematically related double feature with Minari."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The adult-oriented comedy",
      "films": [
        {
          "title": "Four Weddings and a Funeral",
          "year": 1994
        },
        {
          "title": "In Bruges",
          "year": 2008,
          "note": "Martin McDonagh's 'nasty, hilarious' assassin comedy, cited as a career highlight before Three Billboards."
        },
        {
          "title": "500 Days of Summer",
          "year": 2009
        },
        {
          "title": "Garden State",
          "year": 2004,
          "note": "Directed by Zach Braff."
        },
        {
          "title": "Downhill",
          "year": 2020,
          "note": "Julia Louis-Dreyfus and Will Ferrell in a remake of Ruben Östlund's Force Majeure, about a father who abandons his family during a false avalanche scare on a ski trip. Both praise the leads' more serious register and the cinematography, and note it's the first release under Fox Searchlight's new logo."
        },
        {
          "title": "Force Majeure",
          "year": 2014,
          "note": "The Ruben Östlund original that Downhill remakes."
        },
        {
          "title": "Palm Springs",
          "year": 2020,
          "note": "Produced with the Lonely Island; neither host had seen it yet, but word was it sold for a huge sum."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The provocation",
      "films": [
        {
          "title": "Reservoir Dogs",
          "year": 1992
        },
        {
          "title": "Secretary",
          "year": 2002
        },
        {
          "title": "The Blair Witch Project",
          "year": 1999
        },
        {
          "title": "American Psycho",
          "year": 2000
        },
        {
          "title": "The Raid 2",
          "year": 2014
        },
        {
          "title": "Zola",
          "year": 2020,
          "note": "Janicza Bravo's adaptation of the viral Twitter thread about a stripper's road trip to Florida, scored by Mica Levi. Both praise its sensory-overload style and how well it keeps moving."
        },
        {
          "title": "Assassination Nation",
          "year": 2018,
          "note": "Sam Levinson's earlier, less successful stab at similar sensory overload."
        },
        {
          "title": "Spring Breakers",
          "year": 2012,
          "note": "Cited, and dismissed, as a comparison for Zola."
        },
        {
          "title": "Moonlight",
          "year": 2016,
          "note": "Part of the 'A24 Florida movies' lineage Zola extends."
        },
        {
          "title": "The Florida Project",
          "year": 2017,
          "note": "Same lineage."
        },
        {
          "title": "Waves",
          "year": 2019,
          "note": "Same lineage."
        },
        {
          "title": "Promising Young Woman",
          "year": 2020,
          "note": "Emerald Fennell's revenge film starring Carey Mulligan, discussed carefully to avoid spoiling it."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The issues-oriented documentary",
      "films": [
        {
          "title": "The Celluloid Closet",
