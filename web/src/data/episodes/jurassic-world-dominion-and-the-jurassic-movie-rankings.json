{
  "slug": "jurassic-world-dominion-and-the-jurassic-movie-rankings",
  "title": "'Jurassic World: Dominion' and the Jurassic Movie Rankings",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Bryan Curtis"
  ],
  "published": "2022-06-10",
  "runtimeMin": 66,
  "format": "Sean and Bryan Curtis review 'Jurassic World: Dominion,' the legacy-sequel finale that reunites the original cast, then rank all six Jurassic films from worst to first.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Jurassic World: Dominion'",
      "films": [
        {
          "title": "Jurassic World: Dominion",
          "year": 2022,
          "note": "Colin Trevorrow's globe-trotting trilogy-capper: Owen, Claire, a clone daughter, and the returning Grant/Sattler/Malcolm trio versus a biotech CEO and giant Cretaceous locusts. The hosts read it as the franchise's 'Rise of Skywalker': pre-sold, callback-stuffed, not boring but not good."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "The Jurassic Movie Rankings",
      "note": "worst to first (No. 1 first)",
      "subject": "the Jurassic franchise",
      "ranked": true,
      "films": [
        {
          "title": "Jurassic Park",
          "year": 1993,
          "note": "No. 1, unanimous. The Spielberg original: 'oh my God, they created dinosaurs' as both plot and moviegoing miracle. Dean Cundey's photography, Stan Winston and Phil Tippett's effects."
        },
        {
          "title": "Jurassic Park III",
          "year": 2001,
          "note": "Curtis's No. 2, to Sean's disbelief. Joe Johnston's blessedly short 90-minute chase movie; screenplay credit to Alexander Payne and Jim Taylor. Sean calls it mediocre but concedes it's the one you'd throw on."
        },
        {
          "title": "Jurassic World",
          "year": 2015,
          "note": "No. 3. Trevorrow's 2015 reboot: the gyrosphere balls, a new dino or two, 'a copy of a copy' but fun. Made $1.67 billion."
        },
        {
          "title": "The Lost World: Jurassic Park",
          "year": 1997,
          "note": "No. 4 for Curtis, who calls it a lazy, badly lit cash-out with some of Goldblum's worst acting; Sean would rank it higher. Kaminski replaces Cundey; the San Diego Godzilla finale lands for neither host."
        },
        {
          "title": "Jurassic World: Dominion",
          "year": 2022,
          "note": "No. 5. A Bourne/Mission: Impossible/'give me back my daughter'/bug-horror mash-up that piles on one animal too many with the locusts."
        },
        {
          "title": "Jurassic World: Fallen Kingdom",
          "year": 2018,
          "note": "Last. J.A. Bayona's haunted-house-plus-dino-auction entry that both hosts basically blacked out on; the movie that started the running 'what even happened' bit."
        }
      ]
    }
  ],
