{
  "slug": "four-ways-of-looking-at-an-action-movie-the-accountant-2-hav",
  "title": "Four Ways of Looking at an Action Movie: ‘The Accountant 2,’ ‘Havoc,’ ‘A Working Man,’ and ‘The Amateur’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2025-04-28",
  "runtimeMin": 82,
  "format": "Sean, Amanda, and Chris work through four action movies from the same few weeks: 'The Accountant 2,' 'Havoc,' 'A Working Man,' and 'The Amateur,' after an opening on the 'Sinners' box-office run and the 'Revenge of the Sith' re-release.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Is moviegoing actually back?",
      "note": "Sinners, a Sith re-release, and the case for events",
      "films": [
        {
          "title": "Sinners",
          "year": 2025,
          "note": "Down only 5% week over week and past $100M. The hosts read it as word-of-mouth working and proof Ryan Coogler can now sell a movie on his name."
        },
        {
          "title": "Star Wars: Episode III - Revenge of the Sith",
          "year": 2005,
          "note": "The 20th-anniversary re-release made $25M. Sean calls it his favorite prequel while still not a great movie; Chris calls it a generational touchstone, a new hope for people now in their 20s and 30s."
        },
        {
          "title": "One Battle After Another",
          "year": 2025,
          "note": "Floated as the next possible event movie: same studio conceit, a strong-vision filmmaker, and Leo, though nobody's seen it yet."
        },
        {
          "title": "A Minecraft Movie",
          "year": 2025,
          "note": "Quietly closing on a billion dollars: roughly $800M in three weeks, a number Sean once nearly skipped covering."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘The Accountant 2’",
      "note": "Rain Man meets Commando",
      "films": [
        {
          "title": "The Accountant 2",
          "year": 2025,
          "note": "Gavin O'Connor and Ben Affleck's sequel, with Jon Bernthal as lethal brother Brax; Affleck's company and Amazon MGM produced. Sean found it one of the most convoluted mainstream movies in a while: a buddy comedy that lurches into a Juarez human-trafficking plot, plus a savant assassin and a hacker army of neurodivergent kids in Hanover. Shot by Seamus McGarvey; a soft recommend as a 'five o'clock-er.'"
        },
        {
          "title": "The Accountant",
          "year": 2016,
          "note": "The 2016 O'Connor/Affleck original: an autistic forensic accountant who's also a trained killer. A surprise hit that became a dad-action cable staple."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Havoc’",
      "note": "28 minutes of Gareth Evans at full tilt",
      "films": [
        {
          "title": "Havoc",
          "year": 2025,
          "note": "Gareth Evans's Tom Hardy crime movie on Netflix, in development since roughly 2021. Chris calls the first 45 minutes ChatGPT writing a Gangs of London episode, then loses his mind over the Gaspar-noise nightclav set piece and a house fight that ends with a triad shot by a harpoon. Sean: subpar except for 28 ecstatic minutes."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘A Working Man’",
      "note": "the classical Statham vehicle",
      "films": [
        {
          "title": "A Working Man",
          "year": 2025,
          "note": "David Ayer directs, script co-written with Sylvester Stallone from Chuck Dixon's novel 'Levon's Trade.' Statham as an ex-British special-ops foreman in Chicago whose boss's daughter is taken by the Russian mob. David Harbour plays a blind ex-SEAL. Solid but straight. The hosts missed the deranged energy of 'The Beekeeper' and landed on 'pretty boring.'"
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘The Amateur’",
      "note": "68% there, and it's the last 32 that matters",
      "films": [
        {
          "title": "The Amateur",
          "year": 2025,
          "note": "James Hawes directs Rami Malek as a CIA tech operative avenging his wife (Rachel Brosnahan) after a London attack. A deep cast: Caitríona Balfe, Michael Stuhlbarg, Holt McCallany, Julianne Nicholson, Laurence Fishburne. Sean's core complaint: it needs a movie star at its center, not a number two; he'd have cast Andrew Garfield or Ben Whishaw. Set pieces (the glass pool) are strong; the whole was given away in the trailer."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Where action stands, plus a news lap",
      "note": "Miami Vice, Fountain of Youth, and a Memorial Day pileup",
      "films": [
        {
          "title": "Miami Vice",
          "year": 2006,
          "note": "A Joseph Kosinski-directed remake, Dan Gilroy scripting, was just announced without Michael Mann. Chris defends the 2006 Mann film as the superior product and stays conspicuously muted about the reboot."
        },
        {
          "title": "Fountain of Youth",
          "year": 2025,
          "note": "Guy Ritchie's national-treasure-style adventure with John Krasinski and Natalie Portman, headed straight to Apple TV+. The table can't understand why a reported ~$300M movie is skipping theaters."
        },
        {
          "title": "F1",
          "year": 2025,
          "note": "Counted among the coming tentpole action movies; Chris is sold on the footage and wants IMAX."
        },
        {
          "title": "Mission: Impossible - The Final Reckoning",
          "year": 2025,
          "note": "Sean, a self-described Mission Impossible believer, is guarding against overexposure before opening night, and wonders whether it comes in second on Memorial Day weekend."
        },
        {
          "title": "Lilo & Stitch",
          "year": 2025,
          "note": "The live-action remake tracking north of $100M, likely to outgross 'The Final Reckoning' on the same weekend: the kid market beating the grownup market."
        },
        {
          "title": "Hurry Up Tomorrow",
          "year": 2025,
          "note": "The Weeknd film; Chris will probably check it out, still nursing goodwill from 'The Idol.'"
        }
      ]
    }
  ],
