{
  "slug": "movie-swap-aliens-vs-four-weddings-and-a-funeral-the-big-pic",
  "title": "Movie Swap: 'Aliens' vs. 'Four Weddings and a Funeral'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-04-07",
  "runtimeMin": 110,
  "format": "Sean and Amanda's second movie swap: he assigns her James Cameron's Aliens, she gives him Four Weddings and a Funeral. Recorded during the March 2020 shutdown, so it opens on the emptied release calendar and what it does to the Oscars.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Swap: 'Aliens'",
      "note": "Sean's pick",
      "films": [
        {
          "title": "Aliens",
          "year": 1986,
          "note": "Sean's pick and, by his reckoning, Cameron's best. He frames it as a war movie in the mold of The Dirty Dozen, not a horror one. Amanda watched it for the first time, respected the craft, but found the dark, gun-heavy chaos a grueling sit. Nominated for seven Oscars, including Sigourney Weaver for Best Actress."
        },
        {
          "title": "Alien",
          "year": 1979,
          "note": "Ridley Scott's original, which both had seen. Amanda's point of comparison: the first film's fear is existential and unseen, where the sequel shows you dozens of xenomorphs."
        },
        {
          "title": "Alien³",
          "year": 1992,
          "note": "David Fincher's directorial debut; Sean calls it a fascinating watch and a career-altering nightmare to make."
        },
        {
          "title": "Alien Resurrection",
          "year": 1997,
          "note": "Sean finds it borderline unwatchable and won't recommend it."
        },
        {
          "title": "Prometheus",
          "year": 2012,
          "note": "An object of obsession for Sean even though he doesn't think it's good; Amanda saw it in theaters and liked its more cerebral bent."
        },
        {
          "title": "Alien: Covenant",
          "year": 2017,
          "note": "The last film in the franchise. Sean says it matches Aliens only in how disgusting it is."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Swap: 'Four Weddings and a Funeral'",
      "note": "Amanda's pick",
      "films": [
        {
          "title": "Four Weddings and a Funeral",
          "year": 1994,
          "note": "Amanda's pick, and she's stunned Sean had never seen it. Written by Richard Curtis, directed by Mike Newell; the breakout that minted Hugh Grant and, on a $4.4M budget, became the highest-grossing British film of its moment. R-rated and bawdier than the rom-coms it spawned. Sean was won over: the John Hannah funeral eulogy (Auden's 'Funeral Blues') is the scene that got him."
        },
        {
          "title": "Notting Hill",
          "year": 1999,
          "note": "Amanda's dissent: she calls it a masterpiece and the accessible 'studio version' of Four Weddings, even if not quite as good."
        }
      ]
    }
  ],
