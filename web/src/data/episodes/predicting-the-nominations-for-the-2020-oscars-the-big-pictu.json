    {
      "kind": "interview",
      "heading": "Destin Daniel Cretton on 'Just Mercy'",
      "guest": "Destin Daniel Cretton on",
      "films": [
        {
          "title": "Just Mercy",
          "year": 2019,
          "note": "Adapted from Bryan Stevenson's memoir. Cretton on Michael B. Jordan toning down his 'Black Panther'/'Creed II' physique, shooting the death-row cellblock with three synced cameras so the actors' shouted-through-the-wall friendships would read, and the one scene he and Brian dramatized beyond the facts (a courtroom reveal that was really just a fax)."
        },
        {
          "title": "Shang-Chi and the Legend of the Ten Rings",
          "year": 2021,
          "note": "Cretton's next film, brought up only in terms of how he's preparing, not what's in it."
        },
        {
          "title": "Short Term 12",
          "year": 2013,
          "note": "Cretton's breakout; he name-checks its LaKeith Stanfield and Rami Malek discovery pipeline."
        },
        {
          "title": "The Glass Castle",
          "year": 2017
        },
        {
          "title": "Innerspace",
          "year": 1987,
          "note": "The movie that blew Cretton's mind as a kid growing up on Maui: he was young enough to think miniaturized submarines in the bloodstream were real."
        },
        {
          "title": "Aladdin",
          "year": 2019,
          "note": "The last great thing Cretton saw, on a flight to Sydney. He went in expecting to hate it and came out sold on Will Smith."
        }
      ]
    }
