        },
        {
          "title": "Home Alone",
          "year": 1990,
          "note": "No. 3 (tied) - the John Hughes half of a double pick for early childhood."
        },
        {
          "title": "Ferris Bueller's Day Off",
          "year": 1986,
          "note": "No. 3 (tied) - possibly her favorite movie; she's already resigned to Knox being a Cameron, not a Ferris."
