        },
        {
          "title": "The Social Network",
          "year": 2010,
          "note": "Offered as another clip reel that stands alone, from the opening breakup on down."
        },
        {
          "title": "A Few Good Men",
          "year": 1992,
          "note": "The 'you can't handle the truth' VHS-rewind scene all three name in their top four."
        },
        {
          "title": "The Big Short",
          "year": 2015,
          "note": "Bobby's pick: Ryan Gosling chucking the Jenga blocks, after which, he says, he needs nothing else from the movie."
        },
        {
          "title": "The Sound of Music",
          "year": 1965,
          "note": "Sean's childhood VHS-rewind ritual, and the movie Amanda admits she doesn't much like."
        },
        {
          "title": "Deconstructing Harry",
          "year": 1997,
          "note": "Cited as a diss movie: Woody Allen aimed at Philip Roth, nasty and dyspeptic."
        },
        {
          "title": "Irreconcilable Differences",
          "year": 1984,
