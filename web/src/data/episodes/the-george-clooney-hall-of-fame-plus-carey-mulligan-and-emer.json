  "slug": "the-george-clooney-hall-of-fame-plus-carey-mulligan-and-emer",
  "title": "The George Clooney Hall of Fame. Plus: Carey Mulligan and Emerald Fennell!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-12-23",
  "runtimeMin": 113,
  "format": "Ten movies to enshrine George Clooney, then Carey Mulligan and Emerald Fennell on Promising Young Woman.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Will Dune skip HBO Max?",
      "note": "breaking news",
      "films": [
        {
          "title": "Dune",
          "year": 2021,
          "note": "Reports out of a Deadline Q&A suggest it might dodge Warner Bros.' day-and-date HBO Max plan, likely thanks to a contract dispute with Legendary."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "The Midnight Sky",
      "films": [
        {
          "title": "The Midnight Sky",
          "year": 2020,
          "note": "Clooney directs and stars as a scientist crossing the Arctic to warn a returning spaceship crew of a global catastrophe. The hosts call it well-intentioned but draggy, and read it as Clooney working through fatherhood."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The George Clooney Hall of Fame",
      "honoree": "George Clooney",
      "films": [
        {
          "title": "Batman & Robin",
          "year": 1997,
          "note": "A genuine bomb Clooney is still embarrassed by, but the hosts argue it's the most important movie of his career: its failure is what scared studios into Sam Raimi, Bryan Singer, and eventually Christopher Nolan."
        },
        {
          "title": "Out of Sight",
          "year": 1998,
          "note": "The essence-of-Clooney pick, and the start of the Soderbergh partnership that redirected his whole career."
        },
        {
          "title": "Three Kings",
          "year": 1999,
          "note": "Notoriously tense shoot with David O. Russell; nearly got traded out for The Perfect Storm before making the final cut."
        },
        {
          "title": "The Perfect Storm",
          "year": 2000,
          "note": "The blockbuster that proved Clooney could carry a mainstream hit after Batman & Robin."
        },
        {
          "title": "O Brother, Where Art Thou?",
          "year": 2000,
          "note": "Where the wide-eyed, goofball Coen brothers version of Clooney shows up."
        },
        {
          "title": "Ocean's Eleven",
          "year": 2001,
          "note": "No debate here."
        },
        {
          "title": "Good Night, and Good Luck.",
          "year": 2005,
          "note": "His most personal film as a director, an homage to his newsman father, with Clooney scaled back as Fred Friendly."
        },
        {
          "title": "Michael Clayton",
          "year": 2007,
          "note": "The hosts' pick for his best performance, though he lost the Oscar to Daniel Day-Lewis in There Will Be Blood."
        },
        {
          "title": "Fantastic Mr. Fox",
          "year": 2009,
          "note": "The curveball pick, in for a voice performance that leans on the sheer sound of him."
        },
        {
          "title": "The Descendants",
          "year": 2011,
          "note": "The last great Clooney leading performance before the pivot toward directing and producing."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Carey Mulligan and Emerald Fennell on",
      "films": [
        {
          "title": "Promising Young Woman",
          "year": 2020,
          "note": "Fennell's directorial debut, starring Mulligan as a woman avenging a friend. They discuss the tone (a deliberately candy-colored mood board), the comedic cast, and Mulligan's executive producer credit."
        }
      ]
    }
  ],
