  "runtimeMin": 84,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan draft 2008 across six categories (Oscar Nominee, Action Horror, Comedy, Blockbuster, Drama, and Wildcard), from The Dark Knight to Mamma Mia!.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "2008, before the draft",
      "films": [
        {
          "title": "The Dark Knight",
          "year": 2008,
          "note": "Christopher Nolan's Batman sequel, which Sean calls one of the defining films of the century. Its Best Picture snub is credited with pushing the Academy to expand the nominee field to 10."
        },
        {
          "title": "Slumdog Millionaire",
          "year": 2008,
          "note": "Danny Boyle's Best Picture winner, which the hosts say basically didn't lose a single race it ran in that awards season."
        },
        {
          "title": "The Reader",
          "year": 2008,
          "note": "Kate Winslet plays a former Nazi camp guard having an affair with a much younger man. Amanda's verdict, flatly: bad."
        },
        {
          "title": "Doubt",
          "year": 2008,
          "note": "John Patrick Shanley's adaptation of his own play. Amanda remembers seeing it and having a great time."
        },
        {
          "title": "The Wrestler",
          "year": 2008,
          "note": "Darren Aronofsky and Mickey Rourke. Amanda tells the story of getting in a fight with a boyfriend over the ending and breaking up with him within the week."
        },
        {
          "title": "Frost/Nixon",
          "year": 2008,
          "note": "Ron Howard's Best Picture nominee. Called okay, not much more."
        },
        {
          "title": "Milk",
          "year": 2008,
          "note": "Gus Van Sant's Harvey Milk biopic starring Sean Penn. Called fine."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The 2008 Movie Draft",
      "draftOf": "2008 movies",
      "categories": [
        "Oscar Nominee",
        "Action Horror",
        "Comedy",
        "Blockbuster",
        "Drama",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Dark Knight",
              "year": 2008,
              "category": "Oscar Nominee",
              "note": "Sean's first-overall pick. He insists he does love Christopher Nolan's movie, despite the ribbing, and calls it some of the best action filmmaking of the century."
            },
            {
              "title": "Let the Right One In",
              "year": 2008,
              "category": "Action Horror",
              "note": "Tomas Alfredson's vampire film, which Sean pairs thematically with Wall-E as two lonely people finding each other in the dark. He notes Alfredson followed it with Tinker Tailor Soldier Spy, then the much-mocked The Snowman."
            },
            {
              "title": "Forgetting Sarah Marshall",
              "year": 2008,
              "category": "Comedy",
              "note": "Sean's favorite movie of the year, Jason Segel and Judd Apatow's breakup comedy set in Hawaii. He wishes Segel had kept making movies like it instead of moving into TV."
            },
            {
              "title": "WALL-E",
              "year": 2008,
              "category": "Blockbuster",
              "note": "Sean's pick, which he calls a ballet of loneliness with a nearly wordless first act. Amanda and Chris needle him for not remembering the robot's name."
            },
            {
              "title": "Rachel Getting Married",
              "year": 2008,
              "category": "Drama",
              "note": "Jonathan Demme's film, with what Sean calls Anne Hathaway's best performance and some of Demme's finest work behind the camera."
            },
            {
              "title": "Synecdoche, New York",
              "year": 2008,
              "category": "Wildcard",
              "note": "Charlie Kaufman's film, which Sean calls a masterpiece. It was also, he recalls, one of his dad's questionable Thanksgiving movie picks that year."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "In Bruges",
              "year": 2008,
              "category": "Oscar Nominee",
              "note": "Chris's second-overall pick and favorite movie of the year. Martin McDonagh's film with Colin Farrell, Brendan Gleeson, and Ralph Fiennes, whose lone Oscar nomination was for original screenplay."
            },
            {
              "title": "Cloverfield",
              "year": 2008,
              "category": "Action Horror",
              "note": "The found-footage monster movie, whose teaser trailer ran in front of Transformers before the film had even finished shooting. Chris says the marketing was as much of a feat as the movie itself."
            },
            {
              "title": "Burn After Reading",
              "year": 2008,
              "category": "Comedy",
              "note": "The Coen brothers' spy farce with Brad Pitt and John Malkovich, who Chris and Sean call maybe the funniest either of them has ever been on screen."
            },
            {
              "title": "Tropic Thunder",
              "year": 2008,
              "category": "Blockbuster",
              "note": "Chris calls it about as perfect a Hollywood comedy as it gets. Robert Downey Jr. earned an Oscar nomination for playing an actor in blackface."
            },
            {
              "title": "Pride and Glory",
              "year": 2008,
              "category": "Drama",
              "note": "Gavin O'Connor's cop drama with Colin Farrell, Edward Norton, and Robert Duvall. Chris interviewed O'Connor at length after the film came out and calls him one of the most underrated American filmmakers working."
            },
            {
              "title": "Pineapple Express",
              "year": 2008,
              "category": "Wildcard",
              "note": "David Gordon Green and Judd Apatow's stoner comedy, taken over The Strangers, which Chris passed on despite loving it."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Curious Case of Benjamin Button",
              "year": 2008,
              "category": "Oscar Nominee",
              "note": "David Fincher's film with Brad Pitt and Cate Blanchett. Amanda calls it one of her least favorite Fincher movies, beautiful but more him playing dress-up than fully committing."
            },
            {
              "title": "Iron Man",
              "year": 2008,
              "category": "Action Horror",
              "note": "Amanda's first pick, taken third overall. She jokes that Chris cost a Marvel executive her job by talking about the franchise too much on the show."
            },
            {
              "title": "Step Brothers",
              "year": 2008,
              "category": "Comedy",
              "note": "Amanda took it before Chris could, then rewatched it the morning of taping instead of doing errands."
            },
            {
              "title": "Twilight",
              "year": 2008,
              "category": "Blockbuster",
              "note": "Catherine Hardwicke's film, which Amanda defends despite the ribbing, singling out Kristen Stewart and a young Anna Kendrick."
            },
            {
              "title": "Two Lovers",
              "year": 2008,
              "category": "Drama",
              "note": "James Gray's film with Joaquin Phoenix, Gwyneth Paltrow, and Vinessa Shaw. Amanda calls it Gray's masterpiece, at least until The Lost City of Z."
            },
            {
              "title": "Mamma Mia!",
              "year": 2008,
              "category": "Wildcard",
              "note": "Amanda's closer, with Meryl Streep, Pierce Brosnan, and Colin Firth. She describes it as Meryl and a bunch of handsome actors going on vacation in Greece and filming it, their version of Ocean's Eleven."
            }
          ]
        }
      ],
