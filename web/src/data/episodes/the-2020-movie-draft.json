{
  "slug": "the-2020-movie-draft",
  "title": "The 2020 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2023-12-18",
  "runtimeMin": 77,
  "format": "Sean, Amanda, and Chris Ryan draft the movies of 2020, the year COVID gutted the theatrical slate. The blockbuster threshold drops to $25 million, and the picks skew toward small, streaming-era films. Six categories, snake order, one roster each.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "the movies of 2020",
      "categories": [
        "Drama",
        "Action / Horror / Thriller",
        "Comedy",
        "Blockbuster",
        "Oscar Nominee",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "First Cow",
              "year": 2020,
              "category": "Drama",
              "note": "Kelly Reichardt's frontier friendship lost to time; one of the last people he interviewed in person, and she'd only fist-bump as COVID crept in."
            },
            {
              "title": "The Invisible Man",
              "year": 2020,
              "category": "Action / Horror / Thriller",
              "note": "Leigh Whannell's Blumhouse reinvention with Elisabeth Moss; a big surprise hit and the good genre pick still on the board after the blockbusters went."
            },
            {
              "title": "Shithouse",
              "year": 2020,
              "category": "Comedy",
              "note": "Cooper Raiff's college debut, made at 24, with pangs of Linklater and John Hughes; shot in Sean's neighborhood."
            },
            {
              "title": "Tenet",
              "year": 2020,
              "category": "Blockbuster",
              "note": "First overall. The only $25M+ movie worth talking about, seen at a San Diego drive-in reached by driving through a forest fire, cars parked apart."
            },
            {
              "title": "Judas and the Black Messiah",
              "year": 2021,
              "category": "Oscar Nominee",
              "note": "Technically a February 2021 release, allowed under the Oscar-eligibility extension; Daniel Kaluuya's Fred Hampton, a Shaka King they're still waiting to follow up."
            },
            {
              "title": "The Vast of Night",
              "year": 2020,
              "category": "Wild Card",
              "note": "Andrew Patterson's homemade 1950s New Mexico sci-fi built around a long, unbroken tracking shot; his and Sean's favorite of the year, and an Adam Nayman staple."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Never Rarely Sometimes Always",
              "year": 2020,
              "category": "Drama",
              "note": "Eliza Hittman's abortion procedural; Amanda interviewed Hittman at Sundance the day Kobe Bryant died."
            },
            {
              "title": "Extraction",
              "year": 2020,
              "category": "Action / Horror / Thriller",
              "note": "Not an Amanda pick, but Hemsworth throat-punching dudes felt like a release five weeks into lockdown; a top-15 all-time Netflix title."
            },
            {
              "title": "Palm Springs",
              "year": 2020,
              "category": "Comedy",
              "note": "Andy Samberg / Cristin Milioti time-loop rom-com bought at Sundance for a record $17.5M; released on Hulu into a real-life time loop."
            },
            {
              "title": "Bad Boys for Life",
              "year": 2020,
              "category": "Blockbuster",
              "note": "The year's #1 movie at $206M domestic, and the last normal theatrical hang; Chris fixated on the Michael Bay cameo."
            },
            {
              "title": "Quo Vadis, Aida?",
              "year": 2020,
              "category": "Oscar Nominee",
              "note": "Jasmila Zbanic's Bosnian Best International nominee; a UN translator inside the run-up to the Srebrenica massacre, the bottom falling out of everything."
            },
            {
              "title": "The Assistant",
              "year": 2020,
              "category": "Wild Card",
              "note": "Kitty Green's quiet, anxious office-abuse study with Julia Garner and a Matthew Macfadyen HR scene that goes on almost unbearably long; under-seen for when it landed."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Another Round",
              "year": 2020,
              "category": "Drama",
              "note": "Thomas Vinterberg's intentional-alcoholism film with Mads Mikkelsen; sad and funny, unmistakably Scandinavian, capped by that dancing ending. Chris interviewed Mikkelsen and questioned whether he himself was a man."
            },
            {
              "title": "The Rental",
              "year": 2020,
              "category": "Action / Horror / Thriller",
              "note": "Dave Franco and Joe Swanberg's Oregon-Airbnb thriller; a rewatchable, John Carpenter-ish study of class and leisure anxieties."
            },
            {
              "title": "Happiest Season",
              "year": 2020,
              "category": "Comedy",
              "note": "Clea DuVall's Pittsburgh Christmas rom-com with Kristen Stewart, Mackenzie Davis, and Aubrey Plaza; a holiday staple in Chris's house."
            },
            {
              "title": "The Gentlemen",
              "year": 2020,
              "category": "Blockbuster",
              "note": "Guy Ritchie's; taken fourth overall as a pick all three had circled. Charlie Hunnam's AK-47, Hugh Grant's disgusting accent, Michelle Dockery."
            },
            {
              "title": "Mank",
              "year": 2020,
              "category": "Oscar Nominee",
              "note": "David Fincher's Old Hollywood with a dizzying Gary Oldman; Chris's favorite of the year, defended against the anti-Mank crowd."
            },
            {
              "title": "Let Them All Talk",
              "year": 2020,
              "category": "Wild Card",
              "note": "Steven Soderbergh's Queen Mary 2 drama with Meryl Streep and Lucas Hedges; Soderbergh later recognized Chris in person from their Zoom interview."
            }
          ]
        }
      ],
