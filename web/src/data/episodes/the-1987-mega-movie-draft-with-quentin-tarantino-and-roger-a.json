{
  "slug": "the-1987-mega-movie-draft-with-quentin-tarantino-and-roger-a",
  "title": "The 1987 Mega-Movie Draft With Quentin Tarantino and Roger Avary!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan",
    "Quentin Tarantino",
    "Roger Avary"
  ],
  "published": "2022-07-26",
  "runtimeMin": 148,
  "format": "Quentin Tarantino and Roger Avary join Sean, Amanda, and Chris for a five-way snake draft of 1987 across six categories, from Robocop to Babette's Feast.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The 1987 Movie Draft",
      "draftOf": "the movies of 1987",
      "categories": [
        "Drama / Action",
        "Comedy",
        "Oscar Nominee",
        "Horror / Exploitation",
        "Blockbuster",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Roger Avary",
          "picks": [
            {
              "title": "Robocop",
              "year": 1987,
              "category": "Blockbuster",
              "note": "First overall pick. Verhoeven, Peter Weller; nobody else at the table had it in their top four."
            },
            {
              "title": "Hope and Glory",
              "year": 1987,
              "category": "Oscar Nominee",
              "note": "John Boorman's autobiographical account of the London Blitz. His second-favorite Boorman film after Excalibur."
            },
            {
              "title": "River's Edge",
              "year": 1987,
              "category": "Drama / Action",
              "note": "Tim Hunter, from Neil Jimenez's script; Crispin Glover and Keanu Reeves. Premiered at the same Sundance as Reservoir Dogs."
            },
            {
              "title": "Hellraiser",
              "year": 1987,
              "category": "Horror / Exploitation",
              "note": "Clive Barker's debut, picked over Jack Sholder's The Hidden."
            },
            {
              "title": "Innerspace",
              "year": 1987,
              "category": "Comedy",
              "note": "Joe Dante, Martin Short, Dennis Quaid. Where he and his future wife met."
            },
            {
              "title": "Babette's Feast",
              "year": 1987,
              "category": "Wildcard",
              "note": "The foreign-film Oscar winner that year, picked over Barfly."
            }
          ]
        },
        {
          "host": "Quentin Tarantino",
          "picks": [
            {
              "title": "Evil Dead II",
              "year": 1987,
              "category": "Horror / Exploitation",
              "note": "One of his four \"real\" picks for the year; compares its impact to Godard's Breathless."
            },
            {
              "title": "Three O'Clock High",
              "year": 1987,
              "category": "Comedy",
              "note": "Phil Joanou's directorial debut; a flop at the time that he still calls one of the great directorial debuts he'd ever seen."
            },
            {
              "title": "Wall Street",
              "year": 1987,
              "category": "Oscar Nominee",
              "note": "Oliver Stone, Michael Douglas's Best Actor win; ranks it behind JFK among Stone's films."
            },
            {
              "title": "China Girl",
              "year": 1987,
              "category": "Drama / Action",
              "note": "Abel Ferrara's Chinatown-set West Side Story riff, with James Russo."
            },
            {
              "title": "The Secret of My Success",
              "year": 1987,
              "category": "Blockbuster",
              "note": "Michael J. Fox's first movie after Back to the Future; picked partly for editor Paul Hirsch."
            },
            {
              "title": "Crazy Love",
              "year": 1987,
              "category": "Wildcard",
              "note": "Dominique Deruddere's Bukowski anthology film, referred to on the show by its US release title, Love Is a Dog from Hell."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Raising Arizona",
              "year": 1987,
              "category": "Comedy",
              "note": "The Coen Brothers; the Nicolas Cage monologue over Carter Burwell's score. Tarantino says it would've been his own first pick, but let Chris have it."
            },
            {
              "title": "Lethal Weapon",
              "year": 1987,
              "category": "Drama / Action",
              "note": "Mel Gibson and Danny Glover; a sentimental pick from when he started watching \"quasi-adult\" movies."
            },
            {
              "title": "Empire of the Sun",
              "year": 1987,
              "category": "Oscar Nominee",
              "note": "Spielberg; Christian Bale's performance and John Malkovich."
            },
            {
              "title": "Prince of Darkness",
              "year": 1987,
              "category": "Horror / Exploitation",
              "note": "John Carpenter's quantum-physics horror movie, made alongside They Live."
            },
            {
              "title": "The Untouchables",
              "year": 1987,
              "category": "Blockbuster",
              "note": "De Palma, fresh off a Rewatchables rewatch; the Ennio Morricone opening credits."
            },
            {
              "title": "Straight to Hell",
              "year": 1987,
              "category": "Wildcard",
              "note": "Alex Cox's punk Western with Joe Strummer, shot by Tom Richmond (later Tarantino's Killing Zoe DP)."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Fatal Attraction",
              "year": 1987,
              "category": "Blockbuster",
              "note": "Adrian Lyne; the group debates and rejects putting it in horror instead."
            },
            {
              "title": "Broadcast News",
              "year": 1987,
              "category": "Drama / Action",
              "note": "James L. Brooks; Holly Hunter, William Hurt, Albert Brooks."
            },
            {
              "title": "Moonstruck",
              "year": 1987,
              "category": "Oscar Nominee",
              "note": "Cher and Nicolas Cage; argues it predates the modern rom-com template set later by When Harry Met Sally."
            },
            {
              "title": "The Lost Boys",
              "year": 1987,
              "category": "Horror / Exploitation",
              "note": "Joel Schumacher; Kiefer Sutherland, Jason Patric."
            },
            {
              "title": "Baby Boom",
              "year": 1987,
              "category": "Comedy",
              "note": "Written by Nancy Meyers; Diane Keaton."
            },
            {
              "title": "Dirty Dancing",
              "year": 1987,
              "category": "Wildcard",
              "note": "Patrick Swayze and Jennifer Grey; also would have been her Oscar-nominee backup pick."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Full Metal Jacket",
              "year": 1987,
              "category": "Drama / Action",
              "note": "Kubrick; the first new Kubrick film he saw on opening night having already known his work."
            },
            {
              "title": "Predator",
              "year": 1987,
              "category": "Blockbuster",
              "note": "A movie closely tied to Chris Ryan; picked partly to needle him."
            },
            {
              "title": "The Princess Bride",
              "year": 1987,
              "category": "Oscar Nominee",
              "note": "Rob Reiner, from William Goldman's script; Andre the Giant, Mandy Patinkin."
            },
            {
              "title": "Near Dark",
              "year": 1987,
              "category": "Horror / Exploitation",
              "note": "Kathryn Bigelow's vampire film with Bill Paxton; the one pick that genuinely stings Tarantino to have lost."
            },
            {
              "title": "Spaceballs",
              "year": 1987,
              "category": "Comedy",
              "note": "Mel Brooks; picked over Withnail and I."
            },
            {
              "title": "Prince: Sign 'o' the Times",
              "year": 1987,
              "category": "Wildcard",
              "note": "Prince's concert film, made to prop up a lagging album."
            }
          ]
        }
      ],
