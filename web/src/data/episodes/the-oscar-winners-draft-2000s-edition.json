    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2021-04-21",
  "runtimeMin": 76,
  "format": "Sean, Amanda, and Chris Ryan draft the best Oscar-winning performances and films of the 2000s, category by category, then preview the actual Best Picture race.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The news",
      "note": "before the draft",
      "films": [
        {
          "title": "Annette",
          "year": 2021,
          "note": "Opening Cannes; Adam Driver plays a singing stand-up comedian opposite Marion Cotillard."
        },
        {
          "title": "Shang-Chi and the Legend of the Ten Rings",
          "year": 2021,
          "note": "New MCU entrant starring Simu Liu and Tony Leung."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The Oscar winners draft: 2000s edition",
      "note": "eligible films released 2000-2009, drafted across the eight major Oscar categories",
      "draftOf": "Oscar winners, 2000s",
      "categories": [
        "Best Original Screenplay",
        "Best Adapted Screenplay",
        "Best Supporting Actress",
        "Best Supporting Actor",
        "Best Actress",
        "Best Actor",
        "Best Director",
        "Best Picture"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "There Will Be Blood",
              "year": 2007,
              "category": "Best Actor",
              "note": "Daniel Day-Lewis, Sean's favorite performance and favorite movie of the decade, taken with the first pick of the draft."
            },
            {
              "title": "The Departed",
              "year": 2006,
              "category": "Best Director",
              "note": "Martin Scorsese's long-overdue win."
            },
            {
              "title": "Almost Famous",
              "year": 2000,
              "category": "Best Original Screenplay",
              "note": "Cameron Crowe."
            },
            {
              "title": "No Country for Old Men",
              "year": 2007,
              "category": "Best Adapted Screenplay",
              "note": "Joel and Ethan Coen adapting Cormac McCarthy, a novel Chris pushed Sean to read."
            },
            {
              "title": "The Constant Gardener",
              "year": 2005,
              "category": "Best Supporting Actress",
              "note": "Rachel Weisz opposite Ralph Fiennes in Fernando Meirelles' John le Carre adaptation."
            },
            {
              "title": "Inglourious Basterds",
              "year": 2009,
              "category": "Best Supporting Actor",
              "note": "Christoph Waltz as Hans Landa, his breakthrough English-language role."
            },
            {
              "title": "La Vie en Rose",
              "year": 2007,
              "category": "Best Actress",
              "note": "Marion Cotillard as Edith Piaf, the first Best Actress win for a French-language performance."
            },
            {
              "title": "The Lord of the Rings: The Return of the King",
              "year": 2003,
              "category": "Best Picture"
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Training Day",
              "year": 2001,
              "category": "Best Actor",
              "note": "Denzel Washington, taken right after Sean's Daniel Day-Lewis pick."
            },
            {
              "title": "Traffic",
              "year": 2000,
              "category": "Best Director",
              "note": "Steven Soderbergh, who later admitted he was extremely drunk accepting the award."
            },
            {
              "title": "Lost in Translation",
              "year": 2003,
              "category": "Best Original Screenplay",
              "note": "Sofia Coppola. Her Oscar speech thanking Wong Kar-wai is how Amanda first learned about In the Mood for Love."
            },
            {
              "title": "Brokeback Mountain",
              "year": 2005,
              "category": "Best Adapted Screenplay",
              "note": "Larry McMurtry and Diana Ossana; picked partly in memory of McMurtry, who died that year."
            },
            {
              "title": "Michael Clayton",
              "year": 2007,
              "category": "Best Supporting Actress",
              "note": "Tilda Swinton, including the bathroom-mirror breakdown scene."
            },
            {
              "title": "No Country for Old Men",
              "year": 2007,
              "category": "Best Supporting Actor",
              "note": "Javier Bardem as Anton Chigurh."
            },
            {
              "title": "The Queen",
              "year": 2006,
              "category": "Best Actress",
              "note": "Helen Mirren as Elizabeth II in Peter Morgan's script."
            },
            {
              "title": "The Departed",
              "year": 2006,
              "category": "Best Picture",
              "note": "Picked over The Hurt Locker, which Amanda called her own internal movie struggle."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Mystic River",
              "year": 2003,
              "category": "Best Actor",
              "note": "Sean Penn, over Philip Seymour Hoffman's Capote."
            },
            {
              "title": "The Hurt Locker",
              "year": 2008,
              "category": "Best Director",
              "note": "Kathryn Bigelow, beating James Cameron's Avatar."
            },
            {
              "title": "Gosford Park",
              "year": 2001,
              "category": "Best Original Screenplay",
              "note": "Julian Fellowes, by way of director Robert Altman, a precursor to Downton Abbey."
            },
            {
              "title": "The Departed",
              "year": 2006,
              "category": "Best Adapted Screenplay",
              "note": "William Monahan's script. Chris says the movie means a lot to him emotionally even though he still can't fully follow the plot."
            },
            {
              "title": "The Aviator",
              "year": 2004,
              "category": "Best Supporting Actress",
              "note": "Cate Blanchett's Katharine Hepburn impression."
            },
            {
              "title": "The Dark Knight",
              "year": 2008,
              "category": "Best Supporting Actor",
              "note": "Heath Ledger, the obvious pick, and he took it."
            },
            {
              "title": "Erin Brockovich",
              "year": 2000,
              "category": "Best Actress",
              "note": "Julia Roberts opposite Albert Finney and Aaron Eckhart."
            },
            {
              "title": "No Country for Old Men",
              "year": 2007,
              "category": "Best Picture"
            }
          ]
        }
      ],
