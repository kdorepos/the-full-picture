{
  "slug": "the-ethan-hawke-hall-of-fame-and-the-black-phone",
  "title": "The Ethan Hawke Hall of Fame and 'The Black Phone'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2022-06-28",
  "runtimeMin": 78,
  "format": "Sean and Chris review the Scott Derrickson horror hit 'The Black Phone,' then build a 10-film Hall of Fame for Ethan Hawke, running his entire filmography year by year.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "'The Black Phone'",
      "note": "Sean Fennessey, Chris Ryan",
      "films": [
        {
          "title": "The Black Phone",
          "year": 2022,
          "note": "Scott Derrickson's Blumhouse thriller, from a Joe Hill story: a 13-year-old is abducted by a masked killer called the Grabber and starts hearing the voices of his previous victims on a dead phone. Both hosts land around two and a half stars: a strong premise (Chris compares it to 'Dazed and Confused' as a kidnapping movie), undercut by vagueness about the rules of its world. Ethan Hawke, almost entirely masked, is the reason it works."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Ethan Hawke Hall of Fame",
      "note": "10, built year by year across his filmography",
      "honoree": "Ethan Hawke",
      "films": [
        {
          "title": "Dead Poets Society",
          "year": 1989,
          "note": "The film that got him the career; Todd Anderson, 'O Captain, My Captain.' First lock of the episode."
        },
        {
          "title": "Reality Bites",
          "year": 1994,
          "note": "Troy Dyer. Goes in alongside 'Before Sunrise' as a defining performance of his Gen X period."
        },
        {
          "title": "Before Sunrise",
          "year": 1995,
          "note": "Jesse, first of three. Chris argues Jesse should count for all three 'Before' films rather than just this one."
        },
        {
          "title": "Gattaca",
          "year": 1997,
          "note": "In on the strength of the fan base and a performance Sean calls some of Hawke's best acting in his 20s, despite both hosts finding the film itself uneven."
        },
        {
          "title": "Training Day",
          "year": 2001,
          "note": "Jake Hoyt, opposite Denzel Washington. Oscar-nominated; Hawke has said working with Washington changed him as an actor."
        },
        {
          "title": "Before Sunset",
          "year": 2004,
          "note": "Jesse again. One of Sean's favorite movies ever made; the second of the three 'Before' credits toward his total."
        },
        {
          "title": "Sinister",
          "year": 2012,
          "note": "Chosen over 'The Purge' as the Blumhouse-era entry: the reunion with Scott Derrickson that also set up 'The Black Phone.'"
        },
        {
          "title": "Before Midnight",
          "year": 2013,
          "note": "Jesse a third time, closing out the trilogy that counts as three separate inductions."
        },
        {
          "title": "Boyhood",
          "year": 2014,
          "note": "Oscar-nominated. Chris calls the performance among Hawke's best, particularly the later scenes of a father who's finally gotten his life together."
        },
        {
          "title": "First Reformed",
          "year": 2018,
          "note": "Reverend Ernst Toller. The last film added; both call it the performance that most defines him as an actor."
        }
      ]
    }
  ],
