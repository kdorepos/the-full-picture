      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Risky Business",
              "year": 1983,
              "category": "'80s",
              "note": "The movie that made him a star; Rebecca De Mornay, whom he dated for a year after."
            },
            {
              "title": "A Few Good Men",
              "year": 1992,
              "category": "'90s",
              "note": "First overall pick; Rob Reiner at the tail end of his great run."
            },
            {
              "title": "American Made",
              "year": 2017,
              "category": "21st century",
              "note": "The other Doug Liman film, about a pilot turned smuggler who loses his mind."
            },
            {
              "title": "Born on the Fourth of July",
              "year": 1989,
              "category": "Oscar nominee",
              "note": "Oliver Stone; Cruise's Best Actor nomination and a hard watch."
            },
            {
              "title": "Mission: Impossible - Rogue Nation",
              "year": 2015,
              "category": "Mission: Impossible",
              "note": "The McQuarrie era begins; Ilsa arrives and Cruise hangs off the plane."
            },
            {
              "title": "All the Right Moves",
              "year": 1983,
              "category": "Tom Cruise does a sports thing",
              "note": "The last real sports thing on the board; one of the best football sequences in the genre."
            },
            {
              "title": "The Last Samurai",
              "year": 2003,
              "category": "Blockbuster",
              "note": "Down-and-out alcoholic Cruise; Ken Watanabe and the battle sequences carry it."
            },
            {
              "title": "Jack Reacher: Never Go Back",
              "year": 2016,
              "category": "Wild card",
              "note": "The Ed Zwick one that bombed at $58M domestic."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Endless Love",
              "year": 1981,
              "category": "'80s",
              "note": "Franco Zeffirelli; Cruise's screen debut, two scenes, gives a guy the idea to burn a house down."
            },
            {
              "title": "Magnolia",
              "year": 1999,
              "category": "'90s",
              "note": "The Frank T.J. Mackey performance; his best dramatic swing and the start of the auteur run."
            },
            {
              "title": "Edge of Tomorrow",
              "year": 2014,
              "category": "21st century",
              "note": "A good movie nobody believed during his down period; cult status with Emily Blunt."
            },
            {
              "title": "Mission: Impossible - Dead Reckoning Part One",
              "year": 2023,
              "category": "Oscar nominee",
              "note": "The franchise's first Oscar nominations; the cliff jump and the tiny car in Rome."
            },
            {
              "title": "Mission: Impossible",
              "year": 1996,
              "category": "Mission: Impossible",
              "note": "The Langley drop and the knock list; the whole franchise in one image."
            },
            {
              "title": "War of the Worlds",
              "year": 2005,
              "category": "Tom Cruise does a sports thing",
              "note": "The game of catch; Yankees dad, Red Sox kid."
            },
            {
              "title": "Top Gun: Maverick",
              "year": 2022,
              "category": "Blockbuster",
              "note": "The movie Spielberg credits with saving theatrical."
            },
            {
              "title": "Knight and Day",
              "year": 2010,
              "category": "Wild card",
              "note": "Drafted just to needle Bill; Cameron Diaz fixes cars, gets roped into the mission."
            }
          ]
        },
        {
          "host": "Van Lathan",
          "picks": [
            {
              "title": "Cocktail",
              "year": 1988,
              "category": "'80s",
              "note": "The best Cruise performance relative to the quality of the movie; still no 4K."
            },
            {
              "title": "Far and Away",
              "year": 1992,
              "category": "'90s",
              "note": "Taken over Interview with the Vampire on principle; the worst Irish accent he's ever seen."
            },
            {
              "title": "Collateral",
              "year": 2004,
              "category": "21st century",
              "note": "The coolest he's ever been; Michael Mann's definitive LA movie."
            },
            {
              "title": "Vanilla Sky",
              "year": 2001,
              "category": "Oscar nominee",
              "note": "Nominated for Best Original Song; Cameron Diaz at her most unhinged."
            },
            {
              "title": "Mission: Impossible - Fallout",
              "year": 2018,
              "category": "Mission: Impossible",
              "note": "The one that made him all in on the franchise; still the best."
            },
            {
              "title": "Days of Thunder",
              "year": 1990,
              "category": "Tom Cruise does a sports thing",
              "note": "The rental-car race beats anything on the track; Kidman as a 24-year-old neurosurgeon."
            },
            {
              "title": "Interview with the Vampire",
              "year": 1994,
              "category": "Blockbuster",
              "note": "The last blockbuster left; first Cruise-and-Pitt pairing."
            },
            {
              "title": "Legend",
              "year": 1985,
              "category": "Wild card",
              "note": "Ridley Scott and Tim Curry; taken over Oblivion."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "The Outsiders",
              "year": 1983,
              "category": "'80s",
              "note": "Ratty kid on the edge of the ensemble; Macchio and Swayze out-cook him."
            },
            {
              "title": "Eyes Wide Shut",
              "year": 1999,
              "category": "'90s",
              "note": "Kubrick asks him to turn the charisma down; holds up on rewatch, shaped a lot that came after."
            },
            {
              "title": "Valkyrie",
              "year": 2008,
              "category": "21st century",
              "note": "The Bryan Singer Hitler-plot thriller; Cruise skips the German accent."
            },
            {
              "title": "The Firm",
              "year": 1993,
              "category": "Oscar nominee",
              "note": "John Grisham paranoid thriller; the last 15 minutes with the suitcase still land."
            },
            {
              "title": "Mission: Impossible III",
              "year": 2006,
              "category": "Mission: Impossible",
              "note": "The J.J. Abrams one; Philip Seymour Hoffman is the franchise's best villain."
            },
            {
              "title": "The Color of Money",
              "year": 1986,
              "category": "Tom Cruise does a sports thing",
              "note": "King twerp opposite Paul Newman; the Werewolves of London scene."
            },
            {
              "title": "Minority Report",
              "year": 2002,
              "category": "Blockbuster",
              "note": "Spielberg Hitchcock thriller; Cruise as the wrongly-accused man on the run."
            },
            {
              "title": "Mission: Impossible II",
              "year": 2000,
              "category": "Wild card",
              "note": "The John Woo motorcycle fight alone; having a little resurgence."
            }
          ]
        },
        {
          "host": "Bill Simmons",
          "picks": [
            {
              "title": "Taps",
              "year": 1981,
              "category": "'80s",
              "note": "Cruise goes maniac letting off rounds; Sean Penn and Timothy Hutton."
            },
            {
              "title": "Jerry Maguire",
              "year": 1996,
              "category": "'90s",
              "note": "Peak-powers Cruise; in the running for best sports movie of the last 30 years."
            },
            {
              "title": "Jack Reacher",
              "year": 2012,
              "category": "21st century",
              "note": "Too short for the role and it still works; a book fan base in revolt."
            },
            {
              "title": "Rain Man",
              "year": 1988,
              "category": "Oscar nominee",
              "note": "Actually won the Oscar (Hoffman); the archetype before it went stale."
            },
            {
              "title": "Mission: Impossible - Ghost Protocol",
              "year": 2011,
              "category": "Mission: Impossible",
              "note": "The Burj Khalifa climb; got the franchise younger and sexier."
            },
            {
              "title": "Top Gun",
              "year": 1986,
              "category": "Tom Cruise does a sports thing",
              "note": "The volleyball scene; he checks his watch and ends the game."
            },
            {
              "title": "Tropic Thunder",
              "year": 2008,
              "category": "Blockbuster",
              "note": "Les Grossman cleared $195M; the crawdads scene."
            },
            {
              "title": "Oblivion",
              "year": 2013,
              "category": "Wild card",
              "note": "Kosinski's first Cruise film, which begat Maverick; the drones and Morgan Freeman underground."
            }
          ]
