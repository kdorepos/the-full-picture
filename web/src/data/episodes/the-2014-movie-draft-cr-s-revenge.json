      "guest": "Clea Duvall on",
      "films": [
        {
          "title": "Happiest Season",
          "year": 2020,
          "note": "Her second film as director, a holiday rom-com with Kristen Stewart and Mackenzie Davis, moving to Hulu after the pandemic scuttled a theatrical release. Written with Mary Holland; 29 shooting days, edited remotely for six months during lockdown."
        },
        {
          "title": "The Intervention",
          "year": 2016,
          "note": "Her directorial debut; she also acted in it, and decided afterward that directing and acting at once was 'too hard, too crazy making.'"
        },
        {
          "title": "But I'm a Cheerleader",
          "year": 2000,
          "note": "Cited in Sean's introduction as one of her acting roles."
        },
        {
          "title": "Zodiac",
          "year": 2007
        },
        {
          "title": "Argo",
          "year": 2012
        },
        {
          "title": "Home Alone",
          "year": 1990,
          "note": "A visual reference she used with her DP and production designer while prepping Happiest Season's look."
        },
        {
          "title": "Groundhog Day",
          "year": 1993,
          "note": "A winter movie rather than a Christmas one, another reference for capturing the season and the cold."
        }
      ]
