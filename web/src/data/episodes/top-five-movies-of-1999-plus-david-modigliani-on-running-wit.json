  "slug": "top-five-movies-of-1999-plus-david-modigliani-on-running-wit",
  "title": "Top Five Movies of 1999, Plus David Modigliani on ‘Running With Beto’ | Discussion",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2019-03-26",
  "runtimeMin": 106,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan each draft a top five from 1999, a year they argue produced more great movies than any other, alongside a run of forgettable ones from great directors. Then Sean talks to documentarian David Modigliani about 'Running With Beto.'",
  "segments": [
    {
      "kind": "topfive",
      "heading": "Amanda's Top Five",
      "note": "movies of 1999, best to worst",
      "subject": "Movies of 1999",
      "ranked": true,
      "films": [
        {
          "title": "Notting Hill",
          "year": 1999,
          "note": "Her No. 1. Richard Curtis's follow-up to Four Weddings, with Julia Roberts playing a movie star who's engaging with her own fame."
        },
        {
          "title": "The Talented Mr. Ripley",
          "year": 1999,
          "note": "Damon's best performance, she says, an ability he's since edited out of his acting except in flashes as Linus in the Ocean's movies."
        },
        {
          "title": "10 Things I Hate About You",
          "year": 1999,
          "note": "The most rewatchable of the year's teen movies, carried by Heath Ledger's breakout."
        },
        {
          "title": "Election",
          "year": 1999,
          "note": "Tracy Flick as a personality test she can't fully pass."
        },
        {
          "title": "The Thomas Crown Affair",
          "year": 1999,
          "note": "Her actual favorite movie of the five, just not her No. 1: the McTiernan remake with Pierce Brosnan and Rene Russo."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris's Top Five",
      "note": "movies of 1999, best to worst",
      "subject": "Movies of 1999",
      "ranked": true,
      "films": [
        {
          "title": "Fight Club",
          "year": 1999,
          "note": "Filmmaking at its best across the board, though he thinks the way people talk about it has outlasted the movie itself."
        },
        {
          "title": "The Matrix",
          "year": 1999,
          "note": "It was the first DVD he ever owned; he's watched it close to a hundred times."
        },
        {
          "title": "The Insider",
          "year": 1999,
          "note": "Michael Mann's only non-action movie: Pacino and Crowe on the Brown & Williamson tobacco story."
        },
        {
          "title": "The Blair Witch Project",
          "year": 1999,
          "note": "The defining theater experience of his life; he remembers most of the opening-weekend crowd walking out convinced it was real."
        },
        {
          "title": "Go",
          "year": 1999,
          "note": "A rave-culture redo of Pulp Fiction he thinks has aged into a better L.A. time capsule than Swingers."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five",
      "note": "movies of 1999, best to worst",
      "subject": "Movies of 1999",
      "ranked": true,
      "films": [
        {
          "title": "Fight Club",
          "year": 1999,
          "note": "Says more about 2019 than about 1999, he thinks, maybe because of what got made of it."
        },
        {
          "title": "Magnolia",
          "year": 1999,
          "note": "PTA pouring every feeling he had into the longest movie he could make, right after Boogie Nights got him called the next Scorsese."
        },
        {
          "title": "Three Kings",
          "year": 1999,
          "note": "A heist movie about Gulf War soldiers who arrived too late for their war, shot during a production notorious for Clooney and David O. Russell coming to blows."
        },
        {
          "title": "South Park: Bigger, Longer & Uncut",
          "year": 1999,
          "note": "A movie musical with the safety off, its songs sung by everyone from Satan to Saddam Hussein."
        },
        {
          "title": "The Matrix",
          "year": 1999,
          "note": "The first time since seeing Star Wars that he remembers a movie hitting him that hard in a theater."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Eyes Wide Shut",
      "note": "off everyone's list, but not off the table",
      "films": [
        {
          "title": "Eyes Wide Shut",
          "year": 1999,
          "note": "Amanda calls it a fascinating case study of Tom Cruise and Nicole Kidman's actual marriage; Sean ranks it low among great Kubrick films but still says it's the real thing."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "David Modigliani on",
      "films": [
        {
          "title": "Running with Beto",
          "year": 2019,
          "note": "His HBO documentary on Beto O'Rourke's 2018 Senate run, built around whether he could revive Texas turnout rather than whether he'd win."
        },
        {
          "title": "Street Fight",
          "year": 2005,
          "note": "Marshall Curry's film on Cory Booker's first, losing mayoral run. One of two campaign docs he had his crew watch to prove a loss can still make a great film."
        },
        {
          "title": "Mitt",
          "year": 2014,
          "note": "The other reference point: Romney's failed 2012 campaign, which he says felt non-partisan even to viewers who didn't share Romney's politics."
        },
        {
          "title": "The War Room",
          "year": 1993,
          "note": "D.A. Pennebaker's Clinton-campaign doc, cited for its focus on staffers rather than the candidate."
        },
        {
          "title": "Crisis: Behind a Presidential Commitment",
          "year": 1963,
          "note": "A friend's recommendation after the fact: JFK and Bobby Kennedy navigating George Wallace's schoolhouse-door standoff."
        },
        {
          "title": "Don't Look Back",
          "year": 1967,
          "note": "Pennebaker's Dylan tour film, his biggest single influence on Running with Beto for its fly-on-the-wall intimacy."
        }
      ]
    }
  ],
