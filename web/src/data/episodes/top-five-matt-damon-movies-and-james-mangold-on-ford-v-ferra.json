{
  "slug": "top-five-matt-damon-movies-and-james-mangold-on-ford-v-ferra",
  "title": "Top Five Matt Damon Movies and James Mangold on ‘Ford v Ferrari’ | The Big Picture",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2019-11-15",
  "runtimeMin": 119,
  "format": "Amanda Dobbins and Chris Ryan each count down their five best Matt Damon performances, then Sean sits down with James Mangold to talk 'Ford v Ferrari,' the 24-hour Le Mans race, and why he'd rather build a world than wear a superhero costume.",
  "segments": [
    {
      "kind": "topfive",
      "heading": "Amanda Dobbins's Top 5",
      "note": "revealed No. 5 up to No. 1",
      "subject": "Matt Damon movies",
      "ranked": true,
      "films": [
        {
          "title": "The Talented Mr. Ripley",
          "year": 1999,
          "note": "No. 1 - the outlier in his career, playing insecurity instead of overconfidence under a full transformation opposite Jude Law and Philip Seymour Hoffman."
        },
        {
          "title": "Good Will Hunting",
          "year": 1997,
          "note": "No. 2 - the performance every later role gets measured against: prick-headedness, then the big cathartic release."
        },
        {
          "title": "The Martian",
          "year": 2015,
          "note": "No. 3 - his broadest, most everyman turn, and, as Amanda puts it, a $100 million vlog about not getting addicted to opiates on Mars."
        },
        {
          "title": "The Bourne Identity",
          "year": 2002,
          "note": "No. 4 - the movie that reset his career after 'All the Pretty Horses' and set up the next 20 years. Also, per Amanda, one of his hottest scenes."
        },
        {
          "title": "The Departed",
          "year": 2006,
          "note": "No. 5 - more charisma than usual, a duplicitous Boston cop mirrored against Leonardo DiCaprio's wide-open undercover mole."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top 5",
      "note": "revealed No. 5 up to No. 1",
      "subject": "Matt Damon movies",
      "ranked": true,
      "films": [
        {
          "title": "Rounders",
          "year": 1998,
          "note": "No. 1 - the Chucky to Edward Norton's Will Hunting, and as close to Jimmy Stewart as Damon ever gets. Chris says there's not a false note in it."
        },
        {
          "title": "Good Will Hunting",
          "year": 1997,
          "note": "No. 2 - same pick as Amanda's, for the same reason: the role everything after it answers to."
        },
        {
          "title": "The Departed",
          "year": 2006,
          "note": "No. 3 - Chris calls it Damon's best pure performance, closed-off and slimy in a way that requires real self-awareness to play."
        },
        {
          "title": "Contagion",
          "year": 2011,
          "note": "No. 4 - one of eight collaborations with Steven Soderbergh; his reaction to Gwyneth Paltrow's death is some of the best acting he's done."
        },
        {
          "title": "Courage Under Fire",
          "year": 1996,
          "note": "No. 5 - a physical-transformation role as a heroin-addicted medic, in a scene where Denzel Washington cedes the moment to him."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "James Mangold on",
      "films": [
        {
          "title": "Ford v Ferrari",
          "year": 2019,
          "note": "His new film. The red folder scene was his idea, a way to make Carroll Shelby's pitch to Henry Ford II visual. He built the climax around a sustained, nearly 50-minute cut of the 24-hour Le Mans race, telling the crew they were shooting 'Saving Private Ryan in reverse.'"
        },
        {
          "title": "Logan",
          "year": 2017,
          "note": "His version of an IP movie, without a supervillain or a costume Wolverine would ever actually wear, structured like a 'Kramer vs. Kramer' character piece instead of a comic-book plot."
        },
        {
          "title": "Walk the Line",
          "year": 2005,
          "note": "About a man who can only be with the woman he loves for 30 minutes at a time onstage. Joaquin Phoenix's singing voice didn't click into Johnny Cash's register until ten days before they left for Memphis."
        },
        {
          "title": "Girl, Interrupted",
          "year": 1999,
          "note": "Cited as an earlier example of the kind of adult drama he keeps returning to."
        },
        {
          "title": "Heavy",
          "year": 1995,
          "note": "His directorial debut, made deliberately against the '90s indie-cool grain, inspired by 'The Last Picture Show.'"
        },
        {
          "title": "Cop Land",
          "year": 1997,
          "note": "Miramax expected something Tarantino-adjacent; he made an earnest, Western-structured drama instead."
        },
        {
          "title": "The Wolverine",
          "year": 2013,
          "note": "His closest attempt at a studio IP picture, conceived as a Tokyo noir. He came away unsatisfied and told the studio he wouldn't do another one the same way."
        },
        {
          "title": "Ad Astra",
          "year": 2019,
          "note": "James Gray's film, his pick for the last great thing he's seen. It's patient and unhurried, and it doesn't let the audience off easy."
        }
      ]
    }
  ],
