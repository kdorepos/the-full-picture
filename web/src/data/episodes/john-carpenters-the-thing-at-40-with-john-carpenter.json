{
  "slug": "john-carpenters-the-thing-at-40-with-john-carpenter",
  "title": "John Carpenter’s ‘The Thing’ at 40, With John Carpenter!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2022-07-19",
  "runtimeMin": 90,
  "format": "A 40th-anniversary double bill on 'The Thing': Chris Ryan on how a 1982 flop became a cult classic, then a blunt sit-down with John Carpenter himself.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Setting the table on ‘The Thing’",
      "note": "Sean Fennessey and Chris Ryan on the flop that grew into a cult favorite",
      "films": [
        {
          "title": "The Thing",
          "year": 1982,
          "note": "Carpenter's eighth film and first for a studio (Universal), scripted by 'Bad News Bears' writer Bill Lancaster from the story 'Who Goes There?' Ryan calls it all steak and no sizzle: action as character, twelve men and a shape-shifting alien in Antarctica. Rob Bottin's practical creatures (built when he was 22), Kurt Russell as MacCready, Wilford Brimley's meltdown, Donald Moffat's 'tied to this couch' line, and Ennio Morricone's score. Flopped on release, later read as an AIDS-era paranoia artifact and a reference point for practical effects."
        },
        {
          "title": "The Thing from Another World",
          "year": 1951,
          "note": "The 1951 Howard Hawks production Carpenter's film reworks; Hawks is the director he cites most."
        },
        {
          "title": "Alien",
          "year": 1979,
          "note": "Ryan's closest touchstone: working people doing a job until something inexplicable upsets the apple cart. Carpenter, though, shows the monster under fluorescent light instead of hiding it."
        },
        {
          "title": "Blade Runner",
          "year": 1982,
          "note": "Released the very same day as 'The Thing'; both were mostly ignored, then reappraised as more formative than the year's hit."
        },
        {
          "title": "E.T. the Extra-Terrestrial",
          "year": 1982,
          "note": "Opened weeks earlier and took over 1982, blowing the doors off the darker genre films around it."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "John Carpenter on ‘The Thing’",
      "guest": "John Carpenter on",
      "films": [
        {
          "title": "The Thing",
          "year": 1982,
          "note": "Carpenter's own favorite of his films. He talks reception ('devastating,' a backlash after Halloween built him up), showing the monster fully instead of in shadow, Bottin working himself into the hospital, wanting 'less notes' from Morricone, and the hopeless ending he refused to soften: 'There's no happy ending to this. We're fucked.'"
        },
        {
          "title": "Halloween",
          "year": 1978,
          "note": "The hit that made his name and opened the studio doors to 'The Thing'; he scored it himself, contrary to what Universal assumed he'd do."
        },
        {
          "title": "Escape from New York",
          "year": 1981,
          "note": "He'd just wrapped it and went straight to a Universal office to sleep on the couch before starting 'The Thing.'"
        },
        {
          "title": "The Fog",
          "year": 1980,
          "note": "Where he first worked with Rob Bottin, who played the ghost Blake."
        },
        {
          "title": "Prince of Darkness",
          "year": 1987,
          "note": "Part of his Apocalypse trilogy; Fennessey calls it his most underrated film and Carpenter agrees it was a kick to make."
        },
        {
          "title": "In the Mouth of Madness",
          "year": 1994,
          "note": "The third Apocalypse-trilogy film, an idea he only recognized as a trilogy after 'The Thing' showed him he was drawn to end-of-the-world stories."
        },
        {
          "title": "They Live",
          "year": 1988,
          "note": "Cited as the go-to example of his films being easily read as political commentary."
        },
        {
          "title": "It Came from Outer Space",
          "year": 1953,
          "note": "The monster movie he saw as a kid that hooked him on the genre for the rest of the 1950s."
        },
        {
          "title": "The Howling",
          "year": 1981,
          "note": "Bottin's prior effects work before 'The Thing.'"
        },
        {
          "title": "Once Upon a Time in the West",
          "year": 1968,
          "note": "Carpenter calls Morricone's score maybe one of the top three of all time, his favorite going into their collaboration."
        },
        {
          "title": "The Eyes of Tammy Faye",
          "year": 2021,
          "note": "His pick for the last great thing he's seen: Jessica Chastain's Oscar-winning performance."
        }
      ]
    }
  ],
