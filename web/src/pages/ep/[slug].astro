---
import Base from '../../layouts/Base.astro';
import AuctionBody from '../../components/AuctionBody.astro';
import ListBody from '../../components/ListBody.astro';
import DraftBody from '../../components/DraftBody.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../data/episodes/*.json', { eager: true });
  return Object.values(modules).map((m) => ({
    params: { slug: m.default.slug },
    props: { ep: m.default },
  }));
}

const { ep } = Astro.props;
const tmdb = ep.tmdb || {};
const link = (t) => (tmdb[t]?.id ? `https://www.themoviedb.org/movie/${tmdb[t].id}` : null);

const kind = { auction: 'Auction', list: 'Roundtable', discussion: 'Discussion' }[ep.type] || 'Episode';
const pubDate = new Date(ep.published).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });

// Auction hero figures (only used when type === 'auction')
const hammerTotal = (ep.slates ?? []).reduce((n, s) => n + s.spent, 0);
const board = (ep.slates ?? []).flatMap((s) => s.picks).sort((a, b) => (b.price ?? -1) - (a.price ?? -1));
const topLot = board[0];
const paddleOf = {};
(ep.slates ?? []).forEach((s, i) => s.picks.forEach((p) => (paddleOf[p.title] = i + 1)));
const money = (p) => (p == null ? '—' : `$${p.toLocaleString()}`);
---
<Base title={`${ep.title} — The Full Picture`} description={ep.format}>
  <section class="cover">
    <div class="wrap">
      <p class="eyebrow">{ep.show} · {kind}</p>
      <h1>{ep.title}</h1>
      <p class="credits">
        <span>{pubDate}</span><span class="sep">/</span>
        <span>{ep.runtimeMin} min</span><span class="sep">/</span>
        <span>{ep.hosts.join(' · ')}</span>
      </p>
      <p class="lede">{ep.format}</p>

      {ep.type === 'auction' && (
        <>
          <p class="sale-line">
            A sale of <b>{board.length}</b> lots across <b>{ep.slates.length}</b> paddles — <b>${hammerTotal.toLocaleString()}</b> at the hammer.
          </p>
          <p class="toplot-cap">
            Top lot — <b>{topLot.title}</b>, to Paddle {paddleOf[topLot.title]}, <span class="hammer">{money(topLot.price)}</span>.
          </p>
          <div class="sold" aria-hidden="true"><span class="word">Sold</span><span class="fine">Mid-year sale · 2026</span></div>
        </>
      )}

      {ep.type === 'list' && (
        <p class="sale-line">
          <b>{ep.picks.length}</b> critics, <b>{ep.picks.length}</b> favorite films of the year so far.
        </p>
      )}

      {ep.type === 'draft' && (
        <p class="sale-line">
          <b>{ep.teams.reduce((n, t) => n + t.picks.length, 0)}</b> picks across <b>{ep.teams.length}</b> teams — a draft of <em>{ep.draftOf}</em>.
        </p>
      )}
    </div>
  </section>

  {ep.spotifyEpisodeId && (
    <section class="listen">
      <div class="wrap">
        <iframe
          title="Listen on Spotify"
          src={`https://open.spotify.com/embed/episode/${ep.spotifyEpisodeId}?theme=0`}
          width="100%" height="152" frameborder="0" loading="lazy"
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
        ></iframe>
      </div>
    </section>
  )}

  <div class="wrap">
    {ep.type === 'auction' ? <AuctionBody ep={ep} /> : ep.type === 'draft' ? <DraftBody ep={ep} /> : <ListBody ep={ep} />}

    <section class="sale-section">
      <p class="rubric">Also mentioned <span class="sub">raised along the way</span></p>
      {ep.referenced.map((g) => (
        <p class="entrylist">
          <span class="g">{g.group}</span>
          {g.films.map((f) => (link(f)
            ? <a class="entry" href={link(f)} target="_blank" rel="noopener">{f}</a>
            : <span class="entry">{f}</span>))}
        </p>
      ))}
    </section>

    <section class="sale-section">
      <p class="rubric">Not films <span class="sub">filtered out — TV, games, ads</span></p>
      {Object.entries(ep.excluded).map(([k, arr]) => (
        <p class="entrylist dim">
          <span class="g">{k}</span>
          {arr.map((f) => <span class="entry">{f}</span>)}
        </p>
      ))}
    </section>
  </div>
</Base>
