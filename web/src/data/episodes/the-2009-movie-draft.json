    {
      "kind": "discussion",
      "heading": "What we left on the board",
      "note": "undrafted 2009 movies",
      "films": [
        {
          "title": "Paranormal Activity",
          "year": 2009,
          "note": "Oren Peli's found-footage horror, made for under $250,000 and still argued to be one of the most profitable movies ever made by ROI. The franchise that built Blumhouse."
        },
        {
          "title": "Duplicity",
          "year": 2009,
          "note": "Tony Gilroy's Clive Owen/Julia Roberts corporate-espionage caper. Sean calls it 'legitimately incomprehensible' on first viewing and would love the same cast and director for a do-over."
        },
        {
          "title": "District 9",
          "year": 2009,
          "note": "Neill Blomkamp's apartheid-allegory blockbuster from a first-time filmmaker. A Best Picture nominee that looks, in hindsight, like a genre-movie anomaly the category doesn't allow anymore."
        },
        {
          "title": "Where the Wild Things Are",
          "year": 2009,
          "note": "Spike Jonze's Maurice Sendak adaptation. Sean says it made him weep and is now a fixture of reading the book to his own kids."
        },
        {
          "title": "A Single Man",
          "year": 2009,
          "note": "Tom Ford's directorial debut with Colin Firth. Amanda's takeaway is mostly the wardrobe ('beautiful gowns'), and she says it worked better for her than Ford's later Nocturnal Animals."
        },
        {
          "title": "Orphan",
          "year": 2009,
          "note": "The twist-ending horror movie that became a running blog joke that year for how fast people spoiled the ending."
        },
        {
          "title": "The House of the Devil",
          "year": 2009,
          "note": "Ti West's slow-burn homage to '80s babysitter slashers, with an early Greta Gerwig performance."
        },
        {
          "title": "The Last Station",
          "year": 2009,
          "note": "Christopher Plummer, Helen Mirren, and James McAvoy in a Tolstoy drama Chris caught alone at an art-house matinee."
        },
        {
          "title": "Public Enemies",
          "year": 2009,
          "note": "Michael Mann's Dillinger movie with Johnny Depp and Christian Bale. Multiple hosts call it their least favorite Mann film and say they've rewatched Blackhat more often."
        },
        {
          "title": "Two Lovers",
          "year": 2009,
          "note": "James Gray's Joaquin Phoenix drama, a 2008 Cannes premiere with a 2009 U.S. release. Universally liked at the table."
        },
        {
          "title": "Bright Star",
          "year": 2009,
          "note": "Jane Campion's Keats romance, a favorite of both Sean's and Amanda's, called 'so underrated.'"
        },
        {
          "title": "Julie & Julia",
          "year": 2009,
          "note": "Nora Ephron's dual Julia Child/Julie Powell biopic with Meryl Streep and Amy Adams. Amanda says the Streep half is great and the blogging half is 'whatever,' which is why she didn't draft it."
        },
        {
          "title": "The Girlfriend Experience",
          "year": 2009,
          "note": "Soderbergh's other 2009 movie besides The Informant!, with Sasha Grey. Sean admits he undersold it in the moment."
        },
        {
          "title": "Drag Me to Hell",
          "year": 2009,
          "note": "Sam Raimi's horror comeback. Chris regrets not drafting it."
        },
        {
          "title": "The Young Victoria",
          "year": 2009,
          "note": "Emily Blunt as the young Queen Victoria. Amanda calls it a 'quality flick.'"
        },
        {
          "title": "Extract",
          "year": 2009,
          "note": "Mike Judge's workplace comedy with Jason Bateman, joked about as 'an Ozark prequel.'"
        },
        {
          "title": "The September Issue",
          "year": 2009,
          "note": "The Vogue behind-the-scenes documentary: 'pretty good, as those things go.'"
        },
        {
          "title": "Enter the Void",
          "year": 2009,
          "note": "Gaspar Noé, part of a foreign-film year the table admits it didn't draft into."
        },
        {
          "title": "The White Ribbon",
          "year": 2009,
          "note": "Michael Haneke's Palme d'Or winner."
        },
        {
          "title": "Thirst",
          "year": 2009,
          "note": "Park Chan-wook's vampire-priest movie."
        },
        {
          "title": "Mother",
          "year": 2009,
          "note": "Bong Joon-ho's thriller."
        },
        {
          "title": "A Prophet",
          "year": 2009,
          "note": "Jacques Audiard's prison drama."
        },
        {
          "title": "Dogtooth",
          "year": 2009,
          "note": "Yorgos Lanthimos; Chris asks to be the guest whenever they do a 'movie parenting' episode on this one."
        }
      ]
