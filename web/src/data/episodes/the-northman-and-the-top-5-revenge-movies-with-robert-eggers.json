{
  "slug": "the-northman-and-the-top-5-revenge-movies-with-robert-eggers",
  "title": "‘The Northman,’ and the Top 5 Revenge Movies With Robert Eggers!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2022-04-22",
  "runtimeMin": 89,
  "format": "Sean and Chris Ryan dig into Robert Eggers' Viking epic, each draft a top-5 revenge-movie list, then Sean sits down with Eggers himself. Bobby Wagner produces.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "‘The Northman’",
      "note": "Sean and Chris Ryan",
      "films": [
        {
          "title": "The Northman",
          "year": 2022,
          "note": "Eggers' $90-100M Viking epic: Amleth (Alexander Skårsgard), exiled after his uncle murders his father (Ethan Hawke), grows up to avenge him, kill the uncle, and save his mother (Nicole Kidman). Chris calls it the most interesting movie he's seen in a while; both praise the performances and say the film drags in places under its own research and effort. Also stars Anya Taylor-Joy and Björk."
        },
        {
          "title": "The Witch",
          "year": 2015,
          "note": "Eggers' debut; the historical-accuracy streak they trace forward to The Northman."
        },
        {
          "title": "The Lighthouse",
          "year": 2019,
          "note": "Sean's example of Eggers' obsessive research; Chris finds it the funnier of the two on a rewatch with closed captions on."
        },
        {
          "title": "Apocalypse Now",
          "year": 1979,
          "note": "Chris's Coppola comparison for Eggers' insistence on getting exactly what's in his head onto the screen, echoing Ethan Hawke's own reason for taking the role."
        },
        {
          "title": "Gladiator",
          "year": 2000,
          "note": "The other sword-and-shield epic about a man stripped of everything who fights his way home; Sean notes even Eggers told him he has to give it up to this one."
        },
        {
          "title": "The Last Duel",
          "year": 2021,
          "note": "Sean's reference for the multiple points of view The Northman uses to complicate its own vengeance story."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top 5 Revenge Movies",
      "note": "No. 1 first",
      "subject": "revenge movies",
      "ranked": true,
      "films": [
        {
          "title": "Kill Bill: Vol. 2",
          "year": 2004,
          "note": "No. 1: picked for how much time Tarantino gives Bud, Elle, and Bill to explain themselves before the Bride gets to them."
        },
        {
          "title": "Point Blank",
          "year": 1967,
          "note": "No. 2 (paired with The Limey): John Boorman, Lee Marvin as a man avenging his own betrayal by his partner and wife."
        },
        {
          "title": "The Limey",
          "year": 1999,
          "note": "No. 2 (paired with Point Blank): Steven Soderbergh, Terence Stamp avenging his daughter's death; both play with chronology to get inside a mind fixed on vengeance."
        },
        {
          "title": "Carrie",
          "year": 1976,
          "note": "No. 3: Brian De Palma's Stephen King adaptation, an inversion where the torment comes first and the telekinetic payback arrives at the end."
        },
        {
          "title": "Gladiator",
          "year": 2000,
          "note": "No. 4: the version of this story where the stakes and villain are cleanest; Chris calls Ridley Scott the most stable, prolific studio director working on this scale."
        },
        {
          "title": "Man on Fire",
          "year": 2004,
          "note": "No. 5: Tony Scott, Denzel Washington as a bodyguard who unleashes hell on Mexico City after his charge is kidnapped."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top 5 Revenge Movies",
      "note": "No. 1 first",
      "subject": "revenge movies",
      "ranked": true,
      "films": [
        {
          "title": "Once Upon a Time in the West",
          "year": 1968,
          "note": "No. 1: Sean's favorite Sergio Leone, Charles Bronson's Harmonica seeking a revenge the film withholds the reason for until the end."
        },
        {
          "title": "Inglourious Basterds",
          "year": 2009,
          "note": "No. 2: Sean's Tarantino pick, built around Shoshanna as a projectionist annihilating Nazi leadership."
        },
        {
          "title": "The Outlaw Josey Wales",
          "year": 1976,
          "note": "No. 3: Clint Eastwood after his family is killed; Sean calls it the film that set the course for Eastwood's own directing career."
        },
        {
          "title": "Walking Tall",
          "year": 1973,
          "note": "No. 4: the original, not the Dwayne Johnson remake; Joe Don Baker as a sheriff cleaning out a corrupt hometown."
        },
        {
          "title": "Miss 45",
          "year": 1981,
          "note": "No. 5: Abel Ferrara's rape-revenge film starring Zoë Lund; Sean calls it fascinating and influential despite how hard it is to watch."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Robert Eggers on",
      "films": [
        {
          "title": "The Vikings",
          "year": 1958,
          "note": "Richard Fleischer's Kirk Douglas film; Eggers says The Northman's opening deliberately echoes its homecoming feast, minus the raucousness."
        },
        {
          "title": "Blue Ruin",
          "year": 2013,
          "note": "The revenge movie Eggers says convinced him the genre still works, watched a year after his first trip to Iceland."
        },
        {
          "title": "The Road to Wellville",
          "year": 1994,
          "note": "Eggers' answer to the show's closing question: a rewatch he still rates, Anthony Hopkins' over-the-top performance included."
        }
      ]
    }
  ],
