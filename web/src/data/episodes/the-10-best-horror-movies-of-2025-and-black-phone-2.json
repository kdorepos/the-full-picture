{
  "slug": "the-10-best-horror-movies-of-2025-and-black-phone-2",
  "title": "The 10 Best Horror Movies of 2025 and 'Black Phone 2'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2025-10-21",
  "runtimeMin": 122,
  "format": "Sean and Chris Ryan pan the Blumhouse hit 'Black Phone 2,' then run through the year in horror. Plus: Alex Ross Perry on his V/H/S/Halloween segment and the horror anthology.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Black Phone 2'",
      "note": "With Chris Ryan",
      "films": [
        {
          "title": "Black Phone 2",
          "year": 2025,
          "note": "Scott Derrickson's sequel, again written with C. Robert Cargill from Joe Hill's world, with Ethan Hawke back as the Grabber and Mason Thames and Madeleine McGraw as Finney and Gwen. Chris likes the first 45 minutes and the contrast between the abusively high-def present and the 8mm/16mm dream footage, but says it collapses under exposition connecting the two films, retcons the mother's death, and turns the Grabber supernatural a la Freddy Krueger. Too long at 1h55, and boring where a horror movie shouldn't be, yet a real box-office win for a cold Blumhouse."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Is horror too good now?",
      "note": "The big studio horror of 2025",
      "films": [
        {
          "title": "Sinners",
          "year": 2025,
          "note": "One of the year's top-tier swings and a massive hit; you see the vampire siege coming and love it anyway."
        },
        {
          "title": "Weapons",
          "year": 2025,
          "note": "Maybe three jump scares in the whole thing and audiences are mesmerized, proof that a great filmmaker plus a few scares wins."
        },
        {
          "title": "28 Years Later",
          "year": 2025,
          "note": "Big ideas about grief, parenthood and childhood, carried by an iPhone-shot naked zombie alpha."
        },
        {
          "title": "Final Destination Bloodlines",
          "year": 2025,
          "note": "The studio exception, dormant IP nobody expected much from that turned into a modestly budgeted hit by taking real swings."
        },
        {
          "title": "The Conjuring: Last Rites",
          "year": 2025,
          "note": "Likely the biggest Conjuring ever, but drowned in the same endless exposition that sinks Black Phone 2."
        },
        {
          "title": "The Monkey",
          "year": 2025,
          "note": "Osgood Perkins after Longlegs, one of the year's most successful horror films; Chris prefers Longlegs."
        },
        {
          "title": "Until Dawn",
          "year": 2025,
          "note": "Sony's video-game adaptation, which Chris thought was really bad."
        },
        {
          "title": "The Strangers: Chapter 2",
          "year": 2025,
          "note": "Cited as the over-explaining problem: a full origin story for the strangers, exactly what the original's mystery didn't need."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The year in horror",
      "note": "Chris Ryan's 2025 picks and near-misses",
      "films": [
        {
          "title": "V/H/S/Halloween",
          "year": 2025,
          "note": "One of the best in the annual Shudder anthology, lighter and more playful than past installments; Alex Ross Perry's Kidprint segment is the standout."
        },
        {
          "title": "Dangerous Animals",
          "year": 2025,
          "note": "Sean Byrne's sadistic movie about a killer who uses a shark as his weapon; Jai Courtney is a great villain, though Chris finds the surfer-finding-herself opening baggy."
        },
        {
          "title": "Bring Her Back",
          "year": 2025,
          "note": "The Philippou brothers' follow-up to Talk to Me, with a strong Sally Hawkins turn but an instant slog; the dark-web resurrection prequel sounds better than the movie."
        },
        {
          "title": "Strange Harvest",
          "year": 2025,
          "note": "Stuart Ortiz's note-for-note true-crime-doc pastiche about an Inland Empire serial killer with occult powers, well executed on a low budget but more exercise than movie."
        },
        {
          "title": "Shelby Oaks",
          "year": 2025,
          "note": "YouTube critic Chris Stuckmann's crowdfunded debut about vanished ghost-hunter YouTubers, later picked up by Neon with Mike Flanagan as EP; it works as a fake true-crime doc, then falters when it becomes a conventional narrative."
        },
        {
          "title": "Night of the Reaper",
          "year": 2025,
          "note": "Brandon Christensen's babysitter-versus-killer movie, a riff on House of the Devil and Scream that leans on 80s aesthetics but goes its own way."
        },
        {
          "title": "Marshmallow",
          "year": 2025,
          "note": "Daniel DePurgatorio's plot-dependent comedy-horror set at a summer camp; on Shudder."
        },
        {
          "title": "Invader",
          "year": 2025,
          "note": "Mickey Keating's 70-minute run-and-gun film with and produced by Joe Swanberg, pitched toward the Dardennes and Haneke; punishingly handheld but the recommendation of the episode."
        },
        {
          "title": "Companion",
          "year": 2025,
          "note": "A 99-out-of-100 movie hurt by a January release; would have been welcome this month and had too much of itself in the trailer."
        },
        {
          "title": "Good Boy",
          "year": 2025,
          "note": "A killer seen through the eyes of his dog, with one of the great dog performances; better as experiment than movie at 73 minutes, headed to Shudder."
        },
        {
          "title": "Descendent",
          "year": 2025,
          "note": "Peter Cilella's Benson-and-Morehead-adjacent sci-fi horror about a security guard drawn in by aliens as his wife is pregnant; strong filmmaking, with Ross Marquand and Sarah Bolger."
        },
        {
          "title": "Jimmy and Stiggs",
          "year": 2025,
          "note": "Joe Begos's 84-minute splatter-core head trip: a thinly veiled Begos wakes to find aliens in his apartment and has to kill them. Very funny, very gross, with an insane final 20 minutes."
        },
        {
          "title": "Bleeding",
          "year": 2025,
          "note": "A vampire movie as opioid-addiction allegory, with early-Jeff-Nichols Shotgun Stories energy and performances better than the premise needs."
        },
        {
          "title": "Fear Street: Prom Queen",
          "year": 2025,
          "note": "Serviceable, pretty decent."
        },
        {
          "title": "Clown in a Cornfield",
          "year": 2025,
          "note": "A fun killer-clown whodunit slasher, more successful and more tongue-in-cheek than the I Know What You Did Last Summer reboot."
        },
        {
          "title": "I Know What You Did Last Summer",
          "year": 2025,
          "note": "The Gen-Z reboot, well cast but too pleased with its own cleverness and weighed down connecting itself to the old films; a straight remake might have played better."
        },
        {
          "title": "Bone Lake",
          "year": 2025,
          "note": "An Airbnb couples-thriller with hints of partner-swapping; Chris hadn't seen it yet."
        },
        {
          "title": "Witchboard",
          "year": 2025,
          "note": "Chuck Russell's remake of the 1986 Ouija-board movie; Chris hadn't seen it but is eager to, as Russell made Dream Warriors, The Mask and the Blob remake."
        },
        {
          "title": "Hell of a Summer",
          "year": 2025,
          "note": "Finn Wolfhard's co-directed Meatballs-meets-slasher, with Fred Hechinger; a completely entertaining night."
        },
        {
          "title": "Looky Loo",
          "year": 2025,
          "note": "A very fucked-up first-person found-footage stalking film, on VOD."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Alex Ross Perry on",
      "films": [
        {
          "title": "V/H/S/Halloween",
          "year": 2025,
          "note": "His segment Kidprint, a 90s-Blockbuster-'Kid Print'-video nightmare inspired by his essay film Video Heaven, shot in May, out in October; grounded on the fear that scares him most as a parent, a stranger who can just walk in."
        },
        {
          "title": "Creepshow",
          "year": 1982,
          "note": "The single-filmmaker gold standard, rewatchable every Halloween because King writes the funny, fucked-up little stories better than anyone."
        },
        {
          "title": "Creepshow 2",
          "year": 1987,
          "note": "Three single-setting segments and a weak animated wraparound; the Ted Danson beach story is the one everyone loves."
        },
        {
          "title": "Trick 'r Treat",
          "year": 2007,
          "note": "The obvious modern single-filmmaker answer, and everyone's top-five omnibus even if Letterboxd stashes it at No. 10."
        },
        {
          "title": "Kwaidan",
          "year": 1964,
          "note": "Masaaki Kobayashi's film, the highest average on the by-Letterboxd list; watchable across multiple sittings, per Tracy Letts."
        },
        {
          "title": "Dead of Night",
          "year": 1945,
          "note": "The original British omnibus with five directors, second on the by-rating list."
        },
        {
          "title": "Tales from the Hood",
          "year": 1995,
          "note": "A well-regarded single-vision anthology with real consistency."
        },
        {
          "title": "Black Sabbath",
          "year": 1963,
          "note": "Mario Bava's single-filmmaker anthology, near the top of the list."
        },
        {
          "title": "Night Train to Terror",
          "year": 1985,
          "note": "God and the Devil playing chess on a train between shorts that seem to be abandoned features retrofitted into one movie; Alex would rate it a 4 out of 5."
        },
        {
          "title": "Verotika",
          "year": 2016,
          "note": "Glenn Danzig's anthology of his comic stories; not bottom-of-the-barrel, in Alex's telling, whatever the reputation."
        },
        {
          "title": "Death Rider in the House of Vampires",
          "year": 2021,
          "note": "Danzig's vampire Western with Devon Sawa, Julian Sands, Danny Trejo and Eli Roth; a 2.3 on Letterboxd."
        }
      ]
    }
  ],
