{
  "slug": "the-brutalist-the-best-movies-at-the-new-york-film-festival-",
  "title": "‘The Brutalist,’ the Best Movies at the New York Film Festival, and ‘The Apprentice' With Sebastian Stan!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Bobby Wagner"
  ],
  "published": "2024-10-15",
  "runtimeMin": 125,
  "format": "Sean Fennessey and producer Bobby Wagner run down the New York Film Festival, then Brian Curtis joins to argue over ‘The Apprentice' and Sebastian Stan sits for an interview.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The best movies at the New York Film Festival",
      "note": "with Bobby Wagner",
      "films": [
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "Brady Corbett's third feature, shot in VistaVision. Adrien Brody as a Hungarian émigré architect, Guy Pearce as his benefactor. Fennessey's pick for best film of the festival, out December 20."
        },
        {
          "title": "Nickel Boys",
          "year": 2024,
          "note": "RaMell Ross adapts Colson Whitehead's novel about a Jim Crow reform school. Fennessey flagged it at Telluride as the boldest thing he saw."
        },
        {
          "title": "Anora",
          "year": 2024,
          "note": "Sean Baker's Palme d'Or winner, with Mikey Madison as a Brooklyn sex worker who marries an oligarch's son."
        },
        {
          "title": "Emilia Pérez",
          "year": 2024,
          "note": "Jacques Audiard's Mexico-set musical, chosen as France's international submission over All We Imagine as Light."
        },
        {
          "title": "A Real Pain",
          "year": 2024,
          "note": "Jesse Eisenberg writes and directs; Kieran Culkin as the cousin you can't quit."
        },
        {
          "title": "Queer",
          "year": 2024,
          "note": "Guadagnino's William S. Burroughs adaptation with Daniel Craig. Fennessey admired the ambition more than the result."
        },
        {
          "title": "Pavements",
          "year": 2024,
          "note": "Alex Ross Perry's blend of biopic, documentary and jukebox musical about the band Pavement."
        },
        {
          "title": "The Shrouds",
          "year": 2024,
          "note": "Cronenberg on grief and surveillance, with Vincent Cassel and Diane Kruger. Fennessey's favorite film he actually saw in New York."
        },
        {
          "title": "Oh, Canada",
          "year": 2024,
          "note": "Schrader reunites with Richard Gere four decades after American Gigolo; Jacob Elordi plays the younger self."
        },
        {
          "title": "Hard Truths",
          "year": 2024,
          "note": "Mike Leigh reunites with Marianne Jean-Baptiste for the first time since Secrets & Lies."
        },
        {
          "title": "The Seed of the Sacred Fig",
          "year": 2024,
          "note": "Mohammad Rasoulof's Tehran drama, made in exile and running as Germany's submission. The hosts were mixed."
        },
        {
          "title": "Universal Language",
          "year": 2024,
          "note": "Matthew Rankin's Winnipeg-meets-Tehran comedy, Canada's submission."
        },
        {
          "title": "Eephus",
          "year": 2024,
          "note": "Carson Lund's single-day adult baseball-league movie. Wagner's pick."
        },
        {
          "title": "All We Imagine as Light",
          "year": 2024,
          "note": "Payal Kapadia's Mumbai drama about two nurses across a generational divide. Wagner's favorite of the festival."
        },
        {
          "title": "No Other Land",
          "year": 2024,
          "note": "Palestinian-Israeli documentary on the destruction of Masafer Yatta in the West Bank."
        },
        {
          "title": "Happy End",
          "year": 2024,
          "note": "Neo Sora's high-school coming-of-age story set under classroom surveillance."
        },
        {
          "title": "Stranger Eyes",
          "year": 2024,
          "note": "Yeo Siew Hua's Rear Window-style thriller about a couple's abducted child and the surveillance state."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "‘The Apprentice'",
      "note": "with Brian Curtis",
      "films": [
        {
          "title": "The Apprentice",
          "year": 2024,
          "note": "Ali Abbasi's Trump origin story, with Sebastian Stan as Trump and Jeremy Strong as Roy Cohn. Fennessey and Curtis split on whether it reveals anything a decade of coverage hasn't."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation with Sebastian Stan",
      "guest": "Sebastian Stan on",
      "films": [
        {
          "title": "A Different Man",
          "year": 2024,
          "note": "Aaron Schimberg's unsettling character study; Stan in prosthetics opposite Adam Pearson."
        },
        {
          "title": "The Apprentice",
          "year": 2024,
          "note": "On slowly morphing into Trump without tipping into caricature, much of it improvised."
        },
        {
          "title": "I, Tonya",
          "year": 2017,
          "note": "A role Stan says he had to fight for."
        },
        {
          "title": "Dumb Money",
          "year": 2023
        },
        {
          "title": "Perfect Days",
          "year": 2023,
          "note": "Wim Wenders; one of Stan's last-great picks."
        },
        {
          "title": "Licorice Pizza",
          "year": 2021,
          "note": "Stan's other pick: he fell asleep rewatching it, happily."
        }
      ]
    }
  ],
