{
  "slug": "the-2026-oscar-nominations-snubs-surprises-and-wtfs",
  "title": "The 2026 Oscar Nominations: Snubs, Surprises, and WTFs",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2026-01-22",
  "runtimeMin": 64,
  "format": "Sean Fennessey and Amanda Dobbins react to the 2026 Academy Award nominations two hours after they landed, then walk the whole board category by category. Sinners sets a record with 16, One Battle After Another trails with 13, and F1 sneaks into Best Picture after Sean touted it for months and then, at the last minute, predicted Weapons. Along the way: the Chase Infiniti Best Actress snub, It Was Just an Accident missing Best Picture, Delroy Lindo's surprise Supporting nod, and a Best Original Song category one host wants deleted outright.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Snubs, surprises, and WTFs",
      "note": "the stories behind the board",
      "films": [
        {
          "title": "Sinners",
          "year": 2025,
          "note": "16 nominations, the most ever. Casting was added this year, but it still would have broken the record at 15. The hosts expect it to win the most trophies on the night by sheer volume: 16 bites at the apple. Delroy Lindo's car-monologue scene is the one they flag for the clip-reel moment."
        },
        {
          "title": "One Battle After Another",
          "year": 2025,
          "note": "13 nominations, third-most in Academy history, and the presumptive Best Picture winner, though the hosts point out they've barely discussed their favorite film of the year. The Chase Infiniti Best Actress snub, they argue, shows voters underrating the women in a film they otherwise nominated everywhere."
        },
        {
          "title": "F1",
          "year": 2025,
          "note": "The Best Picture surprise. Sean called it for five months, then blinked on nomination morning and predicted Weapons, reasoning the Academy had never nominated three non-English films for Best Picture. Amanda: 'You fucked up, buddy.' Also in for sound and film editing."
        },
        {
          "title": "It Was Just an Accident",
          "year": 2025,
          "note": "Jafar Panahi's Palme d'Or winner is the first Palme d'Or film to miss Best Picture since Titane in 2021. It landed Original Screenplay and International Feature, and the hosts float it winning International as an Argo-style consolation to get Panahi on stage."
        },
        {
          "title": "Song Sung Blue",
          "year": 2025,
          "note": "Kate Hudson's Best Actress nomination is the most-mocked slot of the morning, in over Chase Infiniti and Amanda Seyfried. 'Charlize Theron in Monster Lite Lite,' Sean calls it: the wrong kind of Oscar nostalgia."
        },
        {
          "title": "Weapons",
          "year": 2025,
          "note": "One nomination, Amy Madigan for Supporting Actress. Sean's theory for the shortfall: Zack Cregger is off shooting Resident Evil and skipped the whole campaign. Both hosts would have taken it over F1 in Best Picture."
        },
        {
          "title": "Frankenstein",
          "year": 2025,
          "note": "Nine nominations, but Guillermo del Toro missed Best Director while landing Adapted Screenplay. Strong across the crafts too, including the endlessly-discussed handmade sets."
        },
        {
          "title": "Train Dreams",
          "year": 2025,
          "note": "The 'straight-up good' Best Picture nominee Sean has been holding onto since he saw it at Sundance a year ago. Netflix's second film in the category, with digital cinematography the hosts call hard to pull off."
        }
      ]
    },
