{
  "slug": "the-1994-mega-movie-draft",
  "title": "The 1994 Mega-Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2021-11-02",
  "runtimeMin": 90,
  "format": "Sean, Amanda, and Chris Ryan hand two picks to first-timers Shea Serrano and Van Lathan for a five-person, 30-movie snake draft of 1994: the year of Pulp Fiction, Forrest Gump, and The Shawshank Redemption, with Spanking the Monkey and Baby's Day Out still on the board when it ends.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The 1994 Movie Draft",
      "note": "drama, comedy, Oscar nominee, action/horror, blockbuster, wildcard",
      "draftOf": "1994 movies",
      "categories": [
        "Drama",
        "Comedy",
        "Oscar Nominee",
        "Action/Horror",
        "Blockbuster",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Shea Serrano",
          "picks": [
            {
              "title": "The Lion King",
              "year": 1994,
              "category": "Blockbuster",
              "note": "First overall pick: $763 million worldwide, nearly $100 million ahead of Forrest Gump. Shay snuck into a screening with a childhood friend and says Rafiki's kung-fu homage was the first time he clocked one movie referencing another."
            },
            {
              "title": "Timecop",
              "year": 1994,
              "category": "Action/Horror",
              "note": "Turned down a joke pick of Three Colors: Red for Jean-Claude Van Damme instead. Argues Timecop's three rules of time travel are cleaner than Back to the Future's or Primer's."
            },
            {
              "title": "Above the Rim",
              "year": 1994,
              "category": "Drama",
              "note": "Dwayne Martin, Tupac, Marlon Wayans, and a young Bernie Mac. Shay notes Suge Knight's Source Awards speech was accepting the award for this movie's soundtrack, not for a Death Row release."
            },
            {
              "title": "Airheads",
              "year": 1994,
              "category": "Comedy",
              "note": "Early Adam Sandler and Steve Buscemi, a year before Sandler broke out with Billy Madison."
            },
            {
              "title": "Surviving the Game",
              "year": 1994,
              "category": "Wildcard",
              "note": "Ice-T vehicle Shay says taught him two things: don't take a trip with rich white people, and check the barrel of a gun. Sean calls it a letdown after Juice."
            },
            {
              "title": "Wyatt Earp",
              "year": 1994,
              "category": "Oscar Nominee",
              "note": "The last pick of the draft: Shay says he cares little about it beyond liking Kevin Costner, and that it lives in Tombstone's shadow."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Pulp Fiction",
              "year": 1994,
              "category": "Oscar Nominee",
              "note": "Sean had already bought two books about Quentin Tarantino before this came out. Calls the needle-drop opening credits the moment everything changed for how he thought about movies."
            },
            {
              "title": "Forrest Gump",
              "year": 1994,
              "category": "Blockbuster",
              "note": "A churn-through-cable classic Sean ranks alongside Shawshank, unsophisticated parts and all."
            },
            {
              "title": "Léon: The Professional",
              "year": 1994,
              "category": "Action/Horror",
              "note": "Luc Besson's Natalie Portman debut opposite Jean Reno and Gary Oldman. Sean says he's built a chunk of his podcasting career quoting it."
            },
            {
              "title": "Quiz Show",
              "year": 1994,
              "category": "Drama",
              "note": "Robert Redford's quiz-fixing drama with John Turturro, Ralph Fiennes, and Paul Scofield. Sean says it fed a Jeopardy addiction he had going at the time."
            },
            {
              "title": "The Hudsucker Proxy",
              "year": 1994,
              "category": "Comedy",
              "note": "A box-office flop Sean calls a fork in the road for the Coens, the movie that forced the pivot toward Fargo."
            },
            {
              "title": "Blue Chips",
              "year": 1994,
              "category": "Wildcard",
              "note": "William Friedkin's college-basketball drama with Nick Nolte as coach Pete Bell. Sean calls it one of Nolte's best performances."
            }
          ]
        },
        {
          "host": "Van Lathan",
          "picks": [
            {
              "title": "The Shawshank Redemption",
              "year": 1994,
              "category": "Drama",
              "note": "Van saw it with his father and remembers grown men crying in the theater. Argues that in a redraft of that year's Oscars, it beats Forrest Gump for Best Picture."
            },
            {
              "title": "True Lies",
              "year": 1994,
              "category": "Action/Horror",
              "note": "Van was 14 when this came out. Credits Tom Arnold's chemistry and James Cameron's pacing, and says it's the first action movie he remembers centering the hero's home life."
            },
            {
              "title": "Fresh",
              "year": 1994,
              "category": "Wildcard",
              "note": "Van's most personal pick of the draft, a movie that sent him into a chess phase. He later got to ask producer Lawrence Bender about it on an unrelated shoot, while everyone else only wanted to talk to Bender about Pulp Fiction."
            },
            {
              "title": "The Mask",
              "year": 1994,
              "category": "Blockbuster",
              "note": "Taken over Wolf, which Van wanted but couldn't slot anywhere else. Calls Jim Carrey too hot at that moment for the pick to go wrong."
            },
            {
              "title": "Legends of the Fall",
              "year": 1994,
              "category": "Oscar Nominee",
              "note": "Nominated for Best Cinematography. Van calls it \"top tier mess\" and peak Brad Pitt, ahead of Thelma & Louise or Troy."
            },
            {
              "title": "Blankman",
              "year": 1994,
              "category": "Comedy",
              "note": "Damon Wayans's post-In Living Color superhero comedy, picked over Ace Ventura on principle. Sean calls it one of the worst picks in movie-draft history."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Speed",
              "year": 1994,
              "category": "Blockbuster",
              "note": "One of the rare movies Chris saw in theaters twice back to back, same category as Training Day and Sicario for him. Ranks Keanu Reeves and Sandra Bullock's chemistry above Schwarzenegger and Curtis in True Lies."
            },
            {
              "title": "Clerks",
              "year": 1994,
              "category": "Comedy",
              "note": "Chris calls the two clerks' Death Star conversation the actual birth of podcasting."
            },
            {
              "title": "Hoop Dreams",
              "year": 1994,
              "category": "Oscar Nominee",
              "note": "Nominated for Best Editing, not Best Documentary, a snub Chris and Van needle by naming the four films that actually got the doc nomination that year."
            },
            {
              "title": "Chungking Express",
              "year": 1994,
              "category": "Drama",
              "note": "Chris's entry point into world cinema, citing Christopher Doyle's cinematography and still calling it one of the most romantic movies he's seen."
            },
            {
              "title": "Shallow Grave",
              "year": 1994,
              "category": "Action/Horror",
              "note": "Danny Boyle's directorial debut, introducing Ewan McGregor opposite Christopher Eccleston."
            },
            {
              "title": "Natural Born Killers",
              "year": 1994,
              "category": "Wildcard",
              "note": "Chris calls it the year's most controversial and most covered production, even while admitting it \"comes up really short.\""
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Reality Bites",
              "year": 1994,
              "category": "Comedy",
              "note": "Amanda's introduction to Gen X and Winona Ryder. She says her opinion on whether Winona should end up with Ethan Hawke or Ben Stiller has flipped more than once with age."
            },
            {
              "title": "Four Weddings and a Funeral",
              "year": 1994,
              "category": "Oscar Nominee",
              "note": "Watched it at age 10 on a rental. Calls it her introduction to Hugh Grant, whose Twitter account she recommends."
            },
            {
              "title": "Dumb and Dumber",
              "year": 1994,
              "category": "Blockbuster",
              "note": "A family movie-night rewatch pick. Amanda cites \"our pets' heads are falling off\" as her all-purpose line for when everything's going wrong."
            },
            {
              "title": "Clear and Present Danger",
              "year": 1994,
              "category": "Action/Horror",
              "note": "Amanda names 1988 to 1994 as peak Harrison Ford and singles out the \"how dare you, sir\" Oval Office confrontation."
            },
            {
              "title": "Little Women",
              "year": 1994,
              "category": "Drama",
              "note": "Credits its box-office success with kicking off the wave of Austen adaptations later in the decade, including Sense and Sensibility. Cast: Winona Ryder, Kirsten Dunst, Claire Danes, Christian Bale."
            },
            {
              "title": "Barcelona",
              "year": 1994,
              "category": "Wildcard",
              "note": "A Whit Stillman film with Chris Eigeman, whom Amanda also flags from Kicking and Screaming."
            }
          ]
        }
      ],
      "undrafted": [
        "Spanking the Monkey",
        "Baby's Day Out"
      ]
    }
  ],
