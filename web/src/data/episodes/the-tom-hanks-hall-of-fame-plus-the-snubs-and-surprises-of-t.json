{
  "slug": "the-tom-hanks-hall-of-fame-plus-the-snubs-and-surprises-of-t",
  "title": "The Tom Hanks Hall of Fame. Plus: The Snubs and Surprises of the Independent Spirit Award Nominations. | The Big Picture",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2019-11-22",
  "runtimeMin": 107,
  "format": "Sean and Amanda pick through the Independent Spirit Award nominations, build a 10-film Tom Hanks Hall of Fame, and Sean talks with Marielle Heller about making 'A Beautiful Day in the Neighborhood.'",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Independent Spirit Award Nominations: Snubs and Surprises",
      "films": [
        {
          "title": "Marriage Story",
          "year": 2019,
          "note": "Nominated for Best Feature, but its Robert Altman Award for Best Ensemble knocks Adam Driver and Scarlett Johansson out of the Best Actor and Best Actress races."
        },
        {
          "title": "The Farewell",
          "year": 2019,
          "note": "The only Best Feature nominee here with a real shot at Best Picture."
        },
        {
          "title": "Uncut Gems",
          "year": 2019,
          "note": "Loaded with nominations; they wonder if it just runs the table on this show."
        },
        {
          "title": "A Hidden Life",
          "year": 2019,
          "note": "Terrence Malick's new film, oddly quiet in the awards conversation so far."
        },
        {
          "title": "Clemency",
          "year": 2019,
          "note": "Alfre Woodard nominated for Best Female Lead; its late-December release may cap its Oscar chances."
        },
        {
          "title": "Honey Boy",
          "year": 2019,
          "note": "Shia LaBeouf and Noah Jupe both up for Best Supporting Actor; more press could help this one."
        },
        {
          "title": "The Lighthouse",
          "year": 2019,
          "note": "The 'A24 merch bro' favorite, and a real feat of cinematography beyond that reputation."
        },
        {
          "title": "Give Me Liberty",
          "year": 2019,
          "note": "The one nobody's seen: a Music Box release that barely played theaters after Tribeca and Berlin."
        },
        {
          "title": "Diane",
          "year": 2019,
          "note": "Kent Jones and Mary Kay Place's film, discussed on the show earlier this year."
        },
        {
          "title": "Luce",
          "year": 2019,
          "note": "Julius Onah's film, with acting nominations for its cast."
        },
        {
          "title": "The Climb",
          "year": 2019,
          "note": "Described in its own logline as two friends cycling through France; Sony Pictures Classics has it for a March release."
        },
        {
          "title": "Waves",
          "year": 2019,
          "note": "The surprise snub: one nomination, for Taylor Russell, despite loud fans like Bill Simmons."
        },
        {
          "title": "Midsommar",
          "year": 2019,
          "note": "Zero nominations, no Florence Pugh; they wonder if it got too mainstream, or just too memed, to read as a Spirits movie."
        },
        {
          "title": "Harriet",
          "year": 2019,
          "note": "Zero nominations despite being a real box-office hit."
        },
        {
          "title": "High Flying Bird",
          "year": 2019,
          "note": "One nomination, for Tarell Alvin McCraney's script."
        },
        {
          "title": "Her Smell",
          "year": 2019,
          "note": "The snub that stings most: an independently made Elisabeth Moss vehicle from Alex Ross Perry that seems built for this show."
        },
        {
          "title": "The Last Black Man in San Francisco",
          "year": 2019,
          "note": "One nomination, for Jonathan Majors in supporting."
        },
        {
          "title": "Hustlers",
          "year": 2019,
          "note": "Lorene Scafaria nominated for Best Director even though the film missed Best Feature; Jennifer Lopez also picked up a nomination."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Tom Hanks Hall of Fame",
      "note": "the final 10, cut down from a shortlist of 42",
      "honoree": "Tom Hanks",
      "films": [
        {
          "title": "Big",
          "year": 1988,
          "note": "The breakthrough. The piano scene alone earns it a spot, and it landed him his first Oscar nomination."
        },
        {
          "title": "A League of Their Own",
          "year": 1992,
          "note": "Close to a perfect movie, and technically a supporting turn - Geena Davis is the lead. 'There's no crying in baseball' does a lot of work."
        },
        {
          "title": "Sleepless in Seattle",
          "year": 1993,
          "note": "Outlasted 'You've Got Mail' for the one Hanks-Ryan slot on the list."
        },
        {
          "title": "Philadelphia",
          "year": 1993,
          "note": "His first Best Actor Oscar, and a rare register for him: quiet, frail, unHanksian."
        },
        {
          "title": "Forrest Gump",
          "year": 1994,
          "note": "Debated over how the film handles its title character, but kept for the sweep of it."
        },
        {
          "title": "Apollo 13",
          "year": 1995,
          "note": "Called the most essential Hanks performance - the mold that set for the back half of his career."
        },
        {
          "title": "Toy Story",
          "year": 1995,
          "note": "Set Pixar's whole run in motion. No argument from either host."
        },
        {
          "title": "That Thing You Do!",
          "year": 1996,
          "note": "His own writing-directing credit, kept partly for how much he clearly loves the material."
        },
        {
          "title": "Cast Away",
          "year": 2000,
          "note": "Nearly cut in the last round; survived because dropping it meant admitting he hadn't made a Hall of Fame film since."
        },
        {
          "title": "A Beautiful Day in the Neighborhood",
          "year": 2019,
          "note": "Kept over 'Saving Private Ryan' in the final cut, on the strength of the Daniel Tiger puppet scene alone."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In Conversation With Marielle Heller",
      "guest": "Marielle Heller on",
      "films": [
        {
          "title": "A Beautiful Day in the Neighborhood",
          "year": 2019,
          "note": "Her third feature, built as one long episode of Mister Rogers' Neighborhood, complete with practical miniatures instead of CG."
        },
        {
          "title": "Can You Ever Forgive Me?",
          "year": 2018,
          "note": "Finished nearly a year before its Telluride premiere; she was still wrapping it when this script arrived."
        },
        {
          "title": "The Diary of a Teenage Girl",
          "year": 2015,
          "note": "Her first feature, which started as a play she wrote and starred in before she'd ever directed anything."
        },
        {
          "title": "Won't You Be My Neighbor",
          "year": 2018,
          "note": "The Mister Rogers documentary she cites as proof he couldn't work as a narrative protagonist - too self-aware, no arc to play."
        },
        {
          "title": "Vice",
          "year": 2018,
          "note": "The last great thing she'd seen, watched on the flight in. She likes how bold it is, especially the mid-movie credits gag."
        }
      ]
    }
  ],
