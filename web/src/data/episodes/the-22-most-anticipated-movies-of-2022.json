{
  "slug": "the-22-most-anticipated-movies-of-2022",
  "title": "The 22 Most Anticipated Movies of 2022",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2022-01-06",
  "runtimeMin": 77,
  "format": "Sean and Amanda each rank eleven 2022 movies they can't wait for, revisit Ben Affleck in The Tender Bar, remember Peter Bogdanovich, and Amanda shares some news.",
  "segments": [
    {
      "kind": "review",
      "heading": "The Tender Bar",
      "note": "Ben Affleck's stretch run continues",
      "films": [
        {
          "title": "The Tender Bar",
          "year": 2021,
          "note": "George Clooney directs this J.R. Moehringer adaptation, written by William Monahan. Sean calls it modest and unshowy, a bit of a Wonder Years episode, and says Affleck steals it as the bartender uncle raising the kid."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "Remembering Peter Bogdanovich",
      "note": "The director died this week at 82",
      "honoree": "Peter Bogdanovich",
      "films": [
        {
          "title": "Targets",
          "year": 1968,
          "note": "His low-budget debut, a Corman production."
        },
        {
          "title": "The Last Picture Show",
          "year": 1971,
          "note": "One of the most celebrated films ever made, and the start of an incredible run."
        },
        {
          "title": "What's Up, Doc?",
          "year": 1972,
          "note": "A screwball comedy with Barbra Streisand and Ryan O'Neal."
        },
        {
          "title": "Paper Moon",
          "year": 1973,
          "note": "Ryan O'Neal and his daughter Tatum O'Neal, a delightful period piece."
        },
        {
          "title": "Saint Jack",
          "year": 1979,
          "note": "A later film Sean says has been rightly reclaimed over the years."
        },
        {
          "title": "They All Laughed",
          "year": 1981,
          "note": "With Audrey Hepburn and Ben Gazzara, and Dorothy Stratten, Bogdanovich's partner, who was murdered shortly after."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Most Anticipated Movies of 2022",
      "note": "best to worst",
      "subject": "2022 anticipation",
      "ranked": true,
      "films": [
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "No. 1, third year running, since the original 2020 date. Amanda uses the moment to reveal she's pregnant and worried she'll miss the screening again."
        },
        {
          "title": "Maestro",
          "year": 2023,
          "note": "No. 2. Untitled at the time; Bradley Cooper directing and starring as Leonard Bernstein, with Carey Mulligan as his wife."
        },
        {
          "title": "She Said",
          "year": 2022,
          "note": "No. 3. Maria Schrader directs Carey Mulligan and Zoe Kazan as the reporters who broke the Harvey Weinstein story, from the Jodi Kantor/Megan Twohey book."
        },
        {
          "title": "The Worst Person in the World",
          "year": 2021,
          "note": "No. 4, Amanda's favorite film of the previous year. Joachim Trier's closer to the Oslo trilogy, getting a Neon release in February."
        },
        {
          "title": "The Eternal Daughter",
          "year": 2022,
          "note": "No. 5. Joanna Hogg and Tilda Swinton, shot in secret in Wales during the pandemic."
        },
        {
          "title": "Glass Onion: A Knives Out Mystery",
          "year": 2022,
          "note": "No. 6, referred to on the show as Knives Out 2. Daniel Craig back as Benoit Blanc, shot on location in Greece for Netflix."
        },
        {
          "title": "You Hurt My Feelings",
          "year": 2023,
          "note": "No. 7, called Beth and Don on the show. Nicole Holofcener reteams with Julia Louis-Dreyfus, who plays a novelist whose husband secretly doesn't like her writing."
        },
        {
          "title": "Bros",
          "year": 2022,
          "note": "No. 8 (tied). Billy Eichner co-writes and stars, Nicholas Stoller directs."
        },
        {
          "title": "Fire Island",
          "year": 2022,
          "note": "No. 8 (tied). Joel Kim Booster's Pride and Prejudice riff, directed by Andrew Ahn, with Bowen Yang and Margaret Cho."
        },
        {
          "title": "Elvis",
          "year": 2022,
          "note": "No. 9. Baz Luhrmann's biopic with Austin Butler as Elvis and Tom Hanks as Colonel Parker."
        },
        {
          "title": "Don't Worry Darling",
          "year": 2022,
          "note": "No. 10. Olivia Wilde directs Florence Pugh and Harry Styles."
        },
        {
          "title": "Ticket to Paradise",
          "year": 2022,
          "note": "No. 11. Ol Parker directs George Clooney and Julia Roberts in a romantic comedy shot in Australia."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Most Anticipated Movies of 2022",
      "note": "best to worst",
      "subject": "2022 anticipation",
      "ranked": true,
      "films": [
        {
          "title": "Killers of the Flower Moon",
          "year": 2023,
          "note": "No. 1. Martin Scorsese directs Leonardo DiCaprio and Jesse Plemons, from David Grann's book, for Apple."
        },
        {
          "title": "Nope",
          "year": 2022,
          "note": "No. 2. Jordan Peele's third film, with Daniel Kaluuya and Keke Palmer; Sean knows almost nothing about it and likes it that way."
        },
        {
          "title": "The Northman",
          "year": 2022,
          "note": "No. 3. Robert Eggers' Viking saga with Alexander Skarsgård; Sean warns it'll be stranger and slower than the trailer suggests."
        },
        {
          "title": "White Noise",
          "year": 2022,
          "note": "No. 4. Noah Baumbach adapts the Don DeLillo novel, with Adam Driver and Greta Gerwig, for Netflix."
        },
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "No. 5. The Daniels' follow-up to Swiss Army Man, starring Michelle Yeoh; premieres at SXSW on March 11."
        },
        {
          "title": "The Killer",
          "year": 2023,
          "note": "No. 6. David Fincher and Michael Fassbender for Netflix, no release date yet at the time."
        },
        {
          "title": "The Fabelmans",
          "year": 2022,
          "note": "No. 7 (tied). Steven Spielberg's most autobiographical film, co-written with Tony Kushner, with Seth Rogen."
        },
        {
          "title": "Armageddon Time",
          "year": 2022,
          "note": "No. 7 (tied). James Gray's own Queens childhood, with Anne Hathaway, Anthony Hopkins, and Jeremy Strong."
        },
        {
          "title": "Babylon",
          "year": 2022,
          "note": "No. 8. Damien Chazelle's old-Hollywood epic, with Margot Robbie and Brad Pitt."
        },
        {
          "title": "Women Talking",
          "year": 2022,
          "note": "No. 9. Sarah Polley's return to directing, adapting Miriam Toews, with Frances McDormand, Rooney Mara, Claire Foy, and Jessie Buckley."
        },
        {
          "title": "Tár",
          "year": 2022,
          "note": "No. 10. Todd Field's first film in 15 years, with Cate Blanchett."
        },
        {
          "title": "The Batman",
          "year": 2022,
          "note": "No. 11. Matt Reeves directs Robert Pattinson, Zoë Kravitz, Paul Dano, and Colin Farrell."
        }
      ]
    }
