{
  "slug": "dungeons-amp-dragons-honor-among-thieves-is-good-but-are-mov",
  "title": "‘Dungeons & Dragons: Honor Among Thieves’ Is … Good. But Are Movies Just Brands Now?",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-03-31",
  "runtimeMin": 85,
  "format": "Sean and Amanda on whether a genuinely fun 'Dungeons & Dragons' movie is also one more sign that every film is now a brand, then Sean's interview with 'A Thousand and One' director A.V. Rockwell.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Dungeons & Dragons: Honor Among Thieves’",
      "films": [
        {
          "title": "Dungeons & Dragons: Honor Among Thieves",
          "year": 2023,
          "note": "A heist comedy in fantasy clothes: Chris Pine as the con-artist lead, Michelle Rodriguez as the muscle and emotional center, Hugh Grant playing one goofy, evil note. Sean liked it; Amanda checked out (and left for the bathroom) during the Underdark sequence. Both flag the Hugh-Grant-on-a-pedestal finale as MS Paint-grade CGI."
        },
        {
          "title": "Game Night",
          "year": 2018,
          "note": "Directors John Francis Daley and Jonathan Goldstein's cult comedy; the reason Sean had hope for D&D. 'Run out if you love Game Night,' not Lord of the Rings."
        },
        {
          "title": "Vacation",
          "year": 2015,
          "note": "Daley and Goldstein's earlier legacy-sequel reboot, which soured people on Game Night at the time."
        },
        {
          "title": "Spider-Man: Homecoming",
          "year": 2017,
          "note": "Daley and Goldstein wrote the script, proof they know franchise machinery."
        },
        {
          "title": "The Flash",
          "year": 2023,
          "note": "The pair did a writing pass; they were up for directing both this and Homecoming and got neither."
        },
        {
          "title": "Ant-Man and the Wasp: Quantumania",
          "year": 2023,
          "note": "Amanda's CGI benchmark; Sean says D&D's location shooting beats its all-glop look, faint praise as that is."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Chris Pine career check-in",
      "films": [
        {
          "title": "Star Trek",
          "year": 2009,
          "note": "Maybe the best franchise revival there is; his James T. Kirk is the anchor."
        },
        {
          "title": "Star Trek Beyond",
          "year": 2016,
          "note": "Sean was mixed, though Trekkies call it the closest to a true episode of the show."
        },
        {
          "title": "Wonder Woman",
          "year": 2017,
          "note": "His daffy supporting turn opposite Gal Gadot, the new Harrison Ford move."
        },
        {
          "title": "Unstoppable",
          "year": 2010,
          "note": "One of the last Tony Scott films; a Sean favorite."
        },
        {
          "title": "Hell or High Water",
          "year": 2016,
          "note": "Sean's pick for the best pure movie Pine has led."
        },
        {
          "title": "The Contractor",
          "year": 2022,
          "note": "Doesn't work, but sits in the hired-ex-army-guy subgenre Sean and Chris Ryan like."
        },
        {
          "title": "Don't Worry Darling",
          "year": 2022,
          "note": "A stupid movie whose off-screen drama now feels five years old."
        },
        {
          "title": "All the Old Knives",
          "year": 2022,
          "note": "A spy thriller that made no sense; Sean was disappointed."
        },
        {
          "title": "This Means War",
          "year": 2012,
          "note": "The Reese Witherspoon/Tom Hardy rom-com Amanda calls possibly one of the worst ever."
        },
        {
          "title": "Into the Woods",
          "year": 2014
        },
        {
          "title": "Jack Ryan: Shadow Recruit",
          "year": 2014
        },
        {
          "title": "A Wrinkle in Time",
          "year": 2018
        },
        {
          "title": "The Finest Hours",
          "year": 2016,
          "note": "An interesting side project to the franchise work."
        },
        {
          "title": "Z for Zachariah",
          "year": 2015
        },
        {
          "title": "The Princess Diaries 2: Royal Engagement",
          "year": 2004,
          "note": "Pine as the romantic interest."
        },
        {
          "title": "Just My Luck",
          "year": 2006,
          "note": "Romantic lead opposite Lindsay Lohan."
        },
        {
          "title": "Poolman",
          "year": 2024,
          "note": "Pine's writing-directing debut: essentially Chinatown rewritten for a pool man, with himself in the lead. No distribution at the time of recording."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Are movies just brands now?",
      "films": [
        {
          "title": "Air",
          "year": 2023,
          "note": "The looming brand movie both hosts liked: Sean's coming 'movie therapy' about liking a film built around an Air Jordan."
        },
        {
          "title": "Barbie",
          "year": 2023,
          "note": "Greta Gerwig's doll movie; the 'you made Little Women, you should know better' test case."
        },
        {
          "title": "Tetris",
          "year": 2023,
          "note": "Taron Egerton, opening on Apple TV+."
        },
        {
          "title": "BlackBerry",
          "year": 2023,
          "note": "The only brand movie Sean felt had a strong point of view from conception to execution."
        },
        {
          "title": "Flamin' Hot",
          "year": 2023,
          "note": "The Flamin' Hot Cheeto origin movie, shorthand for the whole brand era."
        },
        {
          "title": "The Social Network",
          "year": 2010,
          "note": "The exception: a product story with an actual point of view and allegory."
        },
        {
          "title": "Clue",
          "year": 1985,
          "note": "The board-game movie Amanda loves, proof the brand movie isn't new."
        },
        {
          "title": "Battleship",
          "year": 2012,
          "note": "Peter Berg's board-game blockbuster; everyone was doing a bit."
        },
        {
          "title": "Ouija",
          "year": 2014
        },
        {
          "title": "Ouija: Origin of Evil",
          "year": 2016,
          "note": "The 'Ouija 2' Sean rates above the first."
        },
        {
          "title": "Cocaine Bear",
          "year": 2023,
          "note": "The 'is there a there there' debate; the problem was they didn't enjoy it."
        },
        {
          "title": "Dungeons & Dragons",
          "year": 2000,
          "note": "The Jeremy Irons / Thora Birch original, quite, quite bad."
        },
        {
          "title": "Little Women",
          "year": 2019,
          "note": "Gerwig's earlier film that raises the bar on Barbie."
        },
        {
          "title": "Lady Bird",
          "year": 2017
        },
        {
          "title": "Napoleon",
          "year": 2023,
          "note": "Ridley Scott's epic, joked to be 'Napoleon: Risk the game.'"
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "A.V. Rockwell on ‘A Thousand and One’",
      "guest": "A.V. Rockwell on",
      "films": [
        {
          "title": "A Thousand and One",
          "year": 2023,
          "note": "Rockwell's feature debut and farewell to her New York coming-of-age era, spanning Giuliani's terms (1994-2001). Teyana Taylor as Inez, cast from several hundred tapes; a story of gentrification erasing Black Harlem."
        },
        {
          "title": "New Jack City",
          "year": 1991,
          "note": "A 90s New York / Harlem reference point Rockwell studied for how the city was shot."
        },
        {
          "title": "Juice",
          "year": 1992,
          "note": "Same wave of Harlem-shot films she used as reference."
        },
        {
          "title": "Sugar Hill",
          "year": 1994
        },
        {
          "title": "West Side Story",
          "year": 1961,
          "note": "Its opening dance on rubble was a Black and Brown community that had been displaced, part of the history Rockwell researched."
        }
      ]
    }
