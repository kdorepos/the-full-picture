{
  "slug": "the-10-best-movies-of-2022-so-far",
  "title": "The 10 Best Movies of 2022 … So Far",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2022-07-01",
  "runtimeMin": 92,
  "format": "The mid-year check-in. Sean goes around the Ringer's staff one at a time and asks each for a single favorite movie of 2022 so far. Amanda cheats and picks two; so does Sean, at the end.",
  "segments": [
    {
      "kind": "list",
      "heading": "The picks",
      "note": "one critic, one film (mostly)",
      "picks": [
        {
          "by": "Amanda Dobbins",
          "title": "Petite Maman",
          "year": 2021,
          "note": "Celine Sciamma's follow-up to Portrait of a Lady on Fire. A 72-minute story about a young girl who meets her mother as a child, in the woods. Amanda saw it in 2021 but counts it as a 2022 pick since that's when it played in the U.S."
        },
        {
          "by": "Amanda Dobbins",
          "title": "Deep Water",
          "year": 2022,
          "note": "Adrian Lyne's return, with Ben Affleck as a retired ship-drone developer who tends snails and Ana de Armas as his wife. Amanda calls the first 80 minutes highly enjoyable, if not exactly good."
        },
        {
          "by": "Chris Ryan",
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "The easiest pick of the day. Chris calls it a clinic in movie-star acting, with action set pieces among the best of the decade."
        },
        {
          "by": "Van Lathan",
          "title": "Hustle",
          "year": 2022,
          "note": "Adam Sandler as a Sixers scout who finds a streetball talent (Juancho Hernangomez) playing in Spain. Van calls it comfort cinema, low-concept and well-executed, with Anthony Edwards the standout as the villain."
        },
        {
          "by": "Mallory Rubin",
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "The Daniels' multiversal story, led by Michelle Yeoh. Mallory calls it the rare multiverse tale that's actually interested in being infinite, built around a real family and immigrant story."
        },
        {
          "by": "Rob Mahoney",
          "title": "The Northman",
          "year": 2022,
          "note": "Robert Eggers' Viking revenge epic starring Alexander Skarsgard. Rob says the historical specificity is what makes an old story feel new, and that it rewards a second watch."
        },
        {
          "by": "Charles Holmes",
          "title": "Belle",
          "year": 2021,
          "note": "Mamoru Hosoda's anime, a Beauty and the Beast story set inside a virtual world. Charles says it's the rare film about the internet that feels as chaotic as actually being online."
        },
        {
          "by": "Adam Nayman",
          "title": "Crimes of the Future",
          "year": 2022,
          "note": "David Cronenberg's return to body horror, with Viggo Mortensen and Kristen Stewart. Adam calls it late-style Cronenberg, unhurried and very funny, and pairs it with Jackass Forever as a double bill about aging bodies."
        },
        {
          "by": "Adam Nayman",
          "title": "Jackass Forever",
          "year": 2022,
          "note": "Adam's bonus pick, mostly for Johnny Knoxville, whose performance he's been championing all year."
        },
        {
          "by": "Joanna Robinson",
          "title": "The Batman",
          "year": 2022,
          "note": "Matt Reeves' Batman. Joanna makes the case that it's best seen in a theater, pointing to the gap between how it played there versus at home on HBO Max."
        },
        {
          "by": "Rob Harvilla",
          "title": "Kimi",
          "year": 2022,
          "note": "Steven Soderbergh's streaming thriller, starring Zoe Kravitz as a tech worker who overhears a crime. Rob likes that it's 90 minutes and doesn't overplay its COVID-era setting."
        },
        {
          "by": "Sean Fennessey",
          "title": "Turning Red",
          "year": 2022,
          "note": "Domee Shi's directorial debut for Pixar, about a 13-year-old who turns into a giant red panda when her emotions spike. Sean says it hit him hardest of anything all year and was underserved by going straight to Disney+."
        },
        {
          "by": "Sean Fennessey",
          "title": "RRR",
          "year": 2022,
          "note": "S.S. Rajamouli's three-hour Tollywood epic starring N.T. Rama Rao Jr. and Ram Charan as fictionalized Indian revolutionaries. Sean calls it maximalist in every sense and recommends Rajamouli's Baahubali films too."
        }
      ]
    }
  ],
