{
  "slug": "is-weapons-a-classic-and-an-oscar-contender-plus-the-best-mo",
  "title": "Is ‘Weapons’ a Classic? And an Oscar Contender? Plus: The Best Movies at TIFF!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-09-15",
  "runtimeMin": 97,
  "format": "Adam Nayman files a dispatch from TIFF's 50th edition, then Chris Ryan joins to argue over whether 'Weapons' is a classic and an Oscar contender, plus the ninth 'Conjuring.'",
  "segments": [
    {
      "kind": "interview",
      "heading": "The Best Movies at TIFF",
      "note": "Adam Nayman's Toronto dispatch",
      "guest": "Adam Nayman on",
      "films": [
        {
          "title": "Blue Heron",
          "year": 2025,
          "note": "A debut feature by a Toronto director Nayman is friends with; he says it was topping Metacritic for the fall, above Hamnet, with prizes at both Locarno and TIFF."
        },
        {
          "title": "Nirvanna the Band the Show the Movie",
          "year": 2025,
          "note": "Hometown-hero premiere in the shadow of the CN Tower, which the crew breached to shoot the opening stunt."
        },
        {
          "title": "Wake Up Dead Man: A Knives Out Mystery",
          "year": 2025,
          "note": "Rian Johnson's third Benoit Blanc case, built around faith. Sidelines Daniel Craig for Josh O'Connor, whom Nayman says carries the film."
        },
        {
          "title": "The Mastermind",
          "year": 2025,
          "note": "Kelly Reichardt's latest, more Josh O'Connor; Sean hasn't seen it yet."
        },
        {
          "title": "The Smashing Machine",
          "year": 2025,
          "note": "Benny Safdie's solo debut. Dwayne Johnson's Mark Kerr is better than the Oscar hype; the fidelity to the existing documentary begs why. Blunt underused."
        },
        {
          "title": "Frankenstein",
          "year": 2025,
          "note": "del Toro's long-gestating passion project: meticulous handmade production design at war with weightless CG. Cool at Venice/Telluride, warmer in Toronto (runner-up audience award)."
        },
        {
          "title": "Hamnet",
          "year": 2025,
          "note": "Chloé Zhao's Maggie O'Farrell adaptation; won the People's Choice Award and is a Best Picture frontrunner. Nayman resisted it, felt nothing until Hamlet arrives; filmmakers hate it, critics love it."
        },
        {
          "title": "The Testament of Ann Lee",
          "year": 2025,
          "note": "Mona Fastvold and Brady Corbet on the founding of the Shakers, as an O Brother-style folk musical. Amanda's favorite of the fest; Amanda Seyfried leads; still no distribution."
        },
        {
          "title": "Maddie's Secret",
          "year": 2025,
          "note": "John Early's cheaply-made after-school-special pastiche, 'Wet Hot May December.' The one film everyone on the ground liked."
        },
        {
          "title": "No Other Choice",
          "year": 2025,
          "note": "Park Chan-wook's Westlake adaptation; won the International People's Choice Award. Nayman found the operatic pulp overlong."
        },
        {
          "title": "The Road Between Us: The Ultimate Rescue",
          "year": 2025,
          "note": "Barry Avrich documentary programmed, deprogrammed, then reprogrammed amid controversy, and still won the People's Choice Documentary Award."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "‘Weapons’ and ‘The Conjuring: Last Rites’",
      "note": "with Chris Ryan",
      "films": [
        {
          "title": "Weapons",
          "year": 2025,
          "note": "Zach Cregger's horror hit, now a top-30 all-time grosser in the genre. Reads to Sean as a film about grief and communal loss more than school shootings; Amy Madigan's Aunt Gladys is the villain of the year. A Best Picture longshot behind Sinners and One Battle After Another."
        },
        {
          "title": "The Conjuring: Last Rites",
          "year": 2025,
          "note": "The ninth Conjuring, billed as the last. Opened to ~$83M, continuing the year's run of Warner horror, but pious, overlong, and short on scares."
        }
      ]
    }
  ],
