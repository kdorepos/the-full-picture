{
  "slug": "the-presidential-movie-draft-with-griffin-newman-and-david-s",
  "title": "The Presidential Movie Draft, With Griffin Newman and David Sims of 'Blank Check'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan",
    "Griffin Newman",
    "David Sims"
  ],
  "published": "2024-11-05",
  "runtimeMin": 114,
  "format": "Recorded before the September 2024 debate and aired on Election Day: Sean, Amanda, and Chris draft Blank Check's Griffin Newman and David Sims into a six-round draft of movie presidents (VPs and cabinet members are eligible too), across Drama, Comedy, Biopic, Oscar Nominee, VP & Cabinet, and Wildcard.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "movie presidents",
      "note": "presidents can be drafted more than once; each film only once",
      "categories": [
        "Drama",
        "Comedy",
        "Biopic",
        "Oscar Nominee",
        "VP & Cabinet",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Independence Day",
              "year": 1996,
              "category": "Drama",
              "note": "Bill Pullman's President Thomas J. Whitmore, the fighter-pilot president who nukes Houston and gives the speech."
            },
            {
              "title": "Mars Attacks!",
              "year": 1996,
              "category": "Comedy",
              "note": "Jack Nicholson's President Dale, whose diplomacy-first read on the Martians gets him and most of Congress killed."
            },
            {
              "title": "Thirteen Days",
              "year": 2000,
              "category": "Biopic",
              "note": "Bruce Greenwood as JFK, which Sean rates one of the rare good screen Kennedys."
            },
            {
              "title": "Lincoln",
              "year": 2012,
              "category": "Oscar Nominee",
              "note": "Daniel Day-Lewis's third Oscar; the chalk No. 1, and it clears out the cabinet in the movie too."
            },
            {
              "title": "The Best Man",
              "year": 1964,
              "category": "VP & Cabinet",
              "note": "Gore Vidal's convention drama, with Henry Fonda as an Adlai Stevenson-ish former Secretary of State."
            },
            {
              "title": "Captain America: Civil War",
              "year": 2016,
              "category": "Wildcard",
              "note": "William Hurt as Secretary of State Thaddeus Ross, who later becomes president, and later still the Red Hulk."
            }
          ]
        },
        {
          "host": "Griffin Newman",
          "picks": [
            {
              "title": "Fail Safe",
              "year": 1964,
              "category": "Drama",
              "note": "Henry Fonda confined to a bunker with Larry Hagman; Griffin's pick for the best presidential performance he's seen."
            },
            {
              "title": "Bill & Ted's Excellent Adventure",
              "year": 1989,
              "category": "Comedy",
              "note": "Robert V. Barron's time-traveled super-Lincoln, who gains a wider view of history and still goes home to get shot."
            },
            {
              "title": "Secret Honor",
              "year": 1984,
              "category": "Biopic",
              "note": "Robert Altman's one-man Nixon monologue, Philip Baker Hall collapsing from the inside; a loose, imagined biopic."
            },
            {
              "title": "Being There",
              "year": 1979,
              "category": "Oscar Nominee",
              "note": "Jack Warden's President Bobby, swayed by a gardener's platitudes; Griffin is 'mostly drafting Jack Warden's face.'"
            },
            {
              "title": "Transformers",
              "year": 2007,
              "category": "VP & Cabinet",
              "note": "Jon Voight as SecDef John Keller, who picks up a shotgun and storms Hoover Dam alongside the Autobots."
            },
            {
              "title": "National Treasure: Book of Secrets",
              "year": 2007,
              "category": "Wildcard",
              "note": "Bruce Greenwood's president, kidnapped at flashlight-point by Nicolas Cage and won over to the cause."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Contender",
              "year": 2000,
              "category": "Drama",
              "note": "Jeff Bridges as President Jackson Evans (Obama's stated favorite screen president), ordering shark sandwiches and unraveling over missing Muenster."
            },
            {
              "title": "The American President",
              "year": 1995,
              "category": "Comedy",
              "note": "Michael Douglas as Andrew Shepherd, Sorkin's rare nice-guy Douglas who wins the room with one speech."
            },
            {
              "title": "Oppenheimer",
              "year": 2023,
              "category": "Biopic",
              "note": "Gary Oldman's one-scene Harry Truman, shot in a day between Slow Horses commitments."
            },
            {
              "title": "Dave",
              "year": 1993,
              "category": "Oscar Nominee",
              "note": "Kevin Kline as look-alike acting president Dave Kovic, fixing the budget and saving the shelter; nominated for screenplay."
            },
            {
              "title": "Wedding Crashers",
              "year": 2005,
              "category": "VP & Cabinet",
              "note": "Christopher Walken as Secretary of the Treasury William Cleary; Amanda drafts the Chesapeake lifestyle as much as the office."
            },
            {
              "title": "Don't Look Up",
              "year": 2021,
              "category": "Wildcard",
              "note": "Meryl Streep as President Janie Orlean, the one who leads everyone to destruction; a pointedly post-2016 pick."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Armageddon",
              "year": 1998,
              "category": "Drama",
              "note": "The unnamed president who empowers NASA to send oil drillers to the asteroid, and whose speech moves Chris every time."
            },
            {
              "title": "Idiocracy",
              "year": 2006,
              "category": "Comedy",
              "note": "Terry Crews as President Dwayne Elizondo Mountain Dew Herbert Camacho, 'less satirical by the year.'"
            },
            {
              "title": "Vice",
              "year": 2018,
              "category": "Biopic",
              "note": "A Cheney biopic, but Sam Rockwell's George W. Bush is the president in it: Chris's third Bush vote of the draft."
            },
            {
              "title": "Dr. Strangelove",
              "year": 1964,
              "category": "Oscar Nominee",
              "note": "Peter Sellers as the bookish, ineffectual President Merkin Muffley; Sellers lost Best Actor to Rex Harrison."
            },
            {
              "title": "Long Shot",
              "year": 2019,
              "category": "VP & Cabinet",
              "note": "Charlize Theron as Secretary of State Charlotte Field, handling a military crisis on Molly and ending the film as president."
            },
            {
              "title": "G.I. Joe: Retaliation",
              "year": 2013,
              "category": "Wildcard",
              "note": "Jonathan Pryce's president, replaced by the disguised Zartan across Rise of Cobra and Retaliation."
            }
          ]
        },
        {
          "host": "David Sims",
          "picks": [
            {
              "title": "Air Force One",
              "year": 1997,
              "category": "Drama",
              "note": "Harrison Ford as President James Marshall ('Get off my plane'), the saber-rattler David always wanted first."
            },
            {
              "title": "Dick",
              "year": 1999,
              "category": "Comedy",
              "note": "Dan Hedaya's full-bulldog Nixon; David goes all-'90s for a second Nixon."
            },
            {
              "title": "Nixon",
              "year": 1995,
              "category": "Biopic",
              "note": "Anthony Hopkins playing Nixon as a reptile in Oliver Stone's bloated epic, David's favorite Stone film."
            },
            {
              "title": "Primary Colors",
              "year": 1998,
              "category": "Oscar Nominee",
              "note": "John Travolta as Governor Jack Stanton, Mike Nichols's Clinton in all but name."
            },
            {
              "title": "Head of State",
              "year": 2003,
              "category": "VP & Cabinet",
              "note": "Bernie Mac as running mate Mitch Gilliam, on fire in 15 minutes of screen time."
            },
            {
              "title": "Escape from New York",
              "year": 1981,
              "category": "Wildcard",
              "note": "Donald Pleasence as the nameless, none-too-nice President of the United States."
            }
          ]
        }
      ],
