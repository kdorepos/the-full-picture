{
  "slug": "mailbag-special-25-movies-you-should-stream-now",
  "title": "Mailbag Special: 25 Movies You Should Stream Now",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-11-13",
  "runtimeMin": 98,
  "format": "A pandemic-era mailbag covering streaming sleepers and a black-and-white syllabus for Mank obsessives, plus a February interview with The Climb's Michelangelo Covino and Kyle Marvin.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The 2021 Logjam and the Theatrical Window",
      "note": "delays, PVOD, and Wonder Woman",
      "films": [
        {
          "title": "Contagion",
          "year": 2011,
          "note": "Amanda's recommended primer on how a limited vaccine actually gets triaged."
        },
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "The most-longed-for tentpole; nobody expects it to hit PVOD 17 days after it opens."
        },
        {
          "title": "Dune",
          "year": 2021,
          "note": "Sean's most-anticipated of the delayed slate, with tempered expectations."
        },
        {
          "title": "Let Him Go",
          "year": 2020,
          "note": "Universal's just-released test of the shortened window."
        },
        {
          "title": "Freaky",
          "year": 2020,
          "note": "Out that weekend under the same AMC/Universal 17-day-to-PVOD deal."
        },
        {
          "title": "Wonder Woman 1984",
          "year": 2020,
          "note": "Still on the calendar for Christmas; the hosts flatly predict it moves off 2020."
        },
        {
          "title": "Wonder Woman",
          "year": 2017,
          "note": "The 2017 original both hosts loved, which makes the delay sting."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The One You Wish You'd Seen on a Big Screen",
      "films": [
        {
          "title": "Mank",
          "year": 2020,
          "note": "Unanimous answer from both hosts."
        },
        {
          "title": "Tenet",
          "year": 2020,
          "note": "Would have been fun in a theater; its soft box office is why the rest of the slate keeps slipping."
        },
        {
          "title": "Da 5 Bloods",
          "year": 2020,
          "note": "Amanda wanted the epic scale of the Vietnam journey on a big screen."
        },
        {
          "title": "Soul",
          "year": 2020,
          "note": "Sean had just seen the Pixar film the night before; another theater regret."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "VOD Sleepers and Hidden Gems",
      "note": "the streaming recommendations",
      "films": [
        {
          "title": "Kajillionaire",
          "year": 2020,
          "note": "One of the ones Amanda finally caught up on."
        },
        {
          "title": "Shithouse",
          "year": 2020,
          "note": "Cooper Raiff's intimate debut; Amanda calls it a case where the small-screen viewing helped."
        },
        {
          "title": "Martin Eden",
          "year": 2019,
          "note": "Italian adaptation of the Jack London novel; likely best-international-feature contender."
        },
        {
          "title": "Totally Under Control",
          "year": 2020,
          "note": "Alex Gibney's COVID-19 documentary, made under quarantine; features Rick Bright."
        },
        {
          "title": "The Dark and the Wicked",
          "year": 2020,
          "note": "A genuinely upsetting horror film from Bryan Bertino; a hard no for Amanda."
        },
        {
          "title": "The Strangers",
          "year": 2008,
          "note": "Bertino's earlier film, which Sean calls one of the most upsetting movies of the century."
        },
        {
          "title": "You Cannot Kill David Arquette",
          "year": 2020,
          "note": "Documentary on Arquette's pro-wrestling comeback, blurring real and kayfabe."
        },
        {
          "title": "Possessor",
          "year": 2020,
          "note": "Brandon Cronenberg's film; Sean interviewed him earlier that week."
        },
        {
          "title": "His House",
          "year": 2020,
          "note": "Horror and international-feature contender streaming on Netflix."
        },
        {
          "title": "Banana Split",
          "year": 2018,
          "note": "Written by and starring Hannah Marks; a limited 2018 release now on Netflix."
        },
        {
          "title": "What the Constitution Means to Me",
          "year": 2020,
          "note": "Heidi Schreck's filmed play; Sean pairs it with Hamilton."
        },
        {
          "title": "Hamilton",
          "year": 2020,
          "note": "The filmed stage production Sean uses as a double-feature match."
        },
        {
          "title": "Fireball: Visitors from Darker Worlds",
          "year": 2020,
          "note": "Werner Herzog's meteorite documentary, then arriving on Apple TV+."
        },
        {
          "title": "David Byrne's American Utopia",
          "year": 2020,
          "note": "Spike Lee's concert film; both hosts' top pick here, on HBO Max."
        }
      ]
    },
