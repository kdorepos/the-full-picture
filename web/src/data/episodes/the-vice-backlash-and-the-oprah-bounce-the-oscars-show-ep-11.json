{
  "slug": "the-vice-backlash-and-the-oprah-bounce-the-oscars-show-ep-11",
  "title": "The 'Vice' Backlash and the Oprah Bounce | The Oscars Show (Ep. 112)",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2018-12-27",
  "runtimeMin": 67,
  "format": "Sean and Amanda break down Vice, weigh On the Basis of Sex and Destroyer, debate whether Oprah's Black Panther push means anything, and run the wide-open Best Picture odds heading into the new year.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Vice'",
      "note": "Adam McKay's Dick Cheney biopic",
      "films": [
        {
          "title": "Vice",
          "year": 2018,
          "note": "Christian Bale's transformation gets the headlines, but Sean and Amanda spend more time on how the fast-cutting, fourth-wall-breaking style avoids the trap of making its subject sympathetic."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "'On the Basis of Sex' and the Ginsburg Documentary",
      "films": [
        {
          "title": "On the Basis of Sex",
          "year": 2018,
          "note": "A more traditional Ruth Bader Ginsburg biopic, starring Felicity Jones and Armie Hammer. Amanda loved it; Sean thinks it's a weaker movie than Vice and shouldn't be in the Oscar conversation."
        },
        {
          "title": "RBG",
          "year": 2018,
          "note": "The documentary both hosts watched around the same time. Amanda found it reductive next to the dramatized version, which she thought actually explained Ginsburg's legal work more clearly."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Oprah's Black Panther Campaign",
      "films": [
        {
          "title": "Black Panther",
          "year": 2018,
          "note": "Oprah threw a screening and gave a speech to Bob Iger about it; Sean and Amanda debate whether her endorsement can actually move the movie into Best Picture contention."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock Up, Stock Down",
      "films": [
        {
          "title": "Mary Poppins Returns",
          "year": 2018,
          "note": "A quieter opening than Disney's usual live-action redo, but Sean and Amanda think it could have Aquaman-style long legs since it needs planning to get little kids there."
        },
        {
          "title": "A Quiet Place",
          "year": 2018,
          "note": "The other half of Emily Blunt's 2018, cited as part of her Best Actress case this season."
        },
        {
          "title": "Aquaman",
          "year": 2018,
          "note": "Keeps coming up all episode as the box-office benchmark and, separately, as the source of one more Nicole Kidman wig joke."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "'Destroyer'",
      "films": [
        {
          "title": "Destroyer",
          "year": 2018,
          "note": "Karyn Kusama's grimy L.A. crime thriller, with Nicole Kidman playing a burned-out cop across two timelines. Sean liked it; Amanda found the wig work and prosthetics too meta to fully buy the performance."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Bird Box and the Roma Effect",
      "films": [
        {
          "title": "Bird Box",
          "year": 2018,
          "note": "Sean thinks more people have watched this on Netflix, going purely by the meme cycle, than have seen Roma."
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "Alfonso Cuarón's Netflix release, framed here as the opposite of Bird Box's passive viewing: people are telling Sean and Amanda they made watching it into an event."
        },
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "Its Best Song shortlist snub (one nomination against two for Mary Poppins Returns) comes up as a small data point on Academy attention. Sean also tried and failed to get his family to see it over Christmas, since no Atlanta theater was still showing it."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Best Foreign Language Film Race",
      "films": [
        {
          "title": "Cold War",
          "year": 2018,
          "note": "Pawel Pawlikowski's 90-minute romance loosely based on his own parents. Sean interviewed him for an upcoming episode. Fair warning from Amanda: it opens with 10 to 15 minutes of a cappella Polish folk singing."
        },
        {
          "title": "Capernaum",
          "year": 2018,
          "note": "Part of what Sean calls the most stacked foreign-language field in memory; Wesley Morris covered it on the show a few weeks earlier."
        },
        {
          "title": "Shoplifters",
          "year": 2018,
          "note": "One both hosts adored, still playing theatrically at the ArcLight weeks after release."
        },
        {
          "title": "Burning",
          "year": 2018,
          "note": "The Korean film Sean counts as the fifth of his five clear contenders."
        },
        {
          "title": "Never Look Away",
          "year": 2018,
          "note": "Florian Henckel von Donnersmarck's follow-up to The Lives of Others. Not yet released in the U.S., but already nominated for Best Foreign Film at the Golden Globes as Germany's entry."
        },
        {
          "title": "The Guilty",
          "year": 2018,
          "note": "Denmark's entry: a cop working an emergency call entirely by phone, a setup Sean compares to Phone Booth."
        }
      ]
    },
