    {
      "kind": "interview",
      "heading": "Gints Zilbalodis on 'Flow'",
      "guest": "Gints Zilbalodis on",
      "films": [
        {
          "title": "Flow",
          "year": 2024,
          "note": "Nominated that morning for both Animated and International Feature. Zilbalodis built it in the free, open-source Blender with a tiny crew, scored it himself before bringing on co-composer Rihards Zaļupe, and blocked the whole thing with a virtual camera in 3D animatics instead of storyboards. The dialogue-free story of a cat learning to trust others grew from a short he made at 15; it's now near the top of the all-time Latvian box office."
        },
        {
          "title": "Away",
          "year": 2019,
          "note": "Zilbalodis's first feature, which he made entirely alone from age 20 to 24 as an unofficial film school, writing, directing, animating, and scoring it himself."
        },
        {
          "title": "Lost Highway",
          "year": 1997,
          "note": "His last-great-thing pick, a David Lynch film he'd just watched for the first time while revisiting Lynch after the director's death. He took from it Lynch's refusal to over-explain his own work."
        }
      ]
    }
