{
  "slug": "the-1991-movie-draft-plus-wim-wenders",
  "title": "The 1991 Movie Draft. Plus: Wim Wenders!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2024-02-09",
  "runtimeMin": 135,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan snake-draft the movies of 1991 across six categories, then Sean talks to Wim Wenders about Perfect Days and Anselm.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "the movies of 1991",
      "categories": [
        "Drama",
        "Action / Thriller / Horror",
        "Comedy",
        "Blockbuster",
        "Oscar Nominee",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Boyz n the Hood",
              "year": 1991,
              "category": "Drama",
              "note": "First pick of the draft: John Singleton's South Central debut, which hit Chris and his friends as movies that finally looked like real life."
            },
            {
              "title": "Dead Again",
              "year": 1991,
              "category": "Action / Thriller / Horror",
              "note": "Kenneth Branagh and Emma Thompson in a Hitchcockian reincarnation thriller from an early Scott Frank script, with a Robin Williams supporting turn. Sean had never seen it."
            },
            {
              "title": "Barton Fink",
              "year": 1991,
              "category": "Comedy",
              "note": "The Coens' black comedy, drafted as a comedy; John Turturro as the blocked screenwriter, John Goodman next door, John Mahoney as a Faulkner stand-in."
            },
            {
              "title": "Backdraft",
              "year": 1991,
              "category": "Blockbuster",
              "note": "Ron Howard's Chicago-firefighter movie and 14-year-old CR's favorite of the year; Kurt Russell, William Baldwin, and a stripped-down De Niro as the arson inspector."
            },
            {
              "title": "The Silence of the Lambs",
              "year": 1991,
              "category": "Oscar Nominee",
              "note": "Jonathan Demme's film swept the top five Oscars, the last to do it, so Chris takes it here rather than in thriller."
            },
            {
              "title": "Hearts of Darkness: A Filmmaker's Apocalypse",
              "year": 1991,
              "category": "Wild Card",
              "note": "Eleanor Coppola's documentary on the making of Apocalypse Now; for a stretch Chris rated it above the film itself."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Truly Madly Deeply",
              "year": 1991,
              "category": "Drama",
              "note": "Anthony Minghella's debut: Alan Rickman comes back as Juliet Stevenson's dead husband, a gentle magical-realism grief movie."
            },
            {
              "title": "Terminator 2: Judgment Day",
              "year": 1991,
              "category": "Action / Thriller / Horror",
              "note": "Taken a slot before Chris expected to lose it; Amanda came to it through a Big Picture movie-swap episode."
            },
            {
              "title": "Father of the Bride",
              "year": 1991,
              "category": "Comedy",
              "note": "Amanda's favorite film of 1991; the Nancy Meyers and Charles Shyer remake with Steve Martin, and the still-unsolved hot-dog-bun math."
            },
            {
              "title": "Beauty and the Beast",
              "year": 1991,
              "category": "Blockbuster",
              "note": "The last animated film nominated for Best Picture for a long stretch; Amanda quotes Lumiere from memory."
            },
            {
              "title": "Thelma & Louise",
              "year": 1991,
              "category": "Oscar Nominee",
              "note": "Ridley Scott's road movie, one of the few 1991 nominees not swallowed by the Silence of the Lambs sweep."
            },
            {
              "title": "My Girl",
              "year": 1991,
              "category": "Wild Card",
              "note": "Macaulay Culkin and Anna Chlumsky; the bee-sting ending that still wrecks Amanda."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "New Jack City",
              "year": 1991,
              "category": "Drama",
              "note": "Mario Van Peebles' crime drama, Wesley Snipes as Nino Brown, with Ice-T, Chris Rock, and the Judd Nelson turn the Rewatchables named an award after."
            },
            {
              "title": "Point Break",
              "year": 1991,
              "category": "Action / Thriller / Horror",
              "note": "Kathryn Bigelow's surfing-heist movie, Keanu Reeves and Patrick Swayze; producer Bobby Wagner had just seen it in theaters the night before."
            },
            {
              "title": "Defending Your Life",
              "year": 1991,
              "category": "Comedy",
              "note": "Albert Brooks' afterlife comedy opposite a pre-comedy-star Meryl Streep, with Rip Torn as his lawyer. Sean calls Brooks his goat."
            },
            {
              "title": "Cape Fear",
              "year": 1991,
              "category": "Blockbuster",
              "note": "Scorsese's remake of the 1962 thriller, De Niro as Max Cady and Nick Nolte as his target; Spielberg produced and nearly directed it. It cleared $75 million."
            },
            {
              "title": "JFK",
              "year": 1991,
              "category": "Oscar Nominee",
              "note": "Oliver Stone's assassination epic, Kevin Costner as Garrison, Hank Corwin's editing; the subject of a Sean-and-Chris pod Amanda listens to once a year."
            },
            {
              "title": "Raise the Red Lantern",
              "year": 1991,
              "category": "Wild Card",
              "note": "Zhang Yimou's 1920s-set drama, taken to spread the word on international film; the first movie Sean was shown in his college Film 101."
            }
          ]
        }
      ],
