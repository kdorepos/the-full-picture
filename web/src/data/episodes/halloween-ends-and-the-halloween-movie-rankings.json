    {
      "kind": "review",
      "heading": "'Halloween Ends'",
      "note": "David Gordon Green's final Myers film",
      "films": [
        {
          "title": "Halloween Ends",
          "year": 2022,
          "note": "The trilogy closer runs 50-plus minutes without Michael and is largely a River's Edge-style story about outcast Corey Campbell. Fennessey felt it served too many masters; Ryan liked the bracing opening and the wood-chipper finale."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Ranking all 13 'Halloween' films",
      "note": "best to worst",
      "subject": "Halloween",
      "ranked": true,
      "films": [
        {
          "title": "Halloween (Carpenter)",
          "year": 1978,
          "note": "The easiest No. 1 on the list; Carpenter's original."
        },
        {
          "title": "Halloween III: Season of the Witch",
          "year": 1982,
          "note": "The Michael-free anthology swing, reclaimed as a fan favorite; feels the most Carpenter."
        },
        {
          "title": "Halloween II (Rosenthal)",
          "year": 1981,
          "note": "Rosenthal's very good slasher, home of the hot-tub kill."
        },
        {
          "title": "Halloween H20: 20 Years Later",
          "year": 1998,
          "note": "Fennessey's favorite use of Jamie Lee Curtis, with an uncredited Kevin Williamson rewrite; Ryan would drop it lower solo."
        },
        {
          "title": "Halloween (Green)",
          "year": 2018,
          "note": "David Gordon Green's table-setter."
        },
        {
          "title": "Halloween 4: The Return of Michael Myers",
          "year": 1988,
          "note": "Dwight H. Little starts the Jamie Lloyd trilogy; the Kathleen Kinmont wall-mount kill."
        },
        {
          "title": "Halloween 5: The Revenge of Michael Myers",
          "year": 1989,
          "note": "The rushed direct sequel; the Man in Black."
        },
        {
          "title": "Halloween II (Zombie)",
          "year": 2009,
          "note": "Rob Zombie's ultimate feel-bad movie, and Ryan's favorite of the pair."
        },
        {
          "title": "Halloween Kills",
          "year": 2021,
          "note": "Fennessey defended its mob-mentality idea; Ryan cared for it less."
        },
        {
          "title": "Halloween (Zombie)",
          "year": 2007,
          "note": "Rob Zombie's mangy but technically striking reboot with an unsympathetic Haddonfield."
        },
        {
          "title": "Halloween: The Curse of Michael Myers",
          "year": 1995,
          "note": "Paul Rudd as grown-up Tommy Doyle in the druid-cult entry; confusing and disliked."
        },
        {
          "title": "Halloween Ends",
          "year": 2022,
          "note": "Fennessey slots it at 12; he really didn't care for it."
        },
        {
          "title": "Halloween: Resurrection",
          "year": 2002,
          "note": "The agreed-upon worst, redeemed only by Busta Rhymes."
        }
