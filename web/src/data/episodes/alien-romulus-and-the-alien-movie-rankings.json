        },
        {
          "title": "Three Kings",
          "year": 1999,
          "note": "One of the O. Russell films Chris still loves, alongside 'I Heart Huckabees.'"
        },
        {
          "title": "I Heart Huckabees",
          "year": 2004
        },
        {
          "title": "American Hustle",
          "year": 2013,
          "note": "Part of the Silver Linings/American Hustle/Joy run Chris was dubious about; floated as the '70s register a Madden movie might use."
