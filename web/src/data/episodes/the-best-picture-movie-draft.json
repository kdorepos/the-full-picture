          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "All Quiet on the Western Front",
              "year": 1930,
              "category": "1930s",
              "note": "Not a favorite watch, but a five-star template for the Hollywood war film."
