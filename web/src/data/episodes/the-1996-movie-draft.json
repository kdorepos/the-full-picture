            {
              "title": "Twister",
              "year": 1996,
              "category": "Blockbuster",
              "note": "the last blockbuster on the board; Sean and Amanda prefer the remake."
            },
            {
              "title": "Lone Star",
              "year": 1996,
              "category": "Wild Card",
              "note": "John Sayles' Texas mystery, the one film Chris rewatched: a season of The Wire in one movie."
