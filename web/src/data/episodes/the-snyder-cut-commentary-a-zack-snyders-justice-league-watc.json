{
  "slug": "the-snyder-cut-commentary-a-zack-snyders-justice-league-watc",
  "title": "The Snyder Cut Commentary: A ‘Zack Snyder’s Justice League’ Watch-along",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2021-03-19",
  "runtimeMin": 248,
  "format": "Sean, Amanda, and Chris Ryan press play on 'Zack Snyder's Justice League' together for the first time and commentate live for all four hours, chasing mother boxes, parademons, and Affleck's hair plugs the whole way.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Zack Snyder's road to the Snyder Cut",
      "note": "his filmography, and how this movie came to exist",
      "films": [
        {
          "title": "Dawn of the Dead",
          "year": 2004,
          "note": "The 'hipster pick' for best Snyder movie."
        },
        {
          "title": "300",
          "year": 2006,
          "note": "The 'normie' answer — still on TV at every Lakers game, per Chris."
        },
        {
          "title": "Watchmen",
          "year": 2009,
          "note": "Sean rewatched the 3.5-hour cut this week; Billy Crudup's Dr. Manhattan is the one piece of it Sean says he really likes."
        },
        {
          "title": "Legend of the Guardians: The Owls of Ga'Hoole",
          "year": 2010,
          "note": "An animated movie about owls that Sean calls his favorite film of 2010 — and, in his telling, 'totally a Zack Snyder movie.'"
        },
        {
          "title": "Sucker Punch",
          "year": 2011,
          "note": "Chris: 'extremely stupid.'"
        },
        {
          "title": "Man of Steel",
          "year": 2013,
          "note": "Amanda couldn't get past the climactic 40 minutes of 'two gods punching each other in the air.'"
        },
        {
          "title": "Batman v Superman: Dawn of Justice",
          "year": 2016,
          "note": "The 'film-nerd pick.' Sean rewatched the 3-hour-5-minute Ultimate Edition this week and didn't think it was bad."
        },
        {
          "title": "Justice League",
          "year": 2017,
          "note": "The Joss Whedon cut: 80 new pages, only 10% of Snyder's footage kept, Danny Elfman replacing Junkie XL. Made $230 million domestic and was widely seen as a failure — all three agree it's the weaker version of tonight's movie."
        },
        {
          "title": "Army of the Dead",
          "year": 2021,
          "note": "Snyder's next film, a zombie heist for Netflix, arriving in about two months; he says he's done with DC after this."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The rest of the DC Extended Universe",
      "films": [
        {
          "title": "Wonder Woman",
          "year": 2017,
          "note": "Amanda's favorite corner of this universe — a brighter, more colorful Themyscira than the one in this cut, per Patty Jenkins's choices."
        },
        {
          "title": "Wonder Woman 1984",
          "year": 2020,
          "note": "Diana learns to fly from Steve in this one, which muddles the in-universe timeline with tonight's movie."
        },
        {
          "title": "Aquaman",
          "year": 2018,
          "note": "James Wan's Atlantis reads as 'pretty technicolor' next to the blue-gray version in this film."
        },
        {
          "title": "Suicide Squad",
          "year": 2016,
          "note": "Got recut jokier under the same studio pressure that shaped the Whedon 'Justice League.'"
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Zack Snyder's Justice League",
      "note": "the four-hour, four-part watch-along",
      "films": [
        {
          "title": "Zack Snyder's Justice League",
          "year": 2021,
          "note": "Watched live, start to finish, on HBO Max, dedicated to Snyder's daughter Autumn. Verdict: clearly more coherent than the Whedon cut, with a real Cyborg origin story (Ray Fisher gets the arc Whedon cut around) and a fuller Darkseid/Steppenwolf mythology — but still, per Sean, about a '2 out of 5,' with none of the villains landing and the action growing 'less and less decipherable' as the runtime piles up."
        }
      ]
    }
  ],
