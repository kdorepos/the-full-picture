{
  "slug": "the-return-of-the-big-oscar-bet-and-the-best-movies-at-the-t",
  "title": "The Return of the Big Oscar Bet and the Best Movies at the Toronto International Film Festival",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2024-09-16",
  "runtimeMin": 111,
  "format": "Adam Nayman phones in from Toronto with the TIFF slate, then Sean and Amanda revive their big Oscar bet and predict all 11 major categories a month before anyone's been nominated.",
  "segments": [
    {
      "kind": "interview",
      "heading": "Dispatches from Toronto",
      "note": "with Canadian correspondent Adam Nayman",
      "guest": "Adam Nayman on TIFF",
      "films": [
        {
          "title": "The Life of Chuck",
          "year": 2024,
          "note": "Won the People's Choice Award, a 12-year precursor to a Best Picture nod. Mike Flanagan's Stephen King adaptation, and still without a distributor."
        },
        {
          "title": "The Room Next Door",
          "year": 2024,
          "note": "Almodovar's first English-language feature. Adam found it designed to win awards and little else."
        },
        {
          "title": "The Shrouds",
          "year": 2024,
          "note": "Cronenberg on grief and repression. Cheap-looking, no US distributor. Still the film Adam couldn't shake."
        },
        {
          "title": "Nightbitch",
          "year": 2024,
          "note": "Marielle Heller's motherhood body-horror with Amy Adams. Adam thought it pulled itself apart while playing it safe."
        },
        {
          "title": "Saturday Night",
          "year": 2024,
          "note": "Jason Reitman's SNL-origin story. Adam's diplomatic pan of its Lorne-Michaels-as-Prometheus myth-making."
        },
        {
          "title": "Friendship",
          "year": 2024,
          "note": "Andrew DeYoung's Tim Robinson / Paul Rudd comedy, just acquired by A24. Adam's favorite of the fest."
        },
        {
          "title": "Cloud",
          "year": 2024,
          "note": "Kiyoshi Kurosawa's online-scammer revenge thriller, one of three features he made this year."
        },
        {
          "title": "Harvest",
          "year": 2024,
          "note": "Athina Rachel Tsangari's pre-industrial community portrait with Caleb Landry Jones."
        },
        {
          "title": "Dahomey",
          "year": 2024,
          "note": "Mati Diop's documentary on looted artifacts repatriated from France to Benin."
        },
        {
          "title": "Caught by the Tides",
          "year": 2024,
          "note": "Jia Zhangke's film assembled from 20 years of footage of Zhao Tao, who ages in real time."
        },
        {
          "title": "Ick",
          "year": 2024,
          "note": "Joseph Kahn's B-movie allegory about apathy, roughly received but, Adam argues, smarter than it looks."
        },
        {
          "title": "Heretic",
          "year": 2024,
          "note": "Hugh Grant back in genre for an A24 horror. Adam liked Grant, not the movie."
        },
        {
          "title": "Matt and Mara",
          "year": 2024,
          "note": "Matt Johnson's Toronto drama, and the TIFF red-carpet debut of Adam's daughter Avery."
        },
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "The 3.5-hour American epic everyone raved about. Adam ran out of time to see it."
        },
        {
          "title": "Anora",
          "year": 2024,
          "note": "Placed third for the Audience Award. Sean Baker's Palme d'Or winner, mirroring the Parasite run."
        },
        {
          "title": "Emilia Pérez",
          "year": 2024,
          "note": "A People's Choice runner-up, lodged in the awards conversation all fall."
        },
        {
          "title": "The Substance",
          "year": 2024,
          "note": "Body-horror on beauty standards, name-checked next to Nightbitch."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Two more from the fest",
      "note": "the ones Sean caught without leaving town",
      "films": [
        {
          "title": "The Order",
          "year": 2024,
          "note": "Justin Kurzel's true-crime drama on an FBI hunt for an '80s white-supremacist cell. Jude Law and a standout Nicholas Hoult. Sean's comp: American History X meets Heat."
        },
        {
          "title": "Babygirl",
          "year": 2024,
          "note": "Halina Reijn's psychological thriller. Nicole Kidman as a robotics CEO, Harris Dickinson as the intern. Sean admired it more than he liked it."
        }
      ]
    },
