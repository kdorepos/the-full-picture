    {
      "kind": "interview",
      "heading": "Jay Roach on 'Bombshell'",
      "guest": "Jay Roach on",
      "films": [
        {
          "title": "Bombshell",
          "year": 2019,
          "note": "Roach on valorizing complicated people: he framed it around a competent woman being harassed as a universal issue. On Theron's transformation, she injured her vocal cords chasing Kelly's voice, and Kazuhiro Tsuji did the makeup. The elevator-sequence score is a cappella women's voices, including his wife Susanna Hoffs and Petra Haden."
        },
        {
          "title": "Recount",
          "year": 2008,
          "note": "His earlier HBO political docudrama."
        },
        {
          "title": "Game Change",
          "year": 2012,
          "note": "The Sarah Palin film he chased before he knew there was a book."
        },
        {
          "title": "Trumbo",
          "year": 2015,
          "note": "Part of the drift toward more serious, graver material."
        },
        {
          "title": "Austin Powers: International Man of Mystery",
          "year": 1997
        },
        {
          "title": "Meet the Parents",
          "year": 2000
        },
        {
          "title": "Jojo Rabbit",
          "year": 2019,
          "note": "His last-great-thing pick: Waititi sneaks up on you, beautifully composed."
        },
        {
          "title": "Darkest Hour",
          "year": 2017,
          "note": "Where Kazuhiro Tsuji transformed Gary Oldman into Churchill; the reference point for Lithgow's Ailes makeup."
        },
        {
          "title": "The Silence of the Lambs",
          "year": 1991,
          "note": "Roach's comp for the layered menace of Lithgow's Roger Ailes."
        },
        {
          "title": "Taxi Driver",
          "year": 1976,
          "note": "One of Petra Haden's a cappella score reproductions Sean admires."
        },
        {
          "title": "Cool Hand Luke",
          "year": 1967,
          "note": "Another Haden a cappella piece."
        }
      ]
    }
