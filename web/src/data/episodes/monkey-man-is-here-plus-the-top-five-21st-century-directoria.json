{
  "slug": "monkey-man-is-here-plus-the-top-five-21st-century-directoria",
  "title": "‘Monkey Man’ Is Here! Plus, the Top Five 21st Century Directorial Debuts.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2024-04-05",
  "runtimeMin": 74,
  "format": "Dev Patel's 'Monkey Man' opens, and Sean and Amanda each rank their five best directorial debuts of the century, in between a lot of doomer-Sean Mets-and-Dodgers venting.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Monkey Man’",
      "note": "Dev Patel's directorial debut",
      "films": [
        {
          "title": "Monkey Man",
          "year": 2024,
          "note": "Patel's Hanuman-inflected revenge beatdown, greenlit at Netflix as a $30M film and moved to Universal for a theatrical release once Jordan Peele came on as a producer. Both hosts read the fast cutting and dropped threads as a long script cut down, but rate the highs (the wallet-heist sequence, the tabla training montage) very high, and admire the caste-and-Modi politics under the fists."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five 21st Century Directorial Debuts",
      "note": "counted down 5 to 1",
      "subject": "21st Century Directorial Debuts",
      "ranked": true,
      "films": [
        {
          "title": "Michael Clayton",
          "year": 2007,
          "note": "Tony Gilroy's debut, and Sean's platonic ideal of the rumpled-guy-in-a-suit movie. He wants Gilroy to put down the lightsabers and come back to it."
        },
        {
          "title": "Get Out",
          "year": 2017,
          "note": "Jordan Peele's announcement: a generational talent whose movies are still events every time out."
        },
        {
          "title": "Ex Machina",
          "year": 2015,
          "note": "Alex Garland on AI and toxic masculinity; a five-star classic Sean can only rank third."
        },
        {
          "title": "The Babadook",
          "year": 2014,
          "note": "Jennifer Kent's grief-horror, early in the arthouse-horror wave alongside Get Out and Hereditary."
        },
        {
          "title": "In the Bedroom",
          "year": 2001,
          "note": "Todd Field's first film: Wilkinson, Spacek, and Tomei in a grief drama Sean calls singular and impossible to make now."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top Five 21st Century Directorial Debuts",
      "note": "counted down 5 to 1",
      "subject": "21st Century Directorial Debuts",
      "ranked": true,
      "films": [
        {
          "title": "Lady Bird",
          "year": 2017,
          "note": "Greta Gerwig solo: Amanda's honest, bracing movie about being a teenage girl."
        },
        {
          "title": "The Virgin Suicides",
          "year": 2000,
          "note": "Sofia Coppola's debut. Amanda flags that its 2000 U.S. release makes it 21st-century eligible and off-limits for the upcoming 1999 movie draft."
        },
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "Bradley Cooper: the one Amanda says they were right about first and the rest caught up to."
        },
        {
          "title": "Gone Baby Gone",
          "year": 2007,
          "note": "Ben Affleck's directing debut; his ledger is still more hits than misses."
        },
        {
          "title": "Palm Springs",
          "year": 2020,
          "note": "Max Barbakow's time-loop rom-com: the one every imitator since has failed to match."
        }
      ]
    }
  ],
