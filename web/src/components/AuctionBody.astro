---
// Auction segment: the sale line + sold stamp, paddles, and hammer-price ledger.
const { seg, tmdb = {} } = Astro.props;
const link = (t) => (tmdb[t]?.id ? `https://www.themoviedb.org/movie/${tmdb[t].id}` : null);
const poster = (t) => (tmdb[t]?.poster ? `https://image.tmdb.org/t/p/w154${tmdb[t].poster}` : null);

const paddle = {};
seg.slates.forEach((s, i) => (paddle[s.host] = i + 1));
const board = seg.slates
  .flatMap((s) => s.picks.map((p) => ({ ...p, host: s.host })))
  .sort((a, b) => (b.price ?? -1) - (a.price ?? -1));
const money = (p) => (p == null ? '—' : `$${p.toLocaleString()}`);
const rank = (i) => String(i + 1).padStart(2, '0');
---
<section class="sale-section">
  <p class="rubric">The paddles <span class="sub">who spent what</span></p>
  <div class="standings">
    {seg.slates.map((s) => (
      <div class="tally" style={`--tone: var(--paddle-${paddle[s.host]})`}>
        <div class="pno">Paddle {paddle[s.host]}</div>
        <div class="host">{s.host}</div>
        <div class="spent">${s.spent.toLocaleString()}</div>
        <div class="lots">{s.picks.length} lots{s.budgetLeft ? ` · $${s.budgetLeft} unspent` : ''}</div>
      </div>
    ))}
  </div>
</section>

<section class="sale-section">
  <p class="rubric">The board <span class="sub">this sale, by hammer price</span></p>
  <ol class="board">
    {board.map((lot, i) => (
      <li class={`lot${i === 0 ? ' lot--top' : ''}`}>
        <span class="lot__rank">{rank(i)}</span>
        <div class="lot__poster">
          {poster(lot.title)
            ? <img src={poster(lot.title)} alt={`${lot.title} poster`} width="46" height="69" loading="lazy" />
            : <span class="noposter" aria-hidden="true"></span>}
        </div>
        <div class="lot__head">
          <div class="lot__title">
            {link(lot.title) ? <a href={link(lot.title)} target="_blank" rel="noopener">{lot.title}</a> : lot.title}
            <span class="yr">{lot.year}</span>
          </div>
          <div class="lot__paddle">
            <span class="paddle" style={`--tone: var(--paddle-${paddle[lot.host]})`}>No.{paddle[lot.host]} <span class="who">{lot.host}</span></span>
          </div>
        </div>
        <span class={`lot__price${lot.price == null ? ' undisclosed' : ''}`}>{money(lot.price)}</span>
        {lot.note && <p class="lot__note">{lot.note}</p>}
      </li>
    ))}
  </ol>
  <p class="ledger-note">Titles link to TMDb where a confident match exists. Unlinked entries are too new to be cataloged or aren't films.</p>
</section>

{seg.undrafted?.length > 0 && (
  <section class="sale-section">
    <p class="rubric">Passed in <span class="sub">raised, no bid</span></p>
    <p class="entrylist">
      {seg.undrafted.map((f) => (link(f)
        ? <a class="entry" href={link(f)} target="_blank" rel="noopener">{f}</a>
        : <span class="entry">{f}</span>))}
    </p>
  </section>
)}

{seg.januarySlate?.length > 0 && (
  <section class="sale-section">
    <p class="rubric">Previous sale <span class="sub">{seg.previousSaleLabel ?? 'January · first-half slate'}</span></p>
    <div class="prev">
      {seg.januarySlate.map((s) => (
        <div class="col">
          <div class="host">{s.host}</div>
          <ul>
            {s.picks.map((m) => (
              <li>
                {link(m.title) ? <a href={link(m.title)} target="_blank" rel="noopener">{m.title}</a> : <span>{m.title}</span>}
                <span class="p">{money(m.price)}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>
)}
