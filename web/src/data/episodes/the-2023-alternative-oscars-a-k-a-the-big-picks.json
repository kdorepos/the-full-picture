  "format": "Sean, Amanda, and Wesley Morris hand out their own awards to the 2022 films the real Oscars left off the ballot, after a verdict on the PGAs, the SAGs, and Tom Cruise's Lifetime Achievement speech.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Before the ballots",
      "note": "the PGAs, the SAGs, and Tom Cruise's victory lap",
      "films": [
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "Swept the PGA and four of the five top SAG awards; the Best Picture race is effectively over."
        },
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "Lost the PGA to Everything Everywhere, but Tom Cruise still walked away with the Lifetime Achievement Award and a ten-minute speech."
        },
        {
          "title": "Apollo 13",
          "year": 1995,
          "note": "Amanda's beloved exception: the one film to sweep DGA, SAG, and PGA and still lose Best Picture."
        },
        {
          "title": "The Woman King",
          "year": 2022,
          "note": "Missed the Best Picture cut entirely; Sean blames Sony and Netflix for not streaming it until after nominations voting closed."
        },
        {
          "title": "Nope",
          "year": 2022,
          "note": "Wesley and Amanda's pick for Best Picture; both admit the genre-movie mash-up lost some Academy voters."
        },
        {
          "title": "Tár",
          "year": 2022,
          "note": "Wesley predicts it'll be remembered as one of the decade's great films even as it loses every category to Everything Everywhere."
        },
        {
          "title": "CODA",
          "year": 2021,
          "note": "Sean's go-to story of knowing a Best Picture winner the instant the credits roll."
        },
        {
          "title": "Till",
          "year": 2022,
          "note": "Set aside as its own conversation about black filmmakers left off this year's ballot."
        },
        {
          "title": "Black Panther: Wakanda Forever",
          "year": 2022,
          "note": "Also shut out of Best Picture, part of the same conversation as The Woman King and Nope."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "The comparison point for The Woman King: an American story that, unlike Parasite, doesn't need an import exception to be a Best Picture contender."
        },
        {
          "title": "Minari",
          "year": 2020,
          "note": "Another benchmark Wesley raises in the same conversation about movies reaching the Best Picture race."
        },
        {
          "title": "Drive My Car",
          "year": 2021,
          "note": "The most recent international import to break into Best Picture, unlike the homegrown Everything Everywhere."
