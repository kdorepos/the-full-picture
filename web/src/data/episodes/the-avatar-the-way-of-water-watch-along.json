    {
      "kind": "review",
      "heading": "The watch-along",
      "note": "live commentary over the full film",
      "films": [
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "Sean and Amanda walk first-timer Chris through all 197 minutes. He warms to the action stretches and to Payakan the tulkun; the rest of the runtime drifts to yogurt, Lane Kiffin, and who would help bury a body. Sean's case: the film only works in 3D, so watching it flat on a TV undersells it."
        }
      ]
    }
