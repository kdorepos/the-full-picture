{
  "slug": "top-five-cult-movies-bad-trip-and-the-empty-man",
  "title": "Top Five Cult Movies, ‘Bad Trip,’ and ‘The Empty Man’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Adam Nayman"
  ],
  "published": "2021-04-09",
  "runtimeMin": 100,
  "format": "Adam Nayman joins to work out what actually makes a movie cult, using Bad Trip and The Empty Man as test cases, before both make their case with five picks apiece. Then Emma Seligman talks about directing Shiva Baby.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Bad Trip’",
      "note": "with Adam Nayman",
      "films": [
        {
          "title": "Bad Trip",
          "year": 2021,
          "note": "Eric Andre's prank comedy with Lil Rel Howery and Tiffany Haddish, shot with hidden cameras and real bystanders. Nayman calls it closer to Jackass than Borat, since the pranks land on the cast and not on strangers, and praises the credit-stinger reveals that let the marks in on the joke."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘The Empty Man’",
      "note": "with Adam Nayman",
      "films": [
        {
          "title": "The Empty Man",
          "year": 2020,
          "note": "David Prior's horror film, shot in 2017-18, shelved by the Fox-Disney merger, then dumped into theaters in October 2020. Adapted from a BOOM! graphic novel Prior largely discarded. Nayman, who interviewed Prior, traces the Fincher DNA (Prior cut Fincher's DVD supplements) and singles out the 20-minute Bhutan prologue and a Wikipedia-clicking sequence as evidence of a smarter movie than its reviews suggested."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "What Makes a Movie a Cult Movie?",
      "note": "with Adam Nayman",
      "films": [
        {
          "title": "The Rocky Horror Picture Show",
          "year": 1975,
          "note": "Nayman's example of cult made to order, already nostalgic for 'true' cult back in 1975 and, fifty years later, closer to a classic than an underground object."
        },
        {
          "title": "Showgirls",
          "year": 1995,
          "note": "The one Nayman wrote a book about: hated in real time with nobody willing to defend it, then reclaimed piece by piece."
        },
        {
          "title": "Ed Wood",
          "year": 1994,
          "note": "Tim Burton's version sands Ed Wood down; Nayman argues the real gateway is watching Wood's own films, not the two-minute Plan 9 clip reel."
        },
        {
          "title": "Repo Man",
          "year": 1984,
          "note": "Nayman's case study for cult that curdles into 'cult canon': the contradiction of a genre built on being uncanonizable."
        },
        {
          "title": "The Room",
          "year": 2003,
          "note": "Contrasted with Rocky Horror: Rocky Horror's audience participation is with the movie, The Room's is at its expense."
        },
        {
          "title": "Mandy",
          "year": 2018,
          "note": "Nayman's example of cult assembled for Twitter screenshots, built deliberately from six movies out of the Danny Peary book."
        },
        {
          "title": "Dune",
          "year": 1984,
          "note": "David Lynch's version. Nayman's line: when Lynch tried to make a Star Wars movie and failed, that's what makes it cult."
        },
        {
          "title": "Kill Bill: Vol. 1",
          "year": 2003,
          "note": "Fennessey and Nayman debate whether Tarantino recycling Drunken Master and City on Fire at a $100 million budget is the best or worst case for cult's mainstreaming."
        },
        {
          "title": "Bad Taste",
          "year": 1987,
          "note": "Peter Jackson's homemade debut, which Nayman still shows his students. The same guy later got $190 million to make The Lord of the Rings."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Adam's Five Cult Movies",
      "subject": "cult movies about cults",
      "ranked": true,
      "films": [
        {
          "title": "Freaks",
          "year": 1932,
          "note": "No. 1: Tod Browning's film, cast with real circus performers. Nayman's pick for 'the great cult movie of them all' because it pulls the audience out of its comfort zone and asks where its sympathies actually lie."
        },
        {
          "title": "The World's Greatest Sinner",
          "year": 1962,
          "note": "Character actor Timothy Carey wrote, directed, produced, and starred in this one-man cult-leader parable. Carey also turns up unnervingly in Kubrick's The Killing and Paths of Glory."
        },
        {
          "title": "Cobra Woman",
          "year": 1944,
          "note": "Maria Montez's island-snake-cult melodrama, a performance Nayman calls great precisely because it would never get an Oscar nomination."
        },
        {
          "title": "Under the Silver Lake",
          "year": 2018,
          "note": "David Robert Mitchell's stoner noir, a pastiche of The Big Lebowski (itself already a pastiche). Nayman calls it, without meaning to, the best Epstein movie."
        },
        {
          "title": "Kill List",
          "year": 2011,
          "note": "Ben Wheatley's second feature. Starts as a hitman movie and doesn't end like one. Also the film Nayman thinks The Empty Man most resembles."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Five Cult Movies",
      "subject": "cult movies",
      "films": [
        {
          "title": "Deep Red",
          "year": 1975,
          "note": "Dario Argento's giallo, which Fennessey first saw at 14 or 15 and says reordered his brain the way Jaws and Star Wars did. He compares the feeling to hearing Nirvana's Bleach for the first time."
        },
        {
          "title": "Office Space",
          "year": 1999,
          "note": "Fennessey's nod to the idea that cult can also be mainstream, and a gateway to the rest of Mike Judge's work."
        },
        {
          "title": "Big Trouble in Little China",
          "year": 1986,
          "note": "John Carpenter's kung fu riff, which Fennessey says sent him down a rabbit hole of Billy Jack movies and old martial-arts mysticism."
        },
        {
          "title": "Altered States",
          "year": 1980,
          "note": "Ken Russell's adaptation of a Paddy Chayefsky script, with a William Hurt performance Fennessey loves. 'Doesn't totally work but also works in my heart.'"
        },
        {
          "title": "Evil Dead II",
          "year": 1987,
          "note": "Sam Raimi's follow-up. Fennessey invokes Godard's line that it's not blood, it's the color red: gore pitched so far past disgusting it becomes Looney Tunes."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Emma Seligman on",
      "films": [
        {
          "title": "Shiva Baby",
          "year": 2020,
          "note": "Seligman's first feature, expanded from her NYU thesis short, shot for under $250,000 and set almost entirely inside one shiva. She went in aiming for slapstick, then found the anxious, claustrophobic register by watching A Woman Under the Influence, Black Swan, and Uncut Gems. Her composer was the one who told her it was, structurally, a horror score."
        },
        {
          "title": "Bottoms",
          "year": 2023,
          "note": "Still in development at the time of this interview. Seligman describes it as a teen comedy in the vein of Wet Hot American Summer, about two queer girls who start a fight club to win over the cheerleaders, co-written with Shiva Baby star Rachel Sennett."
        }
      ]
    }
  ],
