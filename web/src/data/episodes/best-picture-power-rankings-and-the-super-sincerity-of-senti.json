{
  "slug": "best-picture-power-rankings-and-the-super-sincerity-of-senti",
  "title": "Best Picture Power Rankings and the Super-Sincerity of ‘Sentimental Value,’ With Joachim Trier! Plus: Regretting ‘Regretting You.’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-11-24",
  "runtimeMin": 125,
  "format": "Sean and Amanda open on the Warner Bros. Discovery sale, take apart the Colleen Hoover hit 'Regretting You,' split hard over Joachim Trier's 'Sentimental Value,' rebuild the Best Picture top 10, and Sean talks to Trier.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Regretting You’",
      "films": [
        {
          "title": "Regretting You",
          "year": 2025,
          "note": "The Josh Boone / Colleen Hoover adaptation, tracking past $50 million. Allison Williams and Dave Franco are asked to play their own teenage selves and to grieve a car-crash affair, and both are stranded by material that gives them nothing funny to do. Amanda calls it insulting to its audience; Sean thinks it's a Rorschach for what's missing at the multiplex. The mother-daughter scenes with McKenna Grace are the only stretch either of them buys."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Sentimental Value’",
      "films": [
        {
          "title": "Sentimental Value",
          "year": 2025,
          "note": "Trier's Grand Prix winner, reuniting him with Renate Reinsve, plus Stellan Skarsgård as an estranged filmmaker father and Elle Fanning as the American star he tries to substitute for his daughter. Sean's favorite of the year; Amanda saw it twice and hands it the 'I'm dead inside' award: she admires the depression-as-inertia structure but never connected. Both love the house-as-narrator framing and read it against The Royal Tenenbaums."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Best Picture Power Rankings",
      "note": "as of late November",
      "subject": "the 2026 Best Picture race",
      "ranked": true,
      "films": [
        {
          "title": "One Battle After Another",
          "year": 2025,
          "note": "Still No. 1. Neither has been moved off it; the closest thing to a coronation the year has."
        },
        {
          "title": "Hamnet",
          "year": 2025,
          "note": "Holds at 2 on real heat, including a Spielberg-hosted screening, though it isn't out wide yet."
        },
        {
          "title": "Sinners",
          "year": 2025,
          "note": "Steady at 3, propped up by a don't-you-dare-forget-it fanbase and Coogler's fresh Walk of Fame star."
        },
        {
          "title": "Marty Supreme",
          "year": 2025,
          "note": "Jumps to 4. Everyone who's seen it loves it and the Chalamet campaign is relentless; the knock is that Josh Safdie is too early in his career to top One Battle."
        },
        {
          "title": "Frankenstein",
          "year": 2025,
          "note": "Slides to 5 as del Toro locks in and Jacob Elordi rises in Supporting Actor."
        },
        {
          "title": "Sentimental Value",
          "year": 2025,
          "note": "At 6. A festival wow with strong per-screen word of mouth, but the same are-we-sure hedges that dog Hamnet."
        },
        {
          "title": "It Was Just an Accident",
          "year": 2025,
          "note": "Back on at 7. The Palme d'Or winner, and Panahi is here campaigning, even if it hasn't drawn a crowd stateside."
        },
        {
          "title": "Avatar: Fire and Ash",
          "year": 2025,
          "note": "New at 8, taking the one-big-blockbuster slot; they see it in early December and could still be swayed."
        },
        {
          "title": "Train Dreams",
          "year": 2025,
          "note": "At 9, sliding into the Jay Kelly Netflix slot as that one falls off the board."
        },
        {
          "title": "The Secret Agent",
          "year": 2025,
          "note": "Debuts at 10. The Brazil contingent is strong and neither underestimates it, though Sean hasn't seen it yet."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Joachim Trier on",
      "films": [
        {
          "title": "Sentimental Value",
          "year": 2025,
          "note": "Trier on writing a difficult filmmaker father who turned out to mirror his own family, staging Gustav Borg's fake masterpiece as a one-take on a moving train, the actual Oslo house he shot in and rebuilt as a 1930s studio replica, and a soundtrack bookended by Terry Callier and Labi Siffre."
        },
        {
          "title": "The Worst Person in the World",
          "year": 2021,
          "note": "The prior Reinsve film whose reach (Academy nominations, a Hollywood dialogue) shaped the anxiety of following it."
        },
        {
          "title": "Reprise",
          "year": 2006,
          "note": "His debut, bought by Miramax, which sent him on the studio-meeting circuit before he chose to keep working from Norway."
        },
        {
          "title": "Oslo, August 31st",
          "year": 2011,
          "note": "The film he made back home after deciding Hollywood wasn't where he'd feel most free."
        },
        {
          "title": "One Battle After Another",
          "year": 2025,
          "note": "His pick for the last great thing he's seen; he calls Paul Thomas Anderson the master of their filmmaking generation."
        }
      ]
    }
  ],
