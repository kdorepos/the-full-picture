  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan draft 2006 across six categories - Blockbuster, Drama, Comedy, Action Horror Thriller, Oscar Nominee, and Wildcard - from The Departed to Borat.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The 2006 Movie Draft",
      "draftOf": "2006 movies",
      "categories": [
        "Blockbuster",
        "Drama",
        "Comedy",
        "Action Horror Thriller",
        "Oscar Nominee",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Casino Royale",
              "year": 2006,
              "category": "Blockbuster",
              "note": "Sean ranks it second-best of the Craig-era Bonds, behind Skyfall. He once made a 48-minute YouTube video just about Craig's blue-trunks beach entrance."
            },
            {
              "title": "Little Children",
              "year": 2006,
              "category": "Drama",
              "note": "Todd Field's follow-up to In the Bedroom, adapted from Tom Perrotta's novel. Sean defends the narrator device some critics called overwrought."
            },
            {
              "title": "Borat: Cultural Learnings of America for Make Benefit Glorious Nation of Kazakhstan",
              "year": 2006,
              "category": "Comedy",
              "note": "Sean's best in-theater experience of 2006. He rewatched it during Covid ahead of the sequel and says it still holds up."
            },
            {
              "title": "The Descent",
              "year": 2006,
              "category": "Action Horror Thriller",
              "note": "Neil Marshall's caving horror movie, which Sean calls one of the best horror films not just of the year but of the decade."
            },
            {
              "title": "Children of Men",
              "year": 2006,
              "category": "Oscar Nominee",
              "note": "Alfonso Cuaron's dystopian sci-fi drama. Sean puts it in the conversation for best-made movie of the 21st century and singles out Michael Caine."
            },
            {
              "title": "Talladega Nights: The Ballad of Ricky Bobby",
              "year": 2006,
              "category": "Wildcard",
              "note": "Taken partly to needle Chris and Bobby. Sean brings up Christopher Nolan naming it a favorite on The Rich Eisen Show."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Devil Wears Prada",
              "year": 2006,
              "category": "Blockbuster",
              "note": "Amanda blames this movie for her own career in magazines; she saw it a month after graduating college while deciding between publishing and teaching classics."
            },
            {
              "title": "Marie Antoinette",
              "year": 2006,
              "category": "Drama",
              "note": "Sofia Coppola's Kirsten Dunst film, Amanda's favorite Coppola movie by her own admission. She notes the anachronistic soundtrack."
            },
            {
              "title": "The Holiday",
              "year": 2006,
              "category": "Comedy",
              "note": "Nancy Meyers' rom-com. Amanda ranks it behind Something's Gotta Give and It's Complicated among Meyers films and isn't sold on the Jack Black subplot."
            },
            {
              "title": "Inside Man",
              "year": 2006,
              "category": "Action Horror Thriller",
              "note": "Spike Lee's bank-heist thriller, which Amanda calls an A-plus New York movie she saw during her first year living in the city."
            },
            {
              "title": "The Queen",
              "year": 2006,
              "category": "Oscar Nominee",
              "note": "Peter Morgan's Helen Mirren vehicle, which Amanda calls a testing ground for The Crown."
            },
            {
              "title": "Step Up",
              "year": 2006,
              "category": "Wildcard",
              "note": "Taken over She's the Man, for launching Channing Tatum's career."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Mission: Impossible III",
              "year": 2006,
              "category": "Blockbuster",
              "note": "Chris gets ribbed for the pick - Sean and Amanda note it landed at No. 6 on their Mission: Impossible rewatchables ranking - but he stands by Philip Seymour Hoffman's villain."
            },
            {
              "title": "The Prestige",
              "year": 2006,
              "category": "Drama",
              "note": "Christopher Nolan's dueling-magicians film. Chris insists it's not actually his favorite Nolan movie, a line the group won't let him live down for the rest of the episode."
            },
            {
              "title": "Jackass Number Two",
              "year": 2006,
              "category": "Comedy",
              "note": "Chris's second-best in-theater experience of 2006, behind Sean's pick of Borat."
            },
            {
              "title": "Miami Vice",
              "year": 2006,
              "category": "Action Horror Thriller",
              "note": "Michael Mann's film, one of Chris's favorite movies ever made. He defends its Linkin Park/Jay-Z soundtrack and its now-celebrated digital cinematography."
            },
            {
              "title": "The Departed",
              "year": 2006,
              "category": "Oscar Nominee",
              "note": "Chris's first pick of the draft, Scorsese's Boston gangster film. He and Sean have covered it twice on The Rewatchables, including a deep dive on Nicholson's boot to Leo's hand."
            },
            {
              "title": "Dave Chappelle's Block Party",
              "year": 2006,
              "category": "Wildcard",
              "note": "Michel Gondry's concert film, picked as a time-capsule of the Brooklyn music scene Chris was living in and covering for Fader at the time."
            }
          ]
        }
