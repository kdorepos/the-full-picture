{
  "slug": "black-adam-the-worst-movie-of-the-decade",
  "title": "‘Black Adam’: The Worst Movie of the Decade?",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Charles Holmes",
    "Rob Mahoney"
  ],
  "published": "2022-10-25",
  "runtimeMin": 62,
  "format": "Sean, Charles, and Rob sit through 'Black Adam' and use it to litigate The Rock's whole box-office career.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Black Adam'",
      "note": "the number one movie in the country",
      "films": [
        {
          "title": "Black Adam",
          "year": 2022,
          "note": "The Rock's 15-year passion project, directed by Jaume Collet-Serra. Sean calls it a totem of everything wrong with the last decade of the business; Charles had a blast. A hero too powerful to have a real threat, 88% action, slow-mo cribbed from the Snyder films, and 'Paint It Black' over an Egyptian battle. Aldis Hodge's Hawkman spends two hours arguing due process; Pierce Brosnan's Dr. Fate is a sincere Doctor Strange; Sarah Shahi's archaeologist summons him; Noah Centineo's CGI-inflated kid eats chicken wings. Superman turns up mid-credits."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Doing the Rock Johnson",
      "note": "20-plus years of a box-office career",
      "films": [
        {
          "title": "The Scorpion King",
          "year": 2002,
          "note": "The Hollywood transition Sean had high hopes for: the successor to Schwarzenegger and Stallone."
        },
        {
          "title": "The Rundown",
          "year": 2003,
          "note": "One of his best: a stripped-down buddy-cop comedy, a knockoff of a '90s Richard Donner movie."
        },
        {
          "title": "Walking Tall",
          "year": 2004,
          "note": "A smaller, more human-looking Rock taking boards over the head."
        },
        {
          "title": "Southland Tales",
          "year": 2006,
          "note": "One of three genuinely interesting movies he's made: not the lead, from a real filmmaker."
        },
        {
          "title": "The Other Guys",
          "year": 2010,
          "note": "A rare turn as the butt of the joke; both hosts wish he'd do more of this."
        },
        {
          "title": "Pain & Gain",
          "year": 2013,
          "note": "Another interesting one where he's not the star, from a real director."
        },
        {
          "title": "San Andreas",
          "year": 2015,
          "note": "An original, non-IP disaster movie."
        },
        {
          "title": "Central Intelligence",
          "year": 2016,
          "note": "Chemistry with Kevin Hart, which Rob is allergic to."
        },
        {
          "title": "Moana",
          "year": 2016,
          "note": "Arguably his most successful recent work: pure voice, no fights to cherry-pick."
        },
        {
          "title": "Jumanji: Welcome to the Jungle",
          "year": 2017,
          "note": "His number one domestic grosser."
        },
        {
          "title": "Skyscraper",
          "year": 2018,
          "note": "An original script whose explicit goal is still franchisable IP."
        },
        {
          "title": "Hobbs & Shaw",
          "year": 2019,
          "note": "Should have been a layup; doesn't work. Sean's premiere had a 35-minute electrical outage that Dwayne vamped through, charmingly."
        },
        {
          "title": "Jumanji: The Next Level",
          "year": 2019,
          "note": "Third on his domestic list."
        },
        {
          "title": "Jungle Cruise",
          "year": 2021,
          "note": "Collet-Serra's other recent Rock movie. Also didn't work."
        },
        {
          "title": "Red Notice",
          "year": 2021,
          "note": "An original script with Ryan Reynolds and Gal Gadot, roundly mocked."
        },
        {
          "title": "Red One",
          "year": 2023,
          "note": "Breaking news mid-episode: an Amazon 'franchisable piece of IP' whose merchandising tentacles broke Charles's spirit."
        },
        {
          "title": "Fast Five",
          "year": 2011,
          "note": "Number six domestically. Two of his top five are Fast movies."
        },
        {
          "title": "Fast & Furious 6",
          "year": 2013,
          "note": "Number five on the list."
        },
        {
          "title": "Furious 7",
          "year": 2015,
          "note": "His number two domestic grosser."
        },
        {
          "title": "The Mummy Returns",
          "year": 2001,
          "note": "Where it started, further down the box-office list."
        },
        {
          "title": "Get Smart",
          "year": 2008,
          "note": "Also on the top-ten box-office rundown."
        },
        {
          "title": "G.I. Joe: Retaliation",
          "year": 2013,
          "note": "Not bad. Sean would take it over Black Adam. From Jon M. Chu, with a decent cast."
        }
      ]
    }
  ],
