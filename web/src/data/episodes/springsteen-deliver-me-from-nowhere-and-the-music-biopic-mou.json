    },
    {
      "kind": "discussion",
      "heading": "'If I Had Legs, I'd Kick You'",
      "note": "Sean and Amanda",
      "films": [
        {
          "title": "If I Had Legs, I'd Kick You",
          "year": 2025,
          "note": "Mary Bronstein's A24 film, shot in claustrophobic close-up on Rose Byrne as a mother at her limit. The daughter is never shown. Tonally in the Uncut Gems / forced-intimacy vein."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Mary Bronstein on",
      "films": [
        {
          "title": "If I Had Legs, I'd Kick You",
          "year": 2025,
          "note": "Bronstein on writing it on a hotel bathroom floor while her sick daughter slept, walking away from every note until A24 said yes, and the choice to never show the child."
        },
        {
          "title": "Yeast",
          "year": 2008,
          "note": "Her first feature, from the mumblecore New York era, followed by a 17-year gap before this one."
        },
        {
          "title": "Who's Afraid of Virginia Woolf?",
          "year": 1966,
          "note": "The last great thing she saw: a chamber piece that survives on performance alone, which she found already lived inside her own work."
