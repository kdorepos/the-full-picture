{
  "slug": "the-genius-of-uncut-gems-plus-the-safdie-brothers-the-big-pi",
  "title": "The Genius of 'Uncut Gems.' Plus: the Safdie Brothers!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey"
  ],
  "published": "2019-12-26",
  "runtimeMin": 76,
  "format": "Sean Fennessey (with Bobby Wagner) makes his case for Uncut Gems, then Josh and Benny Safdie walk through the decade it took to get Adam Sandler, Kevin Garnett, and the rest of the movie onto a screen.",
  "segments": [
    {
      "kind": "review",
      "heading": "The Genius of 'Uncut Gems'",
      "note": "with Bobby Wagner",
      "films": [
        {
          "title": "Uncut Gems",
          "year": 2019,
          "note": "Sean's Christmas-week case for it: Adam Sandler plays Howard Ratner as a man willing to break every rule to finish what he started, and the film is a rare sports-gambling movie that actually nails what a parlay bet feels like. He places it in the lineage of Sweet Smell of Success and Dog Day Afternoon and calls Kevin Garnett's performance maybe the best ever from an NBA player turned actor. He also credits the supporting cast (Julia Fox, Idina Menzel, Lakeith Stanfield, Eric Bogosian, Judd Hirsch, Mike Francesca, The Weeknd), Daniel Lopatin's score, Darius Khondji's cinematography, and Ronald Bronstein/Benny Safdie's editing and crosstalk-heavy sound design, ending on how the movie insists Howard pay for his sins."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Josh and Benny Safdie on",
      "note": "the decade-long path to Uncut Gems, through casting reshuffles with Amar'e Stoudemire, Kobe Bryant, Joel Embiid, and finally Kevin Garnett",
      "films": [
        {
          "title": "Daddy Longlegs",
          "year": 2010,
          "note": "Their first feature, originally titled Go Get Some Rosemary before it premiered at the height of the recession and got a new title for Sundance. Ronald Bronstein won a Gotham Award for it over Jennifer Lawrence; Sandler has called it one of his favorite movies."
        },
        {
          "title": "Lenny Cooke",
          "year": 2013,
          "note": "A documentary about a once-hyped high-school basketball prospect that they took on as a paying gig expected to last six months and ended up shooting for years."
        },
        {
          "title": "Heaven Knows What",
          "year": 2015,
          "note": "Shot for almost no money with a cast including homeless nonactors; the Safdies say they bet everything on it. Scorsese saw it, loved it, and asked what they were doing next."
        },
        {
          "title": "The Black Balloon",
          "year": 2012,
          "note": "A short film they made after designer Andy Spade pitched them a riff on The Red Balloon in the middle of the night."
        },
        {
          "title": "Good Time",
          "year": 2017,
          "note": "Made for roughly $2 million after everyone told them it needed to be a $12 million movie, with 18- and 22-hour shooting days. Sandler watched it after Cannes and called them out of the blue to say he wanted in on Gems."
        }
      ]
    }
  ],
