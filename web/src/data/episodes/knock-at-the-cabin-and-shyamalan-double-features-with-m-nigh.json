{
  "slug": "knock-at-the-cabin-and-shyamalan-double-features-with-m-nigh",
  "title": "‘Knock at the Cabin’ and Shyamalan Double Features, With M. Night Shyamalan!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Elric Kane",
    "Brian Saur"
  ],
  "published": "2023-02-03",
  "runtimeMin": 92,
  "format": "Sean Fennessey talks Knock at the Cabin with Pure Cinema's Elric Kane and Brian Saur, ranks his own Shyamalan five, trades a deep-cut double feature for each, then sits down with M. Night Shyamalan.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Knock at the Cabin’",
      "note": "with Elric Kane and Brian Saur",
      "films": [
        {
          "title": "Knock at the Cabin",
          "year": 2023,
          "note": "Shyamalan's 15th feature, from Paul Tremblay's novel: two dads and their daughter are held hostage in a cabin and told to sacrifice one of their own to stop the apocalypse. The trio single out the craft (extreme close-ups on distorted vintage lenses, blocking in a confined space, violence kept off-screen) and agree Dave Bautista's gentle-giant Leonard is what holds it together. Shyamalan diverges from the book's ending."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Shyamalan Top Five",
      "note": "his personal ranking, best first",
      "subject": "M. Night Shyamalan",
      "ranked": true,
      "films": [
        {
          "title": "Unbreakable",
          "year": 2000,
          "note": "No. 1. The overlooked one that foretold and subverted the superhero era, with one of his better closing beats."
        },
        {
          "title": "The Sixth Sense",
          "year": 1999,
          "note": "No. 2. His debut, and the one every later film got measured against."
        },
        {
          "title": "Signs",
          "year": 2002,
          "note": "No. 3. Sean's true Knock at the Cabin double: a family stuck in a house as something vast happens outside."
        },
        {
          "title": "The Visit",
          "year": 2015,
          "note": "No. 4. The self-financed Blumhouse comeback."
        },
        {
          "title": "The Village",
          "year": 2004,
          "note": "No. 5. Derided in 2004, now a favorite of Brian's."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The Shyamalan double features",
      "note": "one deep cut per host, per film",
      "picks": [
        {
          "title": "Long Weekend",
          "year": 1978,
          "by": "Elric Kane",
          "note": "Pairs with The Happening. A 1978 Australian eco-horror (writer Everett De Roche) about a feuding couple whose beach trip turns on them as nature takes revenge."
        },
        {
          "title": "The Quiet Earth",
          "year": 1985,
          "by": "Brian Saur",
          "note": "Pairs with The Happening. Geoff Murphy's New Zealand film: Bruno Lawrence wakes to an apparently empty world and slowly learns why."
        },
        {
          "title": "Frightmare",
          "year": 1974,
          "by": "Elric Kane",
          "note": "Pairs with The Visit. Pete Walker's British shocker about a grandmother released from a mental hospital fifteen years after a cannibalism conviction, and not, it turns out, reformed."
        },
        {
          "title": "You'll Like My Mother",
          "year": 1972,
          "by": "Brian Saur",
          "note": "Pairs with The Visit. Lamont Johnson's snowbound thriller: a pregnant widow (Patty Duke) arrives to meet her late husband's very strange mother."
        },
        {
          "title": "Eye of the Devil",
          "year": 1966,
          "by": "Elric Kane",
          "note": "Pairs with The Village as its mirror inverse. A modern couple (David Niven, Deborah Kerr) is pulled into a French vineyard's pagan sacrifice. Sharon Tate's screen debut."
        },
        {
          "title": "Southern Comfort",
          "year": 1981,
          "by": "Brian Saur",
          "note": "Pairs with The Village. Walter Hill's Louisiana-swamp survival film: Guardsmen at war with Cajuns, the outside looking in rather than the inside looking out."
        },
        {
          "title": "Altered",
          "year": 2006,
          "by": "Elric Kane",
          "note": "Pairs with Signs. Eduardo Sánchez's post-Blair Witch creature film: abductees capture one of the aliens that once took them, then realize they've called the rest."
        },
        {
          "title": "Communion",
          "year": 1989,
          "by": "Brian Saur",
          "note": "Pairs with Signs. Christopher Walken as author Whitley Strieber, whose remote cabin becomes the site of a subtly terrifying alien home invasion."
        },
        {
          "title": "Fearless",
          "year": 1993,
          "by": "Elric Kane",
          "note": "Pairs with Unbreakable, the non-superhero version. Peter Weir's plane-crash survivor drama, Jeff Bridges as a man who believes he can't die."
        },
        {
          "title": "Mystery Men",
          "year": 1999,
          "by": "Brian Saur",
          "note": "Pairs with Unbreakable. The 1999 amateur-superhero comedy that plays better in the Marvel-fatigue era than it did on release."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "M. Night Shyamalan on",
      "films": [
        {
          "title": "Knock at the Cabin",
          "year": 2023,
          "note": "The book came to him to produce; he refused the ending, the project died, then the rights returned and he made his own version. On casting Bautista off his Blade Runner 2049 scene, chopping the characters' heads out of frame for a sense of detachment, and shooting on film so he could reshoot toward the pitch he wanted."
        },
        {
          "title": "Drive My Car",
          "year": 2021,
          "note": "Hamaguchi's film was an influence while he wrote; Hamaguchi later sat on his Berlin Film Festival jury."
        },
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "His last great thing: he loved how far it spun the tone and felt it was, in his words, cooked enough."
        }
      ]
    }
  ],
