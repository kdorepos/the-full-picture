          "year": 2005
        },
        {
          "title": "Crip Camp: A Disability Revolution",
          "year": 2020,
          "note": "Briefly noted as well-received."
        },
        {
          "title": "On the Record",
          "year": 2020,
          "note": "Kirby Dick and Amy Ziering's documentary on Drew Dixon's allegations against Russell Simmons at Def Jam, and the wider music industry. Oprah Winfrey removed her producer credit three days before the premiere."
        }
      ]
    },
