{
  "slug": "nosferatu-and-the-top-five-vampire-movies-with-robert-eggers",
  "title": "‘Nosferatu’ and the Top Five Vampire Movies, With Robert Eggers!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan",
    "Rob Mahoney"
  ],
  "published": "2024-12-27",
  "runtimeMin": 106,
  "format": "Sean, Chris Ryan, and Rob Mahoney break down Robert Eggers's Nosferatu remake, each rank five favorite vampire movies, then Sean sits down with Eggers.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Nosferatu’",
      "films": [
        {
          "title": "Nosferatu",
          "year": 2024,
          "note": "Eggers's remake of the 1922 Murnau film, itself an unauthorized take on Stoker's Dracula. The three admire the craft (the Carpathian tracking shots, the driverless carriage, the last 30 minutes) more than they feel it; Chris found it faithful to a fault, Rob less twisty than Eggers's other work. Bill Skarsgård's Orlok is a decaying, mustachioed corpse who feeds from the chest and never breaks his lowered voice; Lily-Rose Depp's physical, possessed performance is the movie for all three. Nicholas Hoult plays Hutter. Produced by Chris Columbus."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top Five Vampire Movies",
      "note": "No. 1 first; two films tie at No. 4",
      "subject": "vampire movies",
      "films": [
        {
          "title": "The Lost Boys",
          "year": 1987,
          "note": "No. 1: Joel Schumacher's Northern California boardwalk town; Chris's first vampire love and the one he rewatches most."
        },
        {
          "title": "Near Dark",
          "year": 1987,
          "note": "No. 2: Kathryn Bigelow's Southwestern travelogue, a Bonnie-and-Clyde couple falling in with roaming vampire criminals. Lance Henriksen and Bill Paxton. His old No. 1; badly in need of a 4K restoration."
        },
        {
          "title": "Only Lovers Left Alive",
          "year": 2013,
          "note": "No. 3 (shared with Rob): Jim Jarmusch's centuries-old lovers, Tilda Swinton and Tom Hiddleston, in a decaying Detroit."
        },
        {
          "title": "Vampires",
          "year": 1998,
          "note": "No. 4 (tie): John Carpenter's Vampires, with James Woods as the Church's vampire hunter Jack Crow. A Saturday-afternoon-cable favorite, and Van Lathan's old No. 1."
        },
        {
          "title": "30 Days of Night",
          "year": 2007,
          "note": "No. 4 (tie): David Slade's month of darkness in Barrow, Alaska. Danny Huston's fast, shark-toothed vampires; Josh Hartnett as the sheriff."
        },
        {
          "title": "Twilight",
          "year": 2008,
          "note": "No. 5: Chris's defense of a fucked-up teenage love story in Forks. Robert Pattinson's Edward as the real Dracula."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Rob Mahoney's Top Five Vampire Movies",
      "note": "No. 1 first",
      "subject": "vampire movies",
      "ranked": true,
      "films": [
        {
          "title": "Let the Right One In",
          "year": 2008,
          "note": "No. 1: Tomas Alfredson's Swedish story of two lonely kids, one a vampire, signaling to each other in a dead-winter apartment block. One of the few near-feel-good vampire movies."
        },
        {
          "title": "Bram Stoker's Dracula",
          "year": 1992,
          "note": "No. 2 (shared with Sean): Coppola going all-in on production design and costume, Gary Oldman going hard every second. Keanu getting worked over by the brides."
        },
        {
          "title": "Only Lovers Left Alive",
          "year": 2013,
          "note": "No. 3 (shared with Chris): the movie Rob recommends most; blood as a hallucinogen, Detroit in decay."
        },
        {
          "title": "Cronos",
          "year": 1993,
          "note": "No. 4: Guillermo del Toro's first film; a golden scarab, eternal life as a curse. An early flash of his creature design."
        },
        {
          "title": "Blade II",
          "year": 2002,
          "note": "No. 5: also del Toro, with the vampire clubs, motorcycle fights, and 'vampire government' that Rob loves. Snipes fully Snipesified."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top Five Vampire Movies",
      "note": "No. 1 first; his 2024 list, separate from the 2022 one",
      "subject": "vampire movies",
      "ranked": true,
      "films": [
        {
          "title": "Fright Night",
          "year": 1985,
          "note": "No. 1: a teen comedy with gloopy practical gross-out effects, Chris Sarandon as the vampire next door. Sean rates the 2011 Colin Farrell remake as pretty good too."
        },
        {
          "title": "Bram Stoker's Dracula",
          "year": 1992,
          "note": "No. 2 (shared with Rob): revisited it for Megalopolis and was floored by the craft."
        },
        {
          "title": "Trouble Every Day",
          "year": 2001,
          "note": "No. 3: Claire Denis's film with Vincent Gallo and Béatrice Dalle, a Trojan-horse genre movie with an unnerving centerpiece kill; kin to The Addiction and Habit."
        },
        {
          "title": "Dracula's Daughter",
          "year": 1936,
          "note": "No. 4: watched for the first time the night before; a Universal sequel and an early, unmistakably crypto-lesbian vampire drama. Directed by Lambert Hillyer, 71 minutes."
        },
        {
          "title": "Martin",
          "year": 1978,
          "note": "No. 5: George Romero's little-seen Pittsburgh study of an alienated teen who thinks he's a vampire, maybe."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Robert Eggers on",
      "films": [
        {
          "title": "Nosferatu",
          "year": 2024,
          "note": "Eggers traces the film to a VHS he mail-ordered at 9 and a black-and-white silent stage version he directed in high school. He watched every Dracula movie but leaned on non-vampire influences (chiefly Jack Clayton's The Innocents); grounded Orlok's chest-feeding, iron stakes, and mustache in folklore and occult research; wrote it pre-COVID; and credits Chris Columbus's Hollywood-storytelling notes. The first of his films he was happy with out of the gate."
        }
      ]
    }
  ],
