{
  "slug": "top-5-clint-eastwood-movies-and-cry-macho",
  "title": "Top 5 Clint Eastwood Movies and ‘Cry Macho’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Adam Nayman",
    "Chris Ryan"
  ],
  "published": "2021-09-17",
  "runtimeMin": 89,
  "format": "Sean Fennessey, Adam Nayman, and Chris Ryan spend an episode on all six decades of Clint Eastwood: 'Cry Macho,' the mythos around him, and a shared, unanimous No. 1.",
  "segments": [
    {
      "kind": "review",
      "heading": "Review: Cry Macho",
      "films": [
        {
          "title": "Cry Macho",
          "year": 2021,
          "note": "Eastwood, 91, directs and stars as a washed-up ranch hand sent into Mexico to retrieve his old boss's son (and a prize fighting rooster). The project sat unmade for over thirty years, with Robert Mitchum, Burt Lancaster, Pierce Brosnan, and eventually Arnold Schwarzenegger all attached before Eastwood finally made it himself."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Sixty years, one persona",
      "note": "the shape of a career",
      "films": [
        {
          "title": "Play Misty for Me",
          "year": 1971,
          "note": "Eastwood's directing debut, released the same year as Dirty Harry, a DJ-stalker thriller the group calls a clear precursor to Fatal Attraction."
        },
        {
          "title": "Dirty Harry",
          "year": 1971,
          "note": "The Don Siegel film that made Eastwood's persona. Adam calls the “do you feel lucky” scene a performance built on total numbness, credited alongside Bullitt as a direct inspiration for the inspector Ruffalo plays in Zodiac."
        },
        {
          "title": "The Outlaw Josey Wales",
          "year": 1976,
          "note": "Cited as a direct influence on Tarantino's screen violence, though Adam notes Tarantino only ever namechecks Leone, never Eastwood himself."
        },
        {
          "title": "Flags of Our Fathers",
          "year": 2006,
          "note": "Adam's example of a film Eastwood directed that isn't “about” Clint Eastwood, unlike Gran Torino or The Mule."
        },
        {
          "title": "Letters from Iwo Jima",
          "year": 2006,
          "note": "Its companion piece: same distinction."
        },
        {
          "title": "Mystic River",
          "year": 2003,
          "note": "Another one Adam says isn't really “about” Clint Eastwood, despite being one of his biggest awards-season hits."
        },
        {
          "title": "Million Dollar Baby",
          "year": 2004,
          "note": "Where Adam draws the line: this one “kind of” is about Clint."
        },
        {
          "title": "Gran Torino",
          "year": 2008,
          "note": "Definitely about Clint, per Adam, and a movie he says friends have “literally threatened his life” over him not loving enough."
        },
        {
          "title": "The Mule",
          "year": 2018,
          "note": "The direct forerunner to Cry Macho the group keeps circling back to, including its own long stretches of just watching Clint drive."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Five",
      "note": "favorite Clint Eastwood movies",
      "subject": "Clint Eastwood movies",
      "ranked": true,
      "films": [
        {
          "title": "Unforgiven",
          "year": 1992,
          "note": "No. 1 - the unanimous pick across all three lists. Sean singles out the opening shot of Eastwood digging his wife's grave, and a David Webb Peoples screenplay that sat unproduced for a decade before Eastwood finally made it."
        },
        {
          "title": "Magnum Force",
          "year": 1973,
          "note": "No. 2 - the Dirty Harry sequel Eastwood made as a direct answer to the original's police-brutality backlash, directed by the “fairly unheralded” Ted Post."
        },
        {
          "title": "The Good, the Bad and the Ugly",
          "year": 1966,
          "note": "No. 3 - from the Man With No Name trilogy, which the group agrees hasn't aged a day, bad dubbing and all."
        },
        {
          "title": "Escape from Alcatraz",
          "year": 1979,
          "note": "No. 4 - directed by Don Siegel; Eastwood has fewer than 100 lines in the whole movie and still anchors every frame."
        },
        {
          "title": "High Plains Drifter",
          "year": 1973,
          "note": "No. 5 - the ghost-stranger revenge Western where a town gets painted red to draw out its killers. Paired here with its unofficial 1985 sequel, Pale Rider."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Adam Nayman's Five",
      "note": "favorite Clint Eastwood movies",
      "subject": "Clint Eastwood movies",
      "ranked": true,
      "films": [
        {
          "title": "Unforgiven",
          "year": 1992,
          "note": "No. 1 - unanimous. The film Adam's been measuring every subsequent Eastwood “victory lap” against since the top of the episode."
        },
        {
          "title": "The Beguiled",
          "year": 1971,
          "note": "No. 2 - an audible away from Dirty Harry, made by the same director (Don Siegel) the same year. Adam calls it Dirty Harry's mirror image: instead of all-powerful, Eastwood spends the whole movie humiliated. Sofia Coppola remade it in 2017."
        },
        {
          "title": "The Bridges of Madison County",
          "year": 1995,
          "note": "No. 3 - “an extraordinary act of transubstantiation” out of a book Adam thinks is bad, built around the scene where Eastwood picks Meryl Streep a bouquet of poisonous flowers."
        },
        {
          "title": "A Perfect World",
          "year": 1993,
          "note": "No. 4 - Kevin Costner as the escaped convict Eastwood's Texas Ranger chases down. Adam calls it a dry run for Cry Macho's mentor-and-kid template, and one of the best-made movies Eastwood has directed."
        },
        {
          "title": "The 15:17 to Paris",
          "year": 2018,
          "note": "No. 5 - a deliberate provocation: a dramatization of a real train terror attack starring the actual men who stopped it, not actors. Adam calls it “the weirdest damn movie” and admits he's the only one of the three who'd watch it twice."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Four",
      "note": "favorite Clint Eastwood movies",
      "subject": "Clint Eastwood movies",
      "ranked": true,
      "films": [
        {
          "title": "Unforgiven",
          "year": 1992,
          "note": "No. 1 - unanimous. Chris credits Gene Hackman's villain, who doesn't think of himself as one, and a beating that finally showed him what movie violence actually looks like, after years of his dad debunking barroom-brawl clichés."
        },
        {
          "title": "For a Few Dollars More",
          "year": 1965,
          "note": "No. 2 - Chris's favorite of the Leone trilogy, for Klaus Kinski above all."
        },
        {
          "title": "In the Line of Fire",
          "year": 1993,
          "note": "No. 3 - Wolfgang Petersen's Secret Service thriller, which Chris calls the best acting of Eastwood's career, built on the phone scenes with John Malkovich and a gentler Rene Russo romance than the usual Eastwood age-gap dynamic."
        },
        {
          "title": "Thunderbolt and Lightfoot",
          "year": 1974,
          "note": "No. 4 - Michael Cimino's bank-robbery caper with an Oscar-nominated Jeff Bridges, which Chris calls the closest Eastwood ever got to Malick."
        }
      ]
    }
  ],
