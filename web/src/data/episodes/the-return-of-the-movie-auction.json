{
  "slug": "the-return-of-the-movie-auction",
  "title": "The Return of the Movie Auction!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2021-07-16",
  "runtimeMin": 129,
  "format": "Sean, Amanda, and Chris go back to the well: another $1,000 each, five more 2021 movies. Then Morgan Neville on Roadrunner, his documentary about Anthony Bourdain.",
  "segments": [
    {
      "kind": "auction",
      "heading": "The paddles",
      "saleLabel": "Second sale · 2021",
      "slates": [
        {
          "host": "Sean Fennessey",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "The Tragedy of Macbeth",
              "year": 2021,
              "price": 255,
              "note": "Won a bidding war with Chris that climbed from $100 to $255. Joel Coen's first solo directing effort, adapting Shakespeare with Denzel Washington and Frances McDormand."
            },
            {
              "title": "Halloween Kills",
              "year": 2021,
              "price": 1,
              "note": "An uncontested dollar bid. David Gordon Green's Michael Myers sequel."
            },
            {
              "title": "Licorice Pizza",
              "year": 2021,
              "price": 515,
              "note": "Drafted under its working title, Soggy Bottom. The single highest bid of either auction, run up by Chris as much out of spite as interest. Paul Thomas Anderson's coming-of-age film set in the San Fernando Valley, starring Cooper Hoffman and Alana Haim."
            },
            {
              "title": "The Harder They Fall",
              "year": 2021,
              "price": 50,
              "note": "Pitched off a trailer Sean had just seen. Jeymes Samuel's revisionist Black western with Regina King and Jonathan Majors."
            },
            {
              "title": "The Card Counter",
              "year": 2021,
              "price": 179,
              "note": "His last $179, uncontested. Paul Schrader's poker drama starring Oscar Isaac."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "spent": 860,
          "budgetLeft": 140,
          "picks": [
            {
              "title": "Blonde",
              "year": 2022,
              "price": 100,
              "note": "Chris bailed at $95. Andrew Dominik's Netflix adaptation of the Joyce Carol Oates novel, with Ana de Armas as Marilyn Monroe."
            },
            {
              "title": "Don't Look Up",
              "year": 2021,
              "price": 215,
              "note": "Outbid Chris by five bucks. Adam McKay's Netflix satire with Jennifer Lawrence and Leonardo DiCaprio."
            },
            {
              "title": "The Power of the Dog",
              "year": 2021,
              "price": 85,
              "note": "Uncontested; she called it a steal on the spot. Jane Campion's first feature since 2009's Bright Star, with Benedict Cumberbatch, Kirsten Dunst, and Jesse Plemons."
            },
            {
              "title": "King Richard",
              "year": 2021,
              "price": 200,
              "note": "Uncontested. Reinaldo Marcus Green's Venus and Serena Williams biopic starring Will Smith."
            },
            {
              "title": "West Side Story",
              "year": 2021,
              "price": 260,
              "note": "Won over Chris, who stopped at $250. Steven Spielberg's remake of the Bernstein-Sondheim musical, with Ansel Elgort and Rachel Zegler."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "Eternals",
              "year": 2021,
              "price": 150,
              "note": "Uncontested. Chloé Zhao's entry into the MCU, with Richard Madden and Angelina Jolie."
            },
            {
              "title": "Spiderhead",
              "year": 2022,
              "price": 80,
              "note": "Drafted as 'Escape From Spider-Head.' Joseph Kosinski's Netflix thriller adapting a George Saunders story, with Chris Hemsworth and Miles Teller."
            },
            {
              "title": "Venom: Let There Be Carnage",
              "year": 2021,
              "price": 50,
              "note": "Uncontested; nobody else wanted to sit through an explanation of symbiote mythology. Tom Hardy and Woody Harrelson."
            },
            {
              "title": "Spider-Man: No Way Home",
              "year": 2021,
              "price": 230,
              "note": "Opened at a dollar and climbed to $230 mostly to keep it out of Sean's hands. Jon Watts's multiverse sequel."
            },
            {
              "title": "Causeway",
              "year": 2022,
              "price": 490,
              "note": "Drafted as 'Red, White and Water,' known then only from paparazzi photos. The second-highest bid of either auction, just under Licorice Pizza. Lila Neugebauer's directing debut, starring Jennifer Lawrence and Brian Tyree Henry."
            }
          ]
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Morgan Neville on",
      "films": [
        {
          "title": "Roadrunner: A Film About Anthony Bourdain",
          "year": 2021,
          "note": "Neville's documentary on the late chef and TV host, assembled from an 18-hour playlist of every song Bourdain ever referenced and about 34 interviews, only 18 of which made the final cut."
        }
      ]
    }
