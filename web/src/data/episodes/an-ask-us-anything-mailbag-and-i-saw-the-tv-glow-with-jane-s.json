    {
      "kind": "discussion",
      "heading": "‘I Saw the TV Glow,’ with Adam Nayman",
      "note": "Sean and Ringer critic Adam Nayman on the film",
      "films": [
        {
          "title": "I Saw the TV Glow",
          "year": 2024,
          "note": "Schoenbrun's second feature: a teenager and a classmate bond over a Buffy-adjacent, late-Nickelodeon-ish show called The Pink Opaque. Nayman reads it as horror, Sean as coming-of-age; both land on Cronenberg and Lynch, the Fred Durst casting coup, and a last fifteen minutes they call harrowing."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Jane Schoenbrun on ‘I Saw the TV Glow’",
      "note": "the writer-director in conversation with Sean",
      "guest": "Jane Schoenbrun on",
      "films": [
        {
          "title": "I Saw the TV Glow",
          "year": 2024,
          "note": "Schoenbrun on building the film tone-first (shoegaze, Snick, the glow of a '90s screen), then finding character and plot on top, junking the story six times to get there, and on Fred Durst as a spice only Fred Durst could add."
        },
        {
          "title": "We're All Going to the World's Fair",
          "year": 2021,
          "note": "Their first feature, a webcam-diary internet-horror movie made with twelve people in the woods: the small canvas TV Glow steps up from."
        }
      ]
    }
