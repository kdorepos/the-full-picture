{
  "slug": "welcome-to-dumpuary-breaking-down-a-bad-movie-buffet-the-big",
  "title": "Welcome to Dumpuary: Breaking Down a Bad Movie Buffet | The Big Picture",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-02-18",
  "runtimeMin": 98,
  "format": "Sean and Amanda wade through February's leftovers (Sonic, the To All the Boys sequel, Birds of Prey, Fantasy Island), then Nat Faxon and Jim Rash talk remaking Force Majeure into Downhill.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Quick Recommends",
      "note": "the good stuff hiding in a bad month",
      "films": [
        {
          "title": "Portrait of a Lady on Fire",
          "year": 2019,
          "note": "Sean interviewed director Celine Sciamma; the movie's only in four or five theaters but already made half a million dollars."
        },
        {
          "title": "The Traitor",
          "year": 2019,
          "note": "Marco Bellocchio's Cosa Nostra epic. Long, Italian, more mood piece than Goodfellas."
        },
        {
          "title": "The Assistant",
          "year": 2019,
          "note": "Julia Garner as an aide to a Harvey Weinstein-esque boss, shot entirely from her point of view. Both hosts recommend it and call it upsetting, \"defeating.\""
        },
        {
          "title": "Horse Girl",
          "year": 2020,
          "note": "Alison Brie for director Jeff Baena. Sean quit the movie twice before finishing it a third time, and only endorses the last 30 minutes."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "The Photograph",
      "films": [
        {
          "title": "The Photograph",
          "year": 2020,
          "note": "Stella Meghie's Issa Rae/LaKeith Stanfield romance, which they don't even count as dumpuary. Amanda: \"a mood in search of a movie,\" no real tension across 95 minutes."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Ones They Skipped",
      "note": "unseen, unmourned",
      "films": [
        {
          "title": "The Grudge",
          "year": 2020,
          "note": "A remake of a remake from Nicolas Pesce. Neither host has seen it."
        },
        {
          "title": "Underwater",
          "year": 2020,
          "note": "Another Kristen Stewart bomb, also unseen."
        },
        {
          "title": "The Lodge",
          "year": 2019,
          "note": "From the Goodnight Mommy team, played Sundance the year before. \"I heard this film was not good.\""
        },
        {
          "title": "The Rhythm Section",
          "year": 2020,
          "note": "Blake Lively and Reed Morano's revenge thriller, pulled from theaters after two weeks before either could catch it."
        },
        {
          "title": "Gretel & Hansel",
          "year": 2020,
          "note": "A horror reimagining of the fairy tale. Unseen."
        },
        {
          "title": "The Turning",
          "year": 2020,
          "note": "A remake of The Turn of the Screw with Brooklynn Prince. Bombed and vanished."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Four Dynamite Features",
      "note": "this week's dumpuary buffet",
      "films": [
        {
          "title": "Sonic the Hedgehog",
          "year": 2020,
          "note": "A hit nobody predicted: Paramount redesigned Sonic and delayed the release after fan backlash, then opened to over $70 million. Amanda: \"it's not good... and I won't be returning to Sonic,\" but \"you could do worse.\""
        },
        {
          "title": "To All the Boys: P.S. I Still Love You",
          "year": 2020,
          "note": "Sequel to a genuine Netflix hit, minus the tension: new director, new love triangle. Amanda says Lana Condor has no chemistry with the new guy."
        },
        {
          "title": "Birds of Prey (and the Fantabulous Emancipation of One Harley Quinn)",
          "year": 2020,
          "note": "Opened to $33 million and got quietly renamed for SEO after the bomb. Sean: ugly, badly paced, \"boring and noisy.\" Amanda liked the cast but wanted the actual team on screen together for more than the last scene."
        },
        {
          "title": "Fantasy Island",
          "year": 2020,
          "note": "Blumhouse's cheap end of the ledger: a 70s anthology show turned PG-13 horror. \"There's a crappy Ryan Gosling in the movie... a crappy Anne Hathaway.\""
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Nat Faxon and Jim Rash on",
      "films": [
        {
          "title": "Downhill",
          "year": 2020,
          "note": "Their first film in seven years, an American remake of Force Majeure that came to them via producer Julia Louis-Dreyfus, first drafted by Jesse Armstrong before he left to run Succession's writers' room."
        }
      ]
    }
  ],
