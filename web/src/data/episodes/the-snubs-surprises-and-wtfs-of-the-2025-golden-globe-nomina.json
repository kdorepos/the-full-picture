    {
      "kind": "interview",
      "heading": "Richard Gere on 'Oh, Canada'",
      "guest": "Richard Gere on",
      "films": [
        {
          "title": "Oh, Canada",
          "year": 2024,
          "note": "Paul Schrader's adaptation of Russell Banks's novel Foregone, about a celebrated documentarian looking back on, and misremembering, his life on camera. Gere took it right after his father died a month shy of 101; he pushed Schrader to bring the wife (Uma Thurman) into the Errol Morris-style Interrotron shot so Leonard Fife could confess directly to her. Jacob Elordi, cast before his breakout, plays the younger Fife."
        },
        {
          "title": "American Gigolo",
          "year": 1980,
          "note": "His first film with Schrader, 45 years earlier. Gere resisted reading Oh, Canada as a demythologizing of that Lothario role, but grants the meta connection of the two men telling a late-life story about how it all began."
        },
        {
          "title": "Chicago",
          "year": 2002,
          "note": "The Rob Marshall musical Gere almost passed on (he'd found the stage show only fine) until a script he calls brilliant made sense of it as a movie about fame and projection. He plays the cynical lawyer who understands the whole game."
        },
        {
          "title": "The Wisdom of Happiness",
          "year": 2024,
          "note": "His last-great-thing pick, and not self-serving by accident: a documentary on the Dalai Lama, a teacher and friend of Gere's for 40-plus years, that he and Oren Moverman re-edited. It premiered at the Zurich Film Festival and left him devastated."
        },
        {
          "title": "Norman: The Moderate Rise and Tragic Fall of a New York Fixer",
          "year": 2016,
          "note": "One of the films Gere names as underseen: a small Joseph Cedar movie, produced by Oren Moverman, that got too small a release."
        },
        {
          "title": "The Hoax",
          "year": 2006,
          "note": "Another underrated pick, one his friend Jonathan Cott brings up often."
        },
        {
          "title": "Dr. T & the Women",
          "year": 2000,
          "note": "The Robert Altman film Gere defends (critics were hard on it) for its refusal to cut the closing childbirth close-up that got it banned from release in Catholic countries."
        },
        {
          "title": "Yanks",
          "year": 1979,
          "note": "Named as a movie that should have been seen and appreciated, off the radar and never should have been."
        },
        {
          "title": "Mr. Jones",
          "year": 1993,
          "note": "His portrait of an extreme bipolar man, which his friend Jonathan Cott insists was completely overlooked."
        }
      ]
    }
  ],
