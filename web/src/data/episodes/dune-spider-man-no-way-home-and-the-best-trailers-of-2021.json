{
  "slug": "dune-spider-man-no-way-home-and-the-best-trailers-of-2021",
  "title": "‘Dune,’ ‘Spider-Man: No Way Home’ and the Best Trailers of 2021",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2021-08-31",
  "runtimeMin": 110,
  "format": "Trailer-season triage on Spider-Man: No Way Home, Eternals, Spencer, and The Power of the Dog, then a listener mailbag on Dune and the mid-budget movie, plus Michael Sarnoski on making Pig with Nicolas Cage.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The best trailers of 2021",
      "note": "an onslaught of fall-preview cuts",
      "films": [
        {
          "title": "Spider-Man: No Way Home",
          "year": 2021,
          "note": "The most-watched trailer ever, per the internet. Sean bailed halfway once it left the John Hughes-ish high-school stuff for Doctor Strange and the multiverse; Amanda credits Tom Holland and Zendaya as a teen-idol entry point. Tobey Maguire, Andrew Garfield, and Jamie Foxx's Electro are the rumored payoff."
        },
        {
          "title": "Eternals",
          "year": 2021,
          "note": "Salma Hayek explaining the setup 'at a second-grade reading level,' which Amanda appreciated. A round of 'the TV remote guy' / Kang confusion follows. Sean reads it as a prequel to the whole MCU."
        },
        {
          "title": "Spencer",
          "year": 2021,
          "note": "Pablo Larraín's Kristen Stewart-as-Diana film, withholding the accent until the last shot. Steven Knight wrote it, Claire Mathon shot it, Jonny Greenwood scored it. Premieres at Venice, opens Nov 5; Amanda measures it against The Crown."
        },
        {
          "title": "The Power of the Dog",
          "year": 2021,
          "note": "Jane Campion's Benedict Cumberbatch / Jesse Plemons / Kirsten Dunst western, the de facto Best Picture front-runner nobody has seen. Amanda 'won' it in the movie auction with no other bids; Sean predicts eight Oscar nominations."
        },
        {
          "title": "The Guilty",
          "year": 2021,
          "note": "Jake Gyllenhaal's Netflix remake, out Sept 24. The drop was only a text-on-screen teaser, which Sean wants banned for dramas three weeks from release."
        },
        {
          "title": "The Guilty (2018)",
          "year": 2018,
          "note": "Gustav Möller's Danish original, a 911-dispatcher thriller nominated for Best International Feature."
        },
        {
          "title": "House of Gucci",
          "year": 2021,
          "note": "The trailer Amanda actually loved: Gaga, Pacino, an unrecognizable Leto, Adam Driver, bad accents. Her flag for the spectacle TV can't match."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The mailbag",
      "note": "listener questions",
      "films": [
        {
          "title": "Dune",
          "year": 2021,
          "note": "Corey asks: theater or HBO Max? Sean is seeing it Wednesday and says go to a theater, safely. He won't grade Villeneuve's biggest film on box office, and warns anyone expecting Star Wars will be disappointed by the novel's strangeness."
        },
        {
          "title": "Lady Bird",
          "year": 2017,
          "note": "Heather's question about original theatrical films; Sean's answer on Greta Gerwig knowing movie history without making you feel you need to."
        },
        {
          "title": "Little Women",
          "year": 2019,
          "note": "Amanda's example of a movie-crazy director guiding you through material, start to finish, even though she'd never read the book."
        },
        {
          "title": "Wonder Boys",
          "year": 2000,
          "note": "Sean's case that The Chair, a three-hour series, would once have just been this two-and-a-half-hour movie."
        },
        {
          "title": "Battle Royale",
          "year": 2000,
          "note": "Kinji Fukasaku's teens-killing-teens film, Sean's 6:30 a.m. baby-and-a-movie pick. His daughter 'loved it, she was totally rapt.'"
        },
        {
          "title": "Irreversible",
          "year": 2002,
          "note": "Gaspar Noé's film Sean will never rewatch, for its harrowing central sequence."
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "Amanda's never-watch-again film: deeply moved, too upset by the ending to sit through it twice."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Michael Sarnoski on",
      "films": [
        {
          "title": "Pig",
          "year": 2021,
          "note": "Sarnoski's debut: Nicolas Cage as a hermit truffle hunter chasing his stolen pig. It began as one line in a folder called 'truffle': 'old man in the woods with his pig.' Shot in 20 days; Cage nailed the multi-page monologues in a take or two, and the Portland underground-fight scene reads to him as straightforward."
        },
        {
          "title": "Revanche",
          "year": 2008,
          "note": "The Austrian film (Sarnoski guesses Polish) he screened for Alex Wolff: an outlaw grieving at his father's country cabin, all stillness and chopped wood."
        },
        {
          "title": "Dead Man",
          "year": 1995,
          "note": "Jim Jarmusch; Sarnoski played Neil Young's guitar score on loop while writing Pig."
        },
        {
          "title": "John Wick",
          "year": 2014,
          "note": "The comparison everyone reaches for, though he hadn't actually seen it until after he wrote the draft."
        },
        {
          "title": "The Green Knight",
          "year": 2021,
          "note": "His last-great-thing: caught it in a theater, floored by the production design and cinematography."
        }
      ]
    }
  ],
