{
  "slug": "the-keanu-reeves-hall-of-fame-and-john-wick-chapter-4",
  "title": "The Keanu Reeves Hall of Fame and ‘John Wick: Chapter 4’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-03-24",
  "runtimeMin": 111,
  "format": "Sean and Amanda build a 10-film Keanu Reeves Hall of Fame ahead of 'John Wick: Chapter 4,' then Chad Stahelski returns to talk stunts, safety, and where the idea came from.",
  "segments": [
    {
      "kind": "halloffame",
      "heading": "The Keanu Reeves Hall of Fame",
      "note": "10 films, built live",
      "honoree": "Keanu Reeves",
      "films": [
        {
          "title": "Bill & Ted's Excellent Adventure",
          "year": 1989,
          "note": "Ted Logan. Sean rewatched it and was chuckling rather than laughing out loud, but it's a lock for both hosts, a hard group to beat."
        },
        {
          "title": "Point Break",
          "year": 1991,
          "note": "Kathryn Bigelow's surf-heist chase. Amanda meant to sample twenty minutes and watched the whole thing. Johnny Utah still turns up as a punchline decades later."
        },
        {
          "title": "My Own Private Idaho",
          "year": 1991,
          "note": "The Gus Van Sant/Shakespeare riff with River Phoenix. Sean calls it a no-brainer for signature '90s indie cinema; Amanda's only hesitation is that it's really a River Phoenix showcase."
        },
        {
          "title": "Speed",
          "year": 1994,
          "note": "The buzz cut and the steely action persona click into place here, opposite Sandra Bullock. 'The greenest of green,' an automatic in for both hosts."
        },
        {
          "title": "The Devil's Advocate",
          "year": 1997,
          "note": "A Florida lawyer at Satan's law firm, opposite Al Pacino. Amanda argues Keanu's the weakest part of his own movie; Sean keeps it in as a personal pick anyway."
        },
        {
          "title": "The Matrix",
          "year": 1999,
          "note": "Neo, the role Keanu was built for. Both hosts call it the most obvious green of the whole list and one of the most influential films of the last quarter century."
        },
        {
          "title": "Hardball",
          "year": 2001,
          "note": "Keanu as a gambling addict coaching a Cabrini-Green kids' baseball team to pay off his debt. Sean fights for it and braces for the angry tweets."
        },
        {
          "title": "Something's Gotta Give",
          "year": 2003,
          "note": "The Nancy Meyers rom-com opposite Diane Keaton and Jack Nicholson. Amanda's outright green on it, proof Keanu should've done more light comedy."
        },
        {
          "title": "John Wick",
          "year": 2014,
          "note": "Nearly went direct-to-video before Lionsgate picked it up weeks before release. Invented its own fight style and relaunched Keanu's career; no argument from either host."
        },
        {
          "title": "John Wick: Chapter 4",
          "year": 2023,
          "note": "The least dialogue Keanu's had in any Wick movie, which Sean argues is the achievement: acting as pure physical presence. Voted in live, over Chapter 2."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "'John Wick: Chapter 4'",
      "note": "Today's release",
      "films": [
        {
          "title": "John Wick: Chapter 4",
          "year": 2023,
          "note": "Chad Stahelski's nearly three-hour action movie, built around roughly six major set pieces across New York, Osaka, Berlin, and Paris: an Osaka Continental brawl, a waterfall nightclub fight against Scott Adkins, an Arc de Triomphe car chase, and a Sacre-Coeur staircase duel against Donnie Yen. Sean calls it the most fun action he's seen in years; both hosts agree the ending leaves the door open on whether Wick actually dies. Dedicated to Lance Reddick, who died the week of release."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Chad Stahelski on 'John Wick: Chapter 4'",
      "guest": "Chad Stahelski on",
      "films": [
        {
          "title": "John Wick: Chapter 4",
          "year": 2023,
          "note": "Stahelski traces the film back to a drunk conversation in a Tokyo hotel bar after Chapter 3's press tour: 'what if John Wick met a samurai?' He walks through casting Bill Skarsgard as the Marquis, his safety philosophy on set, and Lance Reddick's final day of shooting."
        },
        {
          "title": "Project Wolf Hunting",
          "year": 2022,
          "note": "The last great thing Chad says he's seen: a Korean action movie he calls 'batshit crazy... entertaining in the craziest of ways.'"
        }
      ]
    }
  ],
