      "films": [
        {
          "title": "Witness",
          "year": 1985,
          "note": "The Tracy Letts / Blank Check debate: Sean's 4-star COVID rewatch, but he pushes back on it as a Harrison Ford 'masterpiece,' calling it a very good adult crime drama, not Kurosawa."
        },
        {
          "title": "A Few Good Men",
          "year": 1992,
          "note": "'Way up high,' and, contra Letts, not equal to Pelican Brief."
        },
        {
          "title": "The Pelican Brief",
          "year": 1993,
          "note": "'A legal thriller with Denzel and Julia Roberts,' long and a little weird, but Sean likes it."
        },
        {
          "title": "Congo",
          "year": 1995,
          "note": "Sean's non-21st-century #16 most-rewatchable: 'one of the worst movies ever made that is very important to me.' Rewatched it this year."
        },
        {
          "title": "Two Weeks Notice",
          "year": 2002,
          "note": "Amanda's #16: Bullock and Grant save a community center; she'd edit out the Trump cameo."
        },
        {
          "title": "Deadpool",
          "year": 2016,
          "note": "Sean's least-reputable favorite: he loathes Reynolds' screen persona and thinks he's the perfect Deadpool anyway."
        },
        {
          "title": "Salt",
          "year": 2010,
          "note": "Amanda's #16 in progress: hasn't rewatched it enough times yet."
        },
        {
          "title": "Nacho Libre",
          "year": 2006,
          "note": "Jack's pick, rented from the library 'almost every single weekend.'"
        },
        {
          "title": "Tomorrow",
          "year": 1972,
          "note": "The Duvall movie Sean caught on Kanopy, prepping next month's Robert Duvall Hall of Fame."
        },
        {
          "title": "Sense and Sensibility",
          "year": 1995,
          "note": "The movie-swap Sean credits with the show becoming 'sentient': Amanda's costume drama for him."
        },
        {
          "title": "Spider-Man: Into the Spider-Verse",
          "year": 2018,
          "note": "Sean's half of that swap; each liked the other's allergy genre."
        },
        {
          "title": "The Strangers",
          "year": 2008,
          "note": "Sean's horror handoff that started converting Amanda."
        },
        {
          "title": "Midsommar",
          "year": 2019,
          "note": "Amanda straight-up thinks it's great, the Ari Aster breakthrough for her."
        },
        {
          "title": "Marie Antoinette",
          "year": 2006,
          "note": "Amanda got it onto '25 for 25' over Lost in Translation; Sean was gracious about it."
        },
        {
          "title": "Hotel Transylvania",
          "year": 2012,
          "note": "Griffin's running demand for a Hotel Transylvania Hall of Fame (the fourth film 'not canon,' no Sandler)."
        },
        {
          "title": "Avatar",
          "year": 2009,
          "note": "Sean's 2009 Lincoln Plaza 3D screening, 'the dawn of a new age.' Avatar Man's trade offer: he won't give it up for anything."
        },
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "The other 'huge creative accomplishment' Sean keeps."
        },
        {
          "title": "Avatar: Fire and Ash",
          "year": 2025,
          "note": "The third one both found redundant and overlong, the one Sean would swap for a different Cameron film."
        },
        {
          "title": "The Social Reckoning",
          "year": 2026,
          "note": "Jeremy Strong as Zuckerberg, Sorkin directing; Sean expects a predictable docudrama with a Supporting-Actor-bait performance inside it."
        },
        {
          "title": "The Apprentice",
          "year": 2024,
          "note": "Sean's comp for it: an unsuccessful film around a fascinating Strong turn as Roy Cohn."
        },
        {
          "title": "Molly's Game",
          "year": 2017,
          "note": "Strong's second Sorkin credit: 'it's his guy.'"
        },
        {
          "title": "The Trial of the Chicago 7",
          "year": 2020,
          "note": "The third Strong/Sorkin; Sean's seen it twice."
        },
        {
          "title": "Materialists",
          "year": 2025,
          "note": "Cited as maybe breaking up the theatrical rom-com drought, even if it wasn't sold as one."
        }
      ]
