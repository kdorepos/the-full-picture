  "slug": "the-great-avatar-debate-with-blank-checks-griffin-newman-and",
  "title": "The Great 'Avatar' Debate with Blank Check's Griffin Newman and David Sims",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessy"
  ],
  "published": "2022-10-04",
  "runtimeMin": 108,
  "format": "Sean sits down with Griffin Newman and David Sims of Blank Check to relitigate Avatar during its theatrical re-release. They detour through the Matt Damon casting what-if before previewing The Way of Water.",
  "segments": [
    {
      "kind": "review",
      "heading": "The Great Avatar Debate",
      "note": "with Griffin Newman & David Sims of Blank Check",
      "films": [
        {
          "title": "Avatar",
          "year": 2009,
          "note": "Revisited on the strength of a 13-year theatrical re-release. The trio dig into why it's the biggest movie ever made and also the one with no cultural footprint, whether Matt Damon as Jake Sully would have helped or hurt, Zoe Saldana's motion-capture performance, and how deliberately broad and cliche-built the story is."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Previewing The Way of Water",
      "note": "after the break",
      "films": [
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "Cameron shot two sequels back to back and has scripts for two more. The trio weigh whether a marketing campaign built entirely on nostalgia rather than plot can pull off the original's theatrical run."
        }
      ]
    }
  ],
