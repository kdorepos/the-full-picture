{
  "slug": "spider-man-into-the-spider-verse-vs-sense-and-sensibility-pl",
  "title": "'Spider-Man: Into the Spider-Verse' vs. 'Sense and Sensibility.' Plus: Avi Belkin on 'Mike Wallace Is Here'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2019-08-05",
  "runtimeMin": 115,
  "format": "Sean and Amanda each pick a movie the other has never seen and defend it: his is 'Into the Spider-Verse,' hers is 'Sense and Sensibility.' Then Avi Belkin on his Mike Wallace documentary.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Sean's pick: 'Into the Spider-Verse'",
      "note": "the animation swap",
      "films": [
        {
          "title": "Spider-Man: Into the Spider-Verse",
          "year": 2018,
          "note": "Sean's pick. Amanda came in dubious about animation and left won over by the voice cast and the willingness to let the multiverse mechanics stay a blur."
        },
        {
          "title": "Rango",
          "year": 2011,
          "note": "The last non-Pixar, non-Disney animated Best Picture winner before this one; Sean calls it a top-10-of-the-decade contender."
        },
        {
          "title": "Inside Out",
          "year": 2015,
          "note": "Amanda's counterexample for animation that worked on her, because it stayed grounded in something human."
        },
        {
          "title": "Toy Story 4",
          "year": 2019,
          "note": "Named as the year's leading Best Animated Feature contender, with nothing else on the calendar to challenge Spider-Verse's precedent."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Amanda's pick: 'Sense and Sensibility'",
      "note": "the costume drama swap",
      "films": [
        {
          "title": "Sense and Sensibility",
          "year": 1995,
          "note": "Amanda's pick, first seen at age 11. Ang Lee directs Emma Thompson's Oscar-winning script; Sean respects it but can't fully warm to the genre."
        },
        {
          "title": "Howards End",
          "year": 1992,
          "note": "Sean's structural comp for Sense and Sensibility (two sisters, a marriage plot, a fight over inheritance): 'Forster owes Austen some money.'"
        },
        {
          "title": "Clueless",
          "year": 1995,
          "note": "Part of the same 1995 Austen glut, an update of 'Emma.'"
        },
        {
          "title": "Braveheart",
          "year": 1995,
          "note": "The Best Picture winner over Sense and Sensibility that year; Sean notes the two share the historical-costume-epic DNA, minus the marriage plot."
        },
        {
          "title": "Apollo 13",
          "year": 1995,
          "note": "Also up for Best Picture that year; Amanda's other 1995 formative theatrical experience."
        },
        {
          "title": "Babe",
          "year": 1995,
          "note": "The other 1995 Best Picture nominee, and Amanda's rebuttal in the ongoing Lion King argument: 'Babe did a lot of that first.'"
        },
        {
          "title": "The Postman",
          "year": 1995,
          "note": "Il Postino, the fifth Best Picture nominee, flagged as an early Harvey Weinstein campaign play with no lasting legacy."
        },
        {
          "title": "Toy Story",
          "year": 1995,
          "note": "Not nominated for Best Picture at all, which Sean calls the real snub of that year."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Avi Belkin on",
      "films": [
        {
          "title": "Mike Wallace Is Here",
          "year": 2019,
          "note": "Belkin's all-archival portrait of the '60 Minutes' interviewer, built from CBS's unreleased footage and drawn from the idea that Wallace's own toughest questions were aimed at himself."
        },
        {
          "title": "The Insider",
          "year": 1999,
          "note": "Belkin says the Michael Mann film, most people's reference point for Wallace, unfairly reduces him to one weak moment."
        },
        {
          "title": "Avengers: Infinity War",
          "year": 2018,
          "note": "Belkin's answer to Sean's closing question about the last great thing he's seen: 'maybe the best superhero movie I've ever seen.'"
        }
      ]
    }
  ],
