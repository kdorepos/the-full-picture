    {
      "kind": "discussion",
      "heading": "What sold at Sundance",
      "note": "back in Los Angeles",
      "films": [
        {
          "title": "Palm Springs",
          "year": 2020,
          "note": "The festival's biggest sale: $17.5 million and 69 cents from Hulu and Neon, the odd cents added to make it the highest Sundance sale ever. They guess the price reflects Andy Samberg's built-in Brooklyn Nine-Nine audience on Hulu."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "Cited as Neon's last big splashy acquisition, which paid off with a $30 million box office."
        },
        {
          "title": "The Night House",
          "year": 2020,
          "note": "David Bruckner's horror thriller starring Rebecca Hall, bought by Sony for $12 million."
        },
        {
          "title": "The Ritual",
          "year": 2017,
          "note": "Bruckner's previous film, streaming on Netflix."
        },
        {
          "title": "Herself",
          "year": 2020,
          "note": "Phyllida Lloyd's small Irish drama, bought by Amazon, a departure from Amazon's usual Sundance buys."
        },
        {
          "title": "Boys State",
          "year": 2020,
          "note": "Jesse Moss and Amanda McBaine's documentary about teenage boys building a mock American political system in Texas, bought by A24 for Apple TV+. Sean calls it the best movie he saw at the festival."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The biggest disappointment",
      "films": [
        {
          "title": "The Last Thing He Wanted",
          "year": 2020,
          "note": "Dee Rees' Netflix adaptation of the Joan Didion novel, starring Anne Hathaway, Ben Affleck, and Willem Dafoe, about arms dealing and the Contra war in 1980s Nicaragua and El Salvador. Both call it a confusing, total failure despite a promising cast and subject."
        },
        {
          "title": "Play It As It Lays",
          "year": 1972,
          "note": "The earlier, 'famously weird' Didion adaptation, cited as evidence her prose resists adaptation."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "What's next for Anne Hathaway",
      "films": [
        {
          "title": "The Intern",
          "year": 2015
        },
        {
          "title": "Ocean's Eight",
          "year": 2018,
          "note": "She's the 'scene stealer,' per Amanda."
        },
        {
          "title": "Serenity",
          "year": 2019,
          "note": "Called 'a historical disaster,' but 'really funny and dumb.'"
        },
        {
          "title": "The Hustle",
          "year": 2019
        },
        {
          "title": "Dark Waters",
          "year": 2019,
          "note": "A throwaway part she elevates, per Amanda."
        },
        {
          "title": "Roald Dahl's The Witches",
          "year": 2020,
          "note": "Robert Zemeckis' Roald Dahl adaptation; she plays the Grand High Witch."
        },
        {
          "title": "Sesame Street",
          "year": 2022,
          "note": "An upcoming Sesame Street movie from Jonathan Krisel, said to also feature Bo Burnham, with a release date given as January 14, 2022."
        },
        {
          "title": "The Princess Diaries",
          "year": 2001,
          "note": "Cited as evidence she's always been best as a comedian."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Eliza Hittman on",
      "films": [
        {
          "title": "Never Rarely Sometimes Always",
          "year": 2020,
          "note": "Hittman's third feature, about two teenage cousins traveling from rural Pennsylvania to New York City for an abortion. She traces its origin to a 2013 news story about Savita Halappanavar, discusses casting first-time actor Sidney Flanigan (whom she'd met years earlier on the set of Buffalo Juggalos), and the film's sparse, non-naturalistic dialogue. Distributed by Focus Features, opening in March."
        },
        {
          "title": "Beach Rats",
          "year": 2017,
          "note": "Her previous film; she says it didn't open many doors beyond some TV work."
        },
        {
          "title": "Buffalo Juggalos",
          "year": 2013,
          "note": "A staged, documentary-style portrait she produced, on the set of which she first met Sidney Flanigan."
        },
        {
          "title": "Midnight Cowboy",
          "year": 1969,
          "note": "A reference point she revisited for the film's road-trip structure."
        },
        {
          "title": "Atlantics",
          "year": 2019,
          "note": "Mati Diop's film, the 'last great thing' she'd seen, praised for shifting from social realism into something 'haunting and supernatural.'"
        }
      ]
    }
