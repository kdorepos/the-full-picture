---
import Base from '../layouts/Base.astro';

const modules = import.meta.glob('../data/episodes/*.json', { eager: true });
const episodes = Object.values(modules)
  .map((m) => m.default)
  .sort((a, b) => (a.published < b.published ? 1 : -1));

const filmsIn = (s) =>
  (s.films?.length ?? 0) +
  (s.picks?.length ?? 0) +
  (s.teams?.reduce((n, t) => n + t.picks.filter((p) => p.year).length, 0) ?? 0) +
  (s.slates?.reduce((n, sl) => n + sl.picks.length, 0) ?? 0) +
  (s.categories?.reduce((n, c) => n + (c.nominees?.length ?? 0), 0) ?? 0);
const filmCount = (ep) => (ep.segments ?? []).reduce((n, s) => n + filmsIn(s), 0);
const fmt = (d) => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const KIND = {
  review: 'Review', ranking: 'Rankings', topfive: 'Top Five', halloffame: 'Hall of Fame',
  discussion: 'Discussion', interview: 'Interview', list: 'Roundtable', draft: 'Draft',
  auction: 'Auction', awards: 'Awards',
};
const kind = (ep) => [...new Set((ep.segments ?? []).map((s) => KIND[s.kind] ?? 'Segment'))].join(' · ') || 'Episode';
---
<Base title="The Full Picture — every film, every episode" description="A catalogue of every movie discussed on The Big Picture, episode by episode.">
  <section class="cover">
    <div class="wrap">
      <p class="eyebrow">The Big Picture · Film catalogue</p>
      <h1>Every film they name, on the record.</h1>
      <p class="lede">Every movie mentioned on each episode — championed, drafted, or just raised in passing — catalogued and linked.</p>
    </div>
  </section>

  <div class="wrap">
    <section class="sale-section" style="border-bottom:none">
      <p class="rubric">Episodes <span class="sub">newest first</span></p>
      <div class="catalogue">
        {episodes.map((ep) => (
          <a class="sale-card" href={`/ep/${ep.slug}`}>
            <div>
              <span class="eyebrow">{kind(ep)} · {fmt(ep.published)} · {ep.runtimeMin} min</span>
              <h2>{ep.title}</h2>
              <span class="credits">{ep.hosts.join(' · ')}</span>
            </div>
            <span class="count">{filmCount(ep)}<small>films</small></span>
          </a>
        ))}
      </div>
    </section>
  </div>
</Base>
