        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Hollywood's early Vietnam flops",
      "note": "Before The Green Berets, nobody could sell the war",
      "films": [
        {
          "title": "A Yank in Vietnam",
          "year": 1964,
          "note": "Marshall Thompson traveled to Saigon to direct and star, and was grazed by gunfire on set. The film is now completely lost."
        },
        {
          "title": "The Ugly American",
          "year": 1963,
          "note": "Marlon Brando in a thriller set in a fictitious Southeast Asian stand-in for Vietnam, much of it shot in Thailand."
        },
        {
          "title": "Operation CIA",
          "year": 1965,
          "note": "Burt Reynolds as an undercover agent in Saigon; barely a Vietnam movie, at one point he fights a boa constrictor."
        },
        {
          "title": "The Quiet American",
          "year": 1958,
          "note": "Mankiewicz's adaptation of the Graham Greene novel; the role Kieu Chinh couldn't take went to an Italian actor."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "John Wayne makes The Green Berets",
      "note": "For years, the only studio movie about Vietnam",
      "films": [
        {
          "title": "The Green Berets",
          "year": 1968,
          "note": "Wayne produced, starred in, and co-directed it, securing tanks, planes and troops from the Pentagon in exchange for script approval. Critics savaged it and Wayne himself later called it propaganda, but it was one of the biggest hits of 1968."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The documentaries that fought back",
      "note": "Anti-war films no distributor wanted",
      "films": [
        {
          "title": "In the Year of the Pig",
          "year": 1969,
          "note": "Emil de Antonio's doc drew bomb threats and had 'traitors' painted across a screen; an Oscar nomination still couldn't get it a wide release."
        },
        {
          "title": "Winter Soldier",
          "year": 1972,
          "note": "Vets testifying to atrocities over a weekend in Detroit, with a brief cameo from a young John Kerry. Played Cannes; no U.S. distributor picked it up."
        },
        {
          "title": "A Face of War",
          "year": 1968
        },
        {
          "title": "The Anderson Platoon",
          "year": 1967,
          "note": "Won the Academy Award for documentary."
        },
        {
          "title": "Hearts and Minds",
          "year": 1974,
          "note": "Peter Davis's million-dollar doc; Columbia got cold feet and Warner released it. Its 1975 Best Documentary win set off producer Bert Schneider's on-air message from the Viet Cong and Bob Hope's furious rebuttal."
        }
      ]
    }
