      "heading": "Netflix goes to IMAX",
      "note": "before the gavel",
      "films": [
        {
          "title": "Glass Onion: A Knives Out Mystery",
          "year": 2022,
          "note": "Chris's counterexample: Rian Johnson got a token theatrical run for a movie that would have grossed nine figures."
        },
        {
          "title": "Barbie",
          "year": 2023,
          "note": "The mega-success that, per Belloni's reporting, jet-streamed Netflix's willingness to put Greta Gerwig's Narnia on 1,000 IMAX screens."
        },
        {
          "title": "Hot Frosty",
          "year": 2024,
          "note": "Sean's exhibit for the counting-house logic: a cheap Netflix movie the same number of people will watch as a $300M one."
        }
      ]
    },
