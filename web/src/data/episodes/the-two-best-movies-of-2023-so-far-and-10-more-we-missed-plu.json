{
  "slug": "the-two-best-movies-of-2023-so-far-and-10-more-we-missed-plu",
  "title": "The Two Best Movies of 2023 So Far, and 10 More We Missed. Plus: Michelle Williams and Kelly Reichardt!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-04-11",
  "runtimeMin": 93,
  "format": "Sean and Amanda name the two best movies of the year, then race through everything from the first quarter of 2023 they haven't gotten to yet. Plus: Michelle Williams and Kelly Reichardt on their fourth film together.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Super Mario Bros. Movie",
      "note": "a $377 million opening weekend",
      "films": [
        {
          "title": "The Super Mario Bros. Movie",
          "year": 2023,
          "note": "Amanda took a spring-break matinee full of kids yelling 'Goomba' and came out thinking it's a fine ride for seven-year-olds, though she and Sean got into it over what a kids' movie owes a kid beyond distraction."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Showing Up",
      "note": "Michelle Williams and Kelly Reichardt's fourth collaboration",
      "films": [
        {
          "title": "Showing Up",
          "year": 2023,
          "note": "Sean's favorite movie of the year so far: Michelle Williams as a Portland ceramicist making work to show to the same small crowd over and over, funnier and lighter than the director's other films but with the same ache underneath."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "How to Blow Up a Pipeline",
      "films": [
        {
          "title": "How to Blow Up a Pipeline",
          "year": 2022,
          "note": "Adapted from Andreas Malm's nonfiction manifesto into a tightly wound heist thriller about young climate activists. Sean's other favorite of the year: Ocean's Eleven's structure played for tension instead of fun."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Ones We Missed",
      "note": "catching up on the first quarter of 2023",
      "films": [
        {
          "title": "Rye Lane",
          "year": 2023,
          "note": "A day-in-London rom-com with David Jonsson and Vivian Oparah. The best of this batch, per Sean."
        },
        {
          "title": "The Five Devils",
          "year": 2022,
          "note": "A French mother-daughter mystery about a girl with a preternatural sense of smell. Sean called it a scarier, more grounded Petite Maman."
        },
        {
          "title": "Boston Strangler",
          "year": 2023,
          "note": "Keira Knightley as the reporter who broke the case. A handsome, overqualified programmer that can't touch Zodiac."
        },
        {
          "title": "One Fine Morning",
          "year": 2022,
          "note": "Mia Hansen-Løve's latest, with Léa Seydoux. Sean liked it less than her Bergman Island."
        },
        {
          "title": "Pacifiction",
          "year": 2022,
          "note": "Albert Serra's 165-minute slow burn about a French bureaucrat in Tahiti, reportedly David Fincher's favorite film in years."
        },
        {
          "title": "Sharper",
          "year": 2023,
          "note": "A con-artist thriller with Julianne Moore and Sebastian Stan. Good premise, B-minus execution."
        },
        {
          "title": "Tori and Lokita",
          "year": 2022,
          "note": "The Dardenne brothers' latest, about two young African immigrants surviving in a Belgian city. Well made, familiar ground for them."
        },
        {
          "title": "Missing",
          "year": 2023,
          "note": "A screen-life thriller in the Searching mold, Storm Reid hunting for her missing mother."
        },
        {
          "title": "Murder Mystery 2",
          "year": 2023,
          "note": "Adam Sandler and Jennifer Aniston's sequel, half of it shot on what looks like green screen. A few laughs, not much else."
        },
        {
          "title": "A Good Person",
          "year": 2023,
          "note": "Zach Braff directs then-girlfriend Florence Pugh through an opioid-addiction story opposite Morgan Freeman."
        },
        {
          "title": "Shazam! Fury of the Gods",
          "year": 2023,
          "note": "Amanda called it flat-out awful: bad CGI, none of the first film's charm. It got pulled to VOD after three weeks in theaters."
        },
        {
          "title": "Tetris",
          "year": 2023,
          "note": "The 'true story' of the video game's Cold War rights battle, staged like Ocean's Eleven minus the fun. Amanda watched the whole thing anyway."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Coming Up: The Movie Swap",
      "note": "a preview of Friday's three-way swap",
      "films": [
        {
          "title": "Casablanca",
          "year": 1942,
          "note": "Amanda's pitch to Bobby, who's somehow never seen it."
        },
        {
          "title": "Spy Kids",
          "year": 2001,
          "note": "Bobby's pitch, reportedly his fiancée's dad's favorite movie."
        },
        {
          "title": "The In-Laws",
          "year": 1979,
          "note": "Sean's pitch, one of the funniest movies of the '70s."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Michelle Williams and Kelly Reichardt on",
      "films": [
        {
          "title": "Showing Up",
          "year": 2023,
          "note": "Their fourth collaboration after Wendy and Lucy, Meek's Cutoff, and Certain Women. Williams spent weeks with Portland ceramicist Cynthia Lahti to learn to work the clay on camera."
        },
        {
          "title": "The Passionate Friends",
          "year": 1949,
          "note": "Reichardt's last great thing: a David Lean melodrama with Claude Rains, caught on Criterion."
        },
        {
          "title": "Jerry Lee Lewis: Trouble in Mind",
          "year": 2022,
          "note": "Reichardt's other pick, Ethan Coen's then-unreleased documentary, seen 'in a secret way.'"
        }
      ]
    }
