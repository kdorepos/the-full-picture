{
  "slug": "netflix-s-the-irishman-is-alive-and-wellare-movie-theaters-d",
  "title": "Netflix's 'The Irishman' Is Alive and Well—Are Movie Theaters Dead? Plus: Antonio Banderas! | The Oscars Show",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2019-11-05",
  "runtimeMin": 104,
  "format": "Sean and Amanda on The Irishman and Netflix's standoff with theater owners, a weekend of expensive misfires, the Best Supporting Actor field, then Antonio Banderas on Pain and Glory.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Irishman and the theatrical-window standoff",
      "note": "the movie, and the fight over how you'll see it",
      "films": [
        {
          "title": "The Irishman",
          "year": 2019,
          "note": "Scorsese's three-and-a-half-hour Frank Sheeran epic. Both were braced for the runtime and both were floored; the last 90 minutes and the de-aging carry the conversation. Netflix opened it in eight theaters after exhibitors balked at a 45-day window."
        },
        {
          "title": "Goodfellas",
          "year": 1990,
          "note": "The reference point they keep pushing against: the prime-of-life, cocaine-energy gangster movie The Irishman deliberately is not."
        },
        {
          "title": "The Departed",
          "year": 2006,
          "note": "Fithian's false parallel: a Scorsese gangster picture that grossed ~$300M and won Best Picture. Sean's point is there was no Netflix in 2006 and no studio would fund The Irishman today."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "A noisy weekend of expensive misfires",
      "note": "the box office, mostly bad",
      "films": [
        {
          "title": "The King",
          "year": 2019,
          "note": "David Michôd's Henry V retelling with Timothée Chalamet and a scene-stealing Robert Pattinson. Hit Netflix this weekend; real horses, real catapults, didn't land."
        },
        {
          "title": "Terminator: Dark Fate",
          "year": 2019,
          "note": "$185M, Linda Hamilton and Schwarzenegger back, ~$29M domestic. Fine, not good enough: the kind of thing you'd rather rewatch T2 than see."
        },
        {
          "title": "Motherless Brooklyn",
          "year": 2019,
          "note": "Edward Norton's 22-year passion project, made $3.6M. Moves the Jonathan Lethem novel to the 1950s and turns it into a Robert Moses story; the second half, once it leaves the book, is the good part."
        },
        {
          "title": "Harriet",
          "year": 2019,
          "note": "Down-the-middle Tubman biopic with Cynthia Erivo, ~$12M. The counterexample: a movie that found its audience. Focus's second straight $10M+ opener after Downton Abbey."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "Held up with The Lighthouse as the future: specific, strange, sold to the people who want it. Already past $7M for Neon."
        },
        {
          "title": "The Lighthouse",
          "year": 2019,
          "note": "\"Fucking batshit,\" per Amanda: an A24 movie that is emphatically not for her, which is the point of the model."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock up, stock down",
      "note": "the streaming rundown",
      "films": [
        {
          "title": "The Elephant Queen",
          "year": 2019,
          "note": "Classical nature doc narrated by Chiwetel Ejiofor, the lone film in Apple TV+'s launch. May contend for Best Documentary; fits Apple's family-friendly posture."
        },
        {
          "title": "The Banker",
          "year": 2020,
          "note": "Anthony Mackie and Samuel L. Jackson; opens December 6 before Apple TV+. A test of whether Apple chases prestige the way Netflix does."
        },
        {
          "title": "Lady and the Tramp",
          "year": 2019,
          "note": "Disney+'s original-movie play, the opposite of the awards strategy, launching alongside The Mandalorian."
        }
      ]
    },
