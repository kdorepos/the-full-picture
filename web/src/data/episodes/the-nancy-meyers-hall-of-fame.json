{
  "slug": "the-nancy-meyers-hall-of-fame",
  "title": "The Nancy Meyers Hall of Fame",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-10-09",
  "runtimeMin": 114,
  "format": "For Private Benjamin's 40th anniversary, Sean and Amanda build a chronological Hall of Fame out of Nancy Meyers's filmography: all ten inductees, plus the four movies that didn't make the cut.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Where Meyers comes from",
      "note": "before the countdown starts",
      "films": [
        {
          "title": "An Unmarried Woman",
          "year": 1978,
          "note": "Paul Mazursky's Jill Clayburgh film, about a wife whose husband leaves her out of nowhere. Meyers named Mazursky as an influence in a 2015 interview, and Sean calls this the proto Nancy Meyers movie."
        },
        {
          "title": "Bob & Carol & Ted & Alice",
          "year": 1969,
          "note": "The other Mazursky title that comes up when tracing Meyers back to '70s dramedy."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Nancy Meyers Hall of Fame",
      "note": "chronological, and all ten make it in",
      "honoree": "Nancy Meyers",
      "films": [
        {
          "title": "Private Benjamin",
          "year": 1980,
          "note": "Her only Oscar nomination, for a movie neither host can fully defend. Goldie Hawn's rich widow joins the Army; the tone swings from pratfall comedy to melodrama to spy movie and the ending explains nothing. In on the strength of the nomination alone."
        },
        {
          "title": "Irreconcilable Differences",
          "year": 1984,
          "note": "A barely disguised, fairly savage take on the Peter Bogdanovich and Polly Platt split, framed around tiny Drew Barrymore suing to divorce her parents. Shot by William Fraker. Hard to find (Amanda had to buy a copy), and the pick both hosts enjoyed most all week."
        },
        {
          "title": "Baby Boom",
          "year": 1987,
          "note": "Diane Keaton's ad executive inherits a baby and trades Manhattan for a Vermont farmhouse and a baby-food company. Directed by then-husband Charles Shyer; called the source code for every Meyers movie that follows."
        },
        {
          "title": "Father of the Bride",
          "year": 1991,
          "note": "A remake of Vincente Minnelli's 1950 original, narrated by Steve Martin. No real conflict beyond a wedding, 'the fun ten minutes stretched out to the whole movie,' and it still works."
        },
        {
          "title": "The Parent Trap",
          "year": 1998,
          "note": "Meyers's directing debut, Lindsay Lohan playing both twins. Amanda's formative Meyers text at thirteen; Sean, a few years too old for it at release, didn't come around until much later."
        },
        {
          "title": "What Women Want",
          "year": 2000,
          "note": "Mel Gibson's ad man gets electrocuted and starts hearing women's thoughts. A rewrite Meyers doesn't have credit on. Neither host buys his arc, but it made $182 million."
        },
        {
          "title": "Something's Gotta Give",
          "year": 2003,
          "note": "Jack Nicholson, Diane Keaton, and a Paris ending. Called the masterpiece and one of the great films of the 21st century on the show."
        },
        {
          "title": "The Holiday",
          "year": 2006,
          "note": "Kate Winslet and Cameron Diaz swap houses over Christmas while Jack Black sings movie scores in a Blockbuster. Neither host loves it, but they defer to its cult following and vote it in unanimously."
        },
        {
          "title": "It's Complicated",
          "year": 2009,
          "note": "Meryl Streep, Alec Baldwin, and Steve Martin in an $85 million domestic comedy that made $225 million. Amanda's favorite of the ten; shot by John Toll, scored by Hans Zimmer."
        },
        {
          "title": "The Intern",
          "year": 2015,
          "note": "Robert De Niro as a seventy-year-old intern at Anne Hathaway's e-commerce startup. Meyers answering her own Baby Boom thirty years later, without the happy ending."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Cut from the Hall of Fame",
      "note": "considered, then left out",
      "films": [
        {
          "title": "Once Upon a Crime",
          "year": 1992,
          "note": "Co-written with Charles Shyer and Steve Kluger, directed by Eugene Levy. Neither host rewatched it; Amanda calls it a not-good Clue."
        },
        {
          "title": "I Love Trouble",
          "year": 1994,
          "note": "Nick Nolte and Julia Roberts as rival newspaper columnists with no chemistry. 'I kind of want to turn this off,' Sean says, the one clean no of the episode."
        },
        {
          "title": "Father of the Bride Part II",
          "year": 1995,
          "note": "The pregnancy sequel. Neither host rewatched it; both call it nice but not essential."
        },
        {
          "title": "Father of the Bride Part 3(ish)",
          "year": 2020,
          "note": "A Zoom reunion short for World Central Kitchen. Both hosts say it's bad on its own merits, charity aside, and leave it out."
        }
      ]
    }
  ],
