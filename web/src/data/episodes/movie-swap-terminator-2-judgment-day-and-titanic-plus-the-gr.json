{
  "slug": "movie-swap-terminator-2-judgment-day-and-titanic-plus-the-gr",
  "title": "Movie Swap: 'Terminator 2: Judgment Day' and 'Titanic.' Plus: 'The Green Knight'!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2021-07-30",
  "runtimeMin": 115,
  "format": "Another movie swap: Amanda watches Terminator 2 for the first time, Sean revisits Titanic 24 years on, and the two of them turn it into a career audit of James Cameron. Then Sean talks to David Lowery about The Green Knight.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Swap: 'Terminator 2: Judgment Day'",
      "note": "Amanda's first watch",
      "films": [
        {
          "title": "Terminator 2: Judgment Day",
          "year": 1991,
          "note": "Amanda's assignment, seen for the first time the night before. She hated the opening 20 minutes of sci-fi voiceover but came around once it settled into a buddy-comedy road movie; two thumbs up, minus the one-too-many endings. Sean, who was nine when it came out, calls it his Terminator and reads it as a Western: white hat, black hat, a child to protect. They agree the LA River chase still looks unimprovable, and both flag the Sarah Connor voiceover about the robot making the best father as the film's strangest 30 seconds."
        },
        {
          "title": "The Terminator",
          "year": 1984,
          "note": "The 1984 original, which Amanda skipped in favor of reading the Wikipedia page. Sean rewatched it early in the 2020 lockdown and admits it never imprinted on him the way T2 did, too stripped-down and independent."
        },
        {
          "title": "Aliens",
          "year": 1986,
          "note": "Amanda's other Cameron point of reference; the dark opening of T2 reminded her of it. Its Ripley sits alongside Sarah Connor as the two Cameron heroines the hosts keep coming back to."
        },
        {
          "title": "The Abyss",
          "year": 1989,
          "note": "Cited as an early version of the recurring Cameron theme: found technology that could save us or kill us."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Swap: 'Titanic'",
      "note": "Sean's first watch in 24 years",
      "films": [
        {
          "title": "Titanic",
          "year": 1997,
          "note": "Sean's assignment, unseen since its theatrical run 24 years earlier. He was a 16-year-old refusing it on principle while everyone he knew saw it eight or nine times. Both find the Jack-and-Rose romance thin but concede it's the reason the movie works, and both are floored by the scale of the sinking. Amanda, 13 when it came out, treats it as the last true theatrical phenomenon: $2.2 billion, months in theaters, then a third life on TNT and the internet."
        },
        {
          "title": "True Lies",
          "year": 1994,
          "note": "The Cameron film that landed between T2 and Titanic; the hosts note it and Titanic are his non-sci-fi outliers, both built partly around a broken marriage."
        },
        {
          "title": "Avatar",
          "year": 2009,
          "note": "The recurring shadow over the conversation: a movie more successful than Titanic that, they argue, left almost no cultural footprint. Sean was gobsmacked seeing it in IMAX; both wonder whether late-period Cameron lost himself in his own imagined world."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "David Lowery on",
      "films": [
        {
          "title": "The Green Knight",
          "year": 2021,
          "note": "Lowery's Arthurian fable, adapted from the Middle English poem. He describes chasing an epic scale out of a small budget (War and Peace and Lord of the Rings as impossible references), with the Green Knight and Arthur's round table built practically. He cast Dev Patel for a boyishness that lets Gawain grow from manchild to adult, and edited the film himself over a year and a half; the pandemic delay let him keep cutting."
        },
        {
          "title": "A Ghost Story",
          "year": 2017,
          "note": "His template for a film that had to be discovered in the edit, which is why he cut it, and The Green Knight, himself."
        },
        {
          "title": "Pete's Dragon",
          "year": 2016,
          "note": "His Disney film, many times The Green Knight's budget yet a far smaller-feeling production."
        },
        {
          "title": "The Old Man & the Gun",
          "year": 2018,
          "note": "The movie he says represents his personality most (affable, lighthearted) even as his films drift toward a serious edge."
        },
        {
          "title": "Ain't Them Bodies Saints",
          "year": 2013,
          "note": "His first feature, an early attempt to take familiar images and reshape old archetypes."
        },
        {
          "title": "Peter Pan & Wendy",
          "year": 2023,
          "note": "In production for Disney during the interview; ironically, he says, his most adult and complex film to date."
        }
      ]
    }
  ],
