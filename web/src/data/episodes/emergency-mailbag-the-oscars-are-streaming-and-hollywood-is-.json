{
  "slug": "emergency-mailbag-the-oscars-are-streaming-and-hollywood-is-",
  "title": "Emergency Mailbag: The Oscars Are Streaming and Hollywood Is Fighting Over Trolls",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-04-29",
  "runtimeMin": 74,
  "format": "An emergency mailbag: the AMC-Universal standoff over Trolls World Tour's VOD numbers, then the Academy's pandemic rule change that lets streaming movies qualify for the Oscars.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The AMC–Universal Fight",
      "note": "windowing goes public",
      "films": [
        {
          "title": "Trolls World Tour",
          "year": 2020,
          "note": "The $19.99 rental that started it: 5 million-plus rentals, $100M-plus in a month. Universal's Jeff Shell spun the numbers to the Wall Street Journal; AMC's Adam Aron wrote back that AMC would stop licensing Universal films in its ~1,000 theaters."
        },
        {
          "title": "Trolls",
          "year": 2016,
          "note": "The 2016 original made $300M-plus worldwide; the sequel's numbers were domestic-only, so both sides quote the figures that flatter them."
        },
        {
          "title": "The King of Staten Island",
          "year": 2020,
          "note": "Judd Apatow's Pete Davidson movie, another Universal release, still headed to VOD in June. A harder sell than Trolls: no franchise, barely any marketing, and Apatow joked it wouldn't turn a profit."
        },
        {
          "title": "The Hunt",
          "year": 2020,
          "note": "One of the first three Universal titles pushed to VOD at $19.99 after a short theatrical run."
        },
        {
          "title": "The Invisible Man",
          "year": 2020,
          "note": "Same $19.99 early-VOD batch; Jason Blum defended the move on Bill Simmons's podcast."
        },
        {
          "title": "Emma.",
          "year": 2020,
          "note": "Also cut short in theaters and sent to VOD."
        },
        {
          "title": "Scoob!",
          "year": 2020,
          "note": "Warner Bros. moved it to May 15, the kind of easy-to-sell kids' title that suits VOD."
        },
        {
          "title": "Artemis Fowl",
          "year": 2020,
          "note": "A misbegotten Disney project that found a home straight on Disney+."
        },
        {
          "title": "Long Shot",
          "year": 2019,
          "note": "Amanda's example of the adult comedy that underperforms theatrically because people would rather wait to watch it at home."
        },
        {
          "title": "Frozen II",
          "year": 2019,
          "note": "The kind of kids' movie parents used to buy on iTunes to rewatch. Now it just goes straight to Disney+."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Oscar-Rules Mailbag",
      "note": "with producer Bobby Wagner",
      "films": [
        {
          "title": "Mank",
          "year": 2020,
          "note": "The recurring test case: Fincher's black-and-white Mankiewicz drama, written by his late father, inspired partly by Pauline Kael's 'Raising Kane.' Neither host expects Netflix to move it off its late-fall date. Release timing still wins Oscars."
        },
        {
          "title": "The French Dispatch",
          "year": 2021,
          "note": "Wes Anderson's Cannes title, owned by Disney via Fox Searchlight. Disney hasn't shown any appetite for the VOD pivot, so don't expect it early."
        },
        {
          "title": "The Green Knight",
          "year": 2021,
          "note": "A24 stayed silent, keeping a May 29 date while pushing everything else, making it the wildcard of the bunch."
        },
        {
          "title": "Tenet",
          "year": 2020,
          "note": "Christopher Nolan's Warner Bros. movie was meant to reopen theaters July 17; Nolan was reportedly unhappy about AT&T's 'rethinking our theatrical model' talk."
        },
        {
          "title": "Never Rarely Sometimes Always",
          "year": 2020,
          "note": "Both hosts' pick for the best movie released on VOD during quarantine, and their answer to what they'd want to win Best Picture."
        },
        {
          "title": "West Side Story",
          "year": 2021,
          "note": "Spielberg's musical was a presumed contender, but nobody knows if it's even out of post-production."
        },
        {
          "title": "The Irishman",
          "year": 2019,
          "note": "Cited as a campaign that peaked too soon, a caution about how streaming movies burn attention."
        },
        {
          "title": "Marriage Story",
          "year": 2019,
          "note": "Positioned as a theatrical release, part of why its campaign landed with voters."
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "Another Netflix title sold on its theatrical bona fides."
        },
        {
          "title": "The Ballad of Buster Scruggs",
          "year": 2018,
          "note": "Sean's theory: its stray nominations came from voters happily sampling segments on Netflix, or just loving the Coens."
        },
        {
          "title": "Hillbilly Elegy",
          "year": 2020,
          "note": "Ron Howard's Netflix adaptation: 'makes my brain bleed,' but pure Oscar bait."
        },
        {
          "title": "Portrait of a Lady on Fire",
          "year": 2019,
          "note": "The show's cause célèbre: France submitted Les Misérables instead, so it missed the international race. Neon's tiny December LA run made it last year's film. Sean's message to critics of the show's 'Portrait won Best Picture' bit: 'Fuck off.'"
        }
      ]
    }
  ],
