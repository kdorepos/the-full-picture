{
  "slug": "the-20-most-anticipated-movies-of-2020-the-big-picture",
  "title": "The 20 Most Anticipated Movies of 2020",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-01-17",
  "runtimeMin": 70,
  "format": "Sean and Amanda bury Dolittle, then each run down the ten 2020 releases they're actually excited for, plus five wildcards apiece.",
  "segments": [
    {
      "kind": "review",
      "heading": "Dolittle",
      "note": "this week's release",
      "films": [
        {
          "title": "Dolittle",
          "year": 2020,
          "note": "Robert Downey Jr.'s voice is dubbed for the entire film; started life as 'The Voyage of Dr. Dolittle' under Stephen Gaghan before Chris McKay came in for extensive reshoots."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Most Anticipated Movies of 2020",
      "note": "in release-date order, not ranked",
      "films": [
        {
          "title": "No Time to Die",
          "year": 2021,
          "note": "Cary Fukunaga directs Daniel Craig's last Bond; Billie Eilish sings the theme."
        },
        {
          "title": "The Invisible Man",
          "year": 2020,
          "note": "Leigh Whannell's Blumhouse redo, with Elisabeth Moss as a woman stalked by her dead, abusive ex."
        },
        {
          "title": "Wonder Woman 1984",
          "year": 2020,
          "note": "Gal Gadot and Chris Pine return; Kristen Wiig plays Cheetah."
        },
        {
          "title": "Tenet",
          "year": 2020,
          "note": "Christopher Nolan's time-inversion thriller, with John David Washington and Robert Pattinson as 'time spies.'"
        },
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "Joseph Kosinski directs the legacy sequel, with Miles Teller and Glen Powell."
        },
        {
          "title": "Last Night in Soho",
          "year": 2021,
          "note": "Edgar Wright's Baby Driver follow-up, inspired by Don't Look Now and Repulsion; Thomasin McKenzie, Anya Taylor-Joy, Diana Rigg, Terence Stamp."
        },
        {
          "title": "The Trial of the Chicago 7",
          "year": 2020,
          "note": "Aaron Sorkin writes and directs; Jeremy Strong plays Jerry Rubin."
        },
        {
          "title": "Eternals",
          "year": 2021,
          "note": "Chloé Zhao's Marvel prequel, framed as mythology rather than sci-fi; Angelina Jolie and Richard Madden lead a huge cast."
        },
        {
          "title": "Nomadland",
          "year": 2020,
          "note": "Zhao's other 2020 film, a Fox Searchlight drama starring Frances McDormand."
        },
        {
          "title": "King Richard",
          "year": 2021,
          "note": "Will Smith plays Richard Williams, father of Serena and Venus, from Reinaldo Marcus Green."
        },
        {
          "title": "Dune",
          "year": 2021,
          "note": "Denis Villeneuve adapts Frank Herbert; Timothée Chalamet, Rebecca Ferguson, Oscar Isaac, Josh Brolin, Zendaya."
        },
        {
          "title": "Deep Water",
          "year": 2022,
          "note": "Adrian Lyne's first film since Unfaithful, adapting Patricia Highsmith; Ben Affleck and Ana de Armas."
        },
        {
          "title": "Mank",
          "year": 2020,
          "note": "David Fincher's Herman Mankiewicz-vs.-Orson Welles drama, written by his late father Jack Fincher; Gary Oldman and Amanda Seyfried."
        },
        {
          "title": "On the Rocks",
          "year": 2020,
          "note": "Sofia Coppola pairs Bill Murray and Rashida Jones as father and daughter."
        },
        {
          "title": "I'm Thinking of Ending Things",
          "year": 2020,
          "note": "Charlie Kaufman adapts Iain Reid's novel, his first film since Anomalisa; Jesse Plemons and Jessie Buckley."
        },
        {
          "title": "The Souvenir Part II",
          "year": 2021,
          "note": "Joanna Hogg's sequel, with Honor Swinton Byrne; Martin Scorsese exec produces again."
        },
        {
          "title": "After Yang",
          "year": 2021,
          "note": "Kogonada's follow-up to Columbus, about a family whose robotic child stops working; Colin Farrell, Haley Lu Richardson."
        },
        {
          "title": "Annette",
          "year": 2021,
          "note": "Leos Carax's first film since Holy Motors, a musical with songs by Sparks; Adam Driver and Marion Cotillard."
        },
        {
          "title": "Blonde",
          "year": 2022,
          "note": "Andrew Dominik adapts Joyce Carol Oates's fictionalized Marilyn Monroe novel; Ana de Armas stars."
        },
        {
          "title": "The French Dispatch",
          "year": 2021,
          "note": "Wes Anderson's love letter to journalists, first live-action feature since The Grand Budapest Hotel; sprawling ensemble cast."
        },
        {
          "title": "Memoria",
          "year": 2021,
          "note": "Apichatpong Weerasethakul's Neon-backed film, with Tilda Swinton; Neon also bought Parasite."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Wildcards",
      "note": "five picks apiece",
      "films": [
        {
          "title": "Portrait of a Lady on Fire",
          "year": 2019,
          "note": "Céline Sciamma's love story, already in limited release, going wide on Valentine's Day."
        },
        {
          "title": "The Last Thing He Wanted",
          "year": 2020,
          "note": "Dee Rees adapts Joan Didion; Ben Affleck."
        },
        {
          "title": "The Last Duel",
          "year": 2021,
          "note": "Ridley Scott's medieval duel drama; Matt Damon, Adam Driver, Ben Affleck, Jodie Comer."
        },
        {
          "title": "Let Them All Talk",
          "year": 2020,
          "note": "Steven Soderbergh directs Meryl Streep and Candice Bergen, shot partly on a real cruise ship."
        },
        {
          "title": "Macbeth",
          "year": 2021,
          "note": "Joel Coen directs Denzel Washington and Frances McDormand."
        },
        {
          "title": "Cherry",
          "year": 2021,
          "note": "The Russo brothers adapt Nico Walker's novel; Tom Holland as an army medic turned bank robber."
        },
        {
          "title": "Da 5 Bloods",
          "year": 2020,
          "note": "Spike Lee sends four Vietnam vets back for a fallen comrade's remains and buried treasure."
        },
        {
          "title": "Bergman Island",
          "year": 2021,
          "note": "Mia Hansen-Løve's latest."
        },
        {
          "title": "Bad Education",
          "year": 2019,
          "note": "Cory Finley's Toronto standout, with Hugh Jackman, about a school embezzlement scandal on Long Island."
        },
        {
          "title": "The Many Saints of Newark",
          "year": 2021,
          "note": "David Chase's Sopranos prequel, directed by Alan Taylor; Michael Gandolfini plays young Tony."
        }
      ]
    }
  ],
