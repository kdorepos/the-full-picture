{
  "slug": "1917-and-the-roger-deakins-hall-of-fame-spoilers-the-big-pic",
  "title": "'1917' and the Roger Deakins Hall of Fame (SPOILERS) | The Big Picture",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2020-01-15",
  "runtimeMin": 80,
  "format": "Sean, Amanda, and Chris spoil Sam Mendes's one-take war movie in full, then build a 10-film Hall of Fame for its cinematographer, Roger Deakins.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "'1917' (spoilers)",
      "note": "Sean Fennessey, Amanda Dobbins, Chris Ryan — full spoilers",
      "films": [
        {
          "title": "1917",
          "year": 2019,
          "note": "Sam Mendes's one-take WWI movie, dedicated to his grandfather Alfred Mendes. Great filmmaking, thinner as a story: the hosts agree it 'foregrounds its presentation' and doesn't survive a rewatch once the cuts and coincidences are visible. Blake (Dean-Charles Chapman) and Schofield (George MacKay) carry a message across no man's land, but the parade of British character actors along the way (Andrew Scott, Mark Strong, Colin Firth, Benedict Cumberbatch, Richard Madden) pulls you out of the movie about as often as it pulls you in. Amanda liked it most, on a single viewing. The climactic running shot and the blackout at the halfway mark are the flashpoints. 10 Oscar nominations."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Roger Deakins Hall of Fame",
      "note": "the final 10, cut down from a 23-film long list",
      "honoree": "Roger Deakins",
      "films": [
        {
          "title": "Sid and Nancy",
          "year": 1986,
          "note": "Alex Cox's punk biopic, the lock among his English features, kept to represent the early career. The 360-degree circling shot he'd reuse in '1917' is already here, 35 years earlier."
        },
        {
          "title": "Barton Fink",
          "year": 1991,
          "note": "The first Coen collaboration. Cited for the shot of Barton on the beach with the woman on the towel as the waves come in."
        },
        {
          "title": "The Shawshank Redemption",
          "year": 1994,
          "note": "Non-negotiable. Stayed on when nearly everything else got cut."
        },
        {
          "title": "The Man Who Wasn't There",
          "year": 2001,
          "note": "The least-discussed Coen movie and, per Chris, arguably the most beautifully shot. Kept over Fargo for its black-and-white photography."
        },
        {
          "title": "The Assassination of Jesse James by the Coward Robert Ford",
          "year": 2007,
          "note": "Called a masterpiece outright, with the most-praised photography of any film on the list. Andrew Dominik's improvisatory 'move the sun six inches' set was the opposite of the storyboarded Coen process."
        },
        {
          "title": "No Country for Old Men",
          "year": 2007,
          "note": "Total no-brainer. One of three Deakins films released in 2007."
        },
        {
          "title": "A Serious Man",
          "year": 2009,
          "note": "One of Sean's favorite movies; survived several rounds of proposed cuts."
        },
        {
          "title": "Skyfall",
          "year": 2012,
          "note": "The one Sean threatened to walk out over. Has to be on."
        },
        {
          "title": "Sicario",
          "year": 2015,
          "note": "Chris's pick over Prisoners and Blade Runner 2049, a call the others called shameful. Survived to the end after Sean fought to keep it."
        },
        {
          "title": "1917",
          "year": 2019,
          "note": "Almost certainly Deakins's second Oscar, after Blade Runner 2049. Kept as the reason for the episode; briefly 'punched in' for a cut before being reinstated."
        }
      ]
    }
  ],
