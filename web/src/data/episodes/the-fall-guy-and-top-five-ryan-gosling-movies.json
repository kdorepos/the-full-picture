{
  "slug": "the-fall-guy-and-top-five-ryan-gosling-movies",
  "title": "‘The Fall Guy’ and Top Five Ryan Gosling Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2024-05-03",
  "runtimeMin": 80,
  "format": "Sean and Amanda review David Leitch's stuntman action-comedy, then each rank their five favorite Ryan Gosling movies.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘The Fall Guy’",
      "films": [
        {
          "title": "The Fall Guy",
          "year": 2024,
          "note": "A loose summer blockbuster adapted from the Lee Majors TV series, directed by former stuntman David Leitch. Gosling plays a stuntman who follows the love of his life (Emily Blunt, directing her first feature) to an Australian shoot that turns into a crime thriller. Both hosts had a good time, Amanda a bit more than Sean, who flagged fake-looking sparks and CG in the daylight stunts. They liked the Gosling-Blunt chemistry, Aaron Taylor-Johnson doing a McConaughey riff, an All Too Well needle drop, and a DJ Khaled 'All I Do Is Win' cue, and put it in a lineage with Hooper, The Stunt Man, and Get Shorty."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top Five Ryan Gosling Movies",
      "note": "No. 1 first",
      "subject": "Ryan Gosling",
      "ranked": true,
      "films": [
        {
          "title": "Drive",
          "year": 2011,
          "note": "No. 1: the apex of Gosling saying nothing and staying still; 'The Notebook for boys,' a 2011 time capsule down to Christina Hendricks and an early Oscar Isaac."
        },
        {
          "title": "Barbie",
          "year": 2023,
          "note": "No. 2: he called it a perfect film. Any movie where Gosling does a dream ballet makes his top five."
        },
        {
          "title": "The Big Short",
          "year": 2015,
          "note": "No. 3: four scenes, all suit, all venom, Gosling playing character actor and walking off with the ensemble."
        },
        {
          "title": "La La Land",
          "year": 2016,
          "note": "No. 4: his least favorite Chazelle but still a top-five Gosling, a Singin' in the Rain homage carried by reluctant-indie charm and that ending."
        },
        {
          "title": "The Place Beyond the Pines",
          "year": 2012,
          "note": "No. 5: the wheelman half is the one he loves; a Cianfrance reunion after Blue Valentine with Mendelsohn, Cooper, and Eva Mendes."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda Dobbins's Top Five Ryan Gosling Movies",
      "note": "No. 1 first",
      "subject": "Ryan Gosling",
      "ranked": true,
      "films": [
        {
          "title": "The Notebook",
          "year": 2004,
          "note": "No. 1: his most leading-man movie ever, all smolder and little talk; she wishes he and Rachel McAdams had made eight more."
        },
        {
          "title": "The Nice Guys",
          "year": 2016,
          "note": "No. 2: Shane Black buddy-comedy in the tone he's doing in The Fall Guy; real chemistry with Russell Crowe, plus Margaret Qualley and Kim Basinger."
        },
        {
          "title": "Half Nelson",
          "year": 2006,
          "note": "No. 3: revisited it the day before; the Boden-Fleck Sundance drama that got him his first Oscar nomination, opposite Shareeka Epps."
        },
        {
          "title": "First Man",
          "year": 2018,
          "note": "No. 4: the Chazelle Neil Armstrong movie as the end of his not-talking era, a kind of movie stardom that no longer exists."
        },
        {
          "title": "Drive",
          "year": 2011,
          "note": "No. 5: the era of hey-girl stillness and internet's-boyfriend crime dramas."
        }
      ]
    }
  ],
