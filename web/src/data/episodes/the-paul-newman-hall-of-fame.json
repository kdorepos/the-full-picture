{
  "slug": "the-paul-newman-hall-of-fame",
  "title": "The Paul Newman Hall of Fame",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-05-09",
  "runtimeMin": 134,
  "format": "For what would have been Newman's 100th birthday, Sean Fennessey and Amanda Dobbins walk his entire 57-film career, film by film, to settle on the 10 that belong in the Hall of Fame, plus four blues: their picks worth seeking out.",
  "segments": [
    {
      "kind": "halloffame",
      "heading": "The Paul Newman Hall of Fame",
      "note": "the 10 inductees",
      "honoree": "Paul Newman",
      "films": [
        {
          "title": "Cat on a Hot Tin Roof",
          "year": 1958,
          "note": "First Oscar nomination and his first Tennessee Williams on film, the repressed heartthrob as Brick. The tenth and clinching induction."
        },
        {
          "title": "The Hustler",
          "year": 1961,
          "note": "Fast Eddie Felson, beautiful and pathetic at once, in Robert Rossen's hyper-real black and white. The first green of the day."
        },
        {
          "title": "Hud",
          "year": 1963,
          "note": "The amoral antihero audiences rooted for anyway. Paul Schrader calls it maybe the most important performance in film history."
        },
        {
          "title": "Cool Hand Luke",
          "year": 1967,
          "note": "The 50 eggs, the Lalo Schifrin score, 'what we've got here is a failure to communicate.' For Amanda, the first thing you picture when you hear his name."
        },
        {
          "title": "Butch Cassidy and the Sundance Kid",
          "year": 1969,
          "note": "First film with George Roy Hill and his first real old-guy part, opposite Redford. Still slaps."
        },
        {
          "title": "The Sting",
          "year": 1973,
          "note": "Henry Gondorf, wiping his tie across his face at the poker table. The only Newman film to win Best Picture."
        },
        {
          "title": "Slap Shot",
          "year": 1977,
          "note": "Reggie Dunlop and the Hanson brothers, his ideas smuggled into a foul-mouthed hockey comedy written by Nancy Dowd."
        },
        {
          "title": "The Verdict",
          "year": 1982,
          "note": "Frank Galvin, Sean's pick for the performance of his career. Mamet script, Lumet directing; lost the Oscar to Ben Kingsley."
        },
        {
          "title": "The Color of Money",
          "year": 1986,
          "note": "Fast Eddie again, opposite Tom Cruise. Won the Oscar at long last and didn't show up to collect it."
        },
        {
          "title": "Nobody's Fool",
          "year": 1994,
          "note": "Sully Sullivan, the signature old-guy role and the one that got a generation to Newman. His first Richard Russo adaptation."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The blues",
      "note": "beyond the Hall: two picks each, worth seeking out",
      "films": [
        {
          "title": "Paris Blues",
          "year": 1961,
          "note": "Sean's blue. Newman and Sidney Poitier faking jazz in black-and-white Paris, Duke Ellington scoring. 'This is cinema to me.'"
        },
        {
          "title": "Harper",
          "year": 1966,
          "note": "Amanda's blue. William Goldman's private-eye script from a Ross Macdonald novel, and the ice-cube-bowl morning ritual Newman actually did."
        },
        {
          "title": "Sometimes a Great Notion",
          "year": 1971,
          "note": "Sean's second blue, which he also directed. Ken Kesey's Oregon logging family, with a death scene among the most upsetting ever filmed."
        },
        {
          "title": "The Drowning Pool",
          "year": 1975,
          "note": "Amanda's blue, and she won't trade it. The Harper sequel, shot by Gordon Willis, with a very young Melanie Griffith."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The rest of the filmography",
      "note": "everything else they walked through, in order",
      "films": [
        {
          "title": "The Silver Chalice",
          "year": 1954,
          "note": "The Roman-epic debut and a bomb; he spent years apologizing for it."
        },
        {
          "title": "Somebody Up There Likes Me",
          "year": 1956,
          "note": "The star-making Rocky Graziano biopic, though nobody buys his boxing."
        },
        {
          "title": "The Rack",
          "year": 1956,
          "note": "A Rod Serling courtroom drama; worth it for completists."
        },
        {
          "title": "The Helen Morgan Story",
          "year": 1957,
          "note": "Forced on him by Jack Warner; he's the sleazy love interest, not the center."
        },
        {
          "title": "Until They Sail",
          "year": 1957,
          "note": "A modest part in a New Zealand-sisters war romance; he did it for Robert Wise."
        },
        {
          "title": "The Long, Hot Summer",
          "year": 1958,
          "note": "Yellow. The Faulkner mash-up where he and Woodward first throw heat; won him Best Actor at Cannes."
        },
        {
          "title": "The Left Handed Gun",
          "year": 1958,
          "note": "Arthur Penn's debut, a Billy the Kid Western that doesn't work: Newman was 33 playing 18."
        },
        {
          "title": "Rally 'Round the Flag, Boys!",
          "year": 1958,
          "note": "A Newman-Woodward domestic comedy with no fizz."
        },
        {
          "title": "The Young Philadelphians",
          "year": 1959,
          "note": "Black-and-white melodrama of speeches in drawing rooms; he didn't want to make it."
        },
        {
          "title": "From the Terrace",
          "year": 1960,
          "note": "Another Paul-and-Joanne love triangle; would-be Sirk in less skilled hands."
        },
        {
          "title": "Exodus",
          "year": 1960,
          "note": "Preminger's three-and-a-half-hour Israel epic; a slog now read as propaganda. Neither host finished it."
        },
        {
          "title": "Sweet Bird of Youth",
          "year": 1962,
          "note": "Tennessee Williams sanitized again: the castration cut to a beating. Thinner than Cat."
        },
        {
          "title": "Hemingway's Adventures of a Young Man",
          "year": 1962,
          "note": "A small, strange turn as the punch-drunk Battler."
        },
        {
          "title": "A New Kind of Love",
          "year": 1963,
          "note": "The one Woodward talked him into; a bad rom-com with a great makeover scene."
        },
        {
          "title": "The Prize",
          "year": 1963,
          "note": "A Nobel-laureate-turned-detective thriller-comedy; enjoyable, not essential."
        },
        {
          "title": "What a Way to Go!",
          "year": 1964,
          "note": "One of Shirley MacLaine's dead husbands, a bohemian killed by his own paint machine."
        },
        {
          "title": "The Outrage",
          "year": 1964,
          "note": "A Rashomon remake with Newman as a blue-eyed Mexican bandit. Dreadful."
        },
        {
          "title": "Lady L",
          "year": 1965,
          "note": "Period costume drama opposite Sophia Loren; capes are not where you want Newman."
        },
        {
          "title": "Torn Curtain",
          "year": 1966,
          "note": "His one Hitchcock, and it's boring. They didn't like each other."
        },
        {
          "title": "Hombre",
          "year": 1967,
          "note": "A modernist Western he later had regrets about."
        },
        {
          "title": "The Secret War of Harry Frigg",
          "year": 1968,
          "note": "A rare, bad stab at pure comedy that nobody remembers, made right after Cool Hand Luke."
        },
        {
          "title": "Winning",
          "year": 1969,
          "note": "The race-car drama that got him into racing; important to his life, a slog on screen."
        },
        {
          "title": "WUSA",
          "year": 1970,
          "note": "His politics swallowing the movie; pretentious and preachy."
        },
        {
          "title": "Pocket Money",
          "year": 1972,
          "note": "Basically a dumb-cowboy retread of Hud, with Lee Marvin."
        },
        {
          "title": "The Life and Times of Judge Roy Bean",
          "year": 1972,
          "note": "The bear movie. First with John Huston; the closest thing to a yellow in this stretch."
        },
        {
          "title": "The Mackintosh Man",
          "year": 1973,
          "note": "A dense Huston spy thriller carrying the worst Australian accent Sean has ever heard."
        },
        {
          "title": "The Towering Inferno",
          "year": 1974,
          "note": "Irwin Allen disaster spectacle; he's the architect. Perfectly adequate."
        },
        {
          "title": "Silent Movie",
          "year": 1976,
          "note": "A cameo in the Mel Brooks comedy."
        },
        {
          "title": "Buffalo Bill and the Indians, or Sitting Bull's History Lesson",
          "year": 1976,
          "note": "First with Altman, an ahead-of-its-time takedown of Western myth-making."
        },
        {
          "title": "Quintet",
          "year": 1979,
          "note": "Altman's post-apocalyptic board-game disaster. Undefendable, per Sean."
        },
        {
          "title": "When Time Ran Out...",
          "year": 1980,
          "note": "A contractual volcano disaster movie; badly reviewed."
        },
        {
          "title": "Fort Apache, the Bronx",
          "year": 1981,
          "note": "A New York cop drama that visibly inspired Hill Street Blues."
        },
        {
          "title": "Absence of Malice",
          "year": 1981,
          "note": "Pollack's murky journalism drama with Sally Field; an Oscar nom and an icky romance."
        },
        {
          "title": "Harry & Son",
          "year": 1984,
          "note": "Directed and starred; another difficult-dad film, made after his son's death."
        },
        {
          "title": "Fat Man and Little Boy",
          "year": 1989,
          "note": "'Oppenheimer, but bad.' He took the general's role so the bomb story could get made."
        },
        {
          "title": "Blaze",
          "year": 1989,
          "note": "Ron Shelton's Earl Long comedy: a horny Colonel Sanders, and not bad."
        },
        {
          "title": "Mr. & Mrs. Bridge",
          "year": 1990,
          "note": "The last Newman-Woodward feature; a sensitive James Ivory drama. Just fine."
        },
        {
          "title": "The Hudsucker Proxy",
          "year": 1994,
          "note": "Yellow. The Coens' fast-talking farce; he's the grouchy boss."
        },
        {
          "title": "Twilight",
          "year": 1998,
          "note": "A would-be blue: old-guy detective noir with Sarandon, Hackman, and a young Reese Witherspoon."
        },
        {
          "title": "Message in a Bottle",
          "year": 1999,
          "note": "Costner's dad, who encourages the romance and then dies because he's old."
        },
        {
          "title": "Where the Money Is",
          "year": 2000,
          "note": "A small late indie neither host has seen."
        },
        {
          "title": "Road to Perdition",
          "year": 2002,
          "note": "Mendes crime drama opposite Tom Hanks; an Oscar-nommed elder-statesman turn."
        },
        {
          "title": "Cars",
          "year": 2006,
          "note": "Yellow, out of respect. Doc Hudson, the wizened racer."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Behind the camera",
      "note": "the ones he directed but didn't star in",
      "films": [
        {
          "title": "Rachel, Rachel",
          "year": 1968,
          "note": "His directorial debut, starring Joanne Woodward; nominated for Best Picture."
        },
        {
          "title": "The Effect of Gamma Rays on Man-in-the-Moon Marigolds",
          "year": 1972,
          "note": "Directed Woodward to Best Actress at Cannes in a role she hated playing."
        },
        {
          "title": "The Glass Menagerie",
          "year": 1987,
          "note": "Late-career Tennessee Williams, released to little fanfare."
        }
      ]
    }
  ],
