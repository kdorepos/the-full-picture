{
  "slug": "terrifier-3-smile-2-and-the-10-best-horror-movies-of-2024",
  "title": "‘Terrifier 3,’ ‘Smile 2,’ and the 10 Best Horror Movies of 2024",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2024-10-18",
  "runtimeMin": 110,
  "format": "The annual Halloween horror episode: Sean and Chris on Terrifier 3 and Smile 2, a long dig through the streaming pile, and each host's five best horror movies of the year.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Terrifier 3’",
      "note": "the number one movie in America",
      "films": [
        {
          "title": "Terrifier 3",
          "year": 2024,
          "note": "Damien Leone's third Art the Clown film opened at No. 1. Sean's read: these are Michael Bay movies, thin story, but every 18 minutes something you've never seen before. Chris admires the craft the way you'd admire dance choreography without being moved by it."
        },
        {
          "title": "Terrifier 2",
          "year": 2022,
          "note": "The crowdfunded surprise hit that made about $15 million and built the audience. Home of the bedroom kill Sean calls maybe the craziest in movie history: 'Tarkovsky but for slashing someone's skin off.'"
        },
        {
          "title": "Terrifier",
          "year": 2016,
          "note": "The original. Neither host saw it until after 2 blew up."
        },
        {
          "title": "All Hallows' Eve",
          "year": 2013,
          "note": "Art the Clown's first appearance, over a decade before the sequels made a hit. A life's work Leone still owns outright."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Smile 2’",
      "note": "Parker Finn's follow-up",
      "films": [
        {
          "title": "Smile 2",
          "year": 2024,
          "note": "Sky Riley (Naomi Scott) is a pop star relaunching her tour when the smile entity latches onto her guilt over an accident. The craft is strong (roving POV camera, sound design, practical gore), but both hosts find it shrill and repetitive, with maybe 60% of it happening in her head. They agree the final five minutes are bold and funny."
        },
        {
          "title": "Smile",
          "year": 2022,
          "note": "Parker Finn's $217M debut, powered by one of the great recent trailers. More dour and trauma-focused than the sequel."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The streaming pile",
      "note": "gold, or painted copper",
      "films": [
        {
          "title": "Salem's Lot",
          "year": 2024,
          "note": "Gary Dauberman's long-shelved Stephen King adaptation on Max. Both hate it: meandering, streaming-tint, a period piece that looks freshly unboxed. Should have been a miniseries; Dauberman reportedly had a three-and-a-half-hour cut. Sean wanted the Doctor Sleep treatment."
        },
        {
          "title": "V/H/S/Beyond",
          "year": 2024,
          "note": "The annual anthology, on Shudder, leaning sci-fi this time. Standouts: the skydiving-vs-UFOs 'Live and Let Die' (Justin Martinez), the Bollywood-robot 'Dream Girl,' and Kate Siegel's experimental Skinamarink-meets-Alien segment. Justin Long directs one; Jay Cheel does the wraparound."
        },
        {
          "title": "Azrael",
          "year": 2024,
          "note": "E.L. Katz's nearly wordless folk-horror with Samara Weaving fleeing flesh-eaters in a post-apocalypse cult that cut out its own vocal cords. Written by Simon Barrett. More impressive than fun, but a great ending. On Shudder Oct 25."
        },
        {
          "title": "House of Spoils",
          "year": 2024,
          "note": "Ariana DeBose as a chef haunted in her new restaurant. From the Blow the Man Down duo; Sean found it turgid and post-Menu late."
        },
        {
          "title": "Caddo Lake",
          "year": 2024,
          "note": "Not really horror. A time-jump Shyamalan-produced mystery with Dylan O'Brien and Eliza Scanlen. Both liked the performers, neither followed the movie. Sean calls the explication 'quite poor.'"
        },
        {
          "title": "Oddity",
          "year": 2024,
          "note": "Damian McCarthy's Irish horror (Shudder). A blind woman uses arcane curios to avenge her murdered sister. Three or four amazing scares; McCarthy has a real handle on dread."
        },
        {
          "title": "Daddy's Head",
          "year": 2024,
          "note": "A dead patriarch's apparition haunts his son and wife. Crazy sound design, strong creature design, genuine unease: the Shudder house style of obsessive craft."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's 5 best horror movies of 2024",
      "note": "revealed worst to best on air; No. 1 first here",
      "subject": "2024 horror",
      "films": [
        {
          "title": "In a Violent Nature",
          "year": 2024,
          "note": "No. 1: the one that's haunted him most. Long subjective tracking shots from the killer's POV; the cliff-edge kill is on another level even in the year of Terrifier 3. 'The pavement fan's Terrifier.'"
        },
        {
          "title": "Strange Darling",
          "year": 2024,
          "note": "No. 2: JT Mollner's chopped-up thriller, shot on film by Giovanni Ribisi, that plays like a slasher with a twist. Kyle Gallner terrific; the opening scene reframes the whole thing."
        },
        {
          "title": "Alien: Romulus",
          "year": 2024,
          "note": "No. 3: taken purely as a haunted-house horror movie, Fede Alvarez's scares and kills land; the ending is as horrifying as anything in a theater this year."
        },
        {
          "title": "Late Night with the Devil",
          "year": 2023,
          "note": "No. 4: faux-found-footage about a 1970s talk show that summons a demon. David Dastmalchian excellent. The early-in-the-year release probably cost it a higher spot."
        },
        {
          "title": "Horror in the High Desert 3: Firewatch",
          "year": 2024,
          "note": "No. 5: a deep-cut found-footage entry (free on Prime) set in the Mojave. Janky true-crime framing, but relentless tempo and real scares. Sean had never heard of it."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's 5 best horror movies of 2024",
      "note": "revealed worst to best on air; No. 1 first here",
      "subject": "2024 horror",
      "films": [
        {
          "title": "The First Omen",
          "year": 2024,
          "note": "No. 1: Arkasha Stevenson's prequel, in his top 10 of the year. The Omen mythology bores him; Stevenson's take on women's bodies and church control is larded with ideas, gory and beautiful. On Hulu."
        },
        {
          "title": "The Substance",
          "year": 2024,
          "note": "No. 2: Coralie Fargeat's body horror. Demi Moore and Margaret Qualley extraordinary; the practical effects and the swing of the final 45 minutes had him hooting in his seat. He's not there to litigate its feminism."
        },
        {
          "title": "Red Rooms",
          "year": 2023,
          "note": "No. 3 (a double pick with Longlegs): Pascal Plante's Canadian thriller about a woman obsessed with a serial killer's trial. Juliette Gariépy extraordinary; horror as what an overexposure to true crime does to the mind."
        },
        {
          "title": "Longlegs",
          "year": 2024,
          "note": "No. 3 (paired with Red Rooms): Oz Perkins's post-Silence-of-the-Lambs serial-killer film with Maika Monroe. Divisive on its logic; the movie clicked for Sean after interviewing Perkins about his father and upbringing."
        },
        {
          "title": "In a Violent Nature",
          "year": 2024,
          "note": "No. 4: also on Chris's list, at No. 1."
        },
        {
          "title": "Blackout",
          "year": 2024,
          "note": "No. 5: Larry Fessenden's handmade werewolf movie (free on Tubi), one part character study, one part monster movie, with his usual social commentary. Alex Hurt gives a great lead performance."
        }
      ]
    }
  ],
