{
  "slug": "the-20-most-anticipated-movies-of-fall-2022",
  "title": "The 20 Most Anticipated Movies of Fall 2022",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2022-08-22",
  "runtimeMin": 93,
  "format": "Sean and Amanda regroup after a rough summer at the box office and each draft a personal top 10 of the fall's most anticipated movies.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Summer That Was",
      "note": "recapping a strange season at the movies",
      "films": [
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "The one auction pick that actually paid off; Sean calls it the success of the summer."
        },
        {
          "title": "Nope",
          "year": 2022,
          "note": "Amanda's post-leave, spoiler-averse review: an alien that's a camera, some horses, some shrapnel. Sean calls it a breath of fresh air, if slack in its pacing."
        },
        {
          "title": "Bullet Train",
          "year": 2022
        },
        {
          "title": "The Northman",
          "year": 2022
        },
        {
          "title": "Men",
          "year": 2022
        },
        {
          "title": "The Batman",
          "year": 2022,
          "note": "Amanda watched it in 30-minute increments during her leave and had to text Sean to ask who the man at the end was (it was the Joker)."
        },
        {
          "title": "Crimes of the Future",
          "year": 2022,
          "note": "A Cronenberg throwback Sean loved; he got to interview Cronenberg."
        },
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022
        },
        {
          "title": "RRR",
          "year": 2022,
          "note": "Opened in theaters but hit Netflix fast, so a lot of people caught it there instead."
        },
        {
          "title": "Ambulance",
          "year": 2022
        },
        {
          "title": "The Gray Man",
          "year": 2022,
          "note": "A $200 million movie that played 14 theaters for a week before going to Netflix. Both hosts call it a bad business decision and a bad film, citing hacky performances and a Prague set piece Amanda says wastes its own location."
        },
        {
          "title": "Jackass Forever",
          "year": 2022,
          "note": "Amanda saw it twice in theaters."
        },
        {
          "title": "Prey",
          "year": 2022,
          "note": "One of Amanda's five favorite movies of the summer, sight unseen - she just loved the podcast about it."
        },
        {
          "title": "Marcel the Shell with Shoes On",
          "year": 2022,
          "note": "Amanda liked it, didn't love it - found it too tender for her current, fairly raw emotional state."
        },
        {
          "title": "Minions: The Rise of Gru",
          "year": 2022
        },
        {
          "title": "Spiderhead",
          "year": 2022,
          "note": "Sean saw it in a theater and liked it more than most; at home, watching it the day it dropped on Netflix, it didn't work at all for him."
        },
        {
          "title": "Where the Crawdads Sing",
          "year": 2022
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Honorable Mentions",
      "note": "before the countdown",
      "films": [
        {
          "title": "The Woman King",
          "year": 2022,
          "note": "Gina Prince-Bythewood's big theatrical film, out in September."
        },
        {
          "title": "Stars at Noon",
          "year": 2022,
          "note": "Claire Denis, from Cannes."
        },
        {
          "title": "Aftersun",
          "year": 2022,
          "note": "Charlotte Wells's Cannes Jury Prize winner."
        },
        {
          "title": "Dead for a Dollar",
          "year": 2022,
          "note": "A new Walter Hill film - Sean notes Hill is around 80."
        },
        {
          "title": "Bardo, False Chronicle of a Handful of Truths",
          "year": 2022,
          "note": "Alejandro G. Inarritu's return; neither host is a big fan of his recent work, but they expect it to be a fall event regardless."
        },
        {
          "title": "Halloween Ends",
          "year": 2022,
          "note": "Closes out David Gordon Green's trilogy. Sean's more in on these films than most horror fans he knows."
        },
        {
          "title": "Moonage Daydream",
          "year": 2022,
          "note": "The David Bowie documentary."
        },
        {
          "title": "Pearl",
          "year": 2022,
          "note": "Ti West's X sequel."
        },
        {
          "title": "Confess Fletch",
          "year": 2022,
          "note": "Jon Hamm's new Fletch film."
        },
        {
          "title": "Barbarian",
          "year": 2022,
          "note": "Strong early buzz on this one; Sean is seeing it that week."
        },
        {
          "title": "All the Beauty and the Bloodshed",
          "year": 2022,
          "note": "Laura Poitras's Nan Goldin documentary, playing all four festivals."
        },
        {
          "title": "Athena",
          "year": 2022,
          "note": "Romain Gavras, headed to Netflix."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Amanda's 10 Most Anticipated Movies of Fall 2022",
      "note": "best to worst",
      "subject": "Fall 2022",
      "ranked": true,
      "films": [
        {
          "title": "She Said",
          "year": 2022,
          "note": "No. 1 - the Cantor/Twohey/Weinstein adaptation. Amanda loved the book as a journalism nerd, but worries the trailer leans on procedural cliche and that the ending being common knowledge saps the thriller energy a Spotlight-style film needs."
        },
        {
          "title": "Armageddon Time",
          "year": 2022,
          "note": "James Gray's memoiristic companion piece to The Fabelmans, starring Anne Hathaway, Jeremy Strong, and Anthony Hopkins. A shared pick - Sean already saw it at Cannes."
        },
        {
          "title": "Bros",
          "year": 2022,
          "note": "Billy Eichner's studio rom-com, written by and starring him, directed by Nicholas Stoller."
        },
        {
          "title": "The Eternal Daughter",
          "year": 2022,
          "note": "Joanna Hogg's secret COVID project with Tilda Swinton, produced by Martin Scorsese. Hogg was a guest on the show for The Souvenir Part II, where she recommended Heat."
        },
        {
          "title": "Blonde",
          "year": 2022,
          "note": "Andrew Dominik's long-gestating Marilyn Monroe film, with Ana de Armas."
        },
        {
          "title": "Empire of Light",
          "year": 2022,
          "note": "Sam Mendes, with Olivia Colman and Colin Firth - a love story set in an English coastal cinema in the 1980s."
        },
        {
          "title": "Glass Onion: A Knives Out Mystery",
          "year": 2022,
          "note": "Rian Johnson's follow-up, with Daniel Craig back and a large ensemble; premiering at TIFF before a Netflix release."
        },
        {
          "title": "The Whale",
          "year": 2022,
          "note": "Darren Aronofsky's Brendan Fraser comeback vehicle, tipped early as an Oscar performance."
        },
        {
          "title": "Ticket to Paradise",
          "year": 2022,
          "note": "George Clooney and Julia Roberts as a divorced couple reuniting for their daughter's wedding - the trailer that ran before Minions: The Rise of Gru."
        },
        {
          "title": "Don't Worry Darling",
          "year": 2022,
          "note": "No. 10 - Olivia Wilde's follow-up to Booksmart, with Florence Pugh and Harry Styles."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Sean's 10 Most Anticipated Movies of Fall 2022",
      "note": "best to worst",
      "subject": "Fall 2022",
      "ranked": true,
      "films": [
        {
          "title": "White Noise",
          "year": 2022,
          "note": "No. 1 - Noah Baumbach's adaptation of Don DeLillo's novel, with Greta Gerwig and Adam Driver, opening the Venice and New York film festivals."
        },
        {
          "title": "Babylon",
          "year": 2022,
          "note": "Damien Chazelle's first film since First Man, with Margot Robbie, Brad Pitt, and Diego Calva - Sean knows the least about this one of anything on either list."
        },
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "James Cameron's sequel; Sean says Cameron has never made a movie he dislikes."
        },
        {
          "title": "The Fabelmans",
          "year": 2022,
          "note": "Steven Spielberg's most personal film, with Michelle Williams, Paul Dano, and Seth Rogen; opens the same day as Black Panther: Wakanda Forever."
        },
        {
          "title": "Tár",
          "year": 2022,
          "note": "Todd Field's first film in 16 years, with Cate Blanchett as a symphony conductor."
        },
        {
          "title": "Women Talking",
          "year": 2022,
          "note": "Sarah Polley's adaptation of the Miriam Toews novel, with Frances McDormand, Rooney Mara, Claire Foy, Jessie Buckley, and Ben Whishaw."
        },
        {
          "title": "Decision to Leave",
          "year": 2022,
          "note": "Park Chan-wook's new noir, with Tang Wei and Park Hae-il; South Korea's Oscar submission."
        },
        {
          "title": "Black Panther: Wakanda Forever",
          "year": 2022,
          "note": "Ryan Coogler's follow-up, made in the wake of Chadwick Boseman's death."
        },
        {
          "title": "Master Gardener",
          "year": 2022,
          "note": "Paul Schrader's new film, with Joel Edgerton, Sigourney Weaver, and Quintessa Swindell - Sean's favorite living filmmaker."
        },
        {
          "title": "Eileen",
          "year": 2023,
          "note": "No. 10 - William Oldroyd's adaptation of the Ottessa Moshfegh novel, with Anne Hathaway and Thomasin McKenzie. Sean read and loved the book; a listener DM about a Swedish hotel prompted the segment."
        }
      ]
    }
