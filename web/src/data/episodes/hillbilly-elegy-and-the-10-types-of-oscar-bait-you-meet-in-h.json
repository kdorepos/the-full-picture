      "films": [
        {
          "title": "Fort Apache",
          "year": 1948,
          "note": "A 1948 New Republic review of this John Ford film is the first recorded use of 'Oscar bait.'"
        },
        {
          "title": "The Deer Hunter",
          "year": 1978,
          "note": "The origin of the strategy: shown only to voters and critics to qualify, then released wide after nominations. Won Best Picture; producer Alan Carr realized the grim subject only sold once it had nominations attached."
        },
        {
          "title": "Morning Glory",
          "year": 2010,
          "note": "Amanda's dad's kind of 'that'll win the Oscar' call, which the hosts note is emphatically not Oscar bait."
        },
        {
          "title": "Top Five",
          "year": 2014,
          "note": "The other dad pick; neither it nor Morning Glory earned a single nomination."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "Won the Oscar and nobody called it bait: the counterexample showing the term is reserved for films that fail the artistic test first."
        },
        {
          "title": "Moonlight",
          "year": 2016,
