{
  "slug": "the-julia-roberts-hall-of-fame-and-ticket-to-paradise",
  "title": "The Julia Roberts Hall of Fame and ‘Ticket to Paradise’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2022-10-21",
  "runtimeMin": 101,
  "format": "Clooney and Roberts reunite for a Bali rom-com, then Dobbins builds the ten-film Julia Roberts Hall of Fame and Fennessey fights for a 90-second cameo to count.",
  "segments": [
    {
      "kind": "review",
      "heading": "Ticket to Paradise",
      "note": "grade: B",
      "films": [
        {
          "title": "Ticket to Paradise",
          "year": 2022,
          "note": "Divorced parents David and Georgia (Clooney and Roberts) fly to Bali to sabotage their daughter's whirlwind wedding. Directed by Ol Parker. Dobbins: a delightful, disposable night out that 'sticks out like a sore thumb' because nobody makes this kind of star vehicle anymore. Both hosts flag the third act getting speech-heavy and a script that can't decide if the daughter went to college or law school."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Julia Roberts Hall of Fame",
      "note": "ten essential roles, chosen by Dobbins",
      "honoree": "Julia Roberts",
      "films": [
        {
          "title": "Mystic Pizza",
          "year": 1988,
          "note": "Her first real notice, in an ensemble dramedy about a Connecticut pizza joint. Dobbins didn't love the rewatch but watched the whole thing anyway: if you're building the myth, this one matters."
        },
        {
          "title": "Pretty Woman",
          "year": 1990,
          "note": "She was famously the last choice cast, and this is the movie where you watch her become a star in real time. Big mistake. Huge."
        },
        {
          "title": "The Player",
          "year": 1992,
          "note": "A 90-second cameo, playing herself, in Robert Altman's comeback. Fennessey campaigned hard for a cameo to count toward the Hall of Fame."
        },
        {
          "title": "The Pelican Brief",
          "year": 1993,
          "note": "A Grisham conspiracy thriller with Denzel Washington, directed by Alan J. Pakula. Runs long untangling its plot, but 'so who cares': the most underrated of her legal thrillers."
        },
        {
          "title": "My Best Friend's Wedding",
          "year": 1997,
          "note": "She plays the wedding-ruiner, finally using the caustic, mean-mode register she'd kept in her back pocket. Dobbins' pick for her favorite Roberts performance."
        },
        {
          "title": "Notting Hill",
          "year": 1999,
          "note": "Fennessey's favorite: a movie star basically playing herself falls for a London bookshop owner. The film turns her own fame into the actual subject."
        },
        {
          "title": "Erin Brockovich",
          "year": 2000,
          "note": "Won her the Oscar, directed by Soderbergh. A rare case of the trophy actually lining up with the performance: real character work that's still fully Julia."
        },
        {
          "title": "Ocean's Eleven",
          "year": 2001,
          "note": "In, with reservations: Fennessey admits the part barely tests her and floats revisiting the call once Twelve comes up."
        },
        {
          "title": "Ocean's Twelve",
          "year": 2004,
          "note": "The bit where her character impersonates Julia Roberts. A favorite the hosts have referenced on the show before."
        },
        {
          "title": "Ben Is Back",
          "year": 2018,
          "note": "A mother trying to keep her son alive through one night after he comes home from rehab. Both hosts single it out as a late-career high point."
        }
      ]
    }
  ],
