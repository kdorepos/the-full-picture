{
  "slug": "the-10-best-horror-movies-of-the-decade-the-big-picture",
  "title": "The 10 Best Horror Movies of the Decade | The Big Picture",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2019-10-25",
  "runtimeMin": 110,
  "format": "Chris Ryan and Sean Fennessey each build a horror list for the 2010s — Chris's five favorites, then Sean's pick for every year of the decade — before Dolemite Is My Name screenwriters Scott Alexander and Larry Karaszewski talk their long partnership, from Ed Wood to Eddie Murphy.",
  "segments": [
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Best Horror Movies of the Decade",
      "note": "his five, ranked, not necessarily the biggest hits",
      "subject": "Horror movies of the decade",
      "ranked": true,
      "films": [
        {
          "title": "Green Room",
          "year": 2015,
          "note": "No. 1 - Jeremy Saulnier's punk band vs. white-power-gang siege, with Patrick Stewart as a chillingly calm villain."
        },
        {
          "title": "It Follows",
          "year": 2014,
          "note": "No. 2 - David Robert Mitchell's post-industrial Detroit curse movie, starring Maika Monroe."
        },
        {
          "title": "The Invitation",
          "year": 2015,
          "note": "No. 3 - Karyn Kusama turns a Los Angeles dinner party into a claustrophobic trap."
        },
        {
          "title": "You're Next",
          "year": 2011,
          "note": "No. 4 - Adam Wingard's home-invasion siege: a family reunion, animal masks, an arrow through the eye."
        },
        {
          "title": "Unfriended",
          "year": 2015,
          "note": "No. 5 - a haunting that plays out entirely on a group Skype call. The only Blumhouse movie on his list."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Sean's Best Horror Movie of Each Year, 2010-2019",
      "note": "chronological, one per year",
      "films": [
        {
          "title": "Black Swan",
          "year": 2010,
          "note": "Sean's pick for 2010. Chris isn't a fan - tonally not his thing."
        },
        {
          "title": "You're Next",
          "year": 2011,
          "note": "Sean's pick for 2011, also on Chris's top five."
        },
        {
          "title": "The Cabin in the Woods",
          "year": 2012,
          "note": "Sean's pick for 2012. Chris argues it's representational of horror even if it isn't scary."
        },
        {
          "title": "The Conjuring",
          "year": 2013,
          "note": "Sean's pick for 2013."
        },
        {
          "title": "It Follows",
          "year": 2014,
          "note": "Sean's pick for 2014, also No. 2 on Chris's list."
        },
        {
          "title": "The Witch",
          "year": 2015,
          "note": "Sean's pick for 2015 - Robert Eggers' puritanical New England folk-horror debut."
        },
        {
          "title": "Don't Breathe",
          "year": 2016,
          "note": "Sean's pick for 2016 - Fede Alvarez's home-invasion thriller."
        },
        {
          "title": "Get Out",
          "year": 2017,
          "note": "Sean's pick for 2017, and per Sean maybe the best horror movie of the decade regardless of year."
        },
        {
          "title": "Hereditary",
          "year": 2018,
          "note": "Sean's pick for 2018 - Ari Aster's feature debut."
        },
        {
          "title": "Midsommar",
          "year": 2019,
          "note": "Sean's pick for 2019 - Ari Aster's follow-up to Hereditary."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Scott Alexander and Larry Karaszewski on",
      "films": [
        {
          "title": "Dolemite Is My Name",
          "year": 2019,
          "note": "Craig Brewer's Rudy Ray Moore biopic starring Eddie Murphy - the reason the pair are on the show."
        },
        {
          "title": "Ed Wood",
          "year": 1994,
          "note": "Tim Burton's take on their script. The film that set their formula: a sympathetic biopic about a fringe figure."
        },
        {
          "title": "Problem Child",
          "year": 1990,
          "note": "Their first produced script, rewritten by close to a dozen other writers before release."
        },
        {
          "title": "Problem Child 2",
          "year": 1991,
          "note": "The sequel they also wrote."
        },
        {
          "title": "The People vs. Larry Flynt",
          "year": 1996,
          "note": "Directed by Milos Forman - their biopic of the pornographer turned presidential candidate."
        }
      ]
    }
  ],
