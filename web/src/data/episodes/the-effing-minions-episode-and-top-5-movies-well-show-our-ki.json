      "ranked": true,
      "films": [
        {
          "title": "Singin' in the Rain",
          "year": 1952,
          "note": "No. 1 - she's starting with the musical numbers and hoping he loves Donald O'Connor; the dream ballet can wait."
        },
        {
          "title": "Mary Poppins",
          "year": 1964,
