{
  "slug": "creed-iii-and-the-top-10-boxing-movies",
  "title": "‘Creed III’ and the Top 10 Boxing Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-03-03",
  "runtimeMin": 78,
  "format": "A Creed III review, then Sean counts down his ten favorite boxing movies while Amanda pushes back.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Creed III’",
      "films": [
        {
          "title": "Creed III",
          "year": 2023,
          "note": "Michael B. Jordan's directorial debut. Sean and Amanda both liked it without loving it; the fatherhood subplot and the anime-inflected fight camerawork land, the metaphor-made-literal choice in the final bout doesn't. Jonathan Majors as Damien Anderson dominates the first third, then vanishes for 45 minutes. No Stallone, no Rocky, and (Amanda's chief complaint) the Bill Conti horns never play."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Sean's Top 10 Boxing Movies",
      "note": "counted down 10 to 1; listed best-first",
      "subject": "boxing movies",
      "ranked": true,
      "films": [
        {
          "title": "Rocky",
          "year": 1976,
          "note": "No. 1, and nothing else was ever in the running. Made for $960,000, grossed $225 million, won Best Picture over Taxi Driver, Network, and All the President's Men. Sean puts it fourth in that race and still calls it Pantheon."
        },
        {
          "title": "When We Were Kings",
          "year": 1996,
          "note": "No. 2. Leon Gast's Rumble in the Jungle doc, an hour and a half of Ali in the Congo. Sean calls it a natural double feature with Creed III and the reason Michael Mann's Ali always felt redundant."
        },
        {
          "title": "Raging Bull",
          "year": 1980,
          "note": "No. 3. De Niro's Jake LaMotta, plus the body transformation he's still known for. Not the most technically accurate boxing, but that's not the point."
        },
        {
          "title": "Creed",
          "year": 2015,
          "note": "No. 4. Ryan Coogler at 29. 'This movie rules': the dirt-bike ride to Meek Mill is Sean's evidence."
        },
        {
          "title": "Fat City",
          "year": 1972,
          "note": "No. 5, and the saddest on the list. John Huston assimilating into New Hollywood; Stacy Keach and a young Jeff Bridges. 'I'll watch Fat City till I die.'"
        },
        {
          "title": "The Set-Up",
          "year": 1949,
          "note": "No. 6. Robert Wise, 72 minutes, Robert Ryan as an over-the-hill fighter battling a corrupt sport, the kind of corruption Sean notes is still around 75 years later."
        },
        {
          "title": "Hard Times",
          "year": 1975,
          "note": "No. 7. Walter Hill's bare-knuckle picture with Charles Bronson. 'Just a good fight movie.'"
        },
        {
          "title": "Body and Soul",
          "year": 1947,
          "note": "No. 8. Robert Rossen's anti-capitalist morality fable, John Garfield Oscar-nominated, script by soon-to-be-blacklisted Abraham Polonsky. Watching a boxer's soul get methodically corrupted."
        },
        {
          "title": "Rocky II",
          "year": 1979,
          "note": "No. 9. Stallone writing, producing, and directing the movie that built the Sly mythology. 'Corny as fuck,' and Sean was moved anyway."
        },
        {
          "title": "Requiem for a Heavyweight",
          "year": 1962,
          "note": "No. 10. The Anthony Quinn film, though Sean's real love is the 1956 Playhouse 90 teleplay with Jack Palance, about an aging, brain-damaged boxer pushed into pro wrestling."
        }
      ]
    }
  ],
