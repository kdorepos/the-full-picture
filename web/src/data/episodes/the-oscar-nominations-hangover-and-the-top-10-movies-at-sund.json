  ],
  "published": "2023-01-27",
  "runtimeMin": 111,
  "format": "Sean and Amanda relitigate the Oscar nominations, then run down a loaded Sundance slate they watched virtually, before Sean sits down with Brandon Cronenberg for Infinity Pool.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Oscar Nominations Hangover",
      "note": "relitigating the Best Picture race",
      "films": [
        {
          "title": "Elvis",
          "year": 2022,
          "note": "The one nominee Sean can't get behind; Wesley Morris flagged its handling of B.B. King and Black music history."
        },
        {
          "title": "Tar",
          "year": 2022,
          "note": "Still living in the Tar-verse; also the subject of Todd Field's WTF appearance."
        },
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "One of three real contenders, by Sean's count."
        },
        {
          "title": "The Banshees of Inisherin",
          "year": 2022,
          "note": "The other of the three real contenders."
        },
        {
          "title": "The Fabelmans",
          "year": 2022,
          "note": "Sitting in third, per Sean."
        },
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "A dark-horse Best Picture possibility, Sean allows."
        },
        {
          "title": "Triangle of Sadness",
          "year": 2022,
          "note": "Amanda's dark horse; currently No. 2 on VOD charts."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The Sundance 2023 Roundup",
      "note": "attended virtually; one host, one film at a time",
      "picks": [
        {
          "title": "Eileen",
          "year": 2023,
          "by": "Amanda Dobbins",
          "note": "Amanda's No. 1. Adapted by Ottessa Moshfegh and her husband Luke Goebel from Moshfegh's novel; directed by William Oldroyd. Anne Hathaway and Thomasin McKenzie star."
        },
        {
          "title": "Passages",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Sean's pick for best of the festival. Ira Sacks's sexiest movie yet, with Franz Rogowski, Ben Whishaw, and Adele Exarchopoulos. Bought by Mubi."
        },
        {
          "title": "Pianoforte",
          "year": 2023,
          "by": "Amanda Dobbins",
          "note": "Documentary about the International Chopin Piano Competition; the one Sean got shut out of."
        },
        {
          "title": "Infinity Pool",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Brandon Cronenberg's new one, with Alexander Skarsgard and Mia Goth; the subject of Sean's interview later in the episode."
        },
        {
          "title": "Fair Play",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Chloe Domont's debut, starring Alden Ehrenreich and Phoebe Dynevor as hedge-fund analysts secretly engaged. Bought by Netflix for $20 million."
        },
        {
          "title": "You Hurt My Feelings",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Nicole Holofcener reunites with Julia Louis-Dreyfus, with Tobias Menzies, Michaela Watkins, and Arian Moayed."
        },
        {
          "title": "Still: A Michael J. Fox Movie",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Davis Guggenheim's biopic-adjacent portrait, built from conversations with Fox about his career and Parkinson's. Headed to Apple TV+."
        },
        {
          "title": "Invisible Beauty",
          "year": 2023,
          "by": "Amanda Dobbins",
          "note": "Co-directed by its subject, Bethann Hardison, on her runway career and her fight against the industry's whiteness."
        },
        {
          "title": "Magazine Dreams",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Elijah Bynum's Jonathan Majors bodybuilder drama. Reviews split on the back half; the performance is not in question."
        },
        {
          "title": "The Disappearance of Shere Hite",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Nicole Newnham on the sex researcher's rise and erasure; makes a natural double feature with the Judy Blume doc."
        },
        {
          "title": "Judy Blume Forever",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Davina Pardo and Leah Wolchok's portrait of the author, cooperative and warm."
        },
        {
          "title": "Talk to Me",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "The one midnight-slate standout for Sean, from brothers Danny and Michael Philippou."
        },
        {
          "title": "Fairyland",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "Andrew Durham's adaptation of Alysia Abbott's memoir, produced by American Zoetrope; Scoot McNairy plays her father. Amanda had the same reaction to the first half."
        },
        {
          "title": "It's Only Life After All",
          "year": 2023,
          "by": "Sean Fennessy",
          "note": "The Indigo Girls documentary; Sean's one unmissable pick of the festival for personal reasons."
        }
      ]
    },
    {
