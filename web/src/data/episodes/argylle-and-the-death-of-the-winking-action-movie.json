{
  "slug": "argylle-and-the-death-of-the-winking-action-movie",
  "title": "‘Argylle’ and the Death of the Winking Action Movie",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2024-02-07",
  "runtimeMin": 112,
  "format": "Sean Fennessey and Amanda Dobbins pan Matthew Vaughn's ‘Argylle’ and use it to chart the rise and fall of the ‘wink action’ movie, then Sean talks to Mads Mikkelsen and Nikolaj Arcel about ‘The Promised Land.’",
  "segments": [
    {
      "kind": "discussion",
      "heading": "‘Argylle’ and the Death of the Winking Action Movie",
      "note": "with producer Bobby Wagner",
      "films": [
        {
          "title": "Argylle",
          "year": 2024,
          "note": "Matthew Vaughn's roughly $200M spy comedy, which the hosts saw alone and hated. Bryce Dallas Howard plays novelist Ellie Conway, revealed as amnesiac, MK-ULTRA'd agent Rachel Kyle (R. Kyle → \"Argylle\"); Sam Rockwell, Henry Cavill, John Cena, Dua Lipa, Ariana DeBose, and a one-day Samuel L. Jackson fill it out. A C+ CinemaScore and a ~$16M opening against a reported $200M budget. Sean calls it the definitional \"wink action\" movie and the sign the genre is dying."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Mads Mikkelsen and Nikolaj Arcel on ‘The Promised Land’",
      "guest": "Mads Mikkelsen & Nikolaj Arcel on",
      "films": [
        {
          "title": "The Promised Land",
          "year": 2023,
          "note": "Arcel's 1750s Danish historical epic (Danish title \"The Bastard\"), with Mikkelsen as Captain Ludwig Kahlen, a stubborn illegitimate soldier trying to farm the untamable heath. They talk final cut, telling story through Mads's face, and why Danish directors make their worst films in Hollywood."
        },
        {
          "title": "Team America: World Police",
          "year": 2004,
          "note": "Mads's last great thing. He'd just watched it for the first time and couldn't stop laughing."
        },
        {
          "title": "Poor Things",
          "year": 2023,
          "note": "Arcel's last great thing, seen at Telluride; his favorite Lanthimos."
        }
      ]
    }
  ],
