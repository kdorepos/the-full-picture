{
  "slug": "10-movies-we-missed-this-year",
  "title": "10 Movies We Missed This Year",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-07-10",
  "runtimeMin": 70,
  "format": "Before the Barbenheimer weekend, Sean and Amanda clear the backlog: ten mid-2023 releases they never got to on the show, from a raunchy Lionsgate comedy to a Negro Leagues documentary.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The 10 we missed",
      "note": "backlog catch-up, in the order they aired",
      "films": [
        {
          "title": "Joy Ride",
          "year": 2023,
          "note": "Adele Lim's raunchy comedy with Ashley Park, Sherry Cola, Stephanie Hsu, and Sabrina Wu. Sean pegs the jokes at a 50% hit rate but was floored by a third-act turn; Amanda loved it and blames the empty theater on near-nonexistent Lionsgate marketing. A Point Grey (Rogen/Goldberg) production."
        },
        {
          "title": "Insidious: The Red Door",
          "year": 2023,
          "note": "Patrick Wilson's directorial debut and the fifth Insidious, ignoring parts three and four to return to Wilson, Ty Simpkins as Dalton, Rose Byrne, and Lin Shaye. Sean says the reshot scares work but the trauma framing drags; it still beat Indiana Jones with $32M."
        },
        {
          "title": "Elemental",
          "year": 2023,
          "note": "Pixar's anthropomorphic-elements romance between fire (Ember) and water (Wade). Amanda found it baffling and half-baked; Sean calls it a competent two-out-of-four that got stuck on a concept Pixar's usual creative council would have torn up. Quietly holding at the box office for lack of kids' competition."
        },
        {
          "title": "Extraction 2",
          "year": 2023,
          "note": "Sam Hargrave's Chris Hemsworth sequel. Sean admires the ambition of the prison 'oner' but finds the film humorless and self-serious next to John Wick or Mission: Impossible; Amanda liked the helicopter beat and little else. Both dread Extraction 4, 6, and 12."
        },
        {
          "title": "The Blackening",
          "year": 2023,
          "note": "Tim Story's horror-comedy about Black friends stalked at a Juneteenth cabin getaway. Sean says it plays better as comedy than horror (the board-game scene lands; the scares don't) and reads it as the parody that closes out the 'Get Out generation.' Great tagline: 'We can't all die first.'"
        },
        {
          "title": "Amanda",
          "year": 2022,
          "note": "Carolina Cavalli's Italian debut, Benedetta Porcaroli as a friendless 24-year-old who decides a childhood acquaintance is her best friend. Sean's surprise favorite of the batch, Wes Anderson- and Gerwig-adjacent. From Oscilloscope. Amanda (Dobbins) reserves the right to hold all Amandas to a higher standard."
        },
        {
          "title": "Biosphere",
          "year": 2023,
          "note": "Mel Eslyn's soft sci-fi with Mark Duplass and Sterling K. Brown as the last two men on Earth in a geodesic dome. Sean discloses a working relationship with the team (the Jason Isbell doc) but praises Brown; he keeps the physical surprises spoiler-free."
        },
        {
          "title": "Flamin' Hot",
          "year": 2023,
          "note": "Eva Longoria's directorial debut about Richard Montanez, the Frito-Lay janitor who supposedly invented Flamin' Hot Cheetos. Jesse Garcia, Annie Gonzalez, Dennis Haysbert, Tony Shalhoub. Both found it fine and diverting, but the story reportedly isn't true, which sours the up-from-the-bootstraps pitch."
        },
        {
          "title": "The League",
          "year": 2023,
          "note": "Sam Pollard's documentary on the Negro Leagues and Black baseball in the first half of the 20th century. Archival footage plus Willie Mays and Hank Aaron interviews. Sean, a serious baseball reader, learned plenty and calls it a necessary, if dry, film."
        },
        {
          "title": "Earth Mama",
          "year": 2023,
          "note": "Savannah Leaf's debut, Tia Nomore as a pregnant single mother fighting to reclaim two kids from foster care in the Bay Area. Sean compares it to 'Never Rarely Sometimes Always' and flags Jody Lee Lipes's cinematography; a calling-card movie built from Leaf's earlier short with Taylor Russell."
        }
      ]
    }
  ],
