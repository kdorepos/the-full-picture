{
  "slug": "the-1976-movie-draft",
  "title": "The 1976 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan",
    "Tracy Letts"
  ],
  "published": "2026-05-18",
  "runtimeMin": 132,
  "format": "A four-person snake draft of 1976 movies, with playwright and actor Tracy Letts joining Sean, Amanda, and Chris. Each drafter fills a six-slot roster: Drama, Comedy/Horror/Sci-Fi, Thriller or Action, Blockbuster (over $20M box office), Oscar Nominee, and Wild Card. Producer Jack Sanders set the order (Amanda, Chris, Sean, Letts), snaking back each round. Every pick below is confirmed by the hosts' end-of-episode recap.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "1976 movies",
      "categories": [
        "Drama",
        "Comedy/Horror/Sci-Fi",
        "Thriller or Action",
        "Blockbuster",
        "Oscar Nominee",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Mikey and Nicky",
              "year": 1976,
              "category": "Drama",
              "note": "Elaine May's two-hander, Cassavetes and Falk as anxious not-quite-gangsters. 'The movie that explained men to me.'"
            },
            {
              "title": "Cousin Cousine",
              "year": 1975,
              "category": "Comedy/Horror/Sci-Fi",
              "note": "A French romantic comedy she calls 'a French Four Weddings and a Funeral.' A discovery she was completely delighted by, with three Oscar nominations."
            },
            {
              "title": "All the President's Men",
              "year": 1976,
              "category": "Thriller or Action",
              "note": "First overall pick and her favorite film of the year. She took it here to deny it to everyone else, since it fit five of the six categories."
            },
            {
              "title": "A Star Is Born",
              "year": 1976,
              "category": "Blockbuster",
              "note": "The Streisand version, defended against the group's snobbery. Second-highest earner of the year. 'Barbra Streisand is important.'"
            },
            {
              "title": "Marathon Man",
              "year": 1976,
              "category": "Oscar Nominee",
              "note": "'Roy Scheider in Paris.' Olivier's Nazi-dentist thriller, and a Supporting Actor nomination for Olivier."
            },
            {
              "title": "Daguerréotypes",
              "year": 1975,
              "category": "Wild Card",
              "note": "Agnès Varda's documentary about the shopkeepers on her Paris street. A discovery, streaming on Criterion."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Kings of the Road",
              "year": 1976,
              "category": "Drama",
              "note": "Wim Wenders' near-three-hour road movie, shot by Robby Müller. 'A blueprint for Linklater, for Jarmusch.' The last of the pure German Wenders films."
            },
            {
              "title": "The Town That Dreaded Sundown",
              "year": 1976,
              "category": "Comedy/Horror/Sci-Fi",
              "note": "Charles B. Pierce's slasher about a phantom terrorizing Texarkana. Scary in spite of a very stupid B-plot; Chris sees Zodiac in it."
            },
            {
              "title": "The Outlaw Josey Wales",
              "year": 1976,
              "category": "Thriller or Action",
              "note": "One of the great Eastwood films. He praised the cinematography, the Chief Dan George chemistry, and Eastwood finding his own voice."
            },
            {
              "title": "The Omen",
              "year": 1976,
              "category": "Blockbuster",
              "note": "The studio's Exorcist knockoff, Gregory Peck and Lee Remick. 'I like to laugh with this movie more than I'm afraid of it.' Great score."
            },
            {
              "title": "Taxi Driver",
              "year": 1976,
              "category": "Oscar Nominee",
              "note": "Second overall pick. 'One of my favorite movies ever made,' a portrait of loneliness and a great New York film."
            },
            {
              "title": "Logan's Run",
              "year": 1976,
              "category": "Wild Card",
              "note": "'A real head fuck of a movie.' Michael York in a society that culls people at 30. More influential than beloved."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Network",
              "year": 1976,
              "category": "Drama",
              "note": "Third overall pick. 'The movie that made me feel like a grown-up.' Chayefsky's prescient, secretly funny satire, with Duvall, Dunaway, Finch, and Beatty."
            },
            {
              "title": "Buffalo Bill and the Indians, or Sitting Bull's History Lesson",
              "year": 1976,
              "category": "Comedy/Horror/Sci-Fi",
              "note": "Altman and Paul Newman, drafted as a comedy. An embittered satire of the American myth, with Joel Grey a standout."
            },
            {
              "title": "Assault on Precinct 13",
              "year": 1976,
              "category": "Thriller or Action",
              "note": "John Carpenter's second feature, a Rio Bravo-inspired siege movie. The arrival of a major genre filmmaker."
            },
            {
              "title": "The Bad News Bears",
              "year": 1976,
              "category": "Blockbuster",
              "note": "'The best comedy of this year and the last truly great blockbuster.' Ritchie and Matthau, a top-five sports movie for Sean."
            },
            {
              "title": "Harlan County, USA",
              "year": 1976,
              "category": "Oscar Nominee",
              "note": "Barbara Kopple's documentary on the Kentucky coal-miners' strike. 'Maybe the greatest American documentary ever made.' It won Best Documentary."
            },
            {
              "title": "Welcome to L.A.",
              "year": 1976,
              "category": "Wild Card",
              "note": "Alan Rudolph's first film and the first release from Altman's Lions Gate. An acidic portrait of a vapid LA, Keith Carradine and Sissy Spacek."
            }
          ]
        },
        {
          "host": "Tracy Letts",
          "picks": [
            {
              "title": "Lifeguard",
              "year": 1976,
              "category": "Drama",
              "note": "A Sam Elliott vehicle that Letts and his wife were knocked out by. A light film that gets deeper the further in you go."
            },
            {
              "title": "Carrie",
              "year": 1976,
              "category": "Comedy/Horror/Sci-Fi",
              "note": "De Palma. The others were bummed he got it. He argued Spacek and Piper Laurie deserved Oscars, and that it's 'the best movie about high school ever made.'"
            },
            {
              "title": "The Killing of a Chinese Bookie",
              "year": 1976,
              "category": "Thriller or Action",
              "note": "Cassavetes, a category reach. He saw it in Dallas with a Cassavetes Q&A, and loves Mr. Sophistication and Ben Gazzara."
            },
            {
              "title": "Rocky",
              "year": 1976,
              "category": "Blockbuster",
              "note": "Saw it in theaters in '76, and revisited it for his own film, I Play Rocky. Thinks they should have stopped the franchise after the first."
            },
            {
              "title": "Seven Beauties",
              "year": 1975,
              "category": "Oscar Nominee",
              "note": "Lina Wertmüller, with a Best Actor nomination for Giancarlo Giannini. 'The movie you kids should see.' Great, funny, and horrifying."
            },
            {
              "title": "The Man Who Fell to Earth",
              "year": 1976,
              "category": "Wild Card",
              "note": "Nic Roeg and David Bowie. A third viewing 'knocked my socks off.' He praised the StudioCanal 4K steelbook."
            }
          ]
        }
      ],
