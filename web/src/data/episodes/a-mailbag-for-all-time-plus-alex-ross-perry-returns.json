{
  "slug": "a-mailbag-for-all-time-plus-alex-ross-perry-returns",
  "title": "A Mailbag for All Time. Plus: Alex Ross Perry Returns!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessy",
    "Amanda Dobbins"
  ],
  "published": "2025-05-12",
  "runtimeMin": 137,
  "format": "With Cannes opening and no other news, Sean and Amanda open the mailbag (producer Bobby Wagner reads the questions), covering underrated directors, first big letdowns, movie-history what-ifs, marathon themes, family traditions, and which recent films will make the canon. Then Alex Ross Perry stops by to talk Pavements, his biopic-jukebox-musical-museum-documentary about the band.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Mailbag",
      "note": "Sean and Amanda, with Bobby Wagner reading listener questions",
      "films": [
        {
          "title": "C'mon C'mon",
          "year": 2021,
          "note": "Named alongside Kelly Reichardt and Sean Baker as an example of Mike Mills's zone: eight or nine acclaimed indie features, small box office. Amanda saw it while pregnant with Knox; it took her out. Both call it underseen, maybe due to COVID."
        },
        {
          "title": "The Mastermind",
          "year": 2025,
          "note": "Reichardt's new film, playing Cannes this year. Some think it could be an Academy Award contender. Sean says that would've been unthinkable a decade ago."
        },
        {
          "title": "The Village",
          "year": 2004,
          "note": "Sean's answer for first movie to truly let him down: he clocked the twist about six minutes in and sat in that feeling for 90 minutes. He still likes it."
        },
        {
          "title": "How Do You Know",
          "year": 2010,
          "note": "Amanda's pick for first big letdown. James L. Brooks's comedy with Reese Witherspoon (a softball player, à la Jennie Finch), Jack Nicholson, and Owen Wilson. You know five minutes in it won't come together."
        },
        {
          "title": "Must Love Dogs",
          "year": 2005,
          "note": "Another Sean letdown: Diane Lane and John Cusack, seen on a hot summer day at a downtown-Manhattan multiplex. It just didn't play."
        },
        {
          "title": "I Am Legend",
          "year": 2007,
          "note": "Bobby's answer. At 11 he thought it would be the coolest, greatest movie ever; it fell apart for him."
        },
        {
          "title": "Clown in a Cornfield",
          "year": 2025,
          "note": "Cited as the No. 5 movie at the box office that weekend: an IFC/Shudder horror movie that does exactly what the title promises. Nobody had it on their bingo card."
        },
        {
          "title": "I Saw the TV Glow",
          "year": 2024,
          "note": "The film behind the closing question: appreciated by critics and cinephiles, largely unknown to the wider public, the kind of movie Sean expects future filmmakers to cite."
        },
        {
          "title": "Nickel Boys",
          "year": 2024,
          "note": "Sean's biggest recent pick for a film destined for the canon that the public hasn't caught up to. A tough watch at home, but he sees a repertory reputation building."
        },
        {
          "title": "Red Rooms",
          "year": 2023,
          "note": "Talked up repeatedly on the show without ever getting its own episode; Sean sees it starting to get memed the way films do right before they take off."
        },
        {
          "title": "Nope",
          "year": 2022,
          "note": "Amanda's canon nominee, to Sean's surprise. A movie about movies that some cinephiles increasingly call the one, even if it isn't as fun as Get Out."
        },
        {
          "title": "The Fabelmans",
          "year": 2022,
          "note": "Not a big Oscar or box-office movie, but self-reflexive in ways that get people pondering their own relationship to art. They expect it reappraised as one of Spielberg's most important."
        },
        {
          "title": "West Side Story",
          "year": 2021,
          "note": "A great late Spielberg movie hurt by the pandemic that nobody seems to care about. Sean was cool on 2010s Spielberg, hot on the last two."
        },
        {
          "title": "First Cow",
          "year": 2019,
          "note": "One of the last films released before COVID, so a lot of people streamed it at home. Sean thinks that raised Reichardt's profile with younger viewers."
        },
        {
          "title": "Babygirl",
          "year": 2024,
          "note": "The Nicole Kidman movie Amanda sees percolating: a specific, taboo-but-not-perverted set of desires, with the girlboss material landing flatter than the sex. Getting memed, milk and all."
        },
        {
          "title": "Megalopolis",
          "year": 2024,
          "note": "Bobby's pick. Not necessarily canon, but doing enough weird, audacious stuff visually that filmmakers will cite it in 20 years."
        },
        {
          "title": "The Northman",
          "year": 2022,
          "note": "Bobby's other pick: an act of filmmaking built around a specific, non-commercial vision that he thinks will inspire people to make something."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Alex Ross Perry on 'Pavements'",
      "guest": "Alex Ross Perry on",
      "note": "the writer-director's tenth-or-so visit, in person in LA",
      "films": [
        {
          "title": "Pavements",
          "year": 2024,
          "note": "The four-year odyssey: a Pavement movie that is at once a fake biopic (Joe Keery as Malkmus, Nat Wolff, Fred Hechinger, Logan Miller, Griffin Newman), a jukebox musical, a pop-up museum, and a documentary of a reunion tour, all smashed together like a turducken. The band asked for something that felt written, not a traditional doc."
        },
        {
          "title": "Dunkirk",
          "year": 2017,
          "note": "The structural rip-off Perry admits to: three timelines converging about 70 minutes in, so five different versions of the song Grounded lock together at once."
        },
        {
          "title": "Megalopolis",
          "year": 2024,
          "note": "Perry feels a huge affinity for it: someone else working through something and asking why a movie has to be one way. He calls Pavements the indie-rock Megalopolis."
        },
        {
          "title": "A Complete Unknown",
          "year": 2024,
          "note": "The straight-faced biopic Pavements parodies: the 'musician sits down and writes' scene Perry lampoons, and the New York Times coverage about how they made the wig."
        },
        {
          "title": "Free Guy",
          "year": 2021,
          "note": "Joe Keery's other credit; Perry, who admires Keery's real work in Pavements, calls Free Guy garbage: 'my Synecdoche, New York.'"
        }
      ]
    }
  ],
