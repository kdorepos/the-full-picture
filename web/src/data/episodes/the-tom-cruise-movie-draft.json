  "format": "Five drafters snake through Tom Cruise's 46-film career across eight categories, from '80s and '90s to Mission: Impossible and 'Tom Cruise does a sports thing.'",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "Tom Cruise's filmography",
      "categories": [
        "'80s",
