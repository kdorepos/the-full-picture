  "title": "Luca Guadagnino on the Gory Glory of 'Suspiria' | Interview (Ep. 92)",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey"
  ],
  "published": "2018-11-01",
  "runtimeMin": 30,
  "format": "Sean Fennessey talks to Luca Guadagnino about remaking Argento's Suspiria, finishing it alongside the Call Me By Your Name wave, and his plan to disappear into American cinema.",
  "segments": [
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Luca Guadagnino on",
      "films": [
        {
          "title": "Suspiria",
          "year": 2018,
          "note": "The reason for the sit-down: Guadagnino's coven-in-a-dance-school reimagining, a project he says he wanted to make long before the films that made his name. He frames it as being about conflicting powers and the weight of the past, and defends its extreme violence as something the story led him to rather than a stamp he set out to leave."
        },
        {
          "title": "Suspiria (1977)",
          "year": 1977,
          "note": "Dario Argento's original, which he first met as a poster on a shuttered summer theater in northern Italy at 10 and saw at 14. A pastrami lunch in Westwood with writer David Kajganich turned into the remake, which opens the 'sealed world' out onto 1970s Germany and the Baader-Meinhof era."
        },
        {
          "title": "Call Me by Your Name",
          "year": 2017,
          "note": "Finished around the same time; its 'success quote-unquote' landed while Suspiria was nearly done. He calls Suspiria almost the exact opposite (Italian romance versus austere, cold, snowbound Germany) and says he sought out doing two films in one year."
        },
        {
          "title": "A Bigger Splash",
          "year": 2015,
          "note": "He offers the scene of Paul killing Harry as his earlier stab at death played out in real time, granting it was intense but not as visceral, with no blades or guts exposed."
        },
        {
          "title": "I Am Love",
          "year": 2009,
          "note": "Cited with A Bigger Splash and Call Me By Your Name as films about artistic people coping with external forces, a throughline he only saw once Fennessey named it."
        },
        {
          "title": "The Old Man & the Gun",
          "year": 2018,
          "note": "His answer to the show's closing question about the last great thing he'd seen. He calls David Lowery a humanist and a filmmaker he deeply admires."
        }
      ]
    }
  ],
