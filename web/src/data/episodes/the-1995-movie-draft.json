{
  "slug": "the-1995-movie-draft",
  "title": "The 1995 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2020-12-29",
  "runtimeMin": 69,
  "format": "Sean, Amanda, and reigning champion Chris Ryan close out the year by drafting 1995, the year all three say made them into moviegoers.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Who were you in 1995?",
      "note": "before the draft",
      "films": [
        {
          "title": "Pulp Fiction",
          "year": 1994,
          "note": "What Sean calls \"a real catalyzing agent of my life\"; he says 1995 was basically its sequel year. Amanda was 9, too young for it at the time."
        },
        {
          "title": "Get Shorty",
          "year": 1995,
          "note": "Sent Sean down an Elmore Leonard rabbit hole that year."
        },
        {
          "title": "Il Postino",
          "year": 1994,
          "note": "One of the Oscar nominees that baffled a 12-year-old Sean that year."
        },
        {
          "title": "Leaving Las Vegas",
          "year": 1995,
          "note": "Another of that year's Oscar bewilderments, per Sean."
        },
        {
          "title": "Laws of Gravity",
          "year": 1992,
          "note": "Nick Gomez's NYC crime debut, the movie that first put him on Sean's radar."
        },
        {
          "title": "New Jersey Drive",
          "year": 1995,
          "note": "Gomez's follow-up; an interview about it is where Sean first heard the name Richard Price."
        },
        {
          "title": "Clockers",
          "year": 1995,
          "note": "The Richard Price adaptation Gomez was asked about directing in that interview; Spike Lee made it instead, with Harvey Keitel stepping in after Robert De Niro dropped out."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The 1995 Movie Draft",
      "note": "snake draft, six categories, draft order set by a spin of the wheel: Amanda, Chris, Sean",
      "draftOf": "1995 movies",
      "categories": [
        "Drama",
        "Comedy or Horror",
        "Blockbuster",
        "Animated or Foreign Language",
        "Sequel",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Kicking and Screaming",
              "year": 1995,
              "category": "Drama",
              "note": "Amanda didn't see it until a decade later; the first Noah Baumbach movie she saw."
            },
            {
              "title": "Clueless",
              "year": 1995,
              "category": "Comedy or Horror",
              "note": "Her own Pulp Fiction moment, and still, by her count, the best Jane Austen adaptation."
            },
            {
              "title": "Apollo 13",
              "year": 1995,
              "category": "Blockbuster",
              "note": "Her first pick, taken with genuine nerves about beating Chris to it. Best Ron Howard movie, her favorite Tom Hanks performance, watched on VHS \"at least a hundred times.\""
            },
            {
              "title": "Casper",
              "year": 1995,
              "category": "Animated or Foreign Language",
              "note": "\"This one goes out to all the 90s millennials, the true Devon Sawa fans.\""
            },
            {
              "title": "GoldenEye",
              "year": 1995,
              "category": "Sequel",
              "note": "The first Bond movie she saw, though she doesn't rate it among the best. Concedes the N64 game it spawned is another matter."
            },
            {
              "title": "Sense and Sensibility",
              "year": 1995,
              "category": "Wildcard",
              "note": "Ang Lee's adaptation, screenplay by Emma Thompson; her comfort-watch. Passed on Father of the Bride Part II for it."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Heat",
              "year": 1995,
              "category": "Drama",
              "note": "\"It's not only my Apollo 13. It is literally my moon landing.\" Saw it twice in one weekend during the Blizzard of '96."
            },
            {
              "title": "Mallrats",
              "year": 1995,
              "category": "Comedy or Horror",
              "note": "Picked with his heart; saw it two or three times in theaters. Kevin Smith's Clerks follow-up."
            },
            {
              "title": "Crimson Tide",
              "year": 1995,
              "category": "Blockbuster",
              "note": "Denzel Washington and Gene Hackman; Tarantino did an uncredited dialogue polish."
            },
            {
              "title": "Ghost in the Shell",
              "year": 1995,
              "category": "Animated or Foreign Language",
              "note": "By his own admission he's never actually watched it start to finish, only caught it playing on a bar TV."
            },
            {
              "title": "Die Hard with a Vengeance",
              "year": 1995,
              "category": "Sequel",
              "note": "\"DH with a V\" to him and his friends growing up. Started life as an original script, Simon Says, retrofitted into a McClane movie; Samuel L. Jackson's role was reportedly once meant for Laurence Fishburne."
            },
            {
              "title": "Before Sunrise",
              "year": 1995,
              "category": "Wildcard",
              "note": "Making up for once passing on it in a prior draft in favor of Iron Man 3."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Casino",
              "year": 1995,
              "category": "Drama",
              "note": "Scorsese; Sean first saw it on a VHS academy screener he lifted from his uncle's TV console as a teenager."
            },
            {
              "title": "Billy Madison",
              "year": 1995,
              "category": "Comedy or Horror",
              "note": "\"I worship and have always worshiped\" it, per Sean."
            },
            {
              "title": "Se7en",
              "year": 1995,
              "category": "Blockbuster",
              "note": "David Fincher, after the studio battles of Alien 3. Deliberately drafted as Blockbuster, not Drama, to save his Drama pick for Casino."
            },
            {
              "title": "Toy Story",
              "year": 1995,
              "category": "Animated or Foreign Language",
              "note": "\"An absolute game-changing movie in the history of movies,\" by his own account."
            },
            {
              "title": "Batman Forever",
              "year": 1995,
              "category": "Sequel",
              "note": "Joel Schumacher's Val Kilmer entry, with Jim Carrey and Tommy Lee Jones as Riddler and Two-Face. Sean calls it a weak year for sequels overall."
            },
            {
              "title": "The Usual Suspects",
              "year": 1995,
              "category": "Wildcard",
              "note": "Chris McQuarrie's script; Sean says it \"flipped a switch\" in how he thought about movies."
            }
          ]
        }
      ],
