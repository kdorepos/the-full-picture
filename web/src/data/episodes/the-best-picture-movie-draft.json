          "picks": [
            {
              "title": "The Silence of the Lambs",
              "year": 1991,
              "category": "1990s",
              "note": "First overall: the last film to win the Big Five, one of Demme's best."
            },
            {
              "title": "Mutiny on the Bounty",
              "year": 1935,
              "category": "1930s",
              "note": "Underrated winner, taken for Charles Laughton's Captain Bligh."
            },
            {
              "title": "On the Waterfront",
              "year": 1954,
              "category": "1950s",
              "note": "Kazan and Brando in Hoboken, the only '50s pick he'd make."
            },
            {
              "title": "The Godfather",
              "year": 1972,
              "category": "1970s",
              "note": "Sets the template; took it over Part II by '50.1 to 49.9'."
            },
            {
              "title": "Parasite",
              "year": 2019,
              "category": "2010s",
              "note": "The 2010s winner in his headcanon; won the night his live-cut voice cracked."
            },
            {
              "title": "Barry Lyndon",
              "year": 1975,
              "category": "Best Picture Loser",
              "note": "Kubrick shot it by real candlelight."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "It Happened One Night",
              "year": 1934,
              "category": "1930s",
              "note": "Her personal favorite of the decade, a Big Five winner."
            },
            {
              "title": "All About Eve",
              "year": 1950,
              "category": "1950s",
              "note": "Took it over her backup, An American in Paris."
            },
            {
              "title": "The Godfather Part II",
              "year": 1974,
              "category": "1970s",
              "note": "Grabbed it before Sean could; she toggles it above Part I."
            },
            {
              "title": "Titanic",
              "year": 1997,
              "category": "1990s",
              "note": "The safe '90s pick, with The English Patient left as her other option."
            },
            {
              "title": "Moonlight",
              "year": 2016,
              "category": "2010s",
              "note": "The winner she loves; the one Sean's 'new Academy' piece was written about."
            },
            {
              "title": "The Social Network",
              "year": 2010,
              "category": "Best Picture Loser",
              "note": "Rates it over Inception, and endured a Nolan bit to say so."
