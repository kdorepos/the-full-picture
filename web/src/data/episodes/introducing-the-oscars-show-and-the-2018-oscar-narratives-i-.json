{
  "slug": "introducing-the-oscars-show-and-the-2018-oscar-narratives-i-",
  "title": "Introducing 'The Oscars Show' and the 2018 Oscar Narratives I The Oscars Show (Ep. 91)",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2018-10-30",
  "runtimeMin": 48,
  "format": "The first episode of the Ringer's Oscars show. Fennessey and Dobbins map the 2018 Best Picture field, run First Man through a stock-up/stock-down check, and count fifteen names in a crowded Best Actor race.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The Big Picture's Big Picture",
      "note": "the state of the 2018 race",
      "films": [
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "The fourth telling of the story, and the one to beat. Held 28% at the box office in week three; Dobbins calls the first hour among the most exciting dramas in years."
        },
        {
          "title": "Black Panther",
          "year": 2018,
          "note": "The reason the scrapped 'popular Oscar' turned out to be unnecessary: a comic-book movie in the Best Picture conversation on merit."
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "Alfonso Cuaron's memoir of 1970s Mexico City, Netflix's first real Best Picture bid. Tied with A Star Is Born on GoldDerby before its limited theatrical/streaming release."
        },
        {
          "title": "First Man",
          "year": 2018,
          "note": "Damien Chazelle's Neil Armstrong film; the technical-masterpiece slot in the conversation."
        },
        {
          "title": "Widows",
          "year": 2018,
          "note": "The genre entry the hosts expect to talk about for a month straight."
        },
        {
          "title": "Green Book",
          "year": 2018,
          "note": "The crowd-pleaser of the field."
        },
        {
          "title": "The Favourite",
          "year": 2018,
          "note": "The high-comedy traditional-Oscar entry."
        },
        {
          "title": "Crazy Rich Asians",
          "year": 2018,
          "note": "The kind of well-liked crowd-pleaser the axed 'popular Oscar' might have honored."
        },
        {
          "title": "A Quiet Place",
          "year": 2018
        },
        {
          "title": "Incredibles 2",
          "year": 2018
        },
        {
          "title": "Mission: Impossible - Fallout",
          "year": 2018,
          "note": "Named a crowd-pleaser in this segment; revisited at length in the Best Actor segment."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock Up, Stock Down",
      "note": "plus the buzzword: 'campaign poison'",
      "films": [
        {
          "title": "First Man",
          "year": 2018,
          "note": "Verdict: stock down. $75M worldwide on a $59M budget, 88% on Rotten Tomatoes; the hosts blame timing (a week after A Star Is Born) and the film's cold, technical remove."
        },
        {
          "title": "The Girl in the Spider's Web",
          "year": 2018,
          "note": "The 'campaign poison' case: the Claire Foy vehicle meant to catapult her, directed by horror filmmaker Fede Alvarez, arriving quietly and reviewed poorly. Foy verdict: stock down."
        },
        {
          "title": "Unsane",
          "year": 2018,
          "note": "Cited as another Foy role in her wheelhouse of tough, dug-in women."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Big Race: Best Actor",
      "note": "fifteen credible names",
      "films": [
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "Bradley Cooper, 'the lockiest lock of the year' and the one to beat; also the actor-turned-director narrative."
        },
        {
          "title": "First Man",
          "year": 2018,
          "note": "Ryan Gosling in a quiet, focused turn; hurt by his reluctance to campaign."
        },
        {
          "title": "Bohemian Rhapsody",
          "year": 2018,
          "note": "Rami Malek as Freddie Mercury; the hosts call the movie paint-by-numbers but the transformation incredible, complicated by Bryan Singer's firing and controversy."
        },
        {
          "title": "The Mule",
          "year": 2018,
          "note": "Clint Eastwood, a late unseen entry; Cooper is also in it."
        },
        {
          "title": "The Old Man & the Gun",
          "year": 2018,
          "note": "Robert Redford in an under-seen film once billed as his swan song."
        },
        {
          "title": "Vice",
          "year": 2018,
          "note": "Christian Bale, unseen and year-end, with a spot already reserved for him by the pundits."
        },
        {
          "title": "Green Book",
          "year": 2018,
          "note": "Viggo Mortensen as the driver to Mahershala Ali's jazz musician; Peter Farrelly's solo directorial turn."
        },
        {
          "title": "Boy Erased",
          "year": 2018,
          "note": "One of Lucas Hedges's two roles this year; the hosts think he split his own vote."
        },
        {
          "title": "Ben Is Back",
          "year": 2018,
          "note": "Hedges's other role in the crowded slate of similar young-man tragedies."
        },
        {
          "title": "Beautiful Boy",
          "year": 2018,
          "note": "Steve Carell and Timothee Chalamet; Fennessey pegs Chalamet as a movie star about to break out."
        },
        {
          "title": "BlacKkKlansman",
          "year": 2018,
          "note": "John David Washington, one of three Black leads the hosts note are absent from the odds."
        },
        {
          "title": "If Beale Street Could Talk",
          "year": 2018,
          "note": "Stephen James in Barry Jenkins's Baldwin adaptation; a largely unknown cast beyond Regina King and Brian Tyree Henry."
        },
        {
          "title": "Black Panther",
          "year": 2018,
          "note": "Chadwick Boseman, sidelined because the film is treated as a blockbuster rather than an acting movie."
        },
        {
          "title": "Mission: Impossible - Fallout",
          "year": 2018,
          "note": "Fennessey's wild card for Tom Cruise, the greatest movie star of 30 years and still without an Oscar; a case for rewarding physical performance."
        },
        {
          "title": "The Sisters Brothers",
          "year": 2018,
          "note": "Dobbins's wild card for John C. Reilly, who bought and produced the film; the hosts call it his best performance."
        }
      ]
    }
  ],
