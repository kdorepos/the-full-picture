{
  "slug": "are-we-headed-for-a-2020-oscars-disaster-plus-how-disney-run",
  "title": "Are We Headed for a 2020 Oscars Disaster? Plus: How Disney Runs the Movie World, and Jesse Eisenberg and Riley Stearns on 'The Art of Self-Defense' I Discussion",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2019-07-09",
  "runtimeMin": 67,
  "format": "Sean and Amanda open on 'Spider-Man: Far From Home' and the nine-month Marvel gap, work through Disney's live-action remake machine, then war-game a thin-looking 2020 Oscar race and Netflix's spending. Sean closes with a SXSW interview with Riley Stearns and Jesse Eisenberg on 'The Art of Self-Defense.'",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Spider-Man and the Marvel intermission",
      "films": [
        {
          "title": "Spider-Man: Far From Home",
          "year": 2019,
          "note": "Outpaced projections. Amanda's verdict: a charming teen summer trip movie for its target audience, less so as a set-piece film; Gyllenhaal's Mysterio 'doing Fincher the whole time.'"
        },
        {
          "title": "Midsommar",
          "year": 2019,
          "note": "A mild opening the same weekend. Amanda skipped it but had the plot spoiled by Chris Ryan."
        },
        {
          "title": "Avengers: Endgame",
          "year": 2019,
          "note": "The benchmark the 'second-tier' Marvel movies are measured against; with no Marvel release for nine months, Sean chews on what the gap does to moviegoing."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "How Disney runs the movie world",
      "note": "the live-action remake machine",
      "films": [
        {
          "title": "The Lion King",
          "year": 2019,
          "note": "Jon Favreau's remake runs 118 minutes to the 1994 original's 88; Sean can't find where the extra 30 minutes of story come from."
        },
        {
          "title": "Aladdin",
          "year": 2019,
          "note": "A big international earner; the genie 'was just very genie.' Kids like it more than the hosts do."
        },
        {
          "title": "The Little Mermaid",
          "year": 1989,
          "note": "Halle Bailey cast as Ariel for the coming remake; the hosts read the online outrage as mostly bots and a few loud idiots."
        },
        {
          "title": "Beauty and the Beast",
          "year": 2017,
          "note": "Amanda went alone in the afternoon and remembered every word of the songs."
        },
        {
          "title": "Mulan",
          "year": 2020,
          "note": "Niki Caro directs; the trailer dropped during the Women's World Cup final and staffers immediately asked where the talking dragon went."
        },
        {
          "title": "Mary Poppins Returns",
          "year": 2018,
          "note": "Rob Marshall, set to direct the 'Little Mermaid' remake; neither host thought this one worked, and it missed the major Oscar categories."
        },
        {
          "title": "Cinderella",
          "year": 2015,
          "note": "The Lily James version, one of the classics already ticked off."
        },
        {
          "title": "Dumbo",
          "year": 2019
        },
        {
          "title": "Pinocchio",
          "year": 1940,
          "note": "The original animation. Both find it genuinely disturbing, 'especially the donkey boys.' A remake was long rumored."
        },
        {
          "title": "Lady and the Tramp",
          "year": 2019,
          "note": "Headed straight to Disney+ later in the year."
        },
        {
          "title": "Cruella",
          "year": 2021,
          "note": "The '101 Dalmatians' prequel, with Emma Stone; part of a decade of IP still to mine."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Are we headed for a 2020 Oscars disaster?",
      "note": "Sean's fake-anxiety note about the worst Oscar year ever",
      "films": [
        {
          "title": "Once Upon a Time in Hollywood",
          "year": 2019,
          "note": "The first real studio Oscar contender of the year; Sean rewatched 'Inglourious Basterds' and is very excited. Amanda counters it may be Hollywood-loves-Hollywood in the La La Land mold, not a broad crowd-pleaser."
        },
        {
          "title": "Pain and Glory",
          "year": 2019,
          "note": "The new Almodovar; well received at Cannes, with Antonio Banderas a likely best-actor play, but no one's crowning achievement."
        },
        {
          "title": "The Farewell",
          "year": 2019,
          "note": "A24; Sean interviewed writer-director Lulu Wang for the following week. He's unsure it's a best-picture candidate."
        },
        {
          "title": "A Hidden Life",
          "year": 2019,
          "note": "The Malick WWII film, from Fox Searchlight; Sean expects an 'it's time for Malick' campaign."
        },
        {
          "title": "The Report",
          "year": 2019,
          "note": "Amazon's CIA docudrama from Scott Burns; strong at Sundance, but the hosts have heard mixed responses since."
        },
        {
          "title": "A Beautiful Day in the Neighborhood",
          "year": 2019,
          "note": "The Mr. Rogers picture with Tom Hanks."
        },
        {
          "title": "Cats",
          "year": 2019,
          "note": "Tom Hooper; Sean swears he'll be angry if it lands a major nomination. Amanda doubts Taylor Swift moves tickets for a movie about cats."
        },
        {
          "title": "The Goldfinch",
          "year": 2019,
          "note": "Big literary adaptation from the director of 'Brooklyn.' Looks like an Oscar movie from another decade."
        },
        {
          "title": "Little Women",
          "year": 2019,
          "note": "Greta Gerwig's adaptation; Sean is looking forward to a Gerwig-versus-Baumbach awards season."
        },
        {
          "title": "The Woman in the Window",
          "year": 2021,
          "note": "One of many unreleased titles clogging the early contender lists."
        },
        {
          "title": "Ford v Ferrari",
          "year": 2019,
          "note": "American-engineering muscle Sean thinks some voters will respond to, though he worries about the jingoism riding alongside it."
        },
        {
          "title": "Harriet",
          "year": 2019,
          "note": "Kasi Lemmons' Harriet Tubman biopic, with Cynthia Erivo; classic Oscar material on paper."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Netflix spending question",
      "note": "Triple Frontier, Red Notice, and the streamer's Oscar bets",
      "films": [
        {
          "title": "Triple Frontier",
          "year": 2019,
          "note": "J.C. Chandor's Ben Affleck heist movie, reportedly $115M ('that movie had $80 million'). A report claimed its performance was pushing Netflix to rein in film spending; Ted Sarandos said 63M households watched it."
        },
        {
          "title": "Red Notice",
          "year": 2021,
          "note": "The Rock, Gal Gadot, and Ryan Reynolds; a Universal cast-off Netflix swooped in for mid-episode, undercutting the whole 'Netflix is cutting back' thesis. The Rock's deal: $21M plus 30% of profits, which Netflix has to buy out in full."
        },
        {
          "title": "The Irishman",
          "year": 2019,
          "note": "Scorsese's de-aging epic with De Niro, Pesci, and Pacino; rumored at $150M-plus. Sean notes even Scorsese rarely converts: 'Hugo' and 'Gangs of New York' didn't; only 'The Departed' got him across the line."
        },
        {
          "title": "Marriage Story",
          "year": 2019,
          "note": "The then-untitled Noah Baumbach film, in post for over two years and slated for a big Netflix push; a smaller Oscar gamble than 'The Irishman.'"
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "The last time Netflix went all-in on an Oscar campaign; a great film that lost to 'Green Book.'"
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Riley Stearns and Jesse Eisenberg on 'The Art of Self-Defense'",
      "note": "recorded at SXSW in March",
      "guest": "Riley Stearns and Jesse Eisenberg on",
      "films": [
        {
          "title": "The Art of Self-Defense",
          "year": 2019,
          "note": "Stearns' karate comedy about the aspiration of masculinity; a 25-day shoot, dead-earnest tone, jiu-jitsu instead of a stunt-double gloss. Eisenberg on the writing: 'we knew the purpose of every single shot.'"
        },
        {
          "title": "Faults",
          "year": 2014,
          "note": "Stearns' first feature; seeing the new dailies made him realize he had a style after all: his cheat pick for an ideal double feature."
        },
        {
          "title": "Fargo",
          "year": 1996,
          "note": "Stearns names it (with 'Punch-Drunk Love') as the kind of specific, self-contained world he tries to build."
        },
        {
          "title": "Punch-Drunk Love",
          "year": 2002
        },
        {
          "title": "Green Room",
          "year": 2015,
          "note": "Where Stearns became a fan of one of his cast members."
        },
        {
          "title": "Kumiko, the Treasure Hunter",
          "year": 2014,
          "note": "David Zellner's film; Stearns admired his performance and cast him as Henry."
        },
        {
          "title": "Climax",
          "year": 2018,
          "note": "Stearns' last-great-thing pick, though 'Enter the Void' remains his favorite Gaspar Noe."
        },
        {
          "title": "Enter the Void",
          "year": 2010
        },
        {
          "title": "The Living Wake",
          "year": 2007,
          "note": "Eisenberg's reference point for funny-but-not-comic tone: a gift to act inside a consistent world."
        },
        {
          "title": "Zombieland: Double Tap",
          "year": 2019,
          "note": "Eisenberg contrasts its million-shots, cut-it-together scale with the precision of 'The Art of Self-Defense.'"
        }
      ]
    }
  ],
