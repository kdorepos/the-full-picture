      "kind": "review",
      "heading": "'Prey'",
      "note": "the seventh Predator movie, streaming on Hulu",
      "films": [
        {
          "title": "Prey",
          "year": 2022,
          "note": "A 1719-set prequel with a Comanche lead (Amber Midthunder) hunting the first Predator to land on Earth, and the first feature film dubbed entirely in Comanche. Chris calls it 'elemental' and 'muddy, dusty... grimy': slow to start, but the last 70 minutes deliver three or four big set pieces. Both hosts think it plays better on a big screen than the Hulu default."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "The Predator Movie Rankings",
      "note": "best to worst",
      "subject": "the Predator franchise",
      "ranked": true,
      "films": [
        {
          "title": "Predator",
          "year": 1987,
          "note": "No. 1: 'the best use of Schwarzenegger' and, per Sean, 'one of the great action movies maybe ever made.' Hasn't aged a day."
        },
        {
          "title": "Predators",
          "year": 2010,
          "note": "The Robert Rodriguez-produced, Nimrod Antal-directed entry both hosts love: 'trash special ops and junk sci-fi,' with Walton Goggins, Adrien Brody, Laurence Fishburne, Topher Grace, and Mahershala Ali."
        },
        {
          "title": "Prey",
          "year": 2022,
          "note": "'Probably the third best of these films in totality,' per Sean, though he thinks it might climb with rewatches."
        },
        {
          "title": "Predator 2",
          "year": 1990,
          "note": "Danny Glover, Ruben Blades, and a very 1990 gang-war plot. Sean calls it 'honestly less successful than Prey,' though it's earned a cult following over the years."
        },
        {
          "title": "The Predator",
          "year": 2018,
          "note": "Shane Black's version. 'Bad vibe central,' per Sean, who says it 'was not really fully together,' hampered by reshoots and a production controversy that overshadowed it."
        },
        {
          "title": "AVP: Alien vs. Predator",
          "year": 2004,
          "note": "Bottom tier for both hosts. Sean: 'that movie doesn't really stack up to the others.'"
        },
        {
          "title": "Aliens vs Predator: Requiem",
          "year": 2007,
          "note": "The floor of the franchise."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Dan Trachtenberg on",
      "films": [
        {
          "title": "Prey",
          "year": 2022,
          "note": "Trachtenberg pitched it in 2017 as a Rogue One-style side story, then watched it get shelved through the Fox-Disney merger before 20th Century read the script again. He redesigned the Predator's silhouette to recapture the original's three-stage reveal, and describes shooting the swamp sequence in a dug-out mud pit that reeked so badly some actors needed doubles."
        }
      ]
    }
