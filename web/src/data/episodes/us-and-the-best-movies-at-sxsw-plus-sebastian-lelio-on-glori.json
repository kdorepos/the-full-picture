        },
        {
          "title": "The Beach Bum",
          "year": 2019,
          "note": "Harmony Korine's loose, episodic portrait of a Florida burnout poet, with Matthew McConaughey and Snoop Dogg"
        },
        {
          "title": "Running with Beto",
          "year": 2019,
          "note": "HBO documentary following Beto O'Rourke's Senate run against Ted Cruz"
        },
        {
          "title": "Mickey and the Bear",
          "year": 2019,
          "note": "Annabelle Attanasio's debut, with Camila Morrone as a Montana teenager caring for her opioid-addicted veteran father, played by James Badge Dale"
        },
        {
          "title": "Booksmart",
          "year": 2019,
          "note": "Olivia Wilde's directorial debut, with Beanie Feldstein and Kaitlyn Dever cramming a missed high school experience into one night before graduation"
        },
        {
          "title": "Adopt a Highway",
          "year": 2019,
          "note": "Logan Marshall-Green's directorial debut, with Ethan Hawke as an ex-convict trying to rebuild his life"
        },
        {
          "title": "Her Smell",
          "year": 2019,
          "note": "Alex Ross Perry's portrait of a self-destructive 90s rock star, played by Elisabeth Moss"
        },
        {
          "title": "The Art of Self-Defense",
          "year": 2019,
          "note": "Riley Stearns' deadpan story of a man, played by Jesse Eisenberg, who takes up karate after being attacked"
