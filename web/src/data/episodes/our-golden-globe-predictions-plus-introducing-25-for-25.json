        },
        {
          "title": "The Lion King",
          "year": 2019,
          "note": "Notably not requested at home, alongside Mufasa."
        },
        {
          "title": "Aladdin",
          "year": 2019,
          "note": "In the live-action-remake chain the show has covered over the years."
        },
        {
          "title": "Maleficent: Mistress of Evil",
          "year": 2019,
          "note": "Also covered; Alice hasn't gotten that far down the chain."
        },
        {
          "title": "101 Dalmatians",
