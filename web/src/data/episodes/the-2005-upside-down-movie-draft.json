  "published": "2022-09-02",
  "runtimeMin": 104,
  "format": "Sean, Amanda, and Chris draft only movies that bombed, got trashed by critics, or landed a Razzie nod, because 2005 was, in Sean's telling, a genuinely bad year for movies.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The Upside-Down Draft",
      "note": "eligible: under $30M on 1,000+ screens, under 70% on Rotten Tomatoes, or a Razzie nominee — plus one wildcard pick, no restrictions",
      "draftOf": "2005 movies",
      "categories": [
        "Drama",
        "Comedy",
        "Razzie nominee",
        "Action/Thriller/Horror",
        "Bomb",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The New World",
              "year": 2005,
              "category": "Drama",
              "note": "Malick's first film since \"The Thin Red Line,\" 63% on Rotten Tomatoes. Sean calls it one of the most beautiful movies ever made; Chloé Zhao is a fan too."
            },
            {
              "title": "The Weather Man",
              "year": 2005,
              "category": "Comedy",
              "note": "Nicolas Cage as a disrespected weatherman trying to turn his life around, directed by Gore Verbinski, with Michael Caine and Hope Davis."
            },
            {
              "title": "Star Wars: Episode III - Revenge of the Sith",
              "year": 2005,
              "category": "Razzie nominee",
              "note": "\"Was good then, is good now,\" per Sean, who's held the line since arguing about it with a friend back in 2005."
            },
            {
              "title": "The Devil's Rejects",
              "year": 2005,
              "category": "Action/Thriller/Horror",
              "note": "Rob Zombie's follow-up to \"House of 1000 Corpses,\" tied with Chris's \"Wolf Creek\" at a 54% score."
            },
            {
              "title": "Elizabethtown",
              "year": 2005,
              "category": "Bomb",
              "note": "Cameron Crowe's \"Almost Famous\" follow-up, widely blamed for ending his hot streak. Sean still likes it."
            },
            {
              "title": "The Squid and the Whale",
              "year": 2005,
              "category": "Wildcard",
              "note": "Sean grabbed it before Amanda could; one of his favorite films, period."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Family Stone",
              "year": 2005,
              "category": "Drama",
              "note": "Diane Keaton, Craig T. Nelson, Rachel McAdams, and Luke Wilson; 52% on Rotten Tomatoes for a movie Amanda considers a Christmas classic."
            },
            {
              "title": "Hitch",
              "year": 2005,
              "category": "Comedy",
              "note": "Will Smith and Eva Mendes, directed by Andy Tennant. Amanda: \"Hitch is bad,\" but she's taking it anyway."
            },
            {
              "title": "Batman Begins",
              "year": 2005,
              "category": "Razzie nominee",
              "note": "Katie Holmes drew a Worst Supporting Actress nod; the role gets recast in \"The Dark Knight.\""
            },
            {
              "title": "Mr. & Mrs. Smith",
              "year": 2005,
              "category": "Action/Thriller/Horror",
              "note": "Where Brad Pitt and Angelina Jolie met, directed by Doug Liman. 59% on Rotten Tomatoes."
            },
            {
              "title": "Prime",
              "year": 2005,
              "category": "Bomb",
              "note": "Meryl Streep, Uma Thurman, and Bryan Greenberg, chosen over \"Proof\" after \"Mad Hot Ballroom\" turned out to be disqualified."
            },
            {
              "title": "Brokeback Mountain",
              "year": 2005,
              "category": "Wildcard",
              "note": "Ang Lee's film, with Heath Ledger and Jake Gyllenhaal, that lost Best Picture to \"Crash.\""
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Kingdom of Heaven",
              "year": 2005,
              "category": "Drama",
              "note": "Ridley Scott's Crusades epic, 39% on Rotten Tomatoes. Chris prefers the four-hour director's cut but still calls it \"bad Gladiator.\""
            },
            {
              "title": "Fever Pitch",
              "year": 2005,
              "category": "Comedy",
              "note": "The Farrelly brothers adapt Nick Hornby's soccer memoir into a Red Sox movie."
            },
            {
              "title": "War of the Worlds",
              "year": 2005,
              "category": "Razzie nominee",
              "note": "Tom Cruise's Spielberg thriller drew a Worst Actor nomination purely off the Oprah-couch backlash."
            },
            {
              "title": "Wolf Creek",
              "year": 2005,
              "category": "Action/Thriller/Horror",
              "note": "Australian outback horror Chris calls one of the genre's best setups."
            },
            {
              "title": "Domino",
              "year": 2005,
              "category": "Bomb",
              "note": "Tony Scott's Keira Knightley bounty-hunter thriller, scripted by Richard Kelly right after \"Donnie Darko.\""
            },
            {
              "title": "Kiss Kiss Bang Bang",
              "year": 2005,
              "category": "Wildcard",
              "note": "Shane Black's Robert Downey Jr./Val Kilmer neo-noir. Chris still won't pick between this and \"The Nice Guys.\""
            }
          ]
        }
