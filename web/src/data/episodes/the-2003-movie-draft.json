      "teams": [
        {
          "host": "Mallory Rubin",
          "picks": [
            {
              "title": "The Lord of the Rings: The Return of the King",
              "year": 2003,
              "category": "Oscar Nominee",
              "note": "The number one overall pick. 11 Oscar nominations, 11 wins, and a movie she says she rewatches every year."
            },
            {
              "title": "Mystic River",
              "year": 2003,
              "category": "Drama",
              "note": "Six Oscar nominations for the Eastwood film Sean was sure he'd get first."
            },
            {
              "title": "Elf",
              "year": 2003,
              "category": "Blockbuster",
              "note": "A third-round pick that made the rest of the table groan with envy."
            },
            {
              "title": "X2",
              "year": 2003,
              "category": "Action / Horror",
              "note": "She was shocked it lasted this deep into a thin blockbuster year."
            },
            {
              "title": "Love Actually",
              "year": 2003,
              "category": "Comedy",
              "note": "Her annual Christmas watch, defended at length despite Sean calling it terrible."
            },
            {
              "title": "S.W.A.T.",
              "year": 2003,
              "category": "Wild Card",
              "note": "The pick her household kept bringing up unprompted while she prepped."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Finding Nemo",
              "year": 2003,
              "category": "Blockbuster",
              "note": "Second overall. He watches it differently now that he's a new dad."
            },
            {
              "title": "Bad Boys II",
              "year": 2003,
              "category": "Action / Horror",
              "note": "Peak Michael Bay, 360-degree shootout included."
            },
            {
              "title": "The School of Rock",
              "year": 2003,
              "category": "Comedy",
              "note": "Linklater and Jack Black; wasn't even his top comedy option this year."
            },
            {
              "title": "Matchstick Men",
              "year": 2003,
              "category": "Drama",
              "note": "Ridley Scott's low-key con movie, Nicolas Cage opposite Sam Rockwell."
            },
            {
              "title": "City of God",
              "year": 2003,
              "category": "Oscar Nominee",
              "note": "Fernando Meirelles' Brazilian crime epic, taken from a thin category."
            },
            {
              "title": "The Fog of War",
              "year": 2003,
              "category": "Wild Card",
              "note": "Errol Morris's Robert McNamara documentary, picked over Memories of Murder."
            }
          ]
        },
        {
          "host": "Joanna Robinson",
          "picks": [
            {
              "title": "Master and Commander: The Far Side of the World",
              "year": 2003,
              "category": "Drama",
              "note": "Her passion pick, played first overall for her: Peter Weir, Russell Crowe, Paul Bettany."
            },
            {
              "title": "Pirates of the Caribbean: The Curse of the Black Pearl",
              "year": 2003,
              "category": "Blockbuster",
              "note": "Made Orlando Bloom interesting, somehow."
            },
            {
              "title": "A Mighty Wind",
              "year": 2003,
              "category": "Comedy",
              "note": "Not Christopher Guest's best, but she knows every song on the soundtrack."
            },
            {
              "title": "In America",
              "year": 2003,
              "category": "Oscar Nominee",
              "note": "Jim Sheridan; her most-rewatched film of the year, and the one she cries through every time."
            },
            {
              "title": "28 Days Later",
              "year": 2003,
              "category": "Action / Horror",
              "note": "Danny Boyle and Cillian Murphy, right before he got much bigger."
            },
            {
              "title": "The Station Agent",
              "year": 2003,
              "category": "Wild Card",
              "note": "Tom McCarthy's debut, her introduction to Peter Dinklage."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Lost in Translation",
              "year": 2003,
