{
  "slug": "the-1990s-horror-movie-canon-and-i-know-what-you-did-last-su",
  "title": "The 1990s Horror Movie Canon and 'I Know What You Did Last Summer.' Plus: The 'KPop Demon Hunters' Revolution.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-07-30",
  "runtimeMin": 91,
  "format": "Sean and Amanda open on the settling superhero box office, bring in Andy Greenwald to sort out why 'KPop Demon Hunters' took off, pan the new 'I Know What You Did Last Summer,' and close with Sean's 10-film canon of 1990s horror.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The box-office check-in",
      "note": "the superhero life cycle, settling down",
      "films": [
        {
          "title": "The Fantastic 4: First Steps",
          "year": 2025,
          "note": "$118 million domestic on 4,125 screens plus $100 million overseas, tracking 'Superman' and headed for the $600-700 million range. Sean's read: a big part of the business, no longer the biggest, with China checked out and Europe cooling. Andy loved it; the hosts didn't."
        },
        {
          "title": "Superman",
          "year": 2025,
          "note": "The comparison point, off about 54% in its second weekend and landing in the same $600-700 million band. The new baseline for what a superhero tentpole clears now."
        },
        {
          "title": "Avengers: Endgame",
          "year": 2019,
          "note": "The once-in-a-lifetime peak nobody can reheat, no matter what Marvel puts on the 2026 calendar. You can't reheat a souffle."
        },
        {
          "title": "Lilo & Stitch",
          "year": 2025,
          "note": "Amanda's counterexample, the kind of mid-budget hit stepping into the space the billion-dollar superhero movie used to own."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "'KPop Demon Hunters'",
      "note": "with Andy Greenwald",
      "guest": "Andy Greenwald on",
      "films": [
        {
          "title": "KPop Demon Hunters",
          "year": 2025,
          "note": "Directed by Maggie Kang and Chris Appelhans for Sony, released to Netflix, and the first Netflix film to grow week over week. All three came in braced for algorithm slop and got charmed: five genuine K-pop bangers (Sean added 'Golden' and cites 'Soda Pop'), a Minecraft-style collision of tones, chibi and mockumentary flourishes kids read fluently. Amanda watched it with her four-year-old and it saved her summer; Andy the demon-hunting skeptic came around by minute four. The gripe: the half-demon Rumi arc and the Celine character are underdrawn."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "'I Know What You Did Last Summer'",
      "note": "the legacy sequel, and the 1997 hit it reboots",
      "films": [
        {
          "title": "I Know What You Did Last Summer",
          "year": 2025,
          "note": "Written and directed by Jennifer Kaytin Robinson, co-written by Sam Lansky, with Madelyn Cline, Chase Sui Wonders, Jonah Hauer-King, Tyriq Withers, Sarah Pidgeon, and returning originals Jennifer Love Hewitt, Freddie Prinze Jr., and Sarah Michelle Gellar. Both hosts hated it, Amanda calls it disrespectful, Sean one of the worst of the year. The core flaw: a slasher that wants you to love kids too likable to kill, so nobody dies and the stakes evaporate, plus a trauma-on-a-chalkboard streak and a tonal record-scratch ending."
        },
        {
          "title": "I Know What You Did Last Summer (1997)",
          "year": 1997,
          "note": "The Kevin Williamson-scripted original, the second most culturally significant teen slasher of the 90s horror rebirth (the Oppenheimer to Scream's Barbie, per Sean). Not a great script, but studio-craft handsome, with Jennifer Love Hewitt, Sarah Michelle Gellar, Freddie Prinze Jr., and Ryan Phillippe at peak heartthrob. Gellar getting killed off is the kind of real stake the reboot won't touch."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Sean's 1990s horror canon",
      "note": "10 films from a strange decade",
      "subject": "1990s horror",
      "ranked": true,
      "films": [
        {
          "title": "Scream",
          "year": 1996,
          "note": "Still the one that holds up, metabolizing 20 years of slashers and teaching a generation, Sean at 14 included, how to watch movies. Kicked off the whole teen-slasher wave that followed."
        },
        {
          "title": "Wes Craven's New Nightmare",
          "year": 1994,
          "note": "Craven's metatextual Freddy send-off, the real people who made the movies pulled into one. Paired with Scream as Sean's tribute to a filmmaker he thinks is getting forgotten."
        },
        {
          "title": "The Blair Witch Project",
          "year": 1999,
          "note": "The found-footage movie that made the format work, 81 minutes and still terrifying. Sticks to its own rules so hard the unexplained why-keep-filming never breaks the spell."
        },
        {
          "title": "Bram Stoker's Dracula",
          "year": 1992,
          "note": "Arguably the best-made horror film of the decade: Coppola's production design, score, costumes, and Gary Oldman's makeup, give or take a wobbly Keanu Reeves. Sean's argument for the monster movie; Amanda's out on monsters entirely."
        },
        {
          "title": "Ringu",
          "year": 1998,
          "note": "Hideo Nakata's cursed-videotape movie, the Big Bang of the J-horror wave and the basis for the 2002 American remake. Sean takes it over Audition because it came first."
        },
        {
          "title": "In the Mouth of Madness",
          "year": 1994,
          "note": "Probably the last great film John Carpenter made, Sam Neill going insane chasing a Stephen King-esque author whose visions drive readers mad. Just announced for a 4K release, to Sean's group-chat joy."
        },
        {
          "title": "Candyman",
          "year": 1992,
          "note": "The rare pre-Scream horror that stuck, Bernard Rose's Cabrini-Green legend with the late Tony Todd and Virginia Madsen. The say-it-five-times mirror dare every 90s teenager knew."
        },
        {
          "title": "Event Horizon",
          "year": 1997,
          "note": "Paul W.S. Anderson's space-horror one-off (Sam Neill losing his mind on a spaceship), the lone sci-fi entry and, Sean says, genuinely scary. Filed under 'for CR.'"
        },
        {
          "title": "The Exorcist III",
          "year": 1990,
          "note": "A callback to the 70s and 80s classics, home to what Sean calls maybe the great jump scare of the 90s. Tracy and Chris talked him into it in Chicago."
        },
        {
          "title": "Funny Games",
          "year": 1997,
          "note": "Haneke's original German version, two tennis-clad young men terrorizing a family for no clear reason. Fits the violence-is-the-line rule Sean uses to define horror; the scariest movie Tracy's ever seen."
        }
      ]
    }
  ],
