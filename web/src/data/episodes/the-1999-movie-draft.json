{
  "slug": "the-1999-movie-draft",
  "title": "The 1999 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan",
    "Van Lathan",
    "Mallory Rubin",
    "Joanna Robinson",
    "Rob Mahoney"
  ],
  "published": "2024-04-16",
  "runtimeMin": 152,
  "format": "A seven-person snake draft of the movies of 1999, the 40th Big Picture draft, with each drafter filling a six-slot roster across Drama, Comedy, Action/Thriller/Horror, Blockbuster, Oscar Nominee, and Wild Card.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "the movies of 1999",
      "categories": [
        "Drama",
        "Comedy",
        "Action / Thriller / Horror",
        "Blockbuster",
        "Oscar Nominee",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Talented Mr. Ripley",
              "year": 1999,
              "category": "Oscar Nominee",
              "note": "The No. 1 overall pick. Minghella's Italy, young Damon, Jude Law, Gwyneth, Blanchett and Philip Seymour Hoffman all in flight."
            },
            {
              "title": "The Thomas Crown Affair",
              "year": 1999,
              "category": "Action / Thriller / Horror",
              "note": "McTiernan's heist remake; Brosnan's best not-Bond, Rene Russo's clothes. She won't part with it for $10 million."
            },
            {
              "title": "Austin Powers: The Spy Who Shagged Me",
              "year": 1999,
              "category": "Blockbuster",
              "note": "Taken partly out of spite. Heather Graham as Felicity Shagwell."
            },
            {
              "title": "Cruel Intentions",
              "year": 1999,
              "category": "Drama",
              "note": "A teen-Amanda pick and a top-five-most-seen of the year for her."
            },
            {
              "title": "Dick",
              "year": 1999,
              "category": "Comedy",
              "note": "Kirsten Dunst and Michelle Williams as the girls behind Deep Throat; Will Ferrell's Bob Woodward."
            },
            {
              "title": "The Best Man",
              "year": 1999,
              "category": "Wild Card",
              "note": "A melodramatic college-reunion movie with a stacked cast; a functional Regina Hall debut."
            }
          ]
        },
        {
          "host": "Rob Mahoney",
          "picks": [
            {
              "title": "The Matrix",
              "year": 1999,
              "category": "Blockbuster",
              "note": "Second overall. Plays like a noir for the first 40 minutes, then turns into an exposition dump, then becomes the superhero story of the era."
            },
            {
              "title": "Notting Hill",
              "year": 1999,
              "category": "Comedy",
              "note": "Snatched from Amanda one pick early. Richard Curtis; Julia Roberts with a little edge."
            },
            {
              "title": "Election",
              "year": 1999,
              "category": "Oscar Nominee",
              "note": "Payne's suburban-malaise comedy; Rob's pick for best movie of the year."
            },
            {
              "title": "eXistenZ",
              "year": 1999,
              "category": "Action / Thriller / Horror",
              "note": "The goopy-port other side of Jude Law; a Cronenberg double feature with The Matrix."
            },
            {
              "title": "The Straight Story",
              "year": 1999,
              "category": "Drama",
              "note": "Lynch, presented by Disney; Richard Farnsworth nominated. Hits hardest if you're a brother of a brother."
            },
            {
              "title": "Perfect Blue",
              "year": 1997,
              "category": "Wild Card",
              "note": "Satoshi Kon's pop-idol nightmare; maybe the scariest movie of the year, and pertinent to stan culture."
            }
          ]
        },
        {
          "host": "Van Lathan",
          "picks": [
            {
              "title": "Fight Club",
              "year": 1999,
              "category": "Action / Thriller / Horror",
              "note": "Van's favorite of the year. A sticky movie: late capitalism, confronting your delusions, peak Pitt."
            },
            {
              "title": "Star Wars: Episode I - The Phantom Menace",
              "year": 1999,
              "category": "Blockbuster",
              "note": "Cost Van $200 (tires for a ride to Monroe). Terrible on exit, redeemed by the final lightsaber duel."
            },
            {
              "title": "American Beauty",
              "year": 1999,
              "category": "Oscar Nominee",
              "note": "The Best Picture winner nobody else would touch. Van reads it as suburban satire; the table argues it takes itself too seriously."
            },
            {
              "title": "Varsity Blues",
              "year": 1999,
              "category": "Comedy",
              "note": "Besides The Matrix, the '99 movie Van watched the most."
            },
            {
              "title": "Arlington Road",
              "year": 1999,
              "category": "Drama",
              "note": "A taut, very pre-9/11 paranoia thriller. Tim Robbins sinister, the good guys lose."
            },
            {
              "title": "Dogma",
              "year": 1999,
              "category": "Wild Card",
              "note": "The Kevin Smith movie Van feels most connected to, a 'fuck your parents' film. Still hard to stream over rights."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Sixth Sense",
              "year": 1999,
              "category": "Blockbuster",
              "note": "Shyamalan; a Daily Show correspondent spoiled it for Sean, but it still worked. He watched it three times over the weekend."
            },
            {
              "title": "Eyes Wide Shut",
              "year": 1999,
              "category": "Action / Thriller / Horror",
              "note": "Sean's most-anticipated of '99. Kubrick's last, released after his death; read about it in the Post at his warehouse job."
            },
            {
              "title": "South Park: Bigger, Longer & Uncut",
              "year": 1999,
              "category": "Comedy",
              "note": "The movie playing when Sean's now-wife knew he was the one. 80 minutes, still relevant."
            },
            {
              "title": "The Limey",
              "year": 1999,
              "category": "Drama",
              "note": "Soderbergh; Terence Stamp as a career criminal in L.A. Famous for the Soderbergh/Lem Dobbs argument commentary."
            },
            {
              "title": "Being John Malkovich",
              "year": 1999,
              "category": "Oscar Nominee",
              "note": "Jonze and Kaufman; a gateway to weird mainstream movies, and to Lost in Translation."
            },
            {
              "title": "Run Lola Run",
              "year": 1998,
              "category": "Wild Card",
              "note": "Tykwer; Franka Potente running, choose-your-own-adventure structure, all German techno. Bled into Bourne."
            }
          ]
        },
        {
          "host": "Joanna Robinson",
          "picks": [
            {
              "title": "The Mummy",
              "year": 1999,
              "category": "Blockbuster",
              "note": "A '99 banger that's only grown; the movie that made Brendan Fraser and a bisexual awakening for many."
            },
            {
              "title": "Magnolia",
              "year": 1999,
              "category": "Oscar Nominee",
              "note": "PTA; Joanna's favorite Hoffman and Julianne Moore performances, and a huge Cruise moment. The double-VHS box set."
            },
            {
              "title": "Galaxy Quest",
              "year": 1999,
              "category": "Action / Thriller / Horror",
              "note": "The Star Trek parody that hit on VHS and DVD. Weaver, Rickman, Rockwell, Shalhoub."
            },
            {
              "title": "Three Kings",
              "year": 1999,
              "category": "Drama",
              "note": "Russell's Gulf War movie; Ice Cube. Taken to deny Adam."
            },
            {
              "title": "Drop Dead Gorgeous",
              "year": 1999,
              "category": "Comedy",
              "note": "Dry-as-a-bone beauty-pageant mockumentary. Dunst, Denise Richards, Kirstie Alley, Ellen Barkin. Not on streaming."
            },
            {
              "title": "The Iron Giant",
              "year": 1999,
              "category": "Wild Card",
              "note": "Bird's best film; he's not a gun. Taken away from Mallory."
            }
          ]
        },
        {
          "host": "Mallory Rubin",
          "picks": [
            {
              "title": "Office Space",
              "year": 1999,
              "category": "Comedy",
              "note": "A patron-saint film of The Ringer; a heavily-worn DVD and a meme generator ever since."
            },
            {
              "title": "Toy Story 2",
              "year": 1999,
              "category": "Blockbuster",
              "note": "A Pixar behemoth (and the table's agreed weakest Toy Story). 'When She Loved Me' will wreck you."
            },
            {
              "title": "Lock, Stock and Two Smoking Barrels",
              "year": 1998,
              "category": "Action / Thriller / Horror",
              "note": "Guy Ritchie; Mallory watched it endlessly with a high-school boyfriend. Taken to Chris's dismay."
            },
            {
              "title": "10 Things I Hate About You",
              "year": 1999,
              "category": "Wild Card",
              "note": "A top-10 movie of the year for her, grabbed early in Wild Card to keep it off the board. 'Can't Take My Eyes Off You.'"
            },
            {
              "title": "Princess Mononoke",
              "year": 1997,
              "category": "Drama",
              "note": "Miyazaki; beautiful and dark, still holds up. It was this or Iron Giant."
            },
            {
              "title": "The End of the Affair",
              "year": 1999,
              "category": "Oscar Nominee",
              "note": "A Ralph Fiennes passion pick over any actual Oscar winner. Julianne Moore, and a cinematography nom."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "The Blair Witch Project",
              "year": 1999,
              "category": "Blockbuster",
              "note": "One of the most memorable times Chris ever had in a theater; kicked off viral marketing. Van hated it in the theater."
            },
            {
              "title": "The Insider",
              "year": 1999,
              "category": "Oscar Nominee",
              "note": "Michael Mann; Pacino's late-'90s Renaissance and Crowe slingshotting to best-movie-star-alive."
            },
            {
              "title": "Go",
              "year": 1999,
              "category": "Comedy",
              "note": "Chris's Magnolia at the time. Katie Holmes, Sarah Polley, Timothy Olyphant. Overdue for a new scan."
            },
            {
              "title": "Any Given Sunday",
              "year": 1999,
              "category": "Drama",
              "note": "Stone's football movie; Pacino's halftime speech, a Greek conception of drama."
            },
            {
              "title": "8mm",
              "year": 1999,
              "category": "Action / Thriller / Horror",
              "note": "The Machine. Cage and Joaquin Phoenix; a sexually depraved blockbuster and the highest-rated Rewatchables ever."
            },
            {
              "title": "Bowfinger",
              "year": 1999,
              "category": "Wild Card",
              "note": "One of Chris's favorite Steve Martin performances and a great Hollywood send-up. Poorly marketed at the time."
            }
          ]
        }
      ],
