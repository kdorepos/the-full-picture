    {
      "kind": "topfive",
      "heading": "Amanda's Top Five ‘Ballet Trash' Movies",
      "note": "her made-up genre: someone with the skill and the love who doesn't fit, and triumphs",
      "subject": "Ballet trash",
      "ranked": true,
      "films": [
        {
          "title": "Center Stage",
          "year": 2000,
          "note": "No. 1. Nicholas Hytner's ballet-school movie with real dancers and Zoe Saldaña. Amanda rewatched it twice in a day to make this list."
        },
        {
          "title": "Magic Mike",
          "year": 2012,
          "note": "No. 2. Allowed because she invented the genre: her Channing Tatum pick, and Soderbergh's ‘Singin' in the Rain.'"
        },
        {
          "title": "Dirty Dancing",
          "year": 1987,
          "note": "No. 3. Baby, the lift, and Patrick Swayze as a proto-Tatum."
        },
        {
          "title": "Bring It On",
          "year": 2000,
          "note": "No. 4. Kirsten Dunst; cheerleading as choreography theft. Kicked off a run through You Got Served and Step Up."
        },
        {
          "title": "White Nights",
          "year": 1985,
          "note": "No. 5. Taylor Hackford Cold War dance movie with Baryshnikov, Gregory Hines and Isabella Rossellini's debut. Amanda saw it around age eight."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five Dance Movies",
      "note": "his sub-theme: the agony of dance, the physical toll",
      "subject": "Dance movies",
      "ranked": true,
      "films": [
        {
          "title": "All That Jazz",
          "year": 1979,
          "note": "No. 1. Bob Fosse's thinly veiled autobiography, Roy Scheider as Fosse: a fantasia of depression that opens and closes on all-time dance numbers."
        },
        {
          "title": "The Red Shoes",
          "year": 1948,
          "note": "No. 2. Powell and Pressburger on a ballerina forced to choose between art and love; a huge Scorsese influence."
        },
        {
          "title": "Pina",
          "year": 2011,
          "note": "No. 3. Wim Wenders' tribute-turned-performance-piece to choreographer Pina Bausch."
        },
        {
          "title": "It's Always Fair Weather",
          "year": 1955,
          "note": "No. 4. The last, bitter Kelly-Donen collaboration; the Cyd Charisse boxing-ring number. He'd considered An American in Paris first."
        },
        {
          "title": "They Shoot Horses, Don't They?",
          "year": 1969,
          "note": "No. 5. Sydney Pollack's Depression-set dance-marathon tragedy; Jane Fonda and an Oscar-nominated Gig Young."
        }
      ]
    }
