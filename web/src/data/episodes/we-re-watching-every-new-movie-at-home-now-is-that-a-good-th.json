{
  "slug": "we-re-watching-every-new-movie-at-home-now-is-that-a-good-th",
  "title": "We're Watching Every New Movie at Home Now. Is That a Good Thing? Plus: Bill Simmons on 'The Hunt.'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-03-24",
  "runtimeMin": 86,
  "format": "Sean spends a full weekend bingeing eight new VOD releases; then he and Amanda review Emma and The Hunt before Bill Simmons stops by to defend on-demand releases and re-litigate Ben Affleck's career.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Sean's Quarantine Watchlist",
      "note": "everything he watched in one weekend",
      "films": [
        {
          "title": "The Platform",
          "year": 2019,
          "note": "Grueling class-warfare horror on Netflix, watched Friday at 4 p.m., the first of the weekend's binge."
        },
        {
          "title": "Blow the Man Down",
          "year": 2019,
          "note": "Amazon Prime noir Sean pitches as the Coen brothers meets Nicole Holofcener; would pair well with The Lighthouse."
        },
        {
          "title": "Black Christmas",
          "year": 2019,
          "note": "The 2019 remake, an Amazon rental he'd missed at the end of last year."
        },
        {
          "title": "Color Out of Space",
          "year": 2019,
          "note": "A trippy Nicolas Cage cosmic-horror movie on iTunes; he later recommends it to Bill Simmons too."
        },
        {
          "title": "The Jesus Rolls",
          "year": 2019,
          "note": "An ostensible Big Lebowski spinoff following John Turturro's Jesus character."
        },
        {
          "title": "The Wild Goose Lake",
          "year": 2019,
          "note": "A Cannes premiere he caught on Film Movement for a $12 virtual ticket, the best thing he watched all weekend."
        },
        {
          "title": "Saint Frances",
          "year": 2019,
          "note": "An Oscilloscope rental he hadn't started yet, about a young woman's abortion and the friendship that follows."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Emma",
      "note": "on iTunes, missed in theaters",
      "films": [
        {
          "title": "Emma",
          "year": 2020,
          "note": "Autumn de Wilde's directorial debut, with Anya Taylor-Joy as Emma and Johnny Flynn as Knightley. Sean calls it 'a flipped house': fresh coat of paint, same foundation, not entirely trustworthy. Both land on well-made but unnecessary next to Clueless and the 1996 Gwyneth Paltrow version."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "Old-Person Recommendations",
      "note": "for Amanda's mom",
      "picks": [
        {
          "title": "Knives Out",
          "year": 2019,
          "by": "Amanda Dobbins",
          "note": "Currently No. 1 on the VOD chart, behind only Onward."
        },
        {
          "title": "Death on the Nile",
          "year": 1978,
          "by": "Amanda Dobbins",
          "note": "The original Peter Ustinov Poirot, before the remake."
        },
        {
          "title": "Evil Under the Sun",
          "year": 1982,
          "by": "Amanda Dobbins",
          "note": "Another late Agatha Christie outing in the same vein."
        },
        {
          "title": "Local Hero",
          "year": 1983,
          "by": "Sean Fennessey",
          "note": "Bill Forsyth's dramedy about a Texas oil man sent to acquire a Scottish village; newly on Criterion Channel."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "The Hunt",
      "note": "the most talked-about movie nobody saw",
      "films": [
        {
          "title": "The Hunt",
          "year": 2020,
          "note": "Written by Nick Cuse and Damon Lindelof, directed by Craig Zobel. Sean and Amanda land on 'not terrible, just not good': a Blumhouse premise about polarization that never commits to a point of view, saved by Betty Gilpin."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Bill Tells Sean He's Wrong About a Movie",
      "guest": "Bill Simmons on",
      "note": "VOD economics, Affleck, and Hillary Swank's Hunt performance",
      "films": [
        {
          "title": "The Hunt",
          "year": 2020,
          "note": "Bill liked it more than Sean and Amanda did, going in with lower expectations, and thinks Betty Gilpin proved herself a star."
        },
        {
          "title": "The Way Back",
          "year": 2020,
          "note": "Affleck as an alcoholic basketball coach; Bill calls it his best performance in 15 years."
        },
        {
          "title": "The Irishman",
