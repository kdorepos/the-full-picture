{
  "slug": "its-saturday-night-plus-the-top-five-backstage-movies-and-pi",
  "title": "It’s ‘Saturday Night’! Plus: The Top Five Backstage Movies and ‘Piece by Piece.’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2024-10-11",
  "runtimeMin": 115,
  "format": "Sean Fennessey and Chris Ryan review Jason Reitman's real-time SNL-origin movie 'Saturday Night,' then each rank five favorite backstage movies. Then Sean and New York Times critic John Caramanica dig into 'Piece by Piece,' the Lego-animated Pharrell Williams doc.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The ‘A Complete Unknown’ trailer",
      "note": "Mangold's Dylan movie, judged on two minutes",
      "films": [
        {
          "title": "A Complete Unknown",
          "year": 2024,
          "note": "James Mangold's mid-'60s Dylan film, out Christmas Day. Sean, a Dylan obsessive, was underwhelmed by the second trailer and read it as A Star Is Born-style modernization; both figure that means it'll be a hit. The agreed highlight: Boyd Holbrook as Johnny Cash, minus the voice."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Saturday Night’",
      "films": [
        {
          "title": "Saturday Night",
          "year": 2024,
          "note": "Reitman's real-time run at the 90 minutes before the first SNL broadcast, October 11, 1975. Both hosts had fun and found it forgettable, a 'vacuum movie' carried by Jon Batiste's ticking score and a Sorkin-ish invented enemy in Willem Dafoe's network heavy (the real Dave Tebet was an ally). Standouts: Dylan O'Brien as Aykroyd, Cory Michael Smith as Chevy Chase, Rachel Sennott as Rosie Shuster."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The Top Five Backstage Movies",
      "note": "two lists, five apiece: putting on the show",
      "picks": [
        {
          "title": "Singin' in the Rain",
          "year": 1952,
          "by": "Sean Fennessey",
          "note": "No. 1. The making of a picture and the silent-to-talkies turn; one of his all-time favorites."
        },
        {
          "title": "Tropic Thunder",
          "year": 2008,
          "by": "Sean Fennessey",
          "note": "No. 2. Stiller's send-up of actors lost inside a war-movie shoot, knowingly playing off Apocalypse Now and Hearts of Darkness. McConaughey as the agent, money."
        },
        {
          "title": "A Cock and Bull Story",
          "year": 2005,
          "by": "Sean Fennessey",
          "note": "No. 3. Winterbottom's metafictional 'Tristram Shandy' adaptation with Coogan and Brydon, the precursor to The Trip."
        },
        {
          "title": "Living in Oblivion",
          "year": 1995,
          "by": "Sean Fennessey",
          "note": "No. 4. Tom DiCillo's semi-surreal comedy about how hard it is to shoot a low-budget movie, with Steve Buscemi and Catherine Keener."
        },
        {
          "title": "Contempt",
          "year": 1963,
          "by": "Sean Fennessey",
          "note": "No. 5. Godard's 'Le Mépris': a movie about making a movie, with Bardot, Piccoli, Palance, and Fritz Lang as himself."
        },
        {
          "title": "All That Jazz",
          "year": 1979,
          "by": "Chris Ryan",
          "note": "No. 1. Fosse's autobiographical portrait of a director mounting a show while his body and love life fall apart."
        },
        {
          "title": "Broadcast News",
          "year": 1987,
          "by": "Chris Ryan",
          "note": "No. 2. James L. Brooks inside a network news operation; the Albert Brooks fill-in sequence is true backstage."
        },
        {
          "title": "Day for Night",
          "year": 1973,
          "by": "Chris Ryan",
          "note": "No. 3. Truffaut's love letter to the chaos of a film set, the sunnier answer to Contempt."
        },
        {
          "title": "The Stunt Man",
          "year": 1980,
          "by": "Chris Ryan",
          "note": "No. 4. Peter O'Toole as a manipulative director, Steve Railsback as his fugitive stuntman; Richard Rush's ode to practical movie magic."
        },
        {
          "title": "The Player",
          "year": 1992,
          "by": "Chris Ryan",
          "note": "No. 5. Altman's black-hearted satire of studio Hollywood, Tim Robbins as the executive drawn into a murder."
        },
        {
          "title": "Original Cast Album: Company",
          "year": 1970,
          "by": "Chris Ryan",
          "note": "Sidecar to No. 1. Pennebaker's document of the 'Company' cast recording: Sondheim and Elaine Stritch, unvarnished. On Criterion Channel."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "‘Piece by Piece’",
      "guest": "John Caramanica on",
      "films": [
        {
          "title": "Piece by Piece",
          "year": 2024,
          "note": "Morgan Neville's Lego-animated Pharrell Williams doc. Caramanica, who's covered Pharrell since around 1999, and Sean agree it's irresistible as hip-hop nostalgia (the Nore-to-Snoop stretch, the beats visualized as Lego objects) but guarded to the point of empty as a film. Pharrell never appears on camera and reveals almost nothing; the second half, after Gwen Stefani, flatlines."
        }
      ]
    }
  ],
