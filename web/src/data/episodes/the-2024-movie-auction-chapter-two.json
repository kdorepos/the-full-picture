      "slates": [
        {
          "host": "Sean Fennessey",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "Anora",
              "year": 2024,
              "price": 410,
              "note": "Sean Baker; Mikey Madison as a sex worker who marries a Russian oligarch's son. Palme d'Or winner. Top lot of the sale, taken off Chris in a bidding war."
            },
            {
              "title": "Nightbitch",
              "year": 2024,
              "price": 321,
              "note": "Marielle Heller; Amy Adams as a stay-at-home mother whose domestic life turns feral. Sean's Amy-Adams-vs-Mikey-Madison Oscar bet."
            },
            {
              "title": "Emilia Pérez",
              "year": 2024,
              "price": 150,
              "note": "Jacques Audiard; Karla Sofía Gascón, Zoe Saldaña, Selena Gomez. A cartel-boss musical. Netflix's Oscar play."
            },
            {
              "title": "The Wild Robot",
              "year": 2024,
              "price": 118,
              "note": "Chris Sanders' DreamWorks animation; Lupita Nyong'o voices the robot. Sean's call for Best Animated Feature."
            },
            {
              "title": "Moana 2",
              "year": 2024,
              "price": 1,
              "note": "Sean's one allowed sequel, grabbed for a dollar as pure box office."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "spent": 980,
          "budgetLeft": 20,
          "picks": [
            {
              "title": "Trap",
              "year": 2024,
              "price": 345,
              "note": "M. Night Shyamalan; Josh Hartnett as a serial killer boxed in at a pop concert. Amanda's birthday movie: she says she'd have gone to $700."
            },
            {
              "title": "Queer",
              "year": 2024,
              "price": 225,
              "note": "Luca Guadagnino adapts William S. Burroughs; Daniel Craig. Rumored to open Venice. Taken from Sean, who nominated it."
            },
            {
              "title": "Conclave",
              "year": 2024,
              "price": 205,
              "note": "Edward Berger's follow-up to All Quiet on the Western Front; Ralph Fiennes, Stanley Tucci, John Lithgow, Isabella Rossellini. A papal-election thriller Amanda called a Big Picture uniter."
            },
            {
              "title": "Wolfs",
              "year": 2024,
              "price": 200,
              "note": "Jon Watts; George Clooney and Brad Pitt as rival fixers. Apple. An 'I want to believe more than I believe' pick."
            },
            {
              "title": "Babygirl",
              "year": 2024,
              "price": 5,
              "note": "Halina Reijn; Nicole Kidman as a CEO in an affair with her much-younger intern, opposite Harris Dickinson. A $5 leftover buy."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "spent": 1000,
          "budgetLeft": 0,
          "picks": [
            {
              "title": "The Order",
              "year": 2024,
              "price": 320,
              "note": "Justin Kurzel; Jude Law as an FBI agent chasing Nicholas Hoult's white-supremacist group in Idaho. Marc Maron co-stars."
            },
            {
              "title": "Heretic",
              "year": 2024,
              "price": 300,
              "note": "Scott Beck and Bryan Woods; Hugh Grant traps two Mormon missionaries. A24."
            },
            {
              "title": "A Real Pain",
              "year": 2024,
              "price": 200,
              "note": "Jesse Eisenberg writes and directs; he and Kieran Culkin as cousins touring Poland. Sean's favorite of the year so far, so off-limits to him."
            },
            {
              "title": "The Instigators",
              "year": 2024,
              "price": 130,
              "note": "Doug Liman's Boston crime comedy; Matt Damon, Casey Affleck, Hong Chau. Apple. Chris's first-round buy."
            },
            {
              "title": "Blink Twice",
              "year": 2024,
              "price": 50,
              "note": "Zoë Kravitz's directorial debut (once titled Pussy Island); Channing Tatum, Naomi Ackie. Bought cheap after everyone else passed."
            }
          ]
        }
