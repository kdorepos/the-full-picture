{
  "slug": "bros-and-our-top-five-21st-century-comedies",
  "title": "‘Bros’ and Our Top Five 21st Century Comedies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2022-09-30",
  "runtimeMin": 88,
  "format": "Sean Fennessey and Amanda Dobbins review Bros, count down their five favorite comedies of the century, and Sean sits down with co-writer and director Nicholas Stoller.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Bros’",
      "note": "the first wide-release studio gay rom-com",
      "films": [
        {
          "title": "Bros",
          "year": 2022,
          "note": "Billy Eichner plays a podcaster and LGBTQ-museum curator falling for a stiff Hallmark-handsome lawyer (Luke Macfarlane). Amanda calls it a knowing, updated romantic comedy that works; Sean found it more affecting as drama than as comedy, and both agree it runs about 15 minutes long. Nick Stoller directs, Eichner co-writes."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top Five 21st-Century Comedies",
      "note": "No. 1 first",
      "subject": "21st-century comedies",
      "ranked": true,
      "films": [
        {
          "title": "Mean Girls",
          "year": 2004,
          "note": "No. 1. A great script line for line, and it reset how high-school movies and women-led comedies talk."
        },
        {
          "title": "Zoolander",
          "year": 2001,
          "note": "The one she's seen most; whole chunks of dialogue have leaked into her real speech."
        },
        {
          "title": "Superbad",
          "year": 2007,
          "note": "Her favorite of the Apatow run: a movie about boys, not men, more comfortable with its feelings than the rest."
        },
        {
          "title": "Legally Blonde",
          "year": 2001,
          "note": "Holds up completely; she argues it has a smarter take on Marilyn Monroe than Blonde."
        },
        {
          "title": "21 Jump Street",
          "year": 2012,
          "note": "The most recent pick on either list. Lord and Miller remake the action-comedy and high-school movie at once, with Hill and Tatum at a peak."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five 21st-Century Comedies",
      "note": "No. 1 first",
      "subject": "21st-century comedies",
      "ranked": true,
      "films": [
        {
          "title": "Anchorman: The Legend of Ron Burgundy",
          "year": 2004,
          "note": "No. 1. The first Apatow-McKay-Ferrell fusion; laugh for laugh, moment for moment, he calls it the best."
        },
        {
          "title": "Best in Show",
          "year": 2000,
          "note": "A last-minute pivot off In the Loop: he wanted a Christopher Guest movie, and Fred Willard is the best part of it."
        },
        {
          "title": "In Bruges",
          "year": 2008,
          "note": "Martin McDonagh's hitman road-trip comedy with Colin Farrell and Brendan Gleeson, back on his mind ahead of The Banshees of Inisherin."
        },
        {
          "title": "Burn After Reading",
          "year": 2008,
          "note": "His way to represent the Coens; Brad Pitt and Frances McDormand make it the one that makes him laugh out loud most. Shot next to his old Brooklyn Heights apartment."
        },
        {
          "title": "Forgetting Sarah Marshall",
          "year": 2008,
          "note": "A deliberate cheat, tied at No. 5. A movie about a depressed guy that also puts him in Hawaii with Mila Kunis and Kristen Bell; directed by the episode's guest."
        },
        {
          "title": "Step Brothers",
          "year": 2008,
          "note": "The other half of the No. 5 tie. Ferrell and John C. Reilly play grown men forced to become brothers, a psychotic premise that was largely invented on the day."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Nicholas Stoller on",
      "films": [
        {
          "title": "Bros",
          "year": 2022,
          "note": "Five years in the making. Stoller cast Eichner in Neighbors and Friends From College, saw a room die laughing, and built a vehicle around him. He says his movies all start as dramas; this one just sits longer, without a joke, in Billy's beach monologue."
        },
        {
          "title": "Zola",
          "year": 2021,
          "note": "His pick for the last great thing he saw. As a Miami native he rates it and Magic Mike as the two films that best capture Florida."
        },
        {
          "title": "Magic Mike",
          "year": 2012,
          "note": "The other movie he says nails how humid and lush-but-crappy Florida looks."
        }
      ]
    }
  ],
