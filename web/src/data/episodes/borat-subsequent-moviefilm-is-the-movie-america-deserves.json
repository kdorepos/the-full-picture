  "published": "2020-10-27",
  "runtimeMin": 77,
  "format": "Sean and Amanda bring on The Press Box's Brian Curtis and David Shoemaker for Borat's election-season return, then close the month with two remakes nobody asked for.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "‘Borat Subsequent Moviefilm’",
      "note": "with Brian Curtis and David Shoemaker of The Press Box",
      "films": [
        {
          "title": "Borat Subsequent Moviefilm",
          "year": 2020,
          "note": "Sacha Baron Cohen revives the character for the Trump era. Maria Bakalova, as daughter Tutar, draws real Oscar talk, and the Rudy Giuliani hotel scene, already spoiled by pre-release publicity, dominates the conversation. The panel pegs it at 70% scripted framing, 30% stunt, an inversion of the first film, and splits on whether that's a downgrade."
        },
        {
          "title": "Borat",
          "year": 2006,
          "note": "The Larry Charles original, an Oscar-nominated adapted-screenplay comedy phenomenon that grew out of Da Ali G Show. The panel uses it as the roughly 70%-stunt benchmark the sequel flips."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The other new releases",
      "note": "two remakes to close out the month",
      "films": [
        {
          "title": "Rebecca (Wheatley)",
          "year": 2020,
          "note": "Ben Wheatley remakes the Daphne du Maurier novel (marketed as 'not the Hitchcock') with Lily James and Armie Hammer. Amanda: it fails on its own terms, all exterior where the book is interior, with the only spark a late Cairo scene."
        },
        {
          "title": "Rebecca (Hitchcock)",
          "year": 1940,
          "note": "Hitchcock's gothic original with Joan Fontaine and Laurence Olivier, held up as one of the greatest films ever made and an impossible bar for the remake."
        },
        {
          "title": "Roald Dahl's The Witches",
          "year": 2020,
          "note": "The Robert Zemeckis / Guillermo del Toro / Kenya Barris reworking on HBO Max, relocated to 1960s Alabama with a young Black lead. Anne Hathaway's Grand High Witch is the standout and, for Amanda, the thing that's too much for kids."
        },
        {
          "title": "The Witches",
          "year": 1990,
          "note": "Nicholas Roeg's Jim Henson-produced adaptation with Anjelica Huston, a cult creepy-classic the hosts argue didn't need redoing."
        }
      ]
    }
  ],
