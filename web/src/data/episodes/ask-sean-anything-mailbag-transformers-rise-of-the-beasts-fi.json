        },
        {
          "title": "Sick of Myself",
          "year": 2023,
          "note": "Kristoffer Borgli's Norwegian black comedy about a couple competing to be the center of attention; slots next to Shiva Baby and The Worst Person in the World."
        },
        {
          "title": "Reality",
          "year": 2023,
