{
  "slug": "celebrating-scott-pilgrim-vs-the-world-10-years-later-with-e",
  "title": "Celebrating ‘Scott Pilgrim vs. the World’ 10 Years Later With Edgar Wright",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey"
  ],
  "published": "2020-07-21",
  "runtimeMin": 94,
  "format": "Sean Fennessey marks 10 years of 'Scott Pilgrim vs. the World' with two segments: a fan roundtable with Jason Concepcion and Van Lathan on why the movie rules, then a long talk with director Edgar Wright about making it.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Why ‘Scott Pilgrim’ Rules",
      "note": "with Jason Concepcion and Van Lathan",
      "films": [
        {
          "title": "Scott Pilgrim vs. the World",
          "year": 2010,
          "note": "Concepcion and Lathan, both self-described superfans, on why it stuck: a mix of comic book, video game and garage-rock musical that drops you in without explaining its rules, with Scott written as both the hero and the villain. They break down the Lucas Lee and Todd-the-vegan fights, the 'bread makes you fat' scene, and argue a sequel would have to de-center Scott and follow Knives Chau and Ramona."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Edgar Wright on",
      "films": [
        {
          "title": "Scott Pilgrim vs. the World",
          "year": 2010,
          "note": "Wright on the 100-day shoot (his longest), six fight scenes, and Saturday refreshers to keep the choreography in the young cast's heads. Beck cut the Sex Bob-omb demos in his garage in about 72 hours, mostly single takes, and Wright kept them as-is. He recalls a Universal exec asking at the green-light whether the film would work without the effects and fights, and an abandoned finale where Gideon turned into a giant Toho-style mecha. He thinks the film wouldn't get made by a major studio today."
        },
        {
          "title": "Shaun of the Dead",
          "year": 2004,
          "note": "A 2004 Focus Features screening is where producers Jared LeBoff and Adam Siegel first pitched him Scott Pilgrim, describing it as 'John Hughes meets Kill Bill.'"
        },
        {
          "title": "Hot Fuzz",
          "year": 2007,
          "note": "Scott Pilgrim cost four times what Hot Fuzz did, which made Universal nervous about the budget."
        },
        {
          "title": "Baby Driver",
          "year": 2017,
          "note": "Wright says the music-synced staging he perfected here starts with Scott Pilgrim."
        },
        {
          "title": "Ant-Man",
          "year": 2015,
          "note": "He left the project before shooting. That it still turned out a solid Marvel movie tells him how much of the process now runs like a factory, needing minimal input from the director."
        },
        {
          "title": "Last Night in Soho",
          "year": 2021,
          "note": "His next film, a horror, which the 2020 shutdown bumped from that September to the following year."
        }
      ]
    }
  ],
