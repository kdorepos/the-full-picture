{
  "slug": "best-picture-power-rankings-plus-is-emilia-perez-really-a-fr",
  "title": "Best Picture Power Rankings. Plus: Is ‘Emilia Pérez’ Really a Front-Runner?",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Joanna Robinson",
    "Katie Rich"
  ],
  "published": "2024-11-15",
  "runtimeMin": 94,
  "format": "Sean Fennessey rebuilds the Best Picture top 10 with awards writers Joanna Robinson and Katie Rich, two weeks after the 2024 election and with no clear front-runner in the race. Then the three argue over whether Jacques Audiard's 'Emilia Pérez' really belongs near the top.",
  "segments": [
    {
      "kind": "ranking",
      "heading": "Best Picture Power Rankings",
      "note": "the top 10 a month before nominations, best-first",
      "subject": "the 2024 Best Picture race",
      "ranked": true,
      "films": [
        {
          "title": "Anora",
          "year": 2024,
          "note": "No. 1: still the front-runner. Sean called the win out of an August screening; Joanna wonders if it just parks there the way 'Nomadland' did. Neon behind it, strong limited-release business."
        },
        {
          "title": "Conclave",
          "year": 2024,
          "note": "No. 2: the middlebrow mystery making money and memes, with a nod to the U.S. political system. The kind of high-class genre movie Sean keeps saying doesn't get made anymore."
        },
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "No. 3: Sean and Katie on the hype squad. Three and a half hours with an intermission baked in; a 'Tár'-like film built on one enormous central performance, plus that upside-down Statue of Liberty poster."
        },
        {
          "title": "Emilia Pérez",
          "year": 2024,
          "note": "No. 4: Netflix's all-in bet, taken apart at length in the back half. Sean thinks it's ranked a touch high for how it plays with older and international voters."
        },
        {
          "title": "Wicked",
          "year": 2024,
          "note": "No. 5: where the energy is right now, though Sean isn't sold on it as a front-runner. Part 1 of two, ending on 'Defying Gravity'; escapism and presales carry it, but few musicals this bright have won."
        },
        {
          "title": "Dune: Part Two",
          "year": 2024,
          "note": "No. 6: widely admired and a huge hit, but sci-fi rarely wins Best Picture. Katie's comp is 'Avatar: The Way of Water': nominated where it needed to be, wins mostly below the line."
        },
        {
          "title": "A Real Pain",
          "year": 2024,
          "note": "No. 7: Sean is bullish and confident it gets in; Joanna thinks it's overrated as a Best Picture film even if Kieran Culkin is a lock. Bumped down a slot so Joanna could claim a win."
        },
        {
          "title": "Blitz",
          "year": 2024,
          "note": "No. 8: Katie's hobby horse, a technical achievement with below-the-line and international support, and a strong Saoirse Ronan press run. Sean cooler on it, wrong-footed by the script."
        },
        {
          "title": "Sing Sing",
          "year": 2023,
          "note": "No. 9: Joanna's 'heart vote,' back in after being cut last time. A24's slow-roll reissue strategy, Colman Domingo and Clarence Maclin, and a formerly incarcerated cast playing themselves: a CODA-style pattern."
        },
        {
          "title": "The Substance",
          "year": 2024,
          "note": "No. 10: Katie's late add for the zeitgeist, in over Nickel Boys. Sean loves it; some Academy voters he texts with 'fucking hate it,' which is a real problem for the No. 8-9-10 ballot slots."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Is ‘Emilia Pérez’ Really a Front-Runner?",
      "note": "the back-half deep dive",
      "films": [
        {
          "title": "Emilia Pérez",
          "year": 2024,
          "note": "Jacques Audiard's genre-hopping musical crime saga, loosely based on an opera; won the jury prize and a shared best-actress award at Cannes. Sean calls it a failed but worthwhile experiment carried by Zoe Saldaña, with Selena Gomez the weak link and Carla Sofía Gascón the challenging center. Divisive on social media, but the panel expects a strong nomination haul with few, if any, wins."
        }
      ]
    }
  ],
