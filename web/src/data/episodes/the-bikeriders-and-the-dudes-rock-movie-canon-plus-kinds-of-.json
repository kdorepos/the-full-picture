{
  "slug": "the-bikeriders-and-the-dudes-rock-movie-canon-plus-kinds-of-",
  "title": "‘The Bikeriders’ and the ‘Dudes Rock’ Movie Canon, Plus ‘Kinds of Kindness’",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
