{
  "slug": "the-top-five-movies-of-2024",
  "title": "The Top Five Movies of 2024",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan",
    "Adam Nayman",
    "Amanda Dobbins"
  ],
  "published": "2024-12-06",
  "runtimeMin": 99,
  "format": "The year-end countdown. Sean Fennessey, Chris Ryan, and Adam Nayman each rank their five best films of 2024, and Amanda Dobbins phones in a top five (really seven) from parental leave. Precursor awards and three current releases come first.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Out Now",
      "note": "three quick reviews before the lists",
      "films": [
        {
          "title": "Kneecap",
          "year": 2024,
          "note": "Rich Peppiatt's film about a Belfast rap trio agitating for the Irish language; now on Netflix. Chris called it one of the most fun moviegoing experiences of his year. Michael Fassbender appears; Adam hadn't caught it yet."
        },
        {
          "title": "Queer",
          "year": 2024,
          "note": "Luca Guadagnino's second film of 2024, adapting the William Burroughs novel with Daniel Craig as Lee, an American drifting through 1950s Mexico City. Craig won the NBR best-actor prize. Sean and Adam both admired the ambition but found the movie unsuccessful, and Adam preferred Peter Weller in Naked Lunch."
        },
        {
          "title": "The Order",
          "year": 2024,
          "note": "Justin Kurzel's 1983-set thriller about an FBI agent (Jude Law) chasing a white-nationalist bank-robbery cell led by Nicholas Hoult. Shot by Adam Arkapaw. All three had seen it; praised as a tightly built, great-looking B-movie."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top 5",
      "note": "revealed No. 5 up to No. 1",
      "subject": "2024 movies",
      "ranked": true,
      "films": [
        {
          "title": "Civil War",
          "year": 2024,
          "note": "No. 1 - Alex Garland's Heart-of-Darkness road movie with Kirsten Dunst and Cailee Spaeny as war photographers. Chris kept thinking about it after the election and called it a heavyweight title contender."
        },
        {
          "title": "Rebel Ridge",
          "year": 2024,
          "note": "No. 2 - Jeremy Saulnier's civil-asset-forfeiture thriller. Aaron Pierre becomes a movie star; Don Johnson and AnnaSophia Robb co-star. Chris has watched it two or three times."
        },
        {
          "title": "Anora",
          "year": 2024,
          "note": "No. 3 - Sean Baker's Palme d'Or winner. Chris just cared what happened to Mikey Madison's character; three movies in one, ending in an argument he loves that people are having."
        },
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "No. 4 - Brady Corbet's postwar-architect epic. Chris saw it with Sean and was mesmerized; hit the quadrants that matter - sound, image, performance, writing."
        },
        {
          "title": "Strange Darling",
          "year": 2024,
          "note": "No. 5 - JT Mollner's nonlinear serial-killer film with Willa Fitzgerald, Chris's favorite performance of the year. Hard to discuss without spoiling."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Adam Nayman's Top 5",
      "note": "reserves the right to reshuffle when the Ringer list runs",
      "subject": "2024 movies",
      "ranked": true,
      "films": [
        {
          "title": "Red Rooms",
          "year": 2023,
          "note": "No. 1 - Pascal Plante's French-Canadian film. Adam disliked it at first, then reversed himself in a MUBI piece; Juliette Gariepy's performance is an all-timer. Fincher juice, courtroom drama that isn't one."
        },
        {
          "title": "Juror #2",
          "year": 2024,
          "note": "No. 2 - Clint Eastwood's pressurized legal thriller, which Sean and Adam devoted a whole episode to. Adam singled out the ending; a can't-look-at-your-phone movie."
        },
        {
          "title": "Do Not Expect Too Much From the End of the World",
          "year": 2023,
          "note": "No. 3 - Radu Jude's late-capitalism comedy in Bucharest with a Nina Hoss cameo and a 40-minute long take. Adam's best comedy of the year, and a better Bob Dylan movie than A Complete Unknown."
        },
        {
          "title": "The Beast",
          "year": 2024,
          "note": "No. 4 - Bertrand Bonello's three-timeline sci-fi with Lea Seydoux and George MacKay. Adam likes that not everything works; drew walkouts at TIFF, which he takes as a good sign."
        },
        {
          "title": "Nickel Boys",
          "year": 2024,
          "note": "No. 5 - RaMell Ross's first-person adaptation of the Colson Whitehead novel; won best director from the New York Film Critics Circle. Also lands on Sean's list."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top 5",
      "note": "revealed No. 5 up to No. 1",
      "subject": "2024 movies",
      "ranked": true,
      "films": [
        {
          "title": "The Brutalist",
          "year": 2024,
          "note": "No. 1 - Brady Corbet's epic, which Sean has seen twice. He'd been desperate for a big, important-seeming film all year; sees Coppola, George Stevens, Visconti, Bergman, and PTA's The Master on its surface."
        },
        {
          "title": "Nickel Boys",
          "year": 2024,
          "note": "No. 2 - RaMell Ross's film, which Sean says levitates you in its final 20 minutes. He saw it at Telluride; shares its use of archival footage with his No. 1 debate about Here."
        },
        {
          "title": "Challengers",
          "year": 2024,
          "note": "No. 3 - Luca Guadagnino's tennis love triangle. Sean has seen it three times; loves the Reznor/Ross four-on-the-floor score and Josh O'Connor's performance. A meeting point for him and Amanda."
        },
        {
          "title": "Dune: Part Two",
          "year": 2024,
          "note": "No. 4 - Denis Villeneuve's Herbert adaptation, Sean's event movie of the year. The Harkonnen soldiers gliding to the mountaintop sold him; a blockbuster that ends on a tough note."
        },
        {
          "title": "Evil Does Not Exist",
          "year": 2023,
          "note": "No. 5 - Ryusuke Hamaguchi's follow-up to Drive My Car, about a fishing village facing a glamping development. Sean's only seen it once and doesn't want to sully the feeling; pairs it with Zemeckis's Here."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda Dobbins's Top 5",
      "note": "a top seven, really - phoned in from leave, no rules",
      "subject": "2024 movies",
      "ranked": true,
      "films": [
        {
          "title": "Anora",
          "year": 2024,
          "note": "No. 1 - Amanda's pick before Sean even asked. A movie-ass movie that stays with you; she keeps turning over the last scene and everyone's different reading of it."
        },
        {
          "title": "Challengers",
          "year": 2024,
          "note": "No. 2 - the most Amanda movie of the year. Guadagnino, Zendaya, Josh O'Connor, Mike Faist, bumping soundtrack, and fancy hand-cream product placement. Says Luca sees her."
        },
        {
          "title": "Twisters",
          "year": 2024,
          "note": "No. 3 (tie) - one half of the Glen Powell Special, her summer blockbuster aside from Dune 2. A 'we used to build things in this country' vibe."
        },
        {
          "title": "Hit Man",
          "year": 2023,
          "note": "No. 3 (tie) - the other Glen Powell pick, Richard Linklater's Netflix comedy co-written with Powell; probably the best thing she saw on Netflix this year."
        },
        {
          "title": "The Bikeriders",
          "year": 2023,
          "note": "No. 4 - Jeff Nichols's film with Jodie Comer, Tom Hardy, and Austin Butler. The one the guys liked but wouldn't rank; it made hers."
        },
        {
          "title": "The Beekeeper",
          "year": 2024,
          "note": "No. 5 (tie) - the January Jason Statham / David Ayer film, Amanda's transcendent-garbage category. Enjoyed it at the time; hasn't revisited it since the election."
        },
        {
          "title": "Lonely Planet",
          "year": 2024,
          "note": "No. 5 (tie) - Susannah Grant's Netflix film with Laura Dern and Liam Hemsworth. Got her through a dark three days in early October; 'swing route.'"
        }
      ]
    }
  ],
