{
  "slug": "the-15-most-anticipated-movies-at-sundance-plus-randy-newman",
  "title": "The 15 Most Anticipated Movies at Sundance. Plus: Randy Newman!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-01-24",
  "runtimeMin": 69,
  "format": "Sean and Amanda are in Park City for their first Sundance, running through what they've already seen and the fifteen movies they're most excited for, before Sean sits down with Randy Newman to talk Marriage Story, Toy Story, and his cousin Thomas.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Four Movies In",
      "note": "what Sean and Amanda caught before recording",
      "films": [
        {
          "title": "Crip Camp",
          "year": 2020,
          "note": "Netflix documentary from Nicole Newnham and Jim Lebrecht, executive produced by Barack and Michelle Obama, about a summer camp that helped spark the disability rights movement."
        },
        {
          "title": "Summertime",
          "year": 2020,
          "note": "Carlos López Estrada's follow-up to Blindspotting: an interlocking, slam-poetry portrait of 25 young Angelenos. Still for sale."
        },
        {
          "title": "Miss Americana",
          "year": 2020,
          "note": "Lana Wilson's Netflix documentary on Taylor Swift, premiering on the service a week after Sundance."
        },
        {
          "title": "Bad Hair",
          "year": 2020,
          "note": "Justin Simien's 1989-set horror comedy, led by Elle Lorraine with Lena Waithe, Laverne Cox, Blair Underwood, and Vanessa Williams as a mentor figure."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The 15 Most Anticipated",
      "note": "Sean's list, with Amanda's adds mixed in",
      "films": [
        {
          "title": "Zola",
          "year": 2020,
          "note": "Janicza Bravo's A24 adaptation of Zola's viral Twitter thread about a stripper road trip gone wrong, starring Taylour Paige, Riley Keough, and Nicholas Braun."
        },
        {
          "title": "The Dissident",
          "year": 2020,
          "note": "Bryan Fogel's follow-up to his Oscar-winning Icarus, on the murder of Washington Post journalist Jamal Khashoggi."
        },
        {
          "title": "Kajillionaire",
          "year": 2020,
          "note": "Miranda July's first feature since The Future, starring Evan Rachel Wood, Richard Jenkins, Debra Winger, and Gina Rodriguez; produced by Brad Pitt's Plan B."
        },
        {
          "title": "Downhill",
          "year": 2020,
          "note": "Nat Faxon and Jim Rash's English-language redo of Ruben Östlund's Force Majeure, with Julia Louis-Dreyfus and Will Ferrell as a couple whose marriage cracks after a near-avalanche."
        },
        {
          "title": "Never Rarely Sometimes Always",
          "year": 2020,
          "note": "Eliza Hittman's third feature, starring Sidney Flanigan and Talia Ryder, produced by Moonlight's Adele Romanski. Out in March from Focus."
        },
        {
          "title": "Shirley",
          "year": 2020,
          "note": "Josephine Decker's Shirley Jackson drama with Elisabeth Moss and Michael Stuhlbarg, executive produced by Martin Scorsese."
        },
        {
          "title": "The Nest",
          "year": 2020,
          "note": "Sean Durkin's first feature since Martha Marcy May Marlene, starring Jude Law and Carrie Coon."
        },
        {
          "title": "Nine Days",
          "year": 2020,
          "note": "Edson Oda's directorial debut, a sci-fi drama with Winston Duke, Zazie Beetz, Benedict Wong, Bill Skarsgård, and Tony Hale."
        },
        {
          "title": "Dick Johnson Is Dead",
          "year": 2020,
          "note": "Kirsten Johnson's follow-up to Cameraperson, documenting her father's final years. Headed to Netflix."
        },
        {
          "title": "Minari",
          "year": 2020,
          "note": "Lee Isaac Chung's period drama about a Korean American family, starring Steven Yeun and Will Patton."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Movies Amanda Cares About",
      "note": "her additions to the list",
      "films": [
        {
          "title": "The Glorias",
          "year": 2020,
          "note": "Julie Taymor's Gloria Steinem film, with Julianne Moore playing Steinem at one stage of her life alongside Alicia Vikander."
        },
        {
          "title": "Promising Young Woman",
          "year": 2020,
          "note": "Emerald Fennell's directorial debut, starring Carey Mulligan. Fennell wrote for Killing Eve and played Camilla Parker Bowles on The Crown."
        },
        {
          "title": "The Last Thing He Wanted",
          "year": 2020,
          "note": "Dee Rees's adaptation of the Joan Didion novel, starring Anne Hathaway, Ben Affleck, Willem Dafoe, and Rosie Perez."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In Conversation",
      "guest": "Randy Newman on",
      "films": [
        {
          "title": "Marriage Story",
          "year": 2019,
          "note": "His second collaboration with Noah Baumbach: dueling motifs for Charlie and Nicole, scored for chamber orchestra and recorded at the Newman Scoring Stage, named for his uncle Alfred."
        },
        {
          "title": "Toy Story 4",
          "year": 2019,
          "note": "His fourth trip through the franchise, competing this awards season against his cousin Thomas Newman's score."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "His pick for the last great thing he's seen: \"It has a lot of respect for the audience.\""
        }
      ]
    }
  ],
