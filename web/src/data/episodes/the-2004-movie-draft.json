{
  "slug": "the-2004-movie-draft",
  "title": "The 2004 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2021-09-14",
  "runtimeMin": 91,
  "format": "Sean, Amanda, and Chris draft the movies of 2004 across six categories, then argue about who got stuck with Million Dollar Baby.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The 2004 Movie Draft",
      "draftOf": "2004 movies",
      "categories": [
        "Drama",
        "Comedy or Horror",
        "Oscar Winner",
        "Sequel",
        "Blockbuster",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Man on Fire",
              "year": 2004,
              "category": "Drama",
              "note": "Denzel Washington's bodyguard-revenge thriller, taken partly to dodge accusations of category fraud after flirting with The Life Aquatic here instead."
            },
            {
              "title": "Anchorman: The Legend of Ron Burgundy",
              "year": 2004,
              "category": "Comedy or Horror",
              "note": "\"The funniest movie I've ever seen\": the DVD extras and outtakes turned it into a phenomenon that outlived the theatrical run."
            },
            {
              "title": "Ray",
              "year": 2004,
              "category": "Oscar Winner",
              "note": "Taken for Jamie Foxx's total commitment to the Ray Charles bit as much as the movie itself, which he calls \"totally fine.\""
            },
            {
              "title": "Kill Bill: Vol. 2",
              "year": 2004,
              "category": "Sequel",
              "note": "Rewatched recently on cable and holds up better than remembered, closer to a Western than the first volume, with a stacked ensemble."
            },
            {
              "title": "Collateral",
              "year": 2004,
              "category": "Blockbuster",
              "note": "Michael Mann's Tom Cruise/Jamie Foxx two-hander, called one of the best LA movies ever made. The Audioslave-scored coyote scene gets singled out."
            },
            {
              "title": "Shaun of the Dead",
              "year": 2004,
              "category": "Wildcard",
              "note": "Edgar Wright's breakout, still argued as his best or second-best film."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Before Sunset",
              "year": 2004,
              "category": "Drama",
              "note": "The second Linklater/Hawke/Delpy film, called the most beautifully made of the trilogy and a contender for best movie ending ever."
            },
            {
              "title": "The Life Aquatic with Steve Zissou",
              "year": 2004,
              "category": "Comedy or Horror",
              "note": "IMDb lists it as action/adventure/comedy, but it's defended as darker and more of a downer than people remember: a father-son story about not relating."
            },
            {
              "title": "Eternal Sunshine of the Spotless Mind",
              "year": 2004,
              "category": "Oscar Winner",
              "note": "Won Best Original Screenplay; Michel Gondry and Charlie Kaufman's Jim Carrey/Kate Winslet film that's drifted from mainstream hit to cult favorite."
            },
            {
              "title": "Spider-Man 2",
              "year": 2004,
              "category": "Sequel",
              "note": "Sam Raimi's film, argued as the movie most responsible for unlocking two decades of comic-book culture had it flopped."
            },
            {
              "title": "The Aviator",
              "year": 2004,
              "category": "Blockbuster",
              "note": "Scorsese's Howard Hughes biopic with Leonardo DiCaprio, called mid-tier Scorsese but fun and beautifully made."
            },
            {
              "title": "2046",
              "year": 2004,
              "category": "Wildcard",
              "note": "Wong Kar-wai's loose sequel to In the Mood for Love, with Tony Leung, Gong Li, and Zhang Ziyi."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Notebook",
              "year": 2004,
              "category": "Drama",
              "note": "A Nicholas Sparks adaptation that \"should be total garbage\" but isn't, thanks to Rachel McAdams and Ryan Gosling's chemistry."
            },
            {
              "title": "Mean Girls",
              "year": 2004,
              "category": "Comedy or Horror",
              "note": "Still quoted constantly, and the other half of Rachel McAdams's breakout year, alongside The Notebook."
            },
            {
              "title": "The Incredibles",
              "year": 2004,
              "category": "Oscar Winner",
              "note": "Brad Bird's superhero family film, praised for its action and its \"nothing is more important than family\" throughline."
            },
            {
              "title": "Ocean's Twelve",
              "year": 2004,
              "category": "Sequel",
              "note": "Defended, jokingly, as the second-greatest sequel in American history behind The Godfather Part II."
            },
            {
              "title": "Million Dollar Baby",
              "year": 2004,
              "category": "Blockbuster",
              "note": "Eastwood's boxing drama, which swept the Oscars: a reluctant pick after passing on Kill Bill earlier in the draft, remembered for its brutal final act."
            },
            {
              "title": "Napoleon Dynamite",
              "year": 2004,
              "category": "Wildcard",
              "note": "A cult classic complete with \"Vote for Pedro\" merch, worn out on DVD after the fact."
            }
          ]
        }
      ],
