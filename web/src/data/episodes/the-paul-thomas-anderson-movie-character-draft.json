            {
              "title": "The Master",
              "year": 2012,
              "category": "Supporting Actress",
              "note": "Amy Adams as Peggy Dodd, the quietly controlling wife draining Lancaster's pep."
            },
            {
              "title": "Punch-Drunk Love",
              "year": 2002,
              "category": "One Scene Star",
              "note": "Philip Seymour Hoffman as Dean Trumbell, the Mattress Man: 'shut, shut, shut up,' the moment the movie leaves Earth."
