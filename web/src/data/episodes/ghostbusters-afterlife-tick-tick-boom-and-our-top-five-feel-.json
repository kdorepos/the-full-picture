{
  "slug": "ghostbusters-afterlife-tick-tick-boom-and-our-top-five-feel-",
  "title": "'Ghostbusters: Afterlife,' 'Tick, Tick ... Boom!,' and Our Top Five Feel-Good Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2021-11-22",
  "runtimeMin": 90,
  "format": "Sean and Amanda review two new releases, get wrecked by a third, and each count down five feel-good movies. Plus, Sean talks to Mike Mills.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Ghostbusters: Afterlife'",
      "films": [
        {
          "title": "Ghostbusters: Afterlife",
          "year": 2021,
          "note": "Jason Reitman's legacy sequel to his father Ivan's franchise, with McKenna Grace and Finn Wolfhard as kids who inherit the old farmhouse. Amanda calls it a fine movie for seven-year-olds; Sean is bent out of shape by the fan service and the Stay Puft-at-Walmart product placement. The blue blob Muncher is the one thing that made them laugh."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "'Tick, Tick ... Boom!'",
      "films": [
        {
          "title": "Tick, Tick... Boom!",
          "year": 2021,
          "note": "Lin-Manuel Miranda's directorial debut, with Andrew Garfield as 'Rent' creator Jonathan Larson working up an earlier, unfinished musical. Sean will follow Garfield anywhere; Amanda never connected with the songs or the musical-theater world they come from."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "'C'mon C'mon'",
      "films": [
        {
          "title": "C'mon C'mon",
          "year": 2021,
          "note": "Mike Mills's black-and-white film with Joaquin Phoenix as a radio producer minding his nine-year-old nephew (Woody Norman) cross-country. The movie that actually made them feel good; Sean's highest recommendation."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Feel-Good Five",
      "note": "counted down 5 to 1",
      "subject": "Amanda's feel-good movies",
      "ranked": true,
      "films": [
        {
          "title": "Singin' in the Rain",
          "year": 1952,
          "note": "No. 1 - the one she saves for when she's really down; watched it the night before surgery. 'It's like medicine every time.'"
        },
        {
          "title": "Frances Ha",
          "year": 2012,
          "note": "No. 2 - a personal pick; she was the same age in New York at the same time. The pirouette to 'Modern Love' is what falling in love feels like."
        },
        {
          "title": "Bringing Up Baby",
          "year": 1938,
          "note": "No. 3 - Cary Grant and Katharine Hepburn screaming kindly at each other while a leopard runs loose; screwball at its gleeful, smart best."
        },
        {
          "title": "That Thing You Do!",
          "year": 1996,
          "note": "No. 4 - Tom Hanks's one-hit-wonder band movie, seen 75-plus times. Love, art, and the single greatest pop song ever written for a movie."
        },
        {
          "title": "Dave",
          "year": 1993,
          "note": "No. 5 - Ivan Reitman's Kevin Kline body-double comedy; an uncomplicated belief in the goodness of humanity."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Feel-Good Five",
      "note": "counted down 5 to 1",
      "subject": "Sean's feel-good movies",
      "ranked": true,
      "films": [
        {
          "title": "Pee-wee's Big Adventure",
          "year": 1985,
          "note": "No. 1 - Tim Burton's debut, co-written by Paul Reubens and Phil Hartman. The movie that taught Sean you can do anything in a film; way ahead of the curve on parody."
        },
        {
          "title": "Singin' in the Rain",
          "year": 1952,
          "note": "No. 2 - a perfect five-star movie; the big movie rainbow, where he can't stop grinning."
        },
        {
          "title": "My Neighbor Totoro",
          "year": 1988,
          "note": "No. 3 - his only animated pick; Miyazaki's Studio Ghibli film, the one he'll start his daughter on."
        },
        {
          "title": "Local Hero",
          "year": 1983,
          "note": "No. 4 - Bill Forsyth's Scottish oil-town comedy with Burt Lancaster; watched it deep in quarantine and simply felt better."
        },
        {
          "title": "Big",
          "year": 1988,
          "note": "No. 5 - Penny Marshall's Tom Hanks fantasy, seeped into the concrete of his life like Led Zeppelin IV. Four of his five picks are from the '80s."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Mike Mills on 'C'mon C'mon'",
      "guest": "Mike Mills on",
      "films": [
        {
          "title": "C'mon C'mon",
          "year": 2021,
          "note": "Why the caretaker is an uncle, not a father - it condenses the whole novice-parent feeling into every scene, 'like a Buster Keaton movie.' The kid interviews grew out of a SFMOMA video piece asking Silicon Valley children about the future."
        },
        {
          "title": "Beginners",
          "year": 2010,
          "note": "His 'dad film,' drawn from his father; strangers still recommend it to him without knowing he made it."
        },
        {
          "title": "20th Century Women",
          "year": 2016,
          "note": "His 'mom film'; the Greta character is based on one of his sisters. Subject of Sean's first-ever interview for the show, five years earlier."
        },
        {
          "title": "A Hero",
          "year": 2021,
          "note": "One of his two last-great-things - Farhadi's film, which he calls patient and expertly made, with an ambiguity that lingers."
        }
      ]
    }
  ],
