{
  "slug": "the-1997-movie-draft",
  "title": "The 1997 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2022-11-15",
  "runtimeMin": 88,
  "format": "Sean, Amanda, and Chris Ryan snake-draft 1997, a year with Boogie Nights, Jackie Brown, Titanic, Good Will Hunting, and L.A. Confidential all up top and a long tail of B-movies and near-misses behind them.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "the movies of 1997",
      "categories": [
        "Drama",
        "Comedy",
        "Oscar Nominee",
        "Action / Horror / Thriller",
        "Blockbuster",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Boogie Nights",
              "year": 1997,
              "category": "Oscar Nominee",
              "note": "First overall. Paul Thomas Anderson's second film; Sean and Chris spent 13-plus hours on it on another podcast, and Sean calls it one-in-one-A with Jackie Brown for best of the year."
            },
            {
              "title": "The Game",
              "year": 1997,
              "category": "Drama",
              "note": "David Fincher's paranoia thriller with Michael Douglas. Sean argues it's the most underrated Fincher, an homage to '70s Pakula conspiracy movies."
            },
            {
              "title": "Face/Off",
              "year": 1997,
              "category": "Blockbuster",
              "note": "John Woo's face-swap actioner. Not Sean's favorite on the board, but it was an event, and Chris calls it Woo's best American film."
            },
            {
              "title": "Austin Powers: International Man of Mystery",
              "year": 1997,
              "category": "Comedy",
              "note": "Didn't do much at the box office in '97 but became a Halloween-costume, DVD-sales cult hit. Sean saw it before he'd seen more than two Bond movies."
            },
            {
              "title": "Event Horizon",
              "year": 1997,
              "category": "Action / Horror / Thriller",
              "note": "Paul W.S. Anderson's spaceship-in-hell horror movie, with Sam Neill, Laurence Fishburne, and Kathleen Quinlan. Sean thinks its reputation has only grown since."
            },
            {
              "title": "The Devil's Advocate",
              "year": 1997,
              "category": "Wild Card",
              "note": "Taylor Hackford directs a Tony Gilroy script; Al Pacino and Keanu Reeves square off. Sean's personal all-timer, taken over Contact."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Jackie Brown",
              "year": 1997,
              "category": "Oscar Nominee",
              "note": "Chris's adaptation of Elmore Leonard's Rum Punch, with Pam Grier back in a lead role after 15 years and Robert Forster after 25. Sam Jackson, Robert De Niro, Bridget Fonda, and Chris Tucker round out the cast."
            },
            {
              "title": "L.A. Confidential",
              "year": 1997,
              "category": "Drama",
              "note": "Curtis Hanson's James Ellroy adaptation, and a star-making turn for Russell Crowe. Chris saw it multiple times in theaters."
            },
            {
              "title": "Starship Troopers",
              "year": 1997,
              "category": "Action / Horror / Thriller",
              "note": "Paul Verhoeven's satire, which Chris takes as a genuine essay on fascism and also just a really entertaining movie."
            },
            {
              "title": "Con Air",
              "year": 1997,
              "category": "Blockbuster",
              "note": "Steve Buscemi, John Malkovich, Ving Rhames, and Danny Trejo as villains on a prison transport plane. Chris calls it stupid and silly, and likes it anyway."
            },
            {
              "title": "Grosse Pointe Blank",
              "year": 1997,
              "category": "Comedy",
              "note": "John Cusack as a hitman at his high school reunion, with Minnie Driver and a Jeremy Piven cameo. Went under the radar in '97 and became a rewatch favorite."
            },
            {
              "title": "The Boxer",
              "year": 1997,
              "category": "Wild Card",
              "note": "Daniel Day-Lewis and Jim Sheridan's overlooked follow-up to In the Name of the Father, with Emily Watson and Brian Cox. An ex-IRA boxer trying to build a nonsectarian gym in Belfast."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Good Will Hunting",
              "year": 1997,
              "category": "Drama",
              "note": "Amanda's third pick, protected from Sean by their pre-draft dinner. A Gus Van Sant movie that doesn't feel like one, with Matt Damon front and center."
            },
            {
              "title": "Titanic",
              "year": 1997,
              "category": "Oscar Nominee",
              "note": "Amanda's fourth pick. The runaway box-office champ people paid to see three, four, five times in theaters."
            },
            {
              "title": "Men in Black",
              "year": 1997,
              "category": "Comedy",
              "note": "Will Smith and Tommy Lee Jones's chemistry, plus Vincent D'Onofrio as the alien bug. Amanda has long argued he deserved a supporting-actor nomination for it."
            },
            {
              "title": "Air Force One",
              "year": 1997,
              "category": "Action / Horror / Thriller",
              "note": "Harrison Ford as the president, Gary Oldman as the hijacker, Glenn Close and William H. Macy in support, Wolfgang Petersen directing. Amanda's birthday-party movie that summer."
            },
            {
              "title": "My Best Friend's Wedding",
              "year": 1997,
              "category": "Blockbuster",
              "note": "Julia Roberts and Cameron Diaz. A movie Amanda has already given a full Hall of Fame episode to; she argues nothing quite like it clears $150 million anymore."
            },
            {
              "title": "Love Jones",
              "year": 1997,
              "category": "Wild Card",
              "note": "Larenz Tate and Nia Long in a grown-up romantic drama rather than a comedy. Director Theodore Witcher barely worked again; the film later joined the Criterion Collection."
            }
          ]
        }
      ],
