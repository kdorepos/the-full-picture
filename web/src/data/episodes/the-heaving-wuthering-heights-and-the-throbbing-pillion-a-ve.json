  "format": "A Valentine's Day double feature with guest Sam Sanders: Emerald Fennell's 'Wuthering Heights' and Harry Lighton's 'Pillion,' plus Sean's interview with Lighton.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Wuthering Heights’",
      "note": "with Sam Sanders",
      "films": [
        {
          "title": "Wuthering Heights",
          "year": 2026,
          "note": "Emerald Fennell's adaptation, Margot Robbie and Jacob Elordi. Gorgeous in flashes but flat and un-erotic. The group's read: Fennell breaks the book to make a Romeo and Juliet she never lands, all edging and no payoff, with both leads miscast."
        },
        {
          "title": "Wuthering Heights (1939)",
          "year": 1939,
          "note": "William Wyler's version with Laurence Olivier and Merle Oberon. Sean's favorite of the bunch, and in his view the best one made."
        },
        {
          "title": "Wuthering Heights (1970)",
          "year": 1970,
          "note": "Robert Fuest's take, an early Timothy Dalton role."
        },
        {
          "title": "Wuthering Heights (1992)",
          "year": 1992,
          "note": "Juliette Binoche and Ralph Fiennes in his first film role; Sean still hasn't seen it."
        },
        {
          "title": "Wuthering Heights (2011)",
          "year": 2011,
          "note": "Andrea Arnold's, which casts a Black Heathcliff and goes at the novel's race and violence directly."
        },
        {
          "title": "Abismos de pasión",
          "year": 1954,
          "note": "Luis Buñuel's Mexican transposition of the novel."
        },
        {
          "title": "Hurlevent",
          "year": 1985,
          "note": "Jacques Rivette's version."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Pillion’",
      "note": "with Sam Sanders",
      "films": [
        {
          "title": "Pillion",
          "year": 2025,
          "note": "Harry Lighton's debut, Harry Melling and Alexander Skarsgård, adapted from Adam Mars-Jones's novel 'Box Hill.' The Dom-com everyone here loves: a consent-focused BDSM romance that hits classic rom-com beats and, unlike Wuthering Heights, sticks the landing."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Harry Lighton on ‘Pillion’",
      "guest": "Harry Lighton on",
      "films": [
        {
          "title": "The Lives of Others",
          "year": 2006,
          "note": "The first non-English film he ever watched, and the one that made him want to make movies."
        },
        {
          "title": "Kung Fu Panda",
          "year": 2008,
          "note": "His favorite film until 19; he could recite the whole thing."
        },
        {
          "title": "Badlands",
          "year": 1974,
          "note": "Malick touchpoint for the book's shifting tone; he rewatched it while adapting, then chose to drop voiceover entirely."
        },
        {
          "title": "The Wild One",
          "year": 1953,
          "note": "Watched for biker iconography, then steered wide to avoid pastiche."
        },
        {
          "title": "Scorpio Rising",
          "year": 1964,
          "note": "He hadn't seen it until press; the opening needle drop echoes it by accident."
        },
        {
          "title": "The Love That Remains",
          "year": 2025,
          "note": "Hlynur Pálmason's film, his last-great pick. He laughed till he gasped for air."
        },
        {
          "title": "Godland",
          "year": 2022,
          "note": "The Pálmason film that last stunned him."
        }
      ]
    }
