{
  "slug": "the-2016-movie-draft-three-the-hard-way",
  "title": "The 2016 Movie Draft: Three the Hard Way",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2021-03-30",
  "runtimeMin": 83,
  "format": "Sean, Amanda, and Chris draft the movies of 2016 across six categories, after a tribute to George Segal, Jessica Walter, and Bertrand Tavernier.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Remembering Segal, Walter, and Tavernier",
      "note": "in memoriam",
      "films": [
        {
          "title": "California Split",
          "year": 1974,
          "note": "Segal's heavy sweater, sunglasses, and total disregard for his own morality is the energy Sean aspires to."
        },
        {
          "title": "The Hot Rock",
          "year": 1972,
          "note": "Technically a Robert Redford vehicle, but Segal is the reason it holds up."
        },
        {
          "title": "Who's Afraid of Virginia Woolf?",
          "year": 1966,
          "note": "Amanda's other Segal reference point, alongside Just Shoot Me."
        },
        {
          "title": "Grand Prix",
          "year": 1966,
          "note": "Jessica Walter's breakout, a car-racing picture that put her on a track toward a Jane Fonda-style leading-lady career."
        },
        {
          "title": "Bye Bye Braverman",
          "year": 1968,
          "note": "Sidney Lumet's follow-up to The Group, with Walter and Segal opposite each other. Sean went hunting for it and could only find a DVD on Amazon."
        },
        {
          "title": "The Group",
          "year": 1966,
          "note": "Walter's other hard-to-find one. Chris has a framed poster of it in his house."
        },
        {
          "title": "The Bridge at Remagen",
          "year": 1969,
          "note": "An underrated WWII picture Chris calls out as one of his favorite bridge movies."
        },
        {
          "title": "The Watchmaker of St. Paul",
          "year": 1974,
          "note": "Bertrand Tavernier's debut. Nine of his films are streaming on the Criterion Channel."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The 2016 Movie Draft",
      "draftOf": "2016 movies",
      "categories": [
        "Drama",
        "Comedy or Horror",
        "Blockbuster",
        "Animated or Foreign Language",
        "Sequel",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Rogue One: A Star Wars Story",
              "year": 2016,
              "category": "Sequel",
              "note": "Sean's first pick. A story slotted just before A New Hope; Tony Gilroy's late rewrites and reshoots, after Gareth Edwards departed, produced the Vader hallway scene Sean calls a highlight of his decade at the movies."
            },
            {
              "title": "Sully",
              "year": 2016,
              "category": "Blockbuster",
              "note": "Ninety minutes, Hanks at his most competent, and a courtroom trial invented entirely for the movie."
            },
            {
              "title": "Train to Busan",
              "year": 2016,
              "category": "Animated or Foreign Language",
              "note": "A South Korean zombie movie Sean calls maybe the best of the last decade. Pairs well with Snowpiercer."
            },
            {
              "title": "O.J.: Made in America",
              "year": 2016,
              "category": "Wildcard",
              "note": "Ezra Edelman's documentary. Its Best Documentary win prompted the Academy to bar miniseries-length docs from future eligibility, which Sean thinks was the wrong call."
            },
            {
              "title": "Hell or High Water",
              "year": 2016,
              "category": "Drama",
              "note": "Bank robbers bankrupted by banks; also just a good heist movie about brothers."
            },
            {
              "title": "Everybody Wants Some!!",
              "year": 2016,
              "category": "Comedy or Horror",
              "note": "Sean's pick for best movie of the year. Richard Linklater's college comedy bombed at the box office and has been gaining a cult following since. Wyatt Russell's stoned Pink Floyd monologue is a highlight."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Captain America: Civil War",
              "year": 2016,
              "category": "Blockbuster",
              "note": "Chris's platonic ideal of a Marvel movie: half Cap-Iron Man schism, half Spider-Man backdoor pilot."
            },
            {
              "title": "The Conjuring 2",
              "year": 2016,
              "category": "Sequel",
              "note": "The best of the extended Conjuring universe, Chris says. England-set, atmosphere over gore."
            },
            {
              "title": "Manchester by the Sea",
              "year": 2016,
              "category": "Drama",
              "note": "Casey Affleck's performance, plus the Michelle Williams sidewalk scene, which Chris calls one of the most punishing sequences of the decade."
            },
            {
              "title": "Green Room",
              "year": 2016,
              "category": "Comedy or Horror",
              "note": "Jeremy Saulnier's punk-band-versus-skinheads thriller. Chris calls it one of the most intense movies of the decade."
            },
            {
              "title": "Toni Erdmann",
              "year": 2016,
              "category": "Animated or Foreign Language",
              "note": "Maren Ade's German comedy. There was briefly talk of an American remake produced by Lena Dunham, starring Kristen Wiig."
            },
            {
              "title": "Hail, Caesar!",
              "year": 2016,
              "category": "Wildcard",
              "note": "The Coens' Hollywood-fixer comedy. Chris credits a Reverse Shot piece by Adam Nayman with unlocking it for him."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Arrival",
              "year": 2016,
              "category": "Blockbuster",
              "note": "Squeaked past the $100 million threshold. Both Amanda and Chris had it on their best-of-the-decade lists."
            },
            {
              "title": "Moonlight",
              "year": 2016,
              "category": "Drama",
              "note": "The Best Picture winner. Amanda points to how it conveys who a person is, rather than what happens to them."
            },
            {
              "title": "The Invitation",
              "year": 2016,
              "category": "Comedy or Horror",
              "note": "Karen Kusama's Hollywood Hills thriller, the film Chris and his wife took Amanda to see during her first lonely year in LA."
            },
            {
              "title": "The Handmaiden",
              "year": 2016,
              "category": "Animated or Foreign Language",
              "note": "Park Chan-wook. A surprising pickup for Amazon, Chris notes, given how explicit it is."
            },
            {
              "title": "Jason Bourne",
              "year": 2016,
              "category": "Sequel",
              "note": "Tied to Amanda's 2016 honeymoon in Greece; Chris commented on her Parthenon Instagram post about the film's fight-pit scene."
            },
            {
              "title": "A Bigger Splash",
              "year": 2016,
              "category": "Wildcard",
              "note": "Luca Guadagnino. Sean's actual favorite movie of the year, especially the Ralph Fiennes dance scene."
            }
          ]
        }
      ],
