    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Billy Ray on",
      "note": "The Comey Rule screenwriter-director on adapting Comey's story, and on the movies behind his own work",
      "films": [
        {
          "title": "Shattered Glass",
          "year": 2003,
          "note": "The film Ray is still best known for; Sean says journalism students of his generation owe it a debt."
        },
        {
          "title": "Breach",
          "year": 2007,
          "note": "His FBI drama with Chris Cooper and Ryan Phillippe, the first film ever allowed to shoot inside the FBI building."
        },
        {
          "title": "Captain Phillips",
          "year": 2013,
          "note": "One of his real-event scripts, directed by Paul Greengrass."
        },
        {
          "title": "Richard Jewell",
          "year": 2019,
          "note": "Directed by Clint Eastwood; Ray calls an invented detail in the script a 'deep regret.'"
        },
        {
          "title": "All the President's Men",
          "year": 1976,
          "note": "His structural touchstone for what he calls 'people talking in rooms' movies."
        },
        {
          "title": "Jaws",
          "year": 1975,
          "note": "Studied for how it withholds the shark; modeled The Comey Rule's first half on that reveal."
        },
        {
          "title": "Amadeus",
          "year": 1984,
          "note": "Its Salieri narration gave him the idea to frame The Comey Rule through Rod Rosenstein."
        },
        {
          "title": "Schindler's List",
          "year": 1993,
          "note": "His example of a film that, without Spielberg attached, wouldn't get made as a theatrical feature today."
        },
        {
          "title": "Parasite",
          "year": 2019,
          "note": "One of three scripts from the year prior Ray says he was jealous of."
        },
        {
          "title": "Jojo Rabbit",
          "year": 2019,
          "note": "Same group of scripts."
        },
        {
          "title": "1917",
          "year": 2019,
          "note": "Same group of scripts."
        }
      ]
    }
  ],
