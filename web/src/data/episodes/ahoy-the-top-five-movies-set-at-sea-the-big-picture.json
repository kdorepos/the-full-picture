  "published": "2020-05-12",
  "runtimeMin": 70,
  "format": "Sean, Amanda, and Chris each rank their five favorite movies set at sea, after settling what counts as the sea.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Ground rules: what counts as the sea",
      "note": "the setup",
      "films": [
        {
          "title": "Crimson Tide",
          "year": 1995,
          "note": "The theme-week tie-in; a submarine movie, so it qualifies under the rules."
        },
        {
          "title": "Sea Fever",
          "year": 2019,
          "note": "Sean caught it on VOD the week before; proof the sea movie isn't extinct."
        },
        {
          "title": "Underwater",
          "year": 2020,
          "note": "Kristen Stewart on the deep-sea rig, a recent example."
        },
        {
          "title": "Crawl",
          "year": 2019,
          "note": "The alligator horror movie, another one that still gets made."
        },
        {
          "title": "Waterworld",
          "year": 1995,
          "note": "The cautionary tale for directors who wade into a studio tank."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Chris Ryan's Top Five",
      "note": "the terror within and around you",
      "subject": "Chris Ryan",
      "ranked": true,
      "films": [
        {
          "title": "The Hunt for Red October",
          "year": 1990,
          "note": "No. 1 (and Amanda's No. 2). McTiernan directs; Connery's Ramius may be defecting or mad, and Baldwin's Jack Ryan has to find out which."
        },
        {
          "title": "Master and Commander: The Far Side of the World",
          "year": 2003,
          "note": "No. 2. Peter Weir, Russell Crowe as Jack Aubrey; the on-deck surgery is the all-time look-away scene."
        },
        {
          "title": "The Perfect Storm",
          "year": 2000,
          "note": "No. 3. Wolfgang Petersen, of Das Boot, sends Clooney and Wahlberg out for one last haul."
        },
        {
          "title": "White Squall",
          "year": 1996,
          "note": "No. 4. Ridley Scott's gun-for-hire era; Jeff Bridges runs a sail-training academy for boys."
        },
        {
          "title": "Open Water",
          "year": 2003,
          "note": "No. 5. Divers left behind at sea; made for roughly $120k, based on a true story. Chris misdates it to 2013."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda Dobbins's Top Five",
      "note": "aquatic blue, mostly optimistic",
      "subject": "Amanda Dobbins",
      "ranked": true,
      "films": [
        {
          "title": "Titanic",
          "year": 1997,
          "note": "No. 1. Cameron's romance-plus-disaster; the most-seen ocean movie there is."
        },
        {
          "title": "The Hunt for Red October",
          "year": 1990,
          "note": "No. 2, shared with Chris; she woke up thinking it should have been No. 1."
        },
        {
          "title": "The Lady Eve",
          "year": 1941,
          "note": "No. 3. Preston Sturges screwball, much of it aboard an ocean liner."
        },
        {
          "title": "The Little Mermaid",
          "year": 1989,
          "note": "No. 4. The Disney movie that opened the Disney Renaissance. Amanda misdates it to 1999."
        },
        {
          "title": "The Life Aquatic with Steve Zissou",
          "year": 2004,
          "note": "No. 5. Wes Anderson riffing on Jacques Cousteau; an affection that grew with age."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top Five",
      "note": "the archetypes",
      "subject": "Sean Fennessey",
      "ranked": true,
      "films": [
        {
          "title": "Jaws",
          "year": 1975,
          "note": "No. 1. Sean's case: the entire third act is at sea, which for him is what makes a sea movie."
        },
        {
          "title": "Mutiny on the Bounty",
          "year": 1935,
          "note": "No. 2. The Gable version; Charles Laughton's Captain Bligh anchors it."
        },
        {
          "title": "Finding Nemo",
          "year": 2003,
          "note": "No. 3. Pixar's version of the sea as utopia rather than threat."
        },
        {
          "title": "Lifeboat",
          "year": 1944,
          "note": "No. 4. Hitchcock's single-setting experiment, staged entirely in one boat."
        },
        {
          "title": "The Poseidon Adventure",
          "year": 1972,
          "note": "No. 5. Irwin Allen's disaster template; Hackman rages as the reverend. The 1972 original, not the remake."
        }
      ]
    }
  ],
