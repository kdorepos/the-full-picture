  "format": "Sean and Amanda review Joel Coen's solo debut, then Sean drags Amanda through a full re-ranking of all nineteen Coen brothers movies.",
  "segments": [
    {
      "kind": "review",
      "heading": "The Tragedy of Macbeth",
      "note": "Joel Coen's first film without Ethan",
      "films": [
        {
          "title": "The Tragedy of Macbeth",
          "year": 2021,
          "note": "Denzel Washington and Frances McDormand play a pair of 60-somethings, which turns the play from a story about ambition into one about legacy. Both hosts call it austere and a little cold, despite handsome visuals."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Macbeth (and Shakespeare) on screen",
      "note": "how the play's been filmed before",
      "films": [
        {
          "title": "Macbeth (1948)",
          "year": 1948,
          "note": "Orson Welles, stark black and white, a Scottish brogue Sean says just doesn't work."
        },
        {
          "title": "Throne of Blood",
          "year": 1957,
          "note": "Kurosawa's version, one of Sean's all-time favorites since he saw it in 11th grade English class."
        },
        {
          "title": "Macbeth (1971)",
          "year": 1971,
          "note": "Polanski's, brutal and monologue-driven: you hear a lot of Macbeth's psychology narrated in his own head."
        },
        {
          "title": "Scotland, PA",
          "year": 2001,
          "note": "A Sundance-era comedy riff Sean isn't a fan of."
        },
        {
          "title": "Macbeth (2015)",
          "year": 2015,
          "note": "Justin Kurzel's, with Michael Fassbender and Marion Cotillard. Sean calls it a slog."
        },
        {
          "title": "Henry V",
          "year": 1944,
          "note": "Olivier's, the pick for a genuinely text-faithful Shakespeare adaptation."
        },
        {
          "title": "Much Ado About Nothing",
          "year": 1993,
          "note": "Kenneth Branagh's, with Denzel, one of his earlier Shakespeare turns."
        },
        {
          "title": "Romeo and Juliet",
          "year": 1968,
          "note": "Zeffirelli's, the one everybody's shown in high school."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Best Actor race",
      "note": "ten contenders, four real ones",
      "films": [
        {
          "title": "King Richard",
          "year": 2021,
          "note": "Will Smith, the frontrunner. Amanda is emotionally invested in this one winning."
        },
        {
          "title": "Tick, Tick... Boom!",
          "year": 2021,
          "note": "Andrew Garfield. Amanda cannot get on board."
        },
        {
          "title": "Nightmare Alley",
          "year": 2021,
          "note": "Bradley Cooper, doing some early press."
        },
        {
          "title": "Pig",
          "year": 2021,
          "note": "Nicolas Cage, whom Sean is rooting for even though he doubts a nomination happens."
        },
        {
          "title": "Don't Look Up",
          "year": 2021,
          "note": "Leonardo DiCaprio."
        },
        {
          "title": "Licorice Pizza",
          "year": 2021,
          "note": "Cooper Hoffman, getting less acclaim than his co-star Alana Haim."
        },
        {
          "title": "Cyrano",
          "year": 2021,
          "note": "Peter Dinklage, singing in a new musical version, bumped from a January release to February 25."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Stock up: Red Rocket",
