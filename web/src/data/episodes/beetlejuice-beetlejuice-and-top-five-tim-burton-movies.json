{
  "slug": "beetlejuice-beetlejuice-and-top-five-tim-burton-movies",
  "title": "‘Beetlejuice Beetlejuice’ and Top Five Tim Burton Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Van Lathan"
  ],
  "published": "2024-09-06",
  "runtimeMin": 86,
  "format": "Sean, Amanda, and guest Van Lathan review Tim Burton's 36-years-later sequel, trace his career from an unbroken early run to the years it cracked, then each rank their five favorite Burton films.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Beetlejuice Beetlejuice’",
      "films": [
        {
          "title": "Beetlejuice Beetlejuice",
          "year": 2024,
          "note": "A mixed bag they mostly enjoyed: a 5-or-6-out-of-10 that flirts with sucking, then flips into a fun time. Keaton slides back in as if no time passed and Catherine O'Hara feels of the original world; everyone else plays broad, near-cosplay. Overstuffed with parallel plots (Jenna Ortega and Arthur Conti's dead-boy romance, Justin Theroux's reality-TV producer, Monica Bellucci's soul-sucking ex, Willem Dafoe's afterlife cop). Bellucci is the cut everyone would make; the closing musical number lands."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Tim Burton, from Burbank",
      "note": "the legacy argument",
      "films": [
        {
          "title": "Beetlejuice",
          "year": 1988,
          "note": "The 1988 original as the measuring stick: sparing use of Keaton, a bureaucratic afterlife, the Deetzes played sincere-odd rather than as send-ups."
        },
        {
          "title": "Pee-wee's Big Adventure",
          "year": 1985,
          "note": "Burton's debut; Sean argues a stand-up persona has almost never survived the jump to film this well."
        },
        {
          "title": "Batman",
          "year": 1989,
          "note": "The hysteria and the lines around the block; proof a superhero movie could be artful and sinister."
        },
        {
          "title": "Edward Scissorhands",
          "year": 1990,
          "note": "The most autobiographical: the Burbank outcast, in daylight and pastel, made to feel seen."
        },
        {
          "title": "Batman Returns",
          "year": 1992,
          "note": "Called overhated; Warner Bros. balked at how dark and grotty Burton took it, but Keaton and Michelle Pfeiffer carry it."
        },
        {
          "title": "Ed Wood",
          "year": 1994,
          "note": "The Touchstone/Disney pickup; Van's note that Martin Landau's Oscar came at Samuel L. Jackson's expense."
        },
        {
          "title": "Mars Attacks!",
          "year": 1996,
          "note": "A big swing with an insane cast; Sean rates it a success, others read it as the crack where going bigger starts to hurt him."
        },
        {
          "title": "Sleepy Hollow",
          "year": 1999,
          "note": "Where Sean's 'first great run' ends; the first Burton he finds only half-successful."
        },
        {
          "title": "Planet of the Apes",
          "year": 2001,
          "note": "Named as maybe his worst movie, a big embarrassment at the time."
        },
        {
          "title": "Big Fish",
          "year": 2003,
          "note": "The intimate correction after Apes; solid."
        },
        {
          "title": "Charlie and the Chocolate Factory",
          "year": 2005,
          "note": "The line where the latter era starts: the post-Pirates Depp reunion and the turn to a commercial machine."
        },
        {
          "title": "Corpse Bride",
          "year": 2005,
          "note": "Amanda's last real connection to his catalog; a Laika co-production in the Nightmare Before Christmas tradition."
        },
        {
          "title": "Sweeney Todd: The Demon Barber of Fleet Street",
          "year": 2007,
          "note": "An okay Sondheim adaptation; landed for people, not for the hosts. A Depp acting nomination."
        },
        {
          "title": "Alice in Wonderland",
          "year": 2010,
          "note": "The look swallowing the story."
        },
        {
          "title": "Dumbo",
          "year": 2019,
          "note": "Van's big disappointment; a stacked cast (Colin Farrell, Keaton, DeVito, Eva Green, Alan Arkin) and it stinks."
        },
        {
          "title": "Big Eyes",
          "year": 2014,
          "note": "Amanda considered it for her list and cut it, blaming Amy Adams."
        },
        {
          "title": "The Nightmare Before Christmas",
          "year": 1993,
          "note": "The one people wrongly credit to Burton; he produced, Henry Selick directed. Debated for top-five eligibility."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Van Lathan's Top Five Tim Burton Movies",
      "note": "No. 1 first",
      "subject": "Tim Burton",
      "ranked": true,
      "films": [
        {
          "title": "Batman",
          "year": 1989,
          "note": "No. 1: the peak of Burton's powers and, to Van, still the best take on the character."
        },
        {
          "title": "Pee-wee's Big Adventure",
          "year": 1985,
          "note": "No. 2: the Burton movie he's seen most, the one his whole family loved."
        },
        {
          "title": "Edward Scissorhands",
          "year": 1990,
          "note": "No. 3: a deep connection; one of the first movies that made him emote."
        },
        {
          "title": "Beetlejuice",
          "year": 1988,
          "note": "No. 4."
        },
        {
          "title": "Ed Wood",
          "year": 1994,
          "note": "No. 5: great, but the one he's least intimately connected to."
        }
      ]
    },
    {
