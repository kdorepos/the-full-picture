{
  "slug": "godzilla-vs-kong-and-top-five-blockbusters",
  "title": "‘Godzilla vs. Kong’ and Top Five Blockbusters",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Shea Serrano"
  ],
  "published": "2021-04-01",
  "runtimeMin": 82,
  "format": "Sean, Amanda, and Shea Serrano watch the first blockbuster of 2021, then each pick their five favorite blockbusters ever.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Godzilla vs. Kong’",
      "note": "on HBO Max",
      "films": [
        {
          "title": "Godzilla vs. Kong",
          "year": 2021,
          "note": "A 31-minute closing fight and not much reason for the rest. Amanda recaps the plot at length; the crew agrees Kong wins, and Rebecca Hall gets stuck saying things like \"depth charges\" and \"there can't be two alpha Titans.\""
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Shea Serrano's Top Five Blockbusters",
      "subject": "Blockbusters",
      "ranked": true,
      "films": [
        {
          "title": "Furious 7",
          "year": 2015,
          "note": "No. 1 - the Paul Walker goodbye and the Wiz Khalifa song had the whole family crying."
        },
        {
          "title": "Get Out",
          "year": 2017,
          "note": "The theater went dead silent at the police lights, then cheered when the door opened on Rod."
        },
        {
          "title": "Creed",
          "year": 2015,
          "note": "The Rocky theme drops before the last round and Shea, his wife, and his uncles were all in tears."
        },
        {
          "title": "Jurassic World",
          "year": 2015,
          "note": "Blue comes running back for the fight - his fourth-favorite theater experience."
        },
        {
          "title": "Mortal Kombat",
          "year": 1995,
          "note": "Paul W.S. Anderson; his fifth-best moviegoing day ever. \"The best video game movie that's ever been made.\""
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda Dobbins's Top Five Blockbusters",
      "subject": "Blockbusters",
      "ranked": true,
      "films": [
        {
          "title": "Jurassic Park",
          "year": 1993,
          "note": "No. 1 - eight-or-nine-year-old Amanda watching the dinosaurs come to life; read the book first."
        },
        {
          "title": "Titanic",
          "year": 1997,
          "note": "Obvious and not: Bill Paxton's underwater robot, a Best Picture win, and Cameron the goat."
        },
        {
          "title": "Fast Five",
          "year": 2011,
          "note": "Her religious experience - they drag a safe through Rio for 20 minutes."
        },
        {
          "title": "Top Gun",
          "year": 1986,
          "note": "The Iliad with fighter planes; she'll cry when the theme plays for the sequel."
        },
        {
          "title": "Independence Day",
          "year": 1996,
          "note": "Her disaster and alien slot - '90s Will Smith and the White House laser."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean Fennessey's Top Five Blockbusters",
      "subject": "Blockbusters",
      "ranked": true,
      "films": [
        {
          "title": "Terminator 2: Judgment Day",
          "year": 1991,
          "note": "No. 1 - the blockbuster template; effects that still hold up."
        },
        {
          "title": "Mission: Impossible",
          "year": 1996,
          "note": "A late swap in for Die Hard - Brian De Palma handed a reboot and the silent Langley heist."
        },
        {
          "title": "Mad Max: Fury Road",
          "year": 2015,
          "note": "Seen alone at a 10 a.m. show on a sugar high; \"strangle you while feeding you cocaine.\""
        },
        {
          "title": "The Fugitive",
          "year": 1993,
          "note": "Simple story, Harrison Ford at his most virile, Tommy Lee Jones's Oscar."
        },
        {
          "title": "Speed",
          "year": 1994,
          "note": "A tight elevator pitch, then gifted actors saying silly stuff, just like the main event."
        }
      ]
    }
  ],
