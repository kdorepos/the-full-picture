---
import Base from '../layouts/Base.astro';

const modules = import.meta.glob('../data/episodes/*.json', { eager: true });
const episodes = Object.values(modules)
  .map((m) => m.default)
  .sort((a, b) => (a.published < b.published ? 1 : -1));
const publishedSlugs = episodes.map((e) => e.slug);

const filmsIn = (s) =>
  (s.films?.length ?? 0) +
  (s.picks?.length ?? 0) +
  (s.teams?.reduce((n, t) => n + t.picks.filter((p) => p.year).length, 0) ?? 0) +
  (s.slates?.reduce((n, sl) => n + sl.picks.length, 0) ?? 0) +
  (s.categories?.reduce((n, c) => n + (c.nominees?.length ?? 0), 0) ?? 0);
const filmCount = (ep) => (ep.segments ?? []).reduce((n, s) => n + filmsIn(s), 0);
const fmt = (d) => new Date(d).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const KIND = {
  review: 'Review', ranking: 'Rankings', topfive: 'Top Five', halloffame: 'Hall of Fame',
  discussion: 'Discussion', interview: 'Interview', list: 'Roundtable', draft: 'Draft',
  auction: 'Auction', awards: 'Awards',
};
const kind = (ep) => [...new Set((ep.segments ?? []).map((s) => KIND[s.kind] ?? 'Segment'))].join(' · ') || 'Episode';
---
<Base title="The Full Picture: every film, every episode" description="A catalogue of every movie discussed on The Big Picture, episode by episode.">
  <section class="cover">
    <div class="wrap">
      <p class="eyebrow">The Big Picture · Film catalogue</p>
      <h1>Every film they name, on the record.</h1>
      <p class="lede">Every movie mentioned on each episode, catalogued and linked, whether it was reviewed, drafted, or just brought up in passing.</p>
    </div>
  </section>

  <div class="wrap">
    <section id="processing" class="processing" hidden>
      <p class="proc-eyebrow">Now processing <span class="proc-dot" aria-hidden="true"></span></p>
      <h2 class="proc-title" id="proc-title"></h2>
      <div class="proc-bar"><div class="proc-fill" id="proc-fill"></div></div>
      <p class="proc-status" id="proc-status"></p>
    </section>

    <section class="sale-section" style="border-bottom:none">
      <p class="rubric">Episodes <span class="sub">newest first</span></p>
      <p class="ai-note">
        <b>AI-generated</b>
        Episodes are transcribed and analyzed with AI models. The matches aren't perfect —
        expect the occasional misheard title or a link to the wrong film.
      </p>
      <div class="catalogue">
        {episodes.map((ep) => (
          <a class="sale-card" href={`/ep/${ep.slug}`}>
            <div>
              <span class="eyebrow">{kind(ep)} · {fmt(ep.published)} · {ep.runtimeMin} min</span>
              <h2>{ep.title}</h2>
              <span class="credits">{ep.hosts.join(' · ')}</span>
            </div>
            <span class="count">{filmCount(ep)}<small>films</small></span>
          </a>
        ))}
      </div>
    </section>
  </div>

  <script is:inline define:vars={{ publishedSlugs }}>
    // Poll the pipeline's progress.json and reveal the "Now processing" panel while an
    // episode is being transcribed. Hides once it's done or already published on the site.
    const el = document.getElementById('processing');
    const PHASE = {
      downloading: 'Downloading audio',
      transcribing: 'Transcribing',
      transcribed: 'Transcribed, writing up the film list',
    };
    async function tick() {
      try {
        const r = await fetch('/api/progress?t=' + Date.now(), { cache: 'no-store' });
        if (!r.ok) throw 0;
        const p = await r.json();
        if (!p.active || publishedSlugs.includes(p.slug)) { el.hidden = true; return; }
        const pct = Math.max(0, Math.min(100, p.pct ?? 0));
        document.getElementById('proc-title').textContent = p.title || 'A new episode';
        document.getElementById('proc-fill').style.width = pct + '%';
        const label = PHASE[p.phase] || 'Processing';
        const mins = Math.round((p.etaSec ?? 0) / 60);
        const eta = p.phase === 'transcribing' && p.etaSec > 0
          ? ` · ~${mins < 1 ? '1' : mins}m left` : '';
        document.getElementById('proc-status').textContent =
          p.phase === 'transcribing' ? `${label} · ${pct}%${eta}`
            : p.phase === 'transcribed' ? label : `${label}…`;
        el.hidden = false;
      } catch { el.hidden = true; }
    }
    tick();
    setInterval(tick, 15000);
  </script>
</Base>
