        {
          "title": "Megalopolis",
          "year": 2024,
          "note": "Coppola's self-financed epic; the trailer just dropped and it's Cannes-bound, still without US distribution."
        },
        {
          "title": "Horizon: An American Saga - Chapter 1",
          "year": 2024,
          "note": "Costner's self-financed four-part Western, Chapter 1 out June 28, off a combative Deadline interview ('I'm not Ahab')."
        },
        {
          "title": "Challengers",
          "year": 2024,
          "note": "Headed to disc with no 4K and no special features, to Sean's dismay."
        },
        {
          "title": "The Fall Guy",
          "year": 2024,
          "note": "The Gosling stuntman movie. Amanda's up for it, Andy wasn't."
        },
        {
          "title": "Furiosa: A Mad Max Saga",
          "year": 2024,
          "note": "Part of the month's run of classical action, the through-line for the whole draft."
        },
        {
          "title": "Kingdom of the Planet of the Apes",
          "year": 2024,
          "note": "The other May tentpole in that same wave."
        }
      ]
    },
