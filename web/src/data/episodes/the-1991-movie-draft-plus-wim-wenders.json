    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Wim Wenders on",
      "films": [
        {
          "title": "Perfect Days",
          "year": 2023,
          "note": "His Tokyo film about a toilet cleaner who lives in the present; Koji Yakusho's near-wordless performance won Best Actor at Cannes, and it was Japan's international-feature Oscar entry. Wenders shot it in 17 days, mostly in chronological order, with the music playing live in the scenes."
        },
        {
          "title": "Anselm",
          "year": 2023,
          "note": "His 3D documentary on the artist Anselm Kiefer, shot in seven sessions over two and a half years and finished the same year as Perfect Days; an official Cannes entry."
        }
      ]
