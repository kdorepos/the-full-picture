          "picks": [
            {
              "title": "Get Out",
              "year": 2017,
              "category": "Comedy or Horror",
              "note": "The No. 1 overall pick. Sean calls it maybe the most important movie of the last five years."
            },
            {
              "title": "Coco",
              "year": 2017,
              "category": "Animated and Foreign Language",
              "note": "The default Pixar pick in an otherwise thin year for animation."
            },
            {
              "title": "Thor: Ragnarok",
              "year": 2017,
              "category": "Sequel",
              "note": "Taika Waititi's humor unlocked Chris Hemsworth, plus an in-on-the-joke Matt Damon cameo."
            },
            {
              "title": "Good Time",
              "year": 2017,
              "category": "Drama",
              "note": "The Safdie Brothers' breakout, a warmup for Uncut Gems."
            },
            {
              "title": "Baby Driver",
              "year": 2017,
              "category": "Blockbuster",
              "note": "An original jukebox-musical car-heist movie that became a hit almost by accident."
            },
            {
              "title": "The Meyerowitz Stories (New and Selected)",
              "year": 2017,
              "category": "Wildcard",
              "note": "Passed over mother! for Baumbach's ensemble cast: Sandler, Stiller, Hoffman, Thompson."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Lady Bird",
              "year": 2017,
              "category": "Comedy or Horror",
              "note": "Greta Gerwig's feature debut, drafted specifically so Chris couldn't have it."
            },
            {
              "title": "Okja",
              "year": 2017,
              "category": "Animated and Foreign Language",
              "note": "Bong Joon Ho's Netflix film, half in English, but she says it still counts."
            },
            {
              "title": "Star Wars: The Last Jedi",
              "year": 2017,
              "category": "Sequel",
              "note": "Her only real sequel option besides Guardians Vol. 2, which she can't stand."
            },
            {
              "title": "The Lost City of Z",
              "year": 2017,
              "category": "Drama",
              "note": "James Gray's Amazon expedition film, with a Sienna Miller performance she'd build a whole draft around."
            },
            {
              "title": "Wonder Woman",
              "year": 2017,
              "category": "Blockbuster",
              "note": "A pick for Bill Simmons, still mad she liked it. The Themyscira opening finally made superhero movies click for her."
            },
            {
              "title": "The Big Sick",
              "year": 2017,
              "category": "Wildcard",
              "note": "Kumail Nanjiani and Emily V. Gordon's script, with a notable Ray Romano performance."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "It",
              "year": 2017,
              "category": "Comedy or Horror",
              "note": "A Stephen King adaptation that actually delivered, even if the sequel cooled enthusiasm on it."
            },
            {
              "title": "The Square",
              "year": 2017,
              "category": "Animated and Foreign Language",
              "note": "Ruben Östlund's art-world satire, with Claes Bang and Elisabeth Moss."
            },
            {
              "title": "Blade Runner 2049",
              "year": 2017,
              "category": "Sequel",
              "note": "Unfairly maligned at release, he says, for Villeneuve's visuals alone."
            },
            {
              "title": "Phantom Thread",
              "year": 2017,
              "category": "Drama",
              "note": "Paul Thomas Anderson's film, conceded to drama despite his case for comedy."
            },
            {
              "title": "Dunkirk",
              "year": 2017,
              "category": "Blockbuster",
              "note": "The chronological trickery matters less on rewatch than the performances, Kenneth Branagh included."
            },
            {
              "title": "Logan Lucky",
              "year": 2017,
              "category": "Wildcard",
              "note": "A Soderbergh heist movie that plays better now than the 'this changes distribution' hype did at the time."
            }
          ]
