      "films": [
        {
          "title": "The Dark Knight Rises",
          "year": 2012,
          "note": "Watched start to finish, live. Sean loves the top and tail of it but calls the occupied-Gotham middle stretch 'incoherent and stupid,' a knock Amanda seconds. Tom Hardy's Bane, jacked and doing the voice, is the one thing nobody in the room has a bad word for."
        }
      ]
    }
