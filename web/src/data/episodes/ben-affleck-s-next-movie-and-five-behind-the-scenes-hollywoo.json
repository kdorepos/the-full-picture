{
  "slug": "ben-affleck-s-next-movie-and-five-behind-the-scenes-hollywoo",
  "title": "Ben Affleck's Next Movie and Five Behind-the-Scenes Hollywood Stories We Want",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2020-08-11",
  "runtimeMin": 77,
  "format": "Amanda's on vacation, so Chris Ryan sits in for the Ben Affleck Chinatown movie, five doomed film shoots they'd pay to see dramatized, and Sean's talk with Amy Seimetz about She Dies Tomorrow.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Ben Affleck's 'Big Goodbye'",
      "note": "the news",
      "films": [
        {
          "title": "Chinatown",
          "year": 1974,
          "note": "Affleck is set to write and direct an adaptation of Sam Wasson's The Big Goodbye, about the making of it. Chris puts the film in his personal top five."
        },
        {
          "title": "Argo",
          "year": 2012,
          "note": "Affleck's earlier backdoor love letter to moviemaking."
        },
        {
          "title": "Rosemary's Baby",
          "year": 1968,
          "note": "Cited with the rest of Polanski's work as the reason he's a problematic figure to center a film on."
        },
        {
          "title": "Repulsion",
          "year": 1965
        },
        {
          "title": "Knife in the Water",
          "year": 1962
        },
        {
          "title": "Macbeth",
          "year": 1971,
          "note": "Polanski's adaptation."
        },
        {
          "title": "First Cow",
          "year": 2020,
          "note": "Sean's number one film of 2020 so far, name-checked in the opening grab-bag."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "Five Behind-the-Scenes Stories We Want",
      "note": "troubled shoots they'd dramatize",
      "picks": [
        {
          "title": "Apocalypse Now",
          "year": 1979,
          "by": "Chris Ryan",
          "note": "Really a narrative film about Eleanor Coppola's making-of doc Hearts of Darkness. Casting: Sofia Coppola as Eleanor, Nicolas Cage as Francis."
        },
        {
          "title": "Sorcerer",
          "year": 1977,
          "by": "Chris Ryan",
          "note": "Friedkin's doomed Roy Scheider bridge picture, and an excuse to revive the Tangerine Dream score."
        },
        {
          "title": "Winter Kills",
          "year": 1979,
          "by": "Sean Fennessey",
          "note": "Mafia funding, a producer shot in the head, a set shut down three times: a seedy shoot behind a barely watchable film."
        },
        {
          "title": "Ishtar",
          "year": 1987,
          "by": "Sean Fennessey",
          "note": "The love triangle among Beatty, Hoffman, and Elaine May, and the debt Beatty felt he owed May for saving Reds. Cast: Chris Pine, Jason Schwartzman, Catherine Keener."
        },
        {
          "title": "The Conqueror",
          "year": 1956,
          "by": "Sean Fennessey",
          "note": "John Wayne as Genghis Khan, shot downwind of a Nevada nuclear test site; roughly half the crew later died of cancer. Probably a miniseries."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Case for 'Host'",
      "note": "the 56-minute Shudder movie",
      "films": [
        {
          "title": "Host",
          "year": 2020,
          "note": "Rob Savage's Zoom-seance horror shot in quarantine. Chris's favorite of the year: the scares are built entirely out of Zoom itself, and it never overstays 56 minutes."
        },
        {
          "title": "The Blair Witch Project",
          "year": 1999,
          "note": "The comparison point: DIY filmmaking that captures a specific technological moment."
        },
        {
          "title": "Unfriended",
          "year": 2014,
          "note": "The earlier screen-life horror both hosts admire."
        },
        {
          "title": "An American Pickle",
          "year": 2020,
          "note": "The episode's sponsor, but also the jumping-off point for a chat about the small, contained 'medium movie.'"
        },
        {
          "title": "Long Shot",
          "year": 2019,
          "note": "The bigger, busier comedy Pickle gets contrasted against."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "David Ayer's 'The Tax Collector'",
      "note": "a resurrection that isn't",
      "films": [
        {
          "title": "The Tax Collector",
          "year": 2020,
          "note": "Bobby Soto stars, with Shia LaBeouf as the loose-cannon Creeper. Both hosts wanted Ayer back in Harsh Times mode; both found it gauzy, disjointed and dull."
        },
        {
          "title": "End of Watch",
          "year": 2012,
          "note": "Widely held as Ayer's best, most inventive film."
        },
        {
          "title": "Sabotage",
          "year": 2014,
          "note": "Sean's pick for an underrated, badass, well-made Ayer action movie."
        },
        {
          "title": "Fury",
          "year": 2014,
          "note": "The method-acting war movie whose own making, they joke, is worth a movie."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Amy Seimetz on 'She Dies Tomorrow'",
      "guest": "Amy Seimetz on",
      "films": [
        {
          "title": "She Dies Tomorrow",
          "year": 2020,
          "note": "Her self-financed second feature, a contagious-dread horror-comedy she paid for with her Pet Sematary check and shot partly in her own house."
        },
        {
          "title": "Sun Don't Shine",
          "year": 2012,
          "note": "Her first feature, eight years earlier."
        },
        {
          "title": "Pet Sematary",
          "year": 2019,
          "note": "The remake she acted in; its paycheck funded She Dies Tomorrow."
        },
        {
          "title": "Alien: Covenant",
          "year": 2017,
          "note": "One of her recognizable acting roles."
        },
        {
          "title": "Shirley",
          "year": 2020,
          "note": "Josephine Decker's film, her most recent obsession and a proposed double feature."
        },
        {
          "title": "Uncut Gems",
          "year": 2019,
          "note": "One of the Safdie films she cites as anxiety-drama kin."
        },
        {
          "title": "Good Time",
          "year": 2017,
          "note": "The other Safdie touchstone."
        },
        {
          "title": "Frownland",
          "year": 2007,
          "note": "Ronnie Bronstein's film, which she calls an early example of anxiety-as-drama."
        },
        {
          "title": "Resolution",
          "year": 2012,
          "note": "The Benson and Moorhead film going around when Sun Don't Shine was; they went on to produce She Dies Tomorrow."
        }
      ]
    }
  ],
