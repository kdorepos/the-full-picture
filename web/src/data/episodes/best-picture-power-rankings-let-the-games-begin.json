    {
      "kind": "review",
      "heading": "'Sr.'",
      "note": "the new Chris Smith documentary on Netflix",
      "films": [
        {
          "title": "Sr.",
          "year": 2022,
          "note": "Chris Smith's documentary, produced by Robert Downey Jr. and Susan Downey, about Downey Jr.'s father, the underground filmmaker Robert Downey Sr. Junior makes a film about Senior making a film; it turns into the two of them talking, then into a film about Senior's illness. Runs a brisk 90 minutes. Both hosts count it among their favorites of the year."
        },
        {
          "title": "Putney Swope",
          "year": 1969,
          "note": "Downey Sr.'s best-known film, an outsider satire set at an ad agency taken over by its lone Black employee. Sean's mother loved it; he chased it down as a teenager in the late '90s."
        },
        {
          "title": "Pound",
          "year": 1970,
          "note": "Downey Sr.'s film with 16 pounded dogs played by human actors; Robert Downey Jr.'s screen debut. The one Downey Sr. movie Sean hasn't seen."
        },
        {
          "title": "Greaser's Palace",
          "year": 1972,
          "note": "A Paul Thomas Anderson favorite among Downey Sr.'s films."
        },
        {
          "title": "Chafed Elbows",
          "year": 1966
        },
        {
          "title": "Two Tons of Turquoise to Taos Tonight",
          "year": 1975
        },
        {
          "title": "Sweet Sweetback's Baadasssss Song",
          "year": 1971,
          "note": "Named alongside Putney Swope as a late-'60s outsider film made outside the studio system."
        },
        {
          "title": "Easy Rider",
          "year": 1969
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "Best Picture Power Rankings",
      "note": "a first-draft top ten, No. 1 first",
      "subject": "2022 Best Picture race",
      "ranked": true,
      "films": [
        {
          "title": "The Fabelmans",
          "year": 2022,
          "note": "No. 1, by a narrow margin. Spielberg, Tony Kushner script, Toronto People's Choice winner. Sean worries no one has seen it yet and that the inevitability factor is a poison pill."
        },
        {
          "title": "Everything Everywhere All at Once",
          "year": 2022,
          "note": "No. 2. Just won Best Picture at the Gothams. A sci-fi comedy with the Daniels working the trail hard; its biggest enthusiasts skew younger than the average Academy voter."
        },
        {
          "title": "Elvis",
          "year": 2022,
          "note": "No. 3. Second most-seen of the bunch, standing ovations at screenings, SAG loves it. Amanda floats it as high as No. 1; Sean isn't a fan but concedes it's playing."
        },
        {
          "title": "The Banshees of Inisherin",
          "year": 2022,
          "note": "No. 4. Respected and controversy-free, but the passion feels muted. Farrell for actor, McDonagh for screenplay."
        },
        {
          "title": "Top Gun: Maverick",
          "year": 2022,
          "note": "No. 5. The one everyone has seen and liked. Amanda argues for higher; Sean thinks the support tops out here."
        },
        {
          "title": "Tár",
          "year": 2022,
          "note": "No. 6. Both hosts love it and both think Cate Blanchett wins actress, but it has no path to the top prize."
        },
        {
          "title": "Women Talking",
          "year": 2022,
          "note": "No. 7. Release pushed to December 23rd, which some think was a mistake. The title and cast make it a likely in."
        },
        {
          "title": "The Woman King",
          "year": 2022,
          "note": "No. 8. Live if the campaign shows up; Gina Prince-Bythewood's Gotham tribute is a good sign."
        },
        {
          "title": "Glass Onion: A Knives Out Mystery",
          "year": 2022,
          "note": "No. 9. Rian Johnson well-liked; it goes into adapted screenplay in a weak year. The open question is whether voters dock it for being a sequel."
        },
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "No. 10, and marked N/A until it screens December 12th. Sean sticks with Big Jim on principle."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Laura Poitras on 'All the Beauty and the Bloodshed'",
      "guest": "Laura Poitras on",
      "films": [
        {
          "title": "All the Beauty and the Bloodshed",
          "year": 2022,
          "note": "Poitras's portrait of artist Nan Goldin, built in chapters around Goldin's archive and her PAIN campaign against the Sackler family. A biography that pivots into a societal critique; Goldin is a producer and collaborator on it."
        },
        {
          "title": "Citizenfour",
          "year": 2014,
          "note": "Poitras met Goldin around its release. She had to appear in it because Snowden was her source and the audience needed to know it."
        },
        {
          "title": "How to Survive a Plague",
          "year": 2012,
          "note": "Produced by Howard Gertler, also a producer here; Poitras cites it as a blueprint for how activism works on screen."
        },
        {
          "title": "Return to Homs",
          "year": 2013,
          "note": "Poitras's pick for the last great thing she saw, on the Syrian uprising."
        }
      ]
    }
  ],
