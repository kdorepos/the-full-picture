{
  "slug": "so-tenet-plus-top-five-movies-about-making-movies",
  "title": "So … ‘Tenet’? Plus: Top Five Movies About Making Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2020-06-30",
  "runtimeMin": 80,
  "format": "Tenet slides its release date again, three straight-to-VOD weekend releases underwhelm, a send-off for Joel Schumacher, and the hosts finally deliver their dueling top-five lists of movies about making movies.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Three new releases, none of them great",
      "note": "Irresistible, Eurovision Song Contest, My Spy",
      "films": [
        {
          "title": "Irresistible",
          "year": 2020,
          "note": "Jon Stewart's small-town political satire, starring Steve Carell and Rose Byrne. Both hosts call it toothless — a movie about the 2016 election made with 2006 thinking."
        },
        {
          "title": "Eurovision Song Contest: The Story of Fire Saga",
          "year": 2020,
          "note": "Will Ferrell and Rachel McAdams on Netflix. Amanda: fine, just not her thing if you don't already care about Eurovision."
        },
        {
          "title": "My Spy",
          "year": 2020,
          "note": "Dave Bautista's action-comedy, bumped from a theatrical STX release to Amazon Prime."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Doctor Sleep's HBO Max director's cut",
      "note": "the three-hour version",
      "films": [
        {
          "title": "Doctor Sleep",
          "year": 2019,
          "note": "Sean is partway through the extended cut and finds it better than the theatrical release — and thinks Rebecca Ferguson's Rose the Hat deserved a movie of her own."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "Remembering Joel Schumacher",
      "note": "1939–2020",
      "honoree": "Joel Schumacher",
      "films": [
        {
          "title": "Sleeper",
          "year": 1973,
          "note": "Schumacher designed the handmade-looking science-fiction costumes early in his career, before he directed."
        },
        {
          "title": "The Last of Sheila",
          "year": 1973,
          "note": "Schumacher as costume designer."
        },
        {
          "title": "Play It As It Lays",
          "year": 1972,
          "note": "The Joan Didion adaptation; Schumacher on costumes."
        },
        {
          "title": "The Wiz",
          "year": 1978,
          "note": "Schumacher wrote the screenplay; Sidney Lumet directed."
        },
        {
          "title": "Car Wash",
          "year": 1976,
          "note": "Schumacher-written ensemble comedy."
        },
        {
          "title": "Sparkle",
          "year": 1976,
          "note": "Schumacher-written; about an aspiring singer."
        },
        {
          "title": "St. Elmo's Fire",
          "year": 1985,
          "note": "Brat Pack touchstone, part of the run Amanda grew up on."
        },
        {
          "title": "The Lost Boys",
          "year": 1987,
          "note": "Late-80s touchpoint Amanda credits Gilbert Cruz with introducing her to."
        },
        {
          "title": "Flatliners",
          "year": 1990,
          "note": "The third of the Brat Pack-era trio, alongside St. Elmo's Fire and The Lost Boys."
        },
        {
          "title": "Falling Down",
          "year": 1993,
          "note": "Michael Douglas as a man unraveling through Los Angeles — tone-deaf and compelling in equal measure, per Sean."
        },
        {
          "title": "The Client",
          "year": 1994,
          "note": "One of Sean's two favorite John Grisham adaptations Schumacher directed."
        },
        {
          "title": "A Time to Kill",
          "year": 1996,
          "note": "The other favorite Grisham adaptation."
        },
        {
          "title": "Batman & Robin",
          "year": 1997,
          "note": "The reputation-definer. Amanda, 12 when it came out, calls it maybe the first superhero movie she ever saw."
        },
        {
          "title": "Tigerland",
          "year": 2000,
          "note": "Part of Schumacher's run of glamorous, dark-and-dingy dramas."
        },
        {
          "title": "Phone Booth",
          "year": 2002,
          "note": "Another entry in that same run."
        },
        {
          "title": "Veronica Guerin",
          "year": 2003,
          "note": "Same run, always with movie stars."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's top five movies about making movies",
      "note": "best to worst",
      "subject": "Movies about making movies",
      "ranked": true,
      "films": [
        {
          "title": "Boogie Nights",
          "year": 1997,
          "note": "No. 1 — Paul Thomas Anderson's second feature, seen through Dirk Diggler's rise. Sean saw it at 15 and calls it one for the ages."
        },
        {
          "title": "The Player",
          "year": 1992,
          "note": "No. 2 — Robert Altman's comeback, scripted by Michael Tolkin, seen through a villainized studio executive. Sean and Amanda picked it independently."
        },
        {
          "title": "Barton Fink",
          "year": 1991,
          "note": "No. 3 — the Coens' tale of a playwright sent to write a wrestling picture in Hollywood, and losing his mind in the process."
        },
        {
          "title": "Who Framed Roger Rabbit?",
          "year": 1988,
          "note": "No. 4 — Robert Zemeckis's cartoon-and-live-action hybrid. Sean pushes back hard on the idea it hasn't aged well."
        },
        {
          "title": "The Bad and the Beautiful",
          "year": 1952,
          "note": "No. 5 — Vincente Minnelli's ruthless portrait of a producer, played by Kirk Douglas. Sean says it was invoked a lot when Harvey Weinstein's history came out."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's top five movies about making movies",
      "note": "best to worst",
      "subject": "Movies about making movies",
      "ranked": true,
      "films": [
        {
          "title": "Singin' in the Rain",
          "year": 1952,
          "note": "No. 1 — Gene Kelly and Stanley Donen's musical about Hollywood's transition from silent films to talkies. Amanda's portal into old Hollywood as a teenager."
        },
        {
          "title": "The Player",
          "year": 1992,
          "note": "No. 2 — Amanda's independent pick of the same film Sean chose at the same spot."
        },
        {
          "title": "Once Upon a Time in Hollywood",
          "year": 2019,
          "note": "No. 3 — Quentin Tarantino's most sentimental film, per Amanda, about the almost-famous getting a second chance."
        },
        {
          "title": "Adaptation",
          "year": 2002,
          "note": "No. 4 — Spike Jonze directing Charlie Kaufman's screenplay about adapting Susan Orlean's The Orchid Thief. Amanda calls it near-impossible for anyone but Kaufman to pull off."
        },
        {
          "title": "Notting Hill",
          "year": 1999,
          "note": "No. 5 — Julia Roberts and Hugh Grant, written by Richard Curtis. Amanda's pick for how it captures 90s movie stardom, nudity clauses and all."
        }
      ]
    }
  ],
