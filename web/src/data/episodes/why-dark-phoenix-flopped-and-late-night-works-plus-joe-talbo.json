  "published": "2019-06-11",
  "runtimeMin": 87,
  "format": "Late Night's slow rollout, why Dark Phoenix cratered, and Joe Talbot on The Last Black Man in San Francisco.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "'Late Night'",
      "note": "Amazon's $13 million Sundance buy",
      "films": [
        {
          "title": "Late Night",
          "year": 2019,
          "note": "Mindy Kaling wrote it and co-stars opposite Emma Thompson as a female late-night host fighting to keep her show; Sean and Amanda call it a rom-com between a mentor and a mentee."
        },
        {
          "title": "Morning Glory",
          "year": 2010,
          "note": "Amanda's closest comparison point: an Aline Brush McKenna rom-com about a morning-show producer, with Rachel McAdams, Harrison Ford, and Diane Keaton."
        },
        {
          "title": "Booksmart",
          "year": 2019,
          "note": "The release-strategy foil: it went wide into 2,000 theaters and underperformed, while Amazon slow-rolled Late Night into limited release to build word of mouth."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Why 'Dark Phoenix' Bombed",
      "note": "$33 million opening, 22% on Rotten Tomatoes, a B- CinemaScore",
      "films": [
        {
          "title": "Dark Phoenix",
          "year": 2019,
          "note": "The 11th X-Men movie, repeating a storyline already told 13 years earlier, and moved twice on the release calendar before landing in a dead June."
        },
        {
          "title": "X-Men: The Last Stand",
          "year": 2006,
          "note": "Already told the Dark Phoenix storyline once."
        },
        {
          "title": "X-Men: First Class",
          "year": 2011,
          "note": "The reboot that relaunched the franchise well."
        },
        {
          "title": "X-Men: Days of Future Past",
          "year": 2014
        },
        {
          "title": "X-Men: Apocalypse",
          "year": 2016,
          "note": "The prequel-era misstep that cost the franchise fan trust ahead of Dark Phoenix."
        },
        {
          "title": "Captain Marvel",
          "year": 2019,
          "note": "The comparison point for a movie that didn't work but still made money."
        },
        {
          "title": "Solo: A Star Wars Story",
          "year": 2018,
          "note": "The cautionary tale for a production's troubles going public."
        },
        {
          "title": "Rogue One: A Star Wars Story",
          "year": 2016,
          "note": "Had a similarly fraught production, salvaged by Tony Gilroy reshoots."
        },
        {
          "title": "Bohemian Rhapsody",
          "year": 2018,
          "note": "Swapped into Dark Phoenix's original November release date."
        },
        {
          "title": "Alita: Battle Angel",
          "year": 2019,
          "note": "Took Dark Phoenix's rescheduled February date instead."
        }
      ]
    },
