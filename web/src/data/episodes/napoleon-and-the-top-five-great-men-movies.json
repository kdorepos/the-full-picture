{
  "slug": "napoleon-and-the-top-five-great-men-movies",
  "title": "‘Napoleon’ and the Top Five \"Great Men\" Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2023-11-22",
  "runtimeMin": 85,
  "format": "The crew reviews Ridley Scott's Napoleon, then each names their favorite \"great men\" movies and argues over whether history turns on one person.",
  "segments": [
    {
      "kind": "review",
      "heading": "‘Napoleon’",
      "note": "Ridley Scott, 2023",
      "films": [
        {
          "title": "Napoleon",
          "year": 2023,
          "note": "Two movies bolted together over 30 years: a psychosexual comedy between Napoleon (Joaquin Phoenix) and Josephine (Vanessa Kirby), and Ridley Scott battle filmmaking. Everyone had fun; everyone wanted the four-hour Apple cut. The consensus is it races through history without ever getting to the bottom of the man, an 'awesome three-star movie.' Highlights: the Toulon siege, the frozen-lake cannon fire at Austerlitz, and the 'destiny has brought me to this lamb chop' dinner-table blowup."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "The Top Five \"Great Men\" Movies",
      "note": "each host's favorites: do the movies interrogate the great man or endorse him?",
      "picks": [
        {
          "by": "Sean Fennessey",
          "title": "Steve Jobs",
          "year": 2015,
          "note": "Works because it never tries to tell the whole life: three backstage scenes, Sorkin dialogue, and a late gloss with his daughter that puts the praise and the blame at his feet."
        },
        {
          "by": "Sean Fennessey",
          "title": "The Assassination of Jesse James by the Coward Robert Ford",
          "year": 2007,
          "note": "One of his favorites of the century: fame and worship through Robert Ford's eyes, demythologizing Brad Pitt's over-the-hill outlaw. 'A movie about being Brad Pitt.'"
        },
        {
          "by": "Sean Fennessey",
          "title": "Amadeus",
          "year": 1984,
          "note": "The great-man inversion, told through a jealous rival: Salieri watching Mozart reach something out of reach."
        },
        {
          "by": "Sean Fennessey",
          "title": "Lincoln",
          "year": 2012,
          "note": "Like Oppenheimer to him: restrained, not the valedictory the branding implies. A great man shown trapped by warring factions."
        },
        {
          "by": "Sean Fennessey",
          "title": "Citizen Kane",
          "year": 1941,
          "note": "His No. 1: invented the sub-genre. You think this guy's great; here's what's really going on under the surface."
        },
        {
          "by": "Amanda Dobbins",
          "title": "Shakespeare in Love",
          "year": 1998,
          "note": "Her classic pick: different when the great man is an artist. Loves the logistics of the theater and the court as much as the romance."
        },
        {
          "by": "Amanda Dobbins",
          "title": "All the King's Men",
          "year": 1949,
          "note": "The 1949 film, based on the novel keyed to Huey Long. Shows a man learning that the only way to win is to cheat, a modern portrait of ambition."
        },
        {
          "by": "Amanda Dobbins",
          "title": "The Lion in Winter",
          "year": 1968,
          "note": "A family of 'great men' plus one great woman: the answer to 'why are you like this' is a lousy dad and annoying brothers. Great Katharine Hepburn."
        },
        {
          "by": "Amanda Dobbins",
          "title": "Malcolm X",
          "year": 1992,
          "note": "Her No. 1: the complicated, tragic life of a major American figure. A favorite Spike Lee film and Denzel performance."
        },
        {
          "by": "Chris Ryan",
          "title": "The Right Stuff",
          "year": 1983,
          "note": "Prompted by Matt Zoller Seitz's Phil Kaufman interview. Goldman wanted a galaxy of American heroes; Kaufman insisted they were fuck-ups with taped-together tech, and that tension is the movie."
        },
        {
          "by": "Chris Ryan",
          "title": "Apollo 13",
          "year": 1995,
          "note": "The flip side of The Right Stuff: hagiography of the man who doesn't make it to the moon, and a team-up of everyone who saves him."
        },
        {
          "by": "Chris Ryan",
          "title": "Wyatt Earp",
          "year": 1994,
          "note": "Costner deciding only he can play the greatest lawman in the West across a decade-spanning epic. Tossed in amid Horizon anticipation."
        },
        {
          "by": "Chris Ryan",
          "title": "Darkest Hour",
          "year": 2017,
          "note": "His throw-in: Gary Oldman's Churchill in nearly every frame, leaving you sure that without him we'd all be at Oktoberfest. Amanda pointedly left it off (too many Churchills)."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "Also out: ‘Rustin’",
      "note": "on Netflix",
      "films": [
        {
          "title": "Rustin",
          "year": 2023,
          "note": "George C. Wolfe's film about Bayard Rustin organizing the 1963 March on Washington, produced in part by the Obamas' Higher Ground. Sean didn't think it was very good, a broad early-'90s-style biopic that plays like a 1997 HBO movie, but rated Colman Domingo's performance highly and wanted the nittier, grittier process-and-ideas version."
        }
      ]
    }
  ],
