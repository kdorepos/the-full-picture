{
  "slug": "the-top-10-underseen-and-overlooked-movies-of-2025-plus-is-t",
  "title": "The Top 10 Underseen and Overlooked Movies of 2025. Plus: ‘Is This Thing On?,’ ‘Ella McCay,’ and Why We Can’t Have Nice Things.",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-12-22",
  "runtimeMin": 72,
  "format": "Sean and Amanda pan two throwback dramas, Bradley Cooper's 'Is This Thing On?' and James L. Brooks's 'Ella McCay,' then each names five underseen 2025 films worth chasing down.",
  "tmdbOverrides": {
    "Ella McCay": 1206008
  },
  "segments": [
    {
      "kind": "discussion",
      "heading": "The News",
      "note": "the first Tom Cruise teaser",
      "films": [
        {
          "title": "Digger",
          "year": 2026,
          "note": "Cruise's first role outside a franchise in years, in Alejandro González Iñárritu's comedy, out October 2. The teaser is Cruise dancing to a Gorillaz song shot from behind; Sean calls it 'Tropic Thunder reheated' and both flag the poster's 'a comedy of catastrophic proportions' blurb as a bad sign."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Is This Thing On?’",
      "films": [
        {
          "title": "Is This Thing On?",
          "year": 2025,
          "note": "Bradley Cooper's third feature, co-written with Will Arnett, about a finance guy who takes up stand-up after an amicable divorce. Both call it 'loser behavior': sincere but soft, undercut by stand-up that isn't funny, a late-arriving volleyball subplot for Laura Dern, and an 'Under Pressure' needle drop lifted straight from 'Aftersun.' Cooper's own supporting turn is the highlight; Peyton Manning's cameo gets a laugh."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Ella McCay’",
      "films": [
        {
          "title": "Ella McCay",
          "year": 2025,
          "note": "James L. Brooks's first film in 15 years, about a 34-year-old who becomes governor of an unnamed New England state. A near-total 'disaster' for both: 'gas leak cinema,' a Leslie Knope tone laid over a four-figure bribery scandal, specificity in all the wrong places, and miscasting down the line. They admire the underlying idea (change comes at the micro level) and Brooks's legacy, not the movie."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Underseen and Overlooked",
      "note": "five 2025 movies that slipped through",
      "subject": "Amanda's overlooked movies of 2025",
      "ranked": true,
      "films": [
        {
          "title": "Jane Austen Wrecked My Life",
          "year": 2025,
          "note": "No. 1 - a self-contained French rom-com built on a love triangle at a Jane Austen writers' residency; as much about writer's block as which suitor wins. Streaming on Netflix."
        },
        {
          "title": "Megadoc",
          "year": 2025,
          "note": "No. 2 - Mike Figgis's documentary on the making of Coppola's 'Megalopolis,' with startling access; a portrait of a filmmaker waiting for the technology to catch up to his vision. On the Criterion Channel."
        },
        {
          "title": "The Wedding Banquet",
          "year": 2025,
          "note": "No. 3 - Andrew Ahn's US-set remake of the Ang Lee film, co-written with James Schamus; a soft-touch story of a gay couple, a lesbian couple, IVF and a green-card marriage. Streaming on Paramount+."
        },
        {
          "title": "Oh, Hi!",
          "year": 2025,
          "note": "No. 4 - Sophie Brooks's Sundance comedy with Molly Gordon and Logan Lerman, in which a first weekend away curdles. Amanda thinks the movie is bad but loves watching Gordon."
        },
        {
          "title": "Eternity",
          "year": 2025,
          "note": "No. 5 - a high-concept afterlife rom-com (pick one eternity, and one of two husbands) that Amanda admits doesn't land the plane but works as a cozy at-home watch. Miles Teller is the standout."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Underseen and Overlooked",
      "note": "five 2025 movies that slipped through",
      "subject": "Sean's overlooked movies of 2025",
      "ranked": true,
      "films": [
        {
          "title": "Vulcanizadora",
          "year": 2024,
          "note": "No. 1 - Joel Potrykus's film-shot indie about two men and a very dark pact in the woods; a hang that turns gnarly. 99 cents to rent on Amazon."
        },
        {
          "title": "The Things You Kill",
          "year": 2025,
          "note": "No. 2 - Alireza Khatami's disorienting thriller; a Turkish professor grieving his mother's suspicious death hires a gardener to take revenge. Canada's unselected Oscar submission."
        },
        {
          "title": "Influencers",
          "year": 2025,
          "note": "No. 3 - Kurtis David Harder's slick, cheaply made sequel to 2023's 'Influencer,' a globe-trotting internet thriller now set in southern France with a clever AI wrinkle."
        },
        {
          "title": "Urchin",
          "year": 2025,
          "note": "No. 4 - Harris Dickinson's directorial debut, a fairly conventional London homelessness drama saved by Frank Dillane's lead performance and a cosmic final act."
        },
        {
          "title": "On Becoming a Guinea Fowl",
          "year": 2024,
          "note": "No. 5 - Rungano Nyoni's A24 second feature; a woman finds her uncle's body in the street and a strange family reckoning follows. Funny and disorienting throughout. On HBO Max."
        }
      ]
    }
