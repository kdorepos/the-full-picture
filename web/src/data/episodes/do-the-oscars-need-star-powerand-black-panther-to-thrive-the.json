{
  "slug": "do-the-oscars-need-star-powerand-black-panther-to-thrive-the",
  "title": "Do the Oscars Need 'Star' Power—and 'Black Panther'—to Thrive? | The Oscars Show (Ep. 102)",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2018-11-27",
  "runtimeMin": 59,
  "format": "Sean and Amanda open the weekly Oscars show by asking whether a race led by small arthouse films leaves the show short on stars, then work through Green Book and Widows, a loaded Best Actress field, and the critics' awards and Golden Globe nominations coming next week.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Do the Oscars Need Star Power?",
      "note": "the frontrunners and the fear of a small-movie race",
      "films": [
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "The starry, blockbuster-adjacent frontrunner. Sean floats it sweeping across the board: it flatters what voters want and takes no work to love, the same thing they said about La La Land."
        },
        {
          "title": "Black Panther",
          "year": 2018,
          "note": "Sean is fairly certain it gets nominated and thinks that's enough; expects it to be a happy-to-be-here nominee rather than a winner. The hosts reject the idea that a Black Panther win is what would save the Oscars."
        },
        {
          "title": "The Favourite",
          "year": 2018,
          "note": "First of the arthouse contenders to open. Amanda pitches it as the rare period piece that's actually funny and watchable, a movie about Queen Anne that plays weirder than it looks."
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "Out December 14 on Netflix. A foreign film with subtitles that voters watch at home on second screens, designed for the home yet best on a big screen. Sean makes the case for it as the race's real frontrunner; the Netflix fight cuts both ways."
        },
        {
          "title": "If Beale Street Could Talk",
          "year": 2018,
          "note": "Barry Jenkins's Baldwin adaptation, also December 14. A quiet, intimate film like Moonlight, but the late release leaves no time to build the evangelizing long tail Moonlight had."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock Up, Stock Down",
      "note": "two contenders that stumbled at the box office",
      "films": [
        {
          "title": "Green Book",
          "year": 2018,
          "note": "The presumed crowd-pleaser that didn't please the crowds over Thanksgiving and drew fire as a white-savior story made by white filmmakers. The hosts expect a Golden Globe bump (it runs as a comedy) and note Don Shirley's family disputing the film's accuracy."
        },
        {
          "title": "Widows",
          "year": 2018,
          "note": "Steve McQueen's stacked heist film underperformed at about $15M on a $40M budget. The theory: it didn't lean into the pulp, playing the heist as messy and real when audiences wanted Ocean's Eleven, and a fragmented, grim poster that mismarketed it."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Best Actress Race",
      "note": "loaded for the first time in years",
      "films": [
        {
          "title": "The Wife",
          "year": 2017,
          "note": "Glenn Close has been the favorite since August for a movie almost no one (including the hosts) can find to watch. Sean compares it to Julianne Moore winning for Still Alice: a career prize for a small film."
        },
        {
          "title": "Can You Ever Forgive Me?",
          "year": 2018,
          "note": "Melissa McCarthy as forger Lee Israel, the comic actor doing something serious. A downbeat character study and a perfect screener movie; Richard E. Grant looks like a Best Supporting Actor lock."
        },
        {
          "title": "Destroyer",
          "year": 2018,
          "note": "Karyn Kusama's violent Christmas release, another Nicole Kidman transformation with prosthetics. Sean's in the bag for it; suspects Kidman made the rounds too recently to break through."
        },
        {
          "title": "Boy Erased",
          "year": 2018,
          "note": "Kidman is also strong here, in supporting territory."
        },
        {
          "title": "Hereditary",
          "year": 2018,
          "note": "Toni Collette's horror performance, which Sean thinks the pop-in-the-screener crowd will never reward."
        },
        {
          "title": "Mary Queen of Scots",
          "year": 2018,
          "note": "Saoirse Ronan, the most-nominated young actress in decades; Sean doubts she gets in this year."
        },
        {
          "title": "Wildlife",
          "year": 2018,
          "note": "Carey Mulligan, one of Sean's five favorite performances of the year, in a movie he fears is too small: the old-fashioned nominate-the-actress kind of turn."
        },
        {
          "title": "A Private War",
          "year": 2018,
          "note": "Rosamund Pike as slain correspondent Marie Colvin. Sean rates it; wonders why Pike never became a bigger thing after Gone Girl."
        },
        {
          "title": "Ben Is Back",
          "year": 2018,
          "note": "Julia Roberts on the outside looking in. A movie star the hosts are glad to have back, though they've heard mixed things about the film."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Looking Ahead: Critics and Golden Globes",
      "note": "next week's precursors",
      "films": [
        {
          "title": "BlacKkKlansman",
          "year": 2018,
          "note": "A statement pick that keeps persisting: Armie Hammer was campaigning for it on Twitter over the weekend. Where Green Book may fail, this may succeed."
        },
        {
          "title": "Stan & Ollie",
          "year": 2018,
          "note": "Amanda's dark horse for the weird late-December Globes love that nobody's really seen."
        }
      ]
    }
  ],
