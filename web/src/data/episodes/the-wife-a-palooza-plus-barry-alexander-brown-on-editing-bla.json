{
  "slug": "the-wife-a-palooza-plus-barry-alexander-brown-on-editing-bla",
  "title": "'The Wife'-a-Palooza, Plus Barry Alexander Brown on Editing 'BlacKkKlansman' | The Oscars Show (Ep. 123)",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2019-02-05",
  "runtimeMin": 92,
  "format": "Amanda finally watches The Wife, ending a months-long bit; Bohemian Rhapsody wins an editing award nobody can explain; and BlacKkKlansman editor Barry Alexander Brown talks 40 years of cutting for Spike Lee.",
  "segments": [
    {
      "kind": "review",
      "heading": "'The Wife'-a-Palooza",
      "note": "Amanda watches the all-time plane movie at last",
      "films": [
        {
          "title": "The Wife",
          "year": 2018,
          "note": "The recurring bit finally pays off. Both hosts agree Glenn Close is doing something new here, but the movie itself is clunky: a third of it plays out in flashback with different actors, and it never explains why Joan agreed to ghostwrite Joe's entire career in the first place."
        },
        {
          "title": "Listen Up, Philip",
          "year": 2014,
          "note": "Jonathan Pryce already played this exact type of narcissistic, thinly veiled Philip Roth stand-in, opposite Elisabeth Moss."
        },
        {
          "title": "Albert Nobbs",
          "year": 2011,
          "note": "Close's previous Oscar nomination, lost to Meryl Streep in The Iron Lady. Also Annie Stark's screen debut, playing a young Glenn Close."
        },
        {
          "title": "Father Figures",
          "year": 2017,
          "note": "Stark played a young version of a Close character here too, practically her whole filmography."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Stock Up, Stock Down",
      "note": "the Ace Eddie and DGA Awards",
      "films": [
        {
          "title": "Bohemian Rhapsody",
          "year": 2018,
          "note": "Wins the Ace Eddie for dramatic editing despite widely mocked continuity errors. Bryan Singer was fired partway through the shoot and Dexter Fletcher finished it. Sean argues the real reward for salvaging it is the $850 million it made."
        },
        {
          "title": "Free Solo",
          "year": 2018,
          "note": "Wins the documentary Ace Eddie; directors Jimmy Chin and Elizabeth Chai Vasarhelyi had been guests on the show the week before."
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "Alfonso Cuarón wins the DGA Award, which Sean says all but locks him in for Best Director."
        },
        {
          "title": "Eighth Grade",
          "year": 2018,
          "note": "Bo Burnham wins the DGA's best first feature award over Bradley Cooper's A Star Is Born."
        },
        {
          "title": "Three Identical Strangers",
          "year": 2018,
          "note": "Tim Wardle wins Best Documentary Directing at the DGA despite the film missing an Oscar nomination entirely."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Big Race",
      "note": "supporting actor and the road to the BAFTAs",
      "films": [
        {
          "title": "Green Book",
          "year": 2018,
          "note": "Mahershala Ali's supporting nomination is complicated by the film's controversies around Nick Vallelonga and Peter Farrelly."
        },
        {
          "title": "Moonlight",
          "year": 2016,
          "note": "Ali's prior, uncontested supporting win, cited as the rare case of the right person winning."
        },
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "Sam Elliott's campaign is 'cursed,' per Sean, up against Mahershala, Adam Driver, Sam Rockwell, and Richard E. Grant."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Barry Alexander Brown on",
      "films": [
        {
          "title": "BlacKkKlansman",
          "year": 2018,
          "note": "His nomination comes 40 years after his first, for a documentary he made in his twenties. He singles out two sequences: Kwame Ture's campus speech, built around individual crowd-member portraits shot separately and cut in afterward, and the Harry Belafonte monologue intercut with a Klan screening of The Birth of a Nation, both cut in days, not weeks."
        },
        {
          "title": "Spider-Man: Into the Spider-Verse",
          "year": 2018,
          "note": "His pick for the last great thing he's seen. He argues animation is still editing: 'however you get there, if you draw the edits, it's an edit.'"
        }
      ]
    }
  ],
