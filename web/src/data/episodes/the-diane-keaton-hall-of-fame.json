{
  "slug": "the-diane-keaton-hall-of-fame",
  "title": "The Diane Keaton Hall of Fame",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2026-07-07",
  "runtimeMin": 143,
  "format": "Sean and Amanda open on a soft box-office weekend, then honor the late Diane Keaton. They walk her whole career and induct their favorite performances into her Hall of Fame. Twelve films make the ballot (The Godfather I and II count as one, per the Robert Duvall rule).",
  "segments": [
    {
      "kind": "halloffame",
      "heading": "The Hall of Fame",
      "honoree": "Diane Keaton",
      "note": "the inducted performances, in the order they argued them",
      "films": [
        {
          "title": "The Godfather",
          "year": 1972,
          "role": "Kay Adams-Corleone",
          "note": "One slot for Parts I and II (the Robert Duvall rule; Part III left off). Amanda floated that she's miscast. Sean defended her as essential, 'the perspectival character, the outsider brought into this world,' and called the 'It was an abortion, Michael' scene 'amazing.'"
        },
        {
          "title": "Annie Hall",
          "year": 1977,
          "role": "Annie Hall",
          "note": "First-ballot automatic, 'a forever movie.' The Best Actress win, and the film that made her a star. Sean noted she plays it naturalistic, 'not doing the Diane Keaton persona as much,' and it informs everything after."
        },
        {
          "title": "Looking for Mr. Goodbar",
          "year": 1977,
          "role": "Theresa Dunn",
          "note": "'One of her great performances,' bracing and unlike anything else she did: a teacher of deaf children exploring her sexuality, with a shocking ending. The trauma framing dates it; the performance doesn't."
        },
        {
          "title": "Manhattan",
          "year": 1979,
          "role": "Mary Wilkie",
          "note": "Sean's pick over Shoot the Moon. As the friend's wife caught in the affair, her scene ending it is 'among her best.' 'A legendary film made complicated by contemporary history.'"
        },
        {
          "title": "Reds",
          "year": 1981,
          "role": "Louise Bryant",
          "note": "The only real person she ever played. 'Electric, perfectly balanced against Warren Beatty, then against Jack Nicholson.' No laughs, none of 'her stuff,' much of it silent reacting. Sean: 'one of the craziest things is it did not win Best Picture.'"
        },
        {
          "title": "Shoot the Moon",
          "year": 1982,
          "role": "Faith Dunlap",
          "note": "Sean's personal deep cut. 'She's the show in Shoot the Moon,' a harsh divorce drama opposite a ferocious Albert Finney, the first time she read as more than a young ingenue."
        },
        {
          "title": "Baby Boom",
          "year": 1987,
          "role": "J.C. Wiatt",
          "note": "'This is the new Diane Keaton,' the start of the Nancy Meyers era and the template for the rest of her career. Her meltdown at the man fixing the well is 'one of the funniest things she's ever done.'"
        },
        {
          "title": "Father of the Bride",
          "year": 1991,
          "role": "Nina Banks",
          "note": "Steve Martin's movie, inducted 'out of respect for all the fathers.' Amanda pushed back that it isn't really hers; Sean calls it 'one of the great films of my lifetime.' A warm foil, 'willfully being a mom.'"
        },
        {
          "title": "Manhattan Murder Mystery",
          "year": 1993,
          "role": "Carol Lipton",
          "note": "Easy yes for both. A later phase that keeps the Keaton and Woody Allen dynamic: 'she's as much the star of it as he is.' 'Very funny. What a great pantsuit.'"
        },
        {
          "title": "The First Wives Club",
          "year": 1996,
          "role": "Annie MacDuggan Paradis",
          "note": "A massive hit and 'a very important movie in her career.' Amanda championed it: Keaton front and center on 'You Don't Own Me,' a film that 'honors women' and sets the template for her later ensembles."
        },
        {
          "title": "Something's Gotta Give",
          "year": 2003,
          "role": "Erica Barry",
          "note": "'Green, of course.' The most autobiographical Nancy Meyers film, and 'a wonderful way of closing up the Reds thing,' reuniting her with Nicholson, happily. A Best Actress nomination, and the birth of 'coastal grandma.'"
        },
        {
          "title": "Morning Glory",
          "year": 2010,
          "role": "Colleen Peck",
          "note": "Amanda's personal deep cut. 'One of the last classic romantic comedies,' Keaton as a past-her-prime newscaster with very funny chemistry opposite Harrison Ford."
        }
      ]
    }
  ],
