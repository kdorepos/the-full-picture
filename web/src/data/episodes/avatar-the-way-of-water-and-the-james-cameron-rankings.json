      "kind": "review",
      "heading": "‘Avatar: The Way of Water’",
      "note": "largely spoiler-free",
      "films": [
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "13 years after the original and three hours and ten minutes long. Sean lands mixed: the third-hour action rips like old-school Terminator 2, but the middle hour among the Metkayina runs leisurely. Shot in 3D at variable high frame rate: the underwater motion-capture looks real, the above-water shots sometimes read like a video-game cut scene."
        }
      ]
    },
    {
      "kind": "ranking",
      "heading": "The James Cameron Rankings",
      "note": "best to worst",
      "subject": "James Cameron",
      "ranked": true,
      "films": [
        {
          "title": "Titanic",
          "year": 1997,
          "note": "No. 1. Amanda's pick; the room concedes. Cameron's first turn as box-office king: Best Picture, DiCaprio and Winslet launched."
        },
        {
          "title": "Aliens",
          "year": 1986,
          "note": "No. 2. The nerds' choice over Titanic. Good for its whole runtime, though it builds on Ridley Scott's original."
        },
        {
          "title": "Terminator 2: Judgment Day",
          "year": 1991,
          "note": "No. 3. The T-1000 morph still looks like the effect other movies chase. Not perfect, but exceptional."
        },
        {
          "title": "The Terminator",
          "year": 1984,
          "note": "No. 4. Made cheaply and looks it: dark, metallic, endlessly ripped off."
        },
        {
          "title": "Avatar",
          "year": 2009,
          "note": "No. 5. The last real technical leap in movies, per Sean; nobody pops it back in, per Chris."
        },
        {
          "title": "True Lies",
          "year": 1994,
          "note": "No. 6. The one with a sense of humor the Avatar films lack. Looks terrible streaming on Peacock, no Blu-ray."
        },
        {
          "title": "The Abyss",
          "year": 1989,
          "note": "No. 7. Asterisked: no Blu-ray release, hard to rewatch. A lot of The Way of Water lives here."
        },
        {
          "title": "Avatar: The Way of Water",
          "year": 2022,
          "note": "No. 8. Bigger, maybe a greater technical feat, but not better than the first."
        },
        {
          "title": "Piranha II: The Spawning",
          "year": 1981,
          "note": "No. 9. Cameron's disowned debut, a sequel to a Roger Corman knockoff. The piranhas fly."
        }
      ]
