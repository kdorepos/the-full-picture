{
  "slug": "nightmare-alley-and-our-favorite-films-noir-with-patton-oswa",
  "title": "'Nightmare Alley' and Our Favorite Films Noir, With Patton Oswalt!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey"
  ],
  "published": "2022-04-29",
  "runtimeMin": 67,
  "format": "Sean makes the case for Guillermo del Toro's overlooked 'Nightmare Alley,' then Patton Oswalt joins to dig into the film and to walk the history of noir decade by decade.",
  "segments": [
    {
      "kind": "review",
      "heading": "'Nightmare Alley'",
      "note": "Sean's case for the movie",
      "films": [
        {
          "title": "Nightmare Alley",
          "year": 2021,
          "note": "Del Toro's 11th film and first since 'The Shape of Water,' co-written with Kim Morgan from William Lindsay Gresham's 1946 novel, ending and all. Bradley Cooper is Stanton Carlisle, a drifter who rises from carny to high-end mentalist, with Toni Collette, Rooney Mara, Cate Blanchett, Willem Dafoe, David Strathairn, Ron Perlman, Mary Steenburgen and Richard Jenkins. A box-office flop against 'No Way Home' that landed four Oscar nods; Sean cooled on it at first, watched it four times, and reads Carlisle as an avatar for the age of the grifter."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Patton Oswalt on film noir",
      "note": "Favorites, decade by decade",
      "guest": "Patton Oswalt on",
      "films": [
        {
          "title": "A Face in the Crowd",
          "year": 1957,
          "note": "Patton's pick for a 'Nightmare Alley' double feature: the other movie that nails what's wrong with us."
        },
        {
          "title": "T-Men",
          "year": 1947,
          "note": "John Alton's cinematography, Charles McGraw's face coming out of the shadows on the docks."
        },
        {
          "title": "Phantom Lady",
          "year": 1944,
          "note": "Ella Raines, whom Patton calls a 90s indie actress stranded in the 40s: a real-life femme fatale."
        },
        {
          "title": "Impact",
          "year": 1949,
          "note": "More Ella Raines; Sean clocks a Linda Fiorentino energy."
        },
        {
          "title": "The Killers",
          "year": 1946,
          "note": "Charles McGraw as Al, the face Patton thinks Frank Miller drew Marv from."
        },
        {
          "title": "The Prowler",
          "year": 1951,
          "note": "A corrupt, damaged cop: the 40s/50s anxiety that you can't trust your authority figures."
        },
        {
          "title": "I Wake Up Screaming",
          "year": 1941,
          "note": "Same fear: the cop is the most dangerous person in the room."
        },
        {
          "title": "On Dangerous Ground",
          "year": 1951,
          "note": "Nicholas Ray, Ida Lupino; Robert Ryan the hero cop who scares you every time he gets near anyone."
        },
        {
          "title": "Bad Day at Black Rock",
          "year": 1955,
          "note": "A Technicolor noir Patton reads as a proto-Trumper movie about resentment aimed at a Japanese American war veteran."
        },
        {
          "title": "Violent Saturday",
          "year": 1955,
          "note": "Another color noir shot on location in Bisbee, Arizona."
        },
        {
          "title": "Kiss Me Deadly",
          "year": 1955,
          "note": "Patton's favorite of all time."
        },
        {
          "title": "Blast of Silence",
          "year": 1961,
          "note": "Allen Baron's overexposed hitman film, shot in a real hurricane. Patton ranks it among his all-time favorite films, not just his favorite noirs."
        },
        {
          "title": "Brighton Rock",
          "year": 1948,
          "note": "The 40s noir sensibility migrating to a fallen-empire Britain."
        },
        {
          "title": "These Are the Damned",
          "year": 1962,
          "note": "Ostensibly sci-fi, really about juvenile delinquency, teddy boys and chaos: British noir by another name."
        },
        {
          "title": "The Long Goodbye",
          "year": 1973,
          "note": "Altman's self-aware, self-parodying noir: Philip Marlowe time-warped into 70s L.A. and unable to cope."
        },
        {
          "title": "Night Moves",
          "year": 1975,
          "note": "Gene Hackman in one of the cynical, weirdly funny 70s noirs."
        },
        {
          "title": "Chinatown",
          "year": 1974,
          "note": "So elegantly designed they couldn't help making the darkness look gorgeous."
        },
        {
          "title": "Hickey & Boggs",
          "year": 1972,
          "note": "Robert Culp and Bill Cosby; the 70s private eye hanging on by his fingernails while it all collapses."
        },
        {
          "title": "The Nickel Ride",
          "year": 1974,
          "note": "With Jason Miller. Patton first caught it two years ago and loved it."
        },
        {
          "title": "Save the Tiger",
          "year": 1973,
          "note": "A prestige film that's really a noir: the garment business, arson, a man wishing for a better world."
        },
        {
          "title": "The Late Show",
          "year": 1977,
          "note": "Art Carney and Lily Tomlin; Sam Spade with a hearing aid and a bus pass, one of the most underrated 70s movies."
        },
        {
          "title": "The Last Seduction",
          "year": 1994,
          "note": "The 90s femme-fatale-to-an-extreme, erotic-thriller strain of noir."
        },
        {
          "title": "Body Heat",
          "year": 1981,
          "note": "Same lineage: the erotic thriller as noir."
        },
        {
          "title": "Bound",
          "year": 1996,
          "note": "The Wachowskis' first film, LGBTQ noir stated flat out."
        },
        {
          "title": "The Big Combo",
          "year": 1955,
          "note": "Lee Van Cleef and his partner read as a gay couple: the story that was always there but couldn't be said out loud."
        },
        {
          "title": "Gilda",
          "year": 1946,
          "note": "A love story flickering between Glenn Ford and the main baddie."
        },
        {
          "title": "Crossfire",
          "year": 1947,
          "note": "Robert Ryan and Robert Mitchum; the source novel's gay GI became a Jewish GI to get it released."
        },
        {
          "title": "Under the Silver Lake",
          "year": 2018,
          "note": "The modern noir Patton keeps trying to rescue: a real idea about our condition using the old style."
        },
        {
          "title": "Crime Wave",
          "year": 1954,
          "note": "Sterling Hayden, André De Toth; shot handheld on location, an accidental documentary of 40s L.A."
        },
        {
          "title": "Pharos of Chaos",
          "year": 1983,
          "note": "The documentary on Sterling Hayden: his back taxes, his HUAC testimony, the agony of his life."
        }
      ]
    }
  ],
