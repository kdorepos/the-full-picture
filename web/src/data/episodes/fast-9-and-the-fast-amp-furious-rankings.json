      "films": [
        {
          "title": "The Fast and the Furious",
          "year": 2001,
          "note": "No. 1: the start of everything, and the best the series ever gets for Dom-and-Brian and for Vin Diesel. Took its title from a 1955 Roger Corman exploitation picture."
        },
        {
          "title": "Fast Five",
          "year": 2011,
          "note": "Where the franchise breaks open. Amanda's actual No. 1 (she agreed to No. 2 only in the spirit of family), and the safe dragged through Rio."
        },
        {
          "title": "Furious 7",
          "year": 2015,
          "note": "The Paul Walker send-off. The beach scene and the Wiz Khalifa song had the whole theater, Shea included, crying."
        },
        {
          "title": "The Fast and the Furious: Tokyo Drift",
          "year": 2006,
          "note": "Shea disliked it at first, now calls it the load-bearing film: take it out and the rest falls apart. Gets a big shout-out in F9."
        },
        {
          "title": "2 Fast 2 Furious",
          "year": 2003,
          "note": "John Singleton, fresh off Baby Boy, introduces Roman and Ludacris and the franchise's looser, funnier tone."
        },
        {
          "title": "Fast & Furious 6",
          "year": 2013,
          "note": "The best Letty movie (the subway fight, the Gina fights), plus the cargo-plane finale and the Shaw family's debut via the younger brother."
        },
        {
          "title": "Fast & Furious",
          "year": 2009,
          "note": "The fourth film. Barely registers for anyone except the Dom-vs-Brian fight over Letty's death."
        },
        {
          "title": "F9",
          "year": 2021,
          "note": "Ranked over Fate purely on the magnet set pieces. Everything around them (the space walk, John Cena) is take-it-or-leave-it."
        },
        {
          "title": "The Fate of the Furious",
          "year": 2017,
          "note": "Charlize Theron as the box-standing villain; Amanda's beloved baby set piece with Statham not quite enough to lift it higher."
        },
        {
          "title": "Fast & Furious Presents: Hobbs & Shaw",
          "year": 2019,
          "note": "Last. Fake helicopter effects and none of the original DNA. Shea left it off his list entirely."
        }
      ]
    },
    {
      "kind": "review",
