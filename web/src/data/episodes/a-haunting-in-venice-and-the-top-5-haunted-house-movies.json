{
  "slug": "a-haunting-in-venice-and-the-top-5-haunted-house-movies",
  "title": "‘A Haunting in Venice’ and the Top 5 Haunted House Movies",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2023-09-19",
  "runtimeMin": 86,
  "format": "Amanda and Sean review Branagh's third Poirot, then each rank five favorite haunted-house movies. Bobby Wagner produces.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "The fall race, post-TIFF",
      "note": "what Toronto shook loose",
      "films": [
        {
          "title": "American Fiction",
          "year": 2023,
          "note": "Cord Jefferson's debut took the TIFF audience prize; the last 11 winners all landed Best Picture nods, so it forces its way into their top ten sight-unseen."
        },
        {
          "title": "The Holdovers",
          "year": 2023,
          "note": "Second at TIFF; Sean already had the Alexander Payne in his ten and expects it to play with the older crowd."
        },
        {
          "title": "The Boy and the Heron",
          "year": 2023,
          "note": "TIFF third place and the new Miyazaki. Sean's seen it, calls it a lot, and wants Andy Greenwald on to talk it through."
        },
        {
          "title": "Anatomy of a Fall",
          "year": 2023,
          "note": "One of the art-house imports Amanda figures American Fiction is now crowding out."
        },
        {
          "title": "The Zone of Interest",
          "year": 2023,
          "note": "Same squeeze: acclaimed but demanding."
        },
        {
          "title": "All of Us Strangers",
          "year": 2023,
          "note": "Getting a heavy Searchlight push."
        },
        {
          "title": "Hit Man",
          "year": 2023,
          "note": "Linklater and Glen Powell's dramedy; Netflix bought it out of TIFF for $20M, the year's biggest acquisition."
        },
        {
          "title": "Woman of the Hour",
          "year": 2023,
          "note": "Cited as another bet a cash-rich Netflix can make while rivals sit tight."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘A Haunting in Venice’",
      "films": [
        {
          "title": "A Haunting in Venice",
          "year": 2023,
          "note": "Branagh's third Poirot, loosely from Christie's 1969 'Hallowe'en Party,' written again by Michael Green. Best-looking of the three by Sean's count; Amanda didn't have a bad time but found the mystery pedestrian and Tina Fey badly miscast. Michelle Yeoh, at home in genre, comes off best."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top 5 Haunted House Movies",
      "note": "No. 1 first",
      "subject": "Haunted House Movies",
      "ranked": true,
      "films": [
        {
          "title": "The Shining",
          "year": 1980,
          "note": "No. 1 — a shared pick. A haunted hotel whose imagery is now so meme-worn Sean wonders whether the internet has blunted it."
        },
        {
          "title": "The Innocents",
          "year": 1961,
          "note": "No. 2 — Jack Clayton's Turn of the Screw, rewritten by Truman Capote, shot in CinemaScope; Sean calls it one of the best-looking films ever made."
        },
        {
          "title": "Hereditary",
          "year": 2018,
          "note": "No. 3 — Ari Aster's supernatural-and-psychological family horror, probably the film he'll be remembered for."
        },
        {
          "title": "The Beyond",
          "year": 1981,
          "note": "No. 4 — Lucio Fulci's Louisiana hotel built over a gate to hell; gory, dread-soaked, and, Sean warns, exactly the kind of thing Amanda would hate."
        },
        {
          "title": "Poltergeist",
          "year": 1982,
          "note": "No. 5 — Tobe Hooper's Spielberg-produced popcorn horror that wrecked Sean as a kid. You moved the headstones but not the bodies."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top 5 Haunted House Movies",
      "note": "No. 1 first — the cozier list",
      "subject": "Haunted House Movies",
      "ranked": true,
      "films": [
        {
          "title": "The Shining",
          "year": 1980,
          "note": "No. 1 — the one number one there can be."
        },
        {
          "title": "Rebecca",
          "year": 1940,
          "note": "No. 2 — the Hitchcock, not the Armie Hammer remake. A house haunted by lies and a dead ex-wife."
        },
        {
          "title": "Beetlejuice",
          "year": 1988,
          "note": "No. 3 — her Money Pit pick: scary in theory, mostly a very funny movie seen from the haunters' side."
        },
        {
          "title": "The Money Pit",
          "year": 1986,
          "note": "No. 4 — the comic version of the suburban dream gone wrong; shot by Gordon Willis, produced by Kennedy and Marshall."
        },
        {
          "title": "What Lies Beneath",
          "year": 2000,
          "note": "No. 5 — Zemeckis, Pfeiffer, and Ford; a twisty haunting she rates genuinely effective."
        }
      ]
    }
  ],
