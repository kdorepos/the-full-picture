{
  "slug": "the-2021-movie-draft",
  "title": "The 2021 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2024-12-13",
  "runtimeMin": 97,
  "format": "A three-person snake draft of the movies of 2021. Chris Ryan, Amanda Dobbins and Sean Fennessey each fill six category slots from a thin, COVID-warped year when studios sent links instead of tickets and Best Picture nominees turned up on streaming.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "the movies of 2021",
      "note": "snake order: Chris, Amanda, Sean",
      "categories": [
        "Drama",
        "Comedy",
        "Oscar Nominee",
        "Action / Horror / Thriller",
        "Blockbuster",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "No Sudden Move",
              "year": 2021,
              "category": "Drama",
              "note": "Soderbergh's Detroit noir with Cheadle and Del Toro; Chris has rewatched it several times and rates it among the best-scripted of the Max run."
            },
            {
              "title": "House of Gucci",
              "year": 2021,
              "category": "Comedy",
              "note": "Drafted straight-faced as a comedy. Chris rewatched it the night before and swears the Leto and Pacino material is genuinely funny."
            },
            {
              "title": "Nightmare Alley",
              "year": 2021,
              "category": "Oscar Nominee",
              "note": "Del Toro's carnival con-man noir, and Chris's pick for the best Bradley Cooper performance."
            },
            {
              "title": "Paranormal Activity: Next of Kin",
              "year": 2021,
              "category": "Action / Horror / Thriller",
              "note": "The seventh and last in the series, William Eubank's Amish-country entry that Chris caught on Paramount+ the day it dropped."
            },
            {
              "title": "Dune",
              "year": 2021,
              "category": "Blockbuster",
              "note": "First overall, the chalk pick; Villeneuve's half-a-book blockbuster, seen day-and-date on streaming and in theaters."
            },
            {
              "title": "The Card Counter",
              "year": 2021,
              "category": "Wildcard",
              "note": "Schrader's poker-and-Abu-Ghraib drama with Oscar Isaac and Tiffany Haddish."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "The Souvenir Part II",
              "year": 2021,
              "category": "Drama",
              "note": "Joanna Hogg's autobiographical follow-up; a foregone conclusion for Amanda, though she prefers Part 1."
            },
            {
              "title": "Shiva Baby",
              "year": 2021,
              "category": "Comedy",
              "note": "Emma Seligman's debut, and Amanda's first sight of Rachel Sennott and Molly Gordon."
            },
            {
              "title": "The Lost Daughter",
              "year": 2021,
              "category": "Oscar Nominee",
              "note": "Maggie Gyllenhaal's Ferrante adaptation with Olivia Colman, taken after Amanda learned The French Dispatch drew zero nominations."
            },
            {
              "title": "No Time to Die",
              "year": 2021,
              "category": "Action / Horror / Thriller",
              "note": "Craig's last Bond, grabbed after a long deliberation, mostly for the opening."
            },
            {
              "title": "Spider-Man: No Way Home",
              "year": 2021,
              "category": "Blockbuster",
              "note": "The un-Amanda blockbuster pick, and the first big post-COVID theatrical moment for the group."
            },
            {
              "title": "C'mon C'mon",
              "year": 2021,
              "category": "Wildcard",
              "note": "Mike Mills' black-and-white uncle-and-nephew movie with Joaquin Phoenix; Amanda saw it just after learning she was expecting Knox."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "The Worst Person in the World",
              "year": 2021,
              "category": "Drama",
              "note": "Joachim Trier's Oslo romance, Sean's second-favorite film of the year and a Best Original Screenplay nominee."
            },
            {
              "title": "Licorice Pizza",
              "year": 2021,
              "category": "Comedy",
              "note": "PTA's 1970s Valley hangout, drafted as a comedy after a Wikipedia ruling of 'dramedy' let Sean choose the lane."
            },
            {
              "title": "West Side Story",
              "year": 2021,
              "category": "Oscar Nominee",
              "note": "Spielberg's remake, a top-5 of Sean's year; Ariana DeBose won an Oscar for it."
            },
            {
              "title": "Malignant",
              "year": 2021,
              "category": "Action / Horror / Thriller",
              "note": "James Wan's day-and-date horror that Sean dismissed at an 8:30am screening and came around on during a nighttime rewatch."
            },
            {
              "title": "Venom: Let There Be Carnage",
              "year": 2021,
              "category": "Blockbuster",
              "note": "Andy Serkis' chaotic sequel, a 'very normal pick.'"
            },
            {
              "title": "The Velvet Underground",
              "year": 2021,
              "category": "Wildcard",
              "note": "Todd Haynes' split-screen band documentary; Sean's best film of 2021."
            }
          ]
        }
      ],
