{
  "slug": "road-house-and-the-top-10-junk-fight-movies-plus-sydney-swee",
  "title": "‘Road House’ and the Top 10 Junk Fight Movies. Plus: Sydney Sweeney’s ‘Immaculate’!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Chris Ryan"
  ],
  "published": "2024-03-22",
  "runtimeMin": 101,
  "format": "Sean and Chris on Sydney Sweeney's 'Immaculate' and Doug Liman's 'Road House' remake, a loose attempt to define the 'junk fight' movie, and Sean's interview with 'Immaculate' director Michael Mohan.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "‘Immaculate’",
      "note": "Sydney Sweeney's nunsploitation horror",
      "films": [
        {
          "title": "Immaculate",
          "year": 2024,
          "note": "Sweeney as an American nun who takes her vows at a remote Italian convent and winds up at the center of its designs. Sean and Chris call it a lean 88-minute horror movie in the Ken Russell / hammer-horror mold, tongue-in-cheek without tipping into camp, and read it as Sweeney knowingly playing her own persona. She chased the script for a decade and produced it herself, reuniting with 'The Voyeurs' director Michael Mohan."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Road House’",
      "note": "the Doug Liman remake",
      "films": [
        {
          "title": "Road House (2024)",
          "year": 2024,
          "note": "Liman's Amazon remake, with Jake Gyllenhaal as ex-UFC fighter Dalton bouncing at a Florida Keys bar. Both hosts have a good-not-great time with a B-movie sent straight to streaming, and spend most of the segment on Gyllenhaal's friendly, alien line readings and on Conor McGregor's heavy, Knox, whom Chris flatly disliked. The complaint that sticks: the whip-pan CGI in the McGregor fight."
        },
        {
          "title": "Road House (1989)",
          "year": 1989,
          "note": "The Patrick Swayze original, which Chris recently covered on 'The Rewatchables.' A philosopher-cooler Western played straight; the 2024 version keeps having characters announce that it's a Western."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The Junk Fights",
      "note": "Chris's garbage-fight canon",
      "films": [
        {
          "title": "Snatch",
          "year": 2000,
          "note": "Bare-knuckle boxing with a bunch of blimey bros. Like this 'Road House,' it's a self-referential movie about other movies."
        },
        {
          "title": "Ong-Bak",
          "year": 2003,
          "note": "Tony Jaa, no wires, no CGI."
        },
        {
          "title": "Undisputed III: Redemption",
          "year": 2010,
          "note": "Scott Adkins in a fighting tournament inside a Russian prison. Chris's pick for the best of the Adkins run."
        },
        {
          "title": "Undisputed",
          "year": 2002,
          "note": "The Wesley Snipes / Ving Rhames prison-boxing original the sequels grew out of."
        },
        {
          "title": "The Raid",
          "year": 2011,
          "note": "Iko Uwais fighting his way up one building. The first one: the compression is what makes it feel garbagey in the best way. The sequel is too much of a crime epic to qualify."
        },
        {
          "title": "The Night Comes for Us",
          "year": 2018,
          "note": "Timo Tjahjanto's 12-minute closing fight, singled out as one of the great modern sequences."
        },
        {
          "title": "Universal Soldier: Day of Reckoning",
          "year": 2012,
          "note": "The runner-up in Chris's Scott Adkins argument."
        },
        {
          "title": "Bloodsport",
          "year": 1988,
          "note": "A purely-fighting original, alongside 'Enter the Dragon,' and the movie the new 'Road House' turns into once the real heavy shows up."
        },
        {
          "title": "Enter the Dragon",
          "year": 1973,
          "note": "The other bedrock classic on the list."
        },
        {
          "title": "Five Deadly Venoms",
          "year": 1978,
          "note": "A Shaw Brothers touchstone; like the Godzilla movies, made only for its set pieces."
        },
        {
          "title": "John Wick",
          "year": 2014,
          "note": "The most celebrated contemporary fight movie, though so slick and studio-made that it complicates Chris's own definition of a junk fight."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Michael Mohan on",
      "films": [
        {
          "title": "Immaculate",
          "year": 2024,
          "note": "Mohan on turning a decade-old, high-school-set script into a nun movie for Sweeney, shooting the ending in a single take, and building 'gateway horror' that curdles into Nunsploitation. Key inspirations: 'Black Narcissus,' 'The Devils,' and the Sweeney-suggested 'Mother Joan of the Angels.'"
        },
        {
          "title": "The Voyeurs",
          "year": 2021,
          "note": "His erotic thriller for Amazon, greenlit fast after Nicole Kidman asked Jen Salke why the studio wasn't making erotic thrillers."
        },
        {
          "title": "Save the Date",
          "year": 2012,
          "note": "His half-million-dollar Sundance indie in the 90s-American-independent mode, which didn't sell and sent him back to hustling."
        },
        {
          "title": "One Too Many Mornings",
          "year": 2010,
          "note": "His $21,000 black-and-white mumblecore-era debut, made with a college roommate over two years."
        }
      ]
    }
  ],
