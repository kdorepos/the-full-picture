  "format": "Sean and Amanda review Netflix's 'The Lovebirds,' then each host ranks a top five all-in-one-day movies.",
  "segments": [
    {
      "kind": "review",
      "heading": "'The Lovebirds'",
      "films": [
        {
          "title": "The Lovebirds",
          "year": 2020,
          "note": "Bumped from a Paramount theatrical release to Netflix by COVID-19. Kumail Nanjiani and Issa Rae have real chemistry, but Michael Showalter's script jams a rom-com, a heist-conspiracy plot, and an Eyes Wide Shut parody into one movie without fully committing to any of them."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "What counts as an all-in-one-day movie",
      "note": "ground rules before the top fives",
      "films": [
        {
          "title": "Groundhog Day",
          "year": 1993,
          "note": "Disqualified - the multiple-iterations-of-the-same-day structure runs counter to the genre's 'this is it, no do-overs' feeling."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Amanda's Top Five All-in-One-Day Movies",
      "subject": "all-in-one-day movies",
      "ranked": true,
      "films": [
        {
          "title": "Ferris Bueller's Day Off",
          "year": 1986,
          "note": "No. 1 - the best day of your life, capped by the parade float lip-sync to 'Twist and Shout.'"
        },
        {
          "title": "Before Sunrise",
          "year": 1995,
          "note": "No. 2 - Ethan Hawke and Julie Delpy fall in love on a train and in one day in Vienna; the purest version of the genre because they never do meet again at that train station."
        },
        {
          "title": "25th Hour",
          "year": 2002,
          "note": "No. 3 - Edward Norton's last day of freedom before prison, directed by Spike Lee and shadowed by 9/11."
        },
        {
          "title": "His Girl Friday",
          "year": 1940,
          "note": "No. 4 - a newspaper deadline and a wedding deadline collide in one frantic, fast-talking day."
        },
        {
          "title": "Can't Hardly Wait",
          "year": 1998,
          "note": "No. 5 - a graduation-night party movie with no ambition beyond being exactly that."
        }
      ]
    },
    {
      "kind": "topfive",
      "heading": "Sean's Top Five All-in-One-Day Movies",
      "subject": "all-in-one-day movies",
      "ranked": true,
      "films": [
        {
          "title": "After Hours",
          "year": 1985,
          "note": "No. 1 - Martin Scorsese's funniest, hippest movie; Griffin Dunne bounces through one increasingly disastrous New York night."
        },
        {
          "title": "Dog Day Afternoon",
          "year": 1975,
          "note": "No. 2 - Sidney Lumet's bank-robbery-gone-wrong, with Al Pacino's Attica-chanting performance as the centerpiece."
        },
        {
          "title": "Dazed and Confused",
          "year": 1993,
          "note": "No. 3 - Richard Linklater's last day of school, the movie that made stars of half its cast."
        },
        {
          "title": "The Texas Chain Saw Massacre",
          "year": 1974,
          "note": "No. 4 - Tobe Hooper's low-budget road-trip-into-a-nightmare, narrated by John Larroquette."
        },
        {
          "title": "Training Day",
          "year": 2001,
          "note": "No. 5 - Ethan Hawke's first day on the job as an undercover narcotics cop, under Denzel Washington's Oscar-winning performance."
        }
      ]
    }
