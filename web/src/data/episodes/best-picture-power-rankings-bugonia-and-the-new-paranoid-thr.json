{
  "slug": "best-picture-power-rankings-bugonia-and-the-new-paranoid-thr",
  "title": "Best Picture Power Rankings, ‘Bugonia,’ and the New Paranoid Thriller, With Yorgos Lanthimos!",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2025-10-31",
  "runtimeMin": 91,
  "format": "Sean Fennessey and Amanda Dobbins do the monthly Best Picture power rankings first, before spoilers, then spoiler-review Yorgos Lanthimos's 'Bugonia' as part of a new wave of paranoid thrillers. Sean closes with an interview with Lanthimos.",
  "segments": [
    {
      "kind": "ranking",
      "heading": "Best Picture Power Rankings",
      "note": "the monthly top 10, best-first (House of Dynamite dropped off)",
      "subject": "Best Picture 2025",
      "ranked": true,
      "films": [
        {
          "title": "One Battle After Another",
          "year": 2025,
          "note": "No. 1, unmoved. Neither host sees a reason it leaves first place; the press hand-wringing over its international box office is just where the cycle is."
        },
        {
          "title": "Hamnet",
          "year": 2025,
          "note": "No. 2. Its wide release is a few weeks out, so the bump is a press-cycle effect; likely headed for No. 1 once people are talking about it."
        },
        {
          "title": "Sinners",
          "year": 2025,
          "note": "No. 3. One of Warner Bros.'s two locks alongside 'One Battle After Another'; the hosts don't see the top three shifting."
        },
        {
          "title": "Sentimental Value",
          "year": 2025,
          "note": "No. 4, holding position until it opens November 7 limited, then wide at Thanksgiving. It's a Cannes title most voters haven't seen yet."
        },
        {
          "title": "Frankenstein",
          "year": 2025,
          "note": "No. 5, the fastest riser, though neither host liked Del Toro's film. It's moving up the list anyway."
        },
        {
          "title": "Wicked for Good",
          "year": 2025,
          "note": "No. 6, up from 10. Neither host anticipates it, but the fan base is fervent and it holds the musical slot."
        },
        {
          "title": "Marty Supreme",
          "year": 2025,
          "note": "No. 7, taking the vacated House of Dynamite spot. Loved at the New York Film Festival; the Chalamet performance is 'lights out.'"
        },
        {
          "title": "It Was Just an Accident",
          "year": 2025,
          "note": "No. 8. Panahi's Cannes winner, out in a very limited capacity."
        },
        {
          "title": "Jay Kelly",
          "year": 2025,
          "note": "No. 9, sliding after a circuitous route and no Frankenstein-style spike. Adam Sandler landed a Gotham nomination for the supporting turn."
        },
        {
          "title": "Bugonia",
          "year": 2025,
          "note": "No. 10, holding on. Academy voters are trained for Lanthimos first, then Emma Stone; the hosts left it in over The Secret Agent, No Other Choice, and Train Dreams."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "‘Bugonia’",
      "note": "spoiler conversation, including the ending",
      "films": [
        {
          "title": "Bugonia",
          "year": 2025,
          "note": "Lanthimos's fourth film with Emma Stone, from a Will Tracy script (adapting the Korean 'Save the Green Planet'), with Jesse Plemons and newcomer Aidan Delbos; Ari Aster produced. Two conspiracy-obsessed men kidnap a pharma CEO they're convinced is an alien. Both hosts are big fans and read it as Lanthimos in his 'Dogtooth' register rather than his 'Poor Things' one: bleak and funny, the most grounded world he's built. They frame it as a new paranoid thriller in the Pakula lineage, with Plemons as a tragic radicalized loser and Stone shedding her sweetheart persona. Spoiler: she really is the alien, a high-ranking Andromedan, and it doesn't save him."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "Yorgos Lanthimos on ‘Bugonia’",
      "note": "his first appearance on the show",
      "guest": "Yorgos Lanthimos on",
      "films": [
        {
          "title": "Bugonia",
          "year": 2025,
          "note": "Lanthimos on receiving a near-finished script for the first time and sending it to Emma Stone the same night. He shot on the huge, still-audible VistaVision Willcam and built a restrictive visual grammar around it, then street-cast Aidan Delbos, who is autistic, for the third lead. He let go of engineering the twist, figuring the journey mattered more than the reveal."
        },
        {
          "title": "Save the Green Planet",
          "year": 2003,
          "note": "The South Korean film 'Bugonia' adapts. Lanthimos read Tracy's script first, then watched the original to confirm the remake was different enough to warrant making."
        },
        {
          "title": "The Mastermind",
          "year": 2025,
          "note": "Lanthimos's last-great-thing pick: Kelly Reichardt's film, which he saw the same day as his own at Telluride. He calls her work delicate but lasting."
        }
      ]
    }
  ],
