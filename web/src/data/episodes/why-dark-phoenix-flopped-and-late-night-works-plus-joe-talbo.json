      "guest": "Joe Talbot on",
      "films": [
        {
          "title": "The Last Black Man in San Francisco",
          "year": 2019,
          "note": "Talbot's first feature, built from years of walks and conversations with childhood friend and co-writer Jimmy Fails about the house Fails's family lost; Jonathan Majors plays his best friend Montgomery."
        },
        {
