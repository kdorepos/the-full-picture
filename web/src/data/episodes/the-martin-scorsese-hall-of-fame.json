  "runtimeMin": 124,
  "format": "Sean, Amanda, and Chris Ryan spend two hours building a 10-slot Martin Scorsese Hall of Fame ahead of 'Killers of the Flower Moon,' fighting over the last two spots the whole way.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Zach Baron's GQ profile, and an end-of-career reckoning",
      "note": "before the hall of fame",
      "films": [
        {
          "title": "Killers of the Flower Moon",
          "year": 2023,
          "note": "Scorsese's first film in four years, the news hook for the episode. Not eligible for the Hall of Fame since nobody's seen it yet."
        }
      ]
    },
    {
      "kind": "halloffame",
      "heading": "The Martin Scorsese Hall of Fame",
      "honoree": "Martin Scorsese",
      "note": "ten slots, built film by film across his whole filmography",
      "films": [
        {
          "title": "Alice Doesn't Live Here Anymore",
          "year": 1974,
          "note": "The late curveball pick over Mean Streets, added for Ellen Burstyn's Oscar-winning turn and a rare Scorsese movie centered on a woman."
        },
        {
          "title": "Taxi Driver",
          "year": 1976,
          "note": "An easy green, called one of the five movies he'll be remembered for. Landed at No. 29 on the 2022 Sight and Sound poll."
        },
        {
          "title": "The Last Waltz",
          "year": 1978,
          "note": "The Band's farewell concert film, a 'definitive green' for capturing Dylan, Clapton, Joni Mitchell, and Robertson on one stage."
        },
        {
          "title": "Raging Bull",
          "year": 1980,
          "note": "An automatic green. De Niro's Jake LaMotta transformation is called one of the most virtuosic filmmaking performances ever made."
        },
        {
          "title": "The King of Comedy",
          "year": 1982,
          "note": "A hard green for Chris and Sean: a prescient black comedy about celebrity, made when Scorsese felt shut out of Hollywood entirely."
        },
        {
          "title": "Goodfellas",
          "year": 1990,
          "note": "The unanimous pick, the one movie that came up when all three hosts described what first taught them how to watch movies."
        },
        {
          "title": "Casino",
          "year": 1995,
          "note": "Added late, edging out Age of Innocence and The Color of Money, even as the hosts admit it retreads Goodfellas' ground."
        },
        {
          "title": "The Departed",
          "year": 2006,
          "note": "His Best Picture and Best Director winner, singled out for kaleidoscopic editing and needle drops the hosts call a new mode for him."
        },
        {
          "title": "The Wolf of Wall Street",
          "year": 2013,
          "note": "Called an 'auto green,' Leo's best performance and a satire of capitalism the hosts say has only gotten more prescient."
        },
        {
          "title": "The Irishman",
          "year": 2019,
          "note": "The closing slot, a meditation on mortality that caps the Goodfellas/Casino gangster throughline, the last pick before the group turns to Killers."
        }
      ]
    }
  ],
