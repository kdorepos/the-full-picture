    "Chris Ryan"
  ],
  "published": "2025-04-15",
  "runtimeMin": 101,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan run a three-person snake draft of the movies of 1990, filling a seven-slot roster each across drama, comedy, action/horror/thriller, Oscar nominee, sequel, blockbuster, and wild card.",
  "segments": [
    {
      "kind": "draft",
      "heading": "The teams",
      "draftOf": "the movies of 1990",
      "categories": [
        "Drama",
        "Comedy",
        "Action / Horror / Thriller",
        "Oscar Nominee",
        "Sequel",
        "Blockbuster",
        "Wild Card"
      ],
      "teams": [
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Miller's Crossing",
              "year": 1990,
              "category": "Drama",
              "note": "The Coen brothers' Prohibition noir; four days out of seven, Chris's favorite film of theirs."
            },
            {
              "title": "House Party",
              "year": 1990,
              "category": "Comedy",
              "note": "Reginald Hudlin's Kid 'n Play comedy; Chris's Dazed and Confused before Dazed and Confused."
            },
            {
              "title": "King of New York",
              "year": 1990,
              "category": "Action / Horror / Thriller",
              "note": "Abel Ferrara's crime story, drafted as a thriller; peak Christopher Walken."
            },
            {
              "title": "Goodfellas",
              "year": 1990,
              "category": "Oscar Nominee",
              "note": "First pick of the draft: Scorsese's mob epic, 'righting a historical wrong' for the film that lost Best Picture to Dances with Wolves."
            },
            {
              "title": "The Exorcist III",
              "year": 1990,
              "category": "Sequel",
              "note": "William Peter Blatty directs, George C. Scott stars; the hallway jump scare Chris won't spoil."
            },
            {
              "title": "Days of Thunder",
              "year": 1990,
              "category": "Blockbuster",
              "note": "Tony Scott's Top Gun with stock cars; Cruise and Kidman first meet on screen. $82 million, just over the wire."
            },
            {
              "title": "The Cook, the Thief, His Wife & Her Lover",
              "year": 1989,
              "category": "Wild Card",
              "note": "Peter Greenaway, Michael Nyman score; Chris's second Greenaway draft pick, after 1982's The Draughtsman's Contract."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Postcards from the Edge",
              "year": 1990,
              "category": "Drama",
              "note": "Mike Nichols directs Carrie Fisher's script; Streep and Shirley MacLaine as a Hollywood mother and daughter."
            },
            {
              "title": "Metropolitan",
              "year": 1990,
              "category": "Comedy",
              "note": "Whit Stillman's debut; Amanda's favorite of the trilogy."
            },
            {
              "title": "The Hunt for Red October",
              "year": 1990,
              "category": "Action / Horror / Thriller",
              "note": "The only submarine Amanda would board; Alec Baldwin's one turn as Jack Ryan."
            },
            {
              "title": "Pretty Woman",
              "year": 1990,
              "category": "Oscar Nominee",
              "note": "Amanda's near-No.-2 rom-com; Julia Roberts breaks out."
            },
            {
              "title": "Die Hard 2",
              "year": 1990,
              "category": "Sequel",
              "note": "The airport one; taken partly to avoid drafting Look Who's Talking Too."
            },
            {
              "title": "Presumed Innocent",
              "year": 1990,
              "category": "Blockbuster",
              "note": "Harrison Ford legal thriller from the Scott Turow novel; better than the Apple remake's ending."
            },
            {
              "title": "Mermaids",
              "year": 1990,
              "category": "Wild Card",
              "note": "Cher, Winona Ryder, and Christina Ricci; a movie Amanda remembers being taken to at five or six."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "Wild at Heart",
              "year": 1990,
              "category": "Drama",
              "note": "Lynch's Palme d'Or road movie; Cage in snakeskin, Laura Dern, Diane Ladd."
            },
            {
              "title": "Home Alone",
              "year": 1990,
              "category": "Comedy",
              "note": "Sean's Casablanca as an eight-year-old."
            },
            {
              "title": "Misery",
              "year": 1990,
              "category": "Action / Horror / Thriller",
              "note": "Rob Reiner's Stephen King adaptation, William Goldman script; Kathy Bates and James Caan."
            },
            {
              "title": "Ghost",
              "year": 1990,
              "category": "Oscar Nominee",
              "note": "Part romance, part grief drama, part supernatural thriller; Swayze, Demi Moore, an Oscar for Whoopi Goldberg."
            },
            {
              "title": "Gremlins 2: The New Batch",
              "year": 1990,
              "category": "Sequel",
              "note": "Joe Dante's batshit sequel set in an everything-skyscraper, with John Glover's benevolent Trump stand-in."
            },
            {
              "title": "Total Recall",
              "year": 1990,
              "category": "Blockbuster",
              "note": "Verhoeven sci-fi satire; a strong case for Schwarzenegger's best. $119 million."
            },
            {
              "title": "Mo' Better Blues",
              "year": 1990,
              "category": "Wild Card",
              "note": "Spike Lee's Do the Right Thing follow-up; Denzel Washington as a jazz musician."
            }
          ]
        }
      ],
