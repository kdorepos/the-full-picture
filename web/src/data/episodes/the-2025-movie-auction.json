          "budgetLeft": 215,
          "picks": [
            {
              "title": "Sinners",
              "year": 2025,
              "price": 270,
              "note": "Ryan Coogler's original Southern-vampire genre movie; Michael B. Jordan plays twins, opposite Hailee Steinfeld."
            },
            {
              "title": "Highest 2 Lowest",
              "year": 2025,
              "price": 205,
              "note": "Spike Lee back with Denzel Washington; a remake of Kurosawa's High and Low, from Apple and A24. Also ASAP Rocky, Ice Spice, Jeffrey Wright."
            },
            {
              "title": "Sentimental Value",
              "year": 2025,
              "price": 110,
              "note": "Joachim Trier's follow-up to The Worst Person in the World; Renate Reinsve, Stellan Skarsgard, Elle Fanning. Chris's arthouse bet on the 85 trigger."
            },
            {
              "title": "Jurassic World Rebirth",
              "year": 2025,
              "price": 100,
              "note": "Gareth Edwards directs Scarlett Johansson and Mahershala Ali. Chris won it while still recapping the Prattverse."
            },
            {
              "title": "The Running Man",
              "year": 2025,
              "price": 100,
              "note": "Edgar Wright and Glen Powell remake the Stephen King story; Colman Domingo, Josh Brolin. Out against Predator: Badlands."
            }
          ]
        },
        {
          "host": "Amanda Dobbins",
