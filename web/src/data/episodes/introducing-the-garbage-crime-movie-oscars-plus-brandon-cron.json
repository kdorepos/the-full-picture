    {
      "kind": "interview",
      "heading": "Brandon Cronenberg on Possessor",
      "guest": "Brandon Cronenberg on",
      "films": [
        {
          "title": "Possessor",
          "year": 2020,
          "note": "The seed was a press-tour sense of being an imposter in his own life; the sci-fi built out from the domestic scenes. Real neuroscience (Jose Delgado's stim-o-ceivers) underpins it, used figuratively."
        },
        {
          "title": "Antiviral",
          "year": 2012,
          "note": "His first feature, eight years earlier, grown out of a film-school short. People keep telling him it was the one to release now."
        },
        {
          "title": "Infinity Pool",
          "year": 2023,
          "note": "Then in development: a tourist-resort satire with sci-fi horror elements. (A second project, Dragon, was also in the works.)"
        },
        {
          "title": "Contagion",
          "year": 2011,
          "note": "The one that actually blew up on Netflix at the start of the pandemic."
        },
        {
          "title": "Fail Safe",
          "year": 1964,
          "note": "The last great thing he saw: Lumet, caught on Criterion during quarantine."
        },
        {
          "title": "The Offence",
          "year": 1973,
          "note": "Another Lumet he kept returning to; shoots a room full of people talking with rare dynamism."
        },
        {
          "title": "Batman",
          "year": 1966,
          "note": "The Adam West movie he watched constantly as a kid. 'It's all the shark repellent in my films.'"
        }
      ]
    }
  ],
