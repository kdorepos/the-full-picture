{
  "slug": "mank-week-the-importance-of-citizen-kane-and-orson-welles",
  "title": "‘Mank' Week: The Importance of ‘Citizen Kane' and Orson Welles",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan",
    "Adam Nayman"
  ],
  "published": "2020-12-01",
  "runtimeMin": 90,
  "format": "Ahead of Fincher's ‘Mank,' a roundtable on ‘Citizen Kane,' Orson Welles, and Pauline Kael's ‘Raising Kane,' then Adam Nayman on the movie itself.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Citizen Kane, Welles, and ‘Raising Kane'",
      "note": "Sean and Amanda with Chris Ryan and Adam Nayman",
      "films": [
        {
          "title": "Citizen Kane",
          "year": 1941,
          "note": "The subject. Welles was 24, with an RKO deal granting him total control; Greg Toland shot the low angles and deep focus, Bernard Herrmann scored his first film, Robert Wise cut it. Nine nominations, one win (screenplay, shared with Mankiewicz). Topped the Sight & Sound poll for decades until Vertigo passed it in 2012."
        },
        {
          "title": "The Magnificent Ambersons",
          "year": 1942,
          "note": "The follow-up, taken out of Welles's hands and re-cut by RKO after Kane underperformed. He spent the rest of his career trying to get back to that first level of control."
        },
        {
          "title": "The Lady from Shanghai",
          "year": 1947,
          "note": "Chris cites it fondly as evidence Welles's body of work is more uneven than Ford's or Hitchcock's."
        },
        {
          "title": "The Third Man",
          "year": 1949,
          "note": "Raised as a Mank-style credit dispute over how much of it was really Welles."
        },
        {
          "title": "Touch of Evil",
          "year": 1958,
          "note": "Adam: Hank Quinlan is diminished, and the film works because of it. Welles turned his own decline into the material."
        },
        {
          "title": "Chimes at Midnight",
          "year": 1966,
          "note": "His Falstaff: loyal and unrewarded. Adam reads the later films as Welles living the regret Kane only imagined."
        },
        {
          "title": "F for Fake",
          "year": 1973,
          "note": "The reliably-unreliable trickster in his 60s. Adam watched it twice during the pandemic."
        },
        {
          "title": "The Other Side of the Wind",
          "year": 2018,
          "note": "The unfinished late film. Adam argues it's proof that Welles deepened rather than squandered his gift."
        },
        {
          "title": "The Stranger",
          "year": 1946,
          "note": "Named as a more conventionally accomplished Welles film that still doesn't carry Kane's weight."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "Adam Nayman on ‘Mank'",
      "note": "after Chris leaves",
      "films": [
        {
          "title": "Mank",
          "year": 2020,
          "note": "Fincher directing his late father Jack's script, itself indebted to Kael's ‘Raising Kane.' Adam reads it less as a who-wrote-Kane argument than a movie about loneliness and a 2020 political parable, with Charles Dance's Hearst and a Welles scene (Tom Burke) Adam finds the weakest part."
        },
        {
          "title": "The Social Network",
          "year": 2010,
          "note": "Adam: more Fincher's ‘Citizen Kane' than ‘Mank' is, a story of ambition that isolates and a 21-year-old smarter than the adults in the room."
        },
        {
          "title": "Alien 3",
          "year": 1992,
          "note": "The primal wound Adam says Fincher never got over: the studio overruled him on it, and he's had a chip on his shoulder about it ever since."
        }
      ]
    }
  ],
