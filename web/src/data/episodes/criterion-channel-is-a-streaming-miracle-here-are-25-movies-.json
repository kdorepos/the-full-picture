{
  "slug": "criterion-channel-is-a-streaming-miracle-here-are-25-movies-",
  "title": "Criterion Channel Is a Streaming Miracle. Here are 25 Movies You Should Watch Now",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey"
  ],
  "published": "2020-04-10",
  "runtimeMin": 138,
  "format": "For the Criterion Channel's first anniversary, Sean starts with five of his own picks. Then he calls up a dozen directors, critics, and friends of the show, one quarantine recommendation apiece, before closing with the channel's programmer.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "Sean's five fast ones",
      "note": "his own picks to start",
      "films": [
        {
          "title": "The Big Knife",
          "year": 1955,
          "note": "Robert Aldrich's dark portrait of how Hollywood felt in 1955, with Jack Palance as an actor in crisis and Ida Lupino. A movie about making movies, and one of the least known."
        },
        {
          "title": "Tokyo Drifter",
          "year": 1966,
          "note": "Seijun Suzuki's neon, hyper-monochromatic crime film, probably his masterpiece. Where Japanese cinema went after Kurosawa and Mifune."
        },
        {
          "title": "The Daytrippers",
          "year": 1996,
          "note": "Greg Mottola, the bard of Long Island, on a family car trip to catch a cheating husband. Sean's hometown too; it echoes inside him."
        },
        {
          "title": "Harlan County USA",
          "year": 1976,
          "note": "Barbara Kopple's documentary on the Brookside coal strike, 180 miners and their wives against Duke Power. A precursor to American Factory."
        }
      ]
    },
    {
      "kind": "list",
      "heading": "Friends of the show pick",
      "note": "one guest, one Criterion film",
      "picks": [
        {
          "title": "Atlantic City",
          "year": 1980,
          "by": "Josh Safdie",
          "note": "Louis Malle's regional film with Burt Lancaster as a bottom-rung gangster and Susan Sarandon dressing her arms with lemons. Malle builds it from small moments; Safdie called back to keep talking about it."
        },
        {
          "title": "Monterey Pop",
          "year": 1968,
          "by": "Liz Hannah",
          "note": "D. A. Pennebaker's 1967 festival film, Janis Joplin's and Otis Redding's breakout. Communal comfort viewing that still plays for new generations."
        },
        {
          "title": "The Discreet Charm of the Bourgeoisie",
          "year": 1972,
          "by": "Sam Esmail",
          "note": "His favorite film of all time. Buñuel's six rich friends who can never sit down to a meal, an essay on class that refuses to cohere into plot. It hasn't dated at all."
        },
        {
          "title": "Thank God It's Friday",
          "year": 1978,
          "by": "Amy Nicholson",
          "note": "A disco movie so disco that Donna Summer plays a wannabe star and won an Oscar for 'Last Dance.' Young Jeff Goldblum as the sleazy club owner. Leonard Maltin called it a bomb; she loved it."
        },
        {
          "title": "Paper Moon",
          "year": 1973,
          "by": "Peyton Reed",
          "note": "Peter Bogdanovich in black and white, Ryan and Tatum O'Neal, Madeline Kahn as Trixie Delight. Reed saw it at nine, and it's guided his work since: comedy that's loose and carefully shot at the same time."
        },
        {
          "title": "A Room with a View",
          "year": 1985,
          "by": "Miranda July",
          "note": "The movie she saw at 14 and confused with her own coming of age. Helena Bonham Carter's breakdown, all-out abandon, is the game plan for July's life."
        },
        {
          "title": "Profound Desires of the Gods",
          "year": 1968,
          "by": "Ari Aster",
          "note": "His way into a Japanese New Wave binge (Imamura, Oshima, Teshigahara). Imamura's longest film, a huge flop that haunts his body of work; an influence on Midsommar."
        },
        {
          "title": "Le Samouraï",
          "year": 1967,
          "by": "Chris Ryan",
          "note": "Jean-Pierre Melville with Alain Delon, the Rosetta Stone for the minimalist hitman film. You can see it in Drive and Ronin, and Brad Pitt studied Delon for Once Upon a Time in Hollywood."
        },
        {
          "title": "Picnic at Hanging Rock",
          "year": 1975,
          "by": "Barry Jenkins",
          "note": "Peter Weir's film, rarely mentioned, put in front of Jenkins in the Leftovers writers' room by Damon Lindelof. Atmospherics, colonialism, sexual hysteria, grounded supernatural mystery."
        },
        {
          "title": "The Lady Vanishes",
          "year": 1938,
          "by": "Erin Lee Carr",
          "note": "Skips past the famous Hitchcocks, Psycho and Vertigo, for a train whodunit that's an early study in gaslighting. Carr, who makes psychological true crime, watched it eating stone crab in Florida."
        },
        {
          "title": "The Harder They Fall",
          "year": 1956,
          "by": "Benny Safdie",
          "note": "Bogart's last film, from Budd Schulberg, with Rod Steiger building up a seven-foot Argentine boxer for the mob. Benny came to it through Schulberg's book Ringside."
        },
        {
          "title": "On the Waterfront",
          "year": 1954,
          "by": "Benny Safdie",
          "note": "The mammoth he'd never touched until now. Brando's 'contender' speech, but it's Steiger's wordless breakdown in the back of the car that floored him."
        },
        {
          "title": "M",
          "year": 1931,
          "by": "Knox Dobbins",
          "note": "Amanda outsourced her pick to her father, the Criterion superfan. Fritz Lang's serial-child-killer Berlin, frightening for the period as much as the crime. He switched from Sweet Smell of Success at the last minute."
        },
        {
          "title": "The Ascent",
          "year": 1977,
          "by": "Alex Ross Perry",
          "note": "Larisa Shepitko, from the household that made Come and See. Two people surviving the tundra, no decisive victories, the bleakest Russian WWII fatalism. Won the top prize at Berlin."
        },
        {
          "title": "The Stranger",
          "year": 1946,
          "by": "Adam Neiman",
          "note": "Orson Welles' third film, a propulsive noir with Welles as a Nazi hiding in a Connecticut town and Edward G. Robinson on his trail. He shot in long takes so producers had nothing to cut."
        }
      ]
    },
    {
      "kind": "interview",
      "heading": "In conversation",
      "guest": "Penelope Bartlett on",
      "note": "the channel's programmer, on her own favorite",
      "films": [
        {
          "title": "Losing Ground",
          "year": 1982,
          "note": "Kathleen Collins, possibly the first feature by an American Black woman filmmaker. A sensual, cerebral study of a marriage, with Bill Gunn. Bartlett recommends the film and Collins' short stories both."
        }
      ]
    }
  ],
