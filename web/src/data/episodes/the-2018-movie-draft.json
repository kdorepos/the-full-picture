{
  "slug": "the-2018-movie-draft",
  "title": "The 2018 Movie Draft",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins",
    "Chris Ryan"
  ],
  "published": "2022-02-24",
  "runtimeMin": 76,
  "format": "Sean Fennessey, Amanda Dobbins, and Chris Ryan draft 2018 across six categories (Drama, Comedy, Oscar Nominee, Action Horror, Blockbuster, and Wildcard), from Black Panther to Den of Thieves.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "2018, before the draft",
      "films": [
        {
          "title": "Green Book",
          "year": 2018,
          "note": "The Best Picture winner. The hosts liked it fine on first viewing, a lighthearted crowd-pleaser, but say it hasn't aged well once you factor in the backlash over how it handled the real-life story."
        },
        {
          "title": "Roma",
          "year": 2018,
          "note": "Alfonso Cuarón's Netflix drama. Amanda saw it in a small screening room and calls it beautiful and harrowing; it lost Best Picture to Green Book even though Cuarón won Best Director."
        },
        {
          "title": "Bohemian Rhapsody",
          "year": 2018,
          "note": "Rami Malek won Best Actor for playing Freddie Mercury, a win the hosts remember as something of a punchline at the time."
        },
        {
          "title": "Vice",
          "year": 2018,
          "note": "Christian Bale's Dick Cheney transformation earned him a Best Actor nomination, in a field crowded with Cooper, Malek, and Dafoe."
        },
        {
          "title": "At Eternity's Gate",
          "year": 2018,
          "note": "Willem Dafoe's Van Gogh film picked up a Best Actor nomination that Sean says barely anyone actually saw."
        },
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "Bradley Cooper's directorial debut, discussed here for its Best Actor nomination before it comes back later as Sean's draft pick."
        },
        {
          "title": "Avengers: Infinity War",
          "year": 2018,
          "note": "The hosts call it the moment the MCU fully became 'the movies now': stars, directors, and studios all funneling into one franchise."
        },
        {
          "title": "Widows",
          "year": 2018,
          "note": "Steve McQueen's Chicago heist thriller made about $75 million, which felt disappointing in a year of $200 million blockbusters. The hosts say it was overlooked by awards bodies at the time."
        }
      ]
    },
    {
      "kind": "draft",
      "heading": "The 2018 Movie Draft",
      "draftOf": "2018 movies",
      "categories": [
        "Drama",
        "Comedy",
        "Oscar Nominee",
        "Action Horror",
        "Blockbuster",
        "Wildcard"
      ],
      "teams": [
        {
          "host": "Amanda Dobbins",
          "picks": [
            {
              "title": "Roma",
              "year": 2018,
              "category": "Drama",
              "note": "Alfonso Cuarón's Netflix film. She calls it beautiful and special, even if it's since become a punchline for every director's attempt to make their own version."
            },
            {
              "title": "Game Night",
              "year": 2018,
              "category": "Comedy",
              "note": "The funniest movie of the year for her, led by Jason Bateman and Rachel McAdams, whose deadpan 'Oh no, he died!' after a stunt gone wrong is her pick for the year's best line."
            },
            {
              "title": "Black Panther",
              "year": 2018,
              "category": "Oscar Nominee",
              "note": "Her first-overall pick. She remembers a packed opening-weekend screening at the Hollywood Arclight and says it made her believe again that these movies could hold real ideas."
            },
            {
              "title": "A Quiet Place",
              "year": 2018,
              "category": "Action Horror",
              "note": "John Krasinski's directorial breakout with Emily Blunt. She caught part of it at South by Southwest and remembers it playing 'like a house on fire.'"
            },
            {
              "title": "Crazy Rich Asians",
              "year": 2018,
              "category": "Blockbuster",
              "note": "Jon M. Chu's adaptation of Kevin Kwan's novel. She calls it smart and funny in a knowingly frivolous way, and wishes the delayed sequel had a bigger budget."
            },
            {
              "title": "Wildlife",
              "year": 2018,
              "category": "Wildcard",
              "note": "Paul Dano's directorial debut, adapted from a Richard Ford novel. She says Carey Mulligan's performance is the one that should have gotten her the recognition Promising Young Woman later did."
            }
          ]
        },
        {
          "host": "Chris Ryan",
          "picks": [
            {
              "title": "Widows",
              "year": 2018,
              "category": "Drama",
              "note": "Steve McQueen's Chicago heist thriller, with Viola Davis and a villainous Colin Farrell, written by Gillian Flynn. He calls it a movie that felt like a slight disappointment on release and got much better on rewatch."
            },
            {
              "title": "The Death of Stalin",
              "year": 2018,
              "category": "Comedy",
              "note": "Armando Iannucci's satire of Politburo jockeying after Stalin's death. He calls it the last great political satire and one of the darkest movies he's ever seen."
            },
            {
              "title": "Avengers: Infinity War",
              "year": 2018,
              "category": "Oscar Nominee",
              "note": "Eligible off a visual-effects nomination. He admits he barely remembers the plot beyond the ending, but says it was the theatrical event of the year."
            },
            {
              "title": "Annihilation",
              "year": 2018,
              "category": "Action Horror",
              "note": "Alex Garland's adaptation of Jeff VanderMeer's novel. He didn't like it on first watch, partly from being too attached to the book, but came around to its ambitious, 2001-style third act."
            },
            {
              "title": "Mission: Impossible - Fallout",
              "year": 2018,
              "category": "Blockbuster",
              "note": "The movie he had the most fun watching all year, seen at least twice in theaters, with the bathroom fight against Henry Cavill as the highlight."
            },
            {
              "title": "Den of Thieves",
              "year": 2018,
              "category": "Wildcard",
              "note": "Christian Gudegast's Gerard Butler heist movie, most of it two guys shooting at each other across a bridge. He's brought it up on the show for years since."
            }
          ]
        },
        {
          "host": "Sean Fennessey",
          "picks": [
            {
              "title": "First Man",
              "year": 2018,
              "category": "Drama",
              "note": "Damien Chazelle's Neil Armstrong film with Ryan Gosling. He underrated it after an empty-IMAX first viewing in Burbank, then came around on a rewatch while prepping to interview Chazelle."
            },
            {
              "title": "The Favourite",
              "year": 2018,
              "category": "Comedy",
              "note": "Yorgos Lanthimos's Queen Anne court drama, written by Deborah Davis and Tony McNamara. Emma Stone won Best Actress for it, and Olivia Colman won Best Actress too, for a role the hosts debate was actually lead."
            },
            {
              "title": "A Star Is Born",
              "year": 2018,
              "category": "Oscar Nominee",
              "note": "Bradley Cooper's directorial debut, one of his two favorite movies of the decade."
            },
            {
              "title": "Hereditary",
              "year": 2018,
              "category": "Action Horror",
              "note": "Ari Aster's family-trauma horror movie with Toni Collette. He saw it at a midnight South by Southwest screening in an empty Austin multiplex and calls Collette's performance one the Academy will never recognize."
            },
            {
              "title": "Spider-Man: Into the Spider-Verse",
              "year": 2018,
              "category": "Blockbuster",
              "note": "He calls it a masterpiece of the decade, maybe the century, and credits it with raising the bar for what an animated movie could look like."
            },
            {
              "title": "First Reformed",
              "year": 2018,
              "category": "Wildcard",
              "note": "Paul Schrader's Ethan Hawke film about a reverend's crisis of faith. One of his favorite movies ever; he says he'd have felt wrong not drafting it."
            }
          ]
        }
      ],
