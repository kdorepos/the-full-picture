{
  "slug": "the-10-most-misused-stars-in-hollywood-and-the-gnarly-magic-",
  "title": "The 10 Most Misused Stars in Hollywood and the Gnarly Magic of 'Send Help'",
  "show": "The Big Picture",
  "network": "The Ringer",
  "hosts": [
    "Sean Fennessey",
    "Amanda Dobbins"
  ],
  "published": "2026-01-30",
  "runtimeMin": 116,
  "format": "Two late-January genre movies — the AI courtroom thriller 'Mercy' and Sam Raimi's survival satire 'Send Help' — bookend a countdown of the stars Hollywood keeps wasting.",
  "segments": [
    {
      "kind": "discussion",
      "heading": "In the news",
      "note": "A Sundance sale, the Beatles biopics, and BAFTA takeaways",
      "films": [
        {
          "title": "The Invite",
          "year": 2026,
          "note": "A24 paid $10M+ at Sundance for Olivia Wilde's adaptation of a Spanish film — Seth Rogen and Wilde as a couple invited to a swingers party by Edward Norton and Penelope Cruz. Part of Wilde's post-'Don't Worry Darling' rebuild, alongside Gregg Araki's 'I Want Your Sex' and Tony Gilroy's 'Behemoth.'"
        }
      ]
    },
    {
      "kind": "review",
      "heading": "'Mercy'",
      "note": "Chris Pratt, an AI judge, and 90 minutes on a countdown clock",
      "films": [
        {
          "title": "Mercy",
          "year": 2026,
          "note": "Timur Bekmambetov's screen-thriller for Amazon MGM: a detective (Chris Pratt) strapped to a chair has 90 real-time minutes to prove to an AI judge (Rebecca Ferguson) that he didn't kill his wife. The hosts read it as propaganda that launders both AI and the surveillance state — Ring footage clears him — and note it cost a reported $60M but looks shot on a phone. Number one at the box office its opening weekend."
        }
      ]
    },
    {
      "kind": "review",
      "heading": "'Send Help'",
      "note": "Sam Raimi strands Rachel McAdams and Dylan O'Brien on an island",
      "films": [
        {
          "title": "Send Help",
          "year": 2026,
          "note": "One of the rare original films from Raimi, reteaming Bill Pope, Bob Murawski, and Danny Elfman. Rachel McAdams's mistreated employee and Dylan O'Brien's sexist boss survive a plane crash onto a deserted island, and the power flips. Sean loves it as classic mean-spirited Raimi (see 'A Simple Plan,' 'Drag Me to Hell') that refuses to make either character likable; both praise McAdams for playing unhinged and ugly. She loves Survivor; it pays off."
        }
      ]
    },
    {
      "kind": "discussion",
      "heading": "The 10 Most Misused Stars in Hollywood",
      "note": "Sean and Amanda alternate picks, with Rachel McAdams as the muse — one anchor film per star",
      "films": [
        {
          "title": "Judas and the Black Messiah",
          "year": 2021,
          "note": "Lakeith Stanfield. Oscar-nominated here, great in 'Get Out' and 'Atlanta,' the lead of 'Sorry to Bother You' — and still not a movie star. Keeps landing second lead ('Roofman,' 'Die My Love'); the hosts want someone to build a film around him."
        },
        {
          "title": "Atonement",
          "year": 2007,
          "note": "James McAvoy. Circa 2007-08 he 'had it all.' Since then, Professor X and a swole M. Night Shyamalan run ('Speak No Evil'), but no franchise or series built around him. Also directed a film ('California Schemin'') that went nowhere."
        },
        {
          "title": "Salt",
          "year": 2010,
          "note": "Angelina Jolie. A $110M-budget phenomenon that grossed roughly $300M and is now half-forgotten. One of the most striking, capable stars alive who — 'Mr. & Mrs. Smith' and 'Girl, Interrupted' aside — made almost no great films. Recent output is 'Maria,' 'Maleficent,' 'Eternals.'"
        },
        {
          "title": "Monkey Man",
          "year": 2024,
          "note": "Dev Patel. He directed himself in it because, he said, nobody would cast him as an action star — and since 'Slumdog Millionaire' and 'Lion,' nobody has handed him a big, good mainstream vehicle. The hosts find him consistently winning and a convincing action lead."
        },
        {
          "title": "A Star Is Born",
          "year": 2018,
          "note": "Bradley Cooper. 'A call coming from inside the house.' A great star and director now doing cameos and self-directed passion projects ('Maestro,' 'Is This Thing On?'); 'The Mule' in 2018 was his last plain movie-star part."
        },
        {
          "title": "After the Hunt",
          "year": 2025,
          "note": "Julia Roberts. Still nuclear-level famous and underused. Good in Luca Guadagnino's film even though the hosts think its script doesn't work; still working with Sam Esmail. They want a Wes or Paul Thomas Anderson to channel her."
        },
        {
          "title": "Nocturnal Animals",
          "year": 2016,
          "note": "Amy Adams. Six-time nominee whose last decade is a run of misfires ('Hillbilly Elegy,' 'Dear Evan Hansen,' 'The Woman in the Window'). The hosts split on whether it's her choices or the town; a comeback may come via Cornel Mundruczo's 'At the Sea.'"
        },
        {
          "title": "One Battle After Another",
          "year": 2025,
          "note": "Regina Hall. PTA found a quiet, solemn register under the comic charisma — power and stillness Hollywood never taps. Great in 'Girls Trip,' but the performance faded in awards season. Next: a Nicholas Stoller comedy, 'Judgment Day.'"
        },
        {
          "title": "Civil War",
          "year": 2024,
          "note": "Kirsten Dunst. Terrific as the war photojournalist, yet keeps landing girlfriend/supporting roles ('Roofman'). '25 for 25' honoree for 'Melancholia' and 'Marie Antoinette'; the pick is to let her lead again. A Sofia Coppola reunion is rumored."
        },
        {
          "title": "Star Trek",
          "year": 2009,
          "note": "Chris Pine. A great Captain Kirk with a scattered post-2020 run ('Poolman,' 'Wish'). Two 2026 indies with women directors ahead — Rachel Lambert's 'Carousel' and the Zellner brothers' 'Alpha Gang' — plus a Gen-Z-formative back catalog ('The Princess Diaries 2,' 'Just My Luck')."
        }
      ]
    }
  ],
